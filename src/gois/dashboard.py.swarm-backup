"""Self-contained read-only web dashboard.

Polls /status every few seconds and renders state. No external assets.
"""

import json
from typing import Optional

from .hermes_cron_exec_ui import inject_hermes_cron_exec

APP_NAV_CSS = """
  body:has(> nav.app-nav) { display: flex; flex-direction: column; min-height: 100dvh; height: 100%; }
  body:has(> nav.app-nav) > main,
  body:has(> nav.app-nav) > .layout { flex: 1; min-height: 0; min-width: 0; width: 100%; }
  .app-nav { border-bottom: 1px solid var(--border); background: var(--panel);
             flex-shrink: 0; position: sticky; top: 0; z-index: 900; }
  .app-nav-inner { display: flex; align-items: center; gap: 14px; padding: 10px 20px;
                   min-height: 64px; width: 100%; max-width: 100%; box-sizing: border-box; }
  .app-nav .brand { display: inline-flex; align-items: center; gap: 10px;
                    text-decoration: none; color: var(--fg);
                    padding: 0 14px 0 0; margin-right: 4px;
                    border-right: 1px solid var(--border); flex-shrink: 0; }
  .app-nav .brand:hover .brand-name { color: var(--accent); }
  .app-nav .brand:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
  .app-nav .brand-icon { width: 40px; height: 40px; flex-shrink: 0;
                         filter: drop-shadow(0 2px 6px rgba(0,0,0,.35)); pointer-events: none; }
  .app-nav .brand-text { display: flex; flex-direction: column; line-height: 1.15;
                         justify-content: center; pointer-events: none; }
  .app-nav .brand-name { font-size: 16px; font-weight: 700; letter-spacing: .3px; }
  .app-nav .brand-tag { font-size: 10px; color: var(--muted); text-transform: uppercase;
                        letter-spacing: .7px; }
  .app-nav .nav-links-wrap { flex: 1 1 auto; min-width: 0; overflow-x: auto;
                             overflow-y: hidden; -webkit-overflow-scrolling: touch;
                             scrollbar-width: thin; touch-action: pan-x;
                             overscroll-behavior-x: contain; }
  .app-nav .nav-links { display: inline-flex; align-items: center; gap: 8px;
                        flex-wrap: nowrap; padding: 4px 6px; min-width: min-content;
                        position: relative; z-index: 1; }
  .app-nav .nav-link { color: var(--muted); text-decoration: none; font-size: 14px;
                       font-weight: 600; padding: 0 18px; border: 1px solid transparent;
                       border-radius: 12px; white-space: nowrap; flex-shrink: 0;
                       display: inline-flex; align-items: center; justify-content: center;
                       gap: 8px; min-height: 48px; min-width: 44px; line-height: 1.2;
                       cursor: pointer; touch-action: manipulation;
                       -webkit-tap-highlight-color: transparent;
                       user-select: none; transition: background .15s, border-color .15s, color .15s; }
  .app-nav .nav-link:hover { color: var(--fg); border-color: var(--border);
                             background: var(--panel-2); }
  .app-nav .nav-link:focus-visible { outline: 2px solid var(--accent);
                                     outline-offset: 2px; }
  .app-nav .nav-link:active { transform: translateY(1px); }
  .app-nav .nav-link.active { color: var(--accent); border-color: var(--accent);
                              background: rgba(106,169,255,.12); }
  .app-nav .nav-link.loading { color: var(--accent); border-color: var(--accent);
                               background: rgba(106,169,255,.14); pointer-events: none;
                               cursor: wait; }
  .app-nav .nav-link.loading::after { content: ""; width: 14px; height: 14px; flex-shrink: 0;
                                      border: 2px solid rgba(106,169,255,.35);
                                      border-top-color: var(--accent); border-radius: 50%;
                                      animation: qcm-nav-spin .7s linear infinite; }
  @keyframes qcm-nav-spin { to { transform: rotate(360deg); } }
  .app-nav .nav-link.offline { opacity: .75; cursor: not-allowed;
                               border-style: dashed; border-color: var(--border); }
  #qcm-page-loading { position: fixed; inset: 0; z-index: 1200;
                      display: none; align-items: center; justify-content: center;
                      background: rgba(15,17,21,.72); backdrop-filter: blur(4px); }
  #qcm-page-loading.show { display: flex; }
  #qcm-page-loading .box { padding: 20px 28px; border-radius: 12px;
                           border: 1px solid var(--border); background: var(--panel);
                           box-shadow: 0 12px 40px rgba(0,0,0,.45);
                           font-size: 15px; font-weight: 600; color: var(--fg);
                           display: flex; align-items: center; gap: 12px; }
  #qcm-page-loading .box::before { content: ""; width: 18px; height: 18px; flex-shrink: 0;
                                   border: 2px solid rgba(106,169,255,.35);
                                   border-top-color: var(--accent); border-radius: 50%;
                                   animation: qcm-nav-spin .7s linear infinite; }
  .app-nav .nav-extra { display: flex; align-items: center; gap: 10px;
                        flex-shrink: 0; margin-left: 4px; }
  /* === Toast / Snackbar system === */
  #qcm-toast-container { position: fixed; bottom: 20px; right: 20px;
                         z-index: 1100; display: flex; flex-direction: column-reverse;
                         gap: 8px; max-width: min(520px, 92vw); width: auto;
                         pointer-events: none; }
  .qcm-toast { display: flex; align-items: flex-start; gap: 10px;
               padding: 12px 16px; border-radius: 10px;
               background: var(--panel); border: 1px solid var(--border);
               color: var(--fg); font-size: 13px; line-height: 1.4;
               box-shadow: 0 8px 24px rgba(0,0,0,.45);
               pointer-events: auto;
               transform: translateX(120%); opacity: 0;
               transition: transform .35s cubic-bezier(.22,1,.36,1),
                           opacity .25s ease; }
  .qcm-toast.show { transform: translateX(0); opacity: 1; }
  .qcm-toast.hiding { transform: translateX(80%); opacity: 0;
                       transition: transform .2s ease-in, opacity .15s; }
  .qcm-toast-icon { flex-shrink: 0; width: 20px; height: 20px;
                    margin-top: 1px; border-radius: 50%;
                    display: flex; align-items: center; justify-content: center;
                    font-size: 12px; font-weight: 700; }
  .qcm-toast.info .qcm-toast-icon { background: var(--accent-dim); color: var(--accent); }
  .qcm-toast.success .qcm-toast-icon { background: rgba(61,220,132,.15); color: var(--ok); }
  .qcm-toast.warn .qcm-toast-icon { background: rgba(255,180,84,.15); color: var(--warn); }
  .qcm-toast.error .qcm-toast-icon { background: rgba(255,90,95,.15); color: var(--bad); }
  .qcm-toast.info { border-color: rgba(106,169,255,.3); }
  .qcm-toast.success { border-color: rgba(61,220,132,.3); }
  .qcm-toast.warn { border-color: rgba(255,180,84,.3); }
  .qcm-toast.error { border-color: rgba(255,90,95,.3); }
  .qcm-toast-body { flex: 1; min-width: 0; }
  .qcm-toast-close { flex-shrink: 0; width: 20px; height: 20px;
                      border: none; background: transparent; color: var(--muted);
                      cursor: pointer; font-size: 14px; line-height: 1;
                      padding: 0; margin: 0 0 0 4px; opacity: .6;
                      display: flex; align-items: center; justify-content: center;
                      border-radius: 4px; }
  .qcm-toast-close:hover { opacity: 1; background: var(--panel-2); }
  @media (max-width: 480px) {
    #qcm-toast-container { left: 12px; right: 12px; max-width: none; bottom: 12px; }
    .qcm-toast { padding: 10px 14px; font-size: 12px; }
  }
  /* old compat */
  #qcm-nav-toast { display: none; }
  .app-nav .logout-btn { background: var(--panel-2); color: var(--muted);
                         border: 1px solid var(--border); border-radius: 10px;
                         padding: 10px 16px; font-size: 13px; font-family: var(--mono);
                         cursor: pointer; min-height: 48px; line-height: 1;
                         touch-action: manipulation; user-select: none; }
  .app-nav .theme-btn { display: inline-flex; align-items: center; justify-content: center;
                         width: 36px; height: 36px; border-radius: 8px;
                         background: transparent; border: 1px solid var(--border);
                         color: var(--muted); cursor: pointer; font-size: 16px; line-height: 1;
                         touch-action: manipulation; user-select: none;
                         transition: background .15s, color .15s, border-color .15s; }
  .app-nav .theme-btn:hover { color: var(--fg); border-color: var(--accent); background: var(--panel-2); }
  .app-nav .theme-btn:focus-visible { outline: 2px solid var(--accent); outline-offset: 1px; }
  .app-nav .qcm-user { display: inline-flex; align-items: center; padding: 4px 10px;
                       border: 1px solid var(--border); border-radius: 8px;
                       background: var(--panel-2); font-family: var(--mono);
                       font-size: 12px; font-weight: 600; color: var(--fg);
                       pointer-events: none; user-select: none; }
  @media (max-width: 720px) {
    .app-nav-inner { padding: 8px 12px; gap: 10px; min-height: 58px; }
    .app-nav .brand-tag { display: none; }
    .app-nav .nav-link { padding: 0 14px; min-height: 44px; font-size: 13px; }
    .app-nav .logout-btn { min-height: 44px; padding: 8px 14px; }
  }
"""

APP_THEME_CSS = """
  :root, [data-theme="dark"] {
    --bg: #0f1115;
    --panel: #171a21;
    --panel-2: #1e222c;
    --border: #262b36;
    --fg: #e6e8ee;
    --muted: #8a93a6;
    --ok: #3ddc84;
    --bad: #ff5a5f;
    --warn: #ffb454;
    --accent: #6aa9ff;
    --accent-dim: rgba(106,169,255,.12);
    --mono: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }
  [data-theme="light"] {
    --bg:#f5f6fa; --panel:#fff; --panel-2:#f0f2f7; --border:#e1e4ec;
    --fg:#15171c; --muted:#5b6477;
  }
  /* Auto-detect system preference when no data-theme is set */
  @media (prefers-color-scheme: light) {
    :root:not([data-theme]) { --bg:#f5f6fa; --panel:#fff; --panel-2:#f0f2f7; --border:#e1e4ec; --fg:#15171c; --muted:#5b6477; }
  }
"""

APP_UI_CSS = """
  button.ctrl, a.ctrl { background: var(--panel-2); color: var(--fg); border: 1px solid var(--border);
                         border-radius: 8px; padding: 8px 14px; font-size: 12px; font-family: var(--mono);
                         cursor: pointer; text-decoration: none; display: inline-flex; align-items: center;
                         justify-content: center; gap: 6px; }
  button.ctrl:hover, a.ctrl:hover { border-color: var(--accent); color: var(--fg); }
  button.ctrl.primary { background: var(--accent); color: #0f1115; border-color: var(--accent);
                         font-weight: 600; }
  button.ctrl.primary:hover { filter: brightness(1.06); }
  button.ctrl:disabled { opacity: .55; cursor: not-allowed; }
  .badge { display: inline-block; padding: 2px 8px; border-radius: 999px;
           background: var(--panel-2); border: 1px solid var(--border);
           color: var(--muted); font-size: 11px; font-family: var(--mono); }
  .badge.ok  { color: var(--ok);  border-color: rgba(61,220,132,.35); background: rgba(61,220,132,.08); }
  .badge.bad { color: var(--bad); border-color: rgba(255,90,95,.35); background: rgba(255,90,95,.08); }
  .badge.warn { color: var(--warn); border-color: rgba(255,180,84,.35); background: rgba(255,180,84,.08); }
  .badge.accent { color: var(--accent); border-color: rgba(106,169,255,.35);
                  background: rgba(106,169,255,.10); }
  .pill { display: inline-flex; align-items: center; gap: 6px;
          padding: 3px 10px; border-radius: 999px; font-size: 11px;
          font-family: var(--mono); border: 1px solid var(--border); }
  .pill.running { color: var(--accent); background: rgba(106,169,255,.10); }
  /* === Kanban card accordion (expand/collapse) === */
  .qcm-card-wrap { margin-bottom: 8px; border: 1px solid var(--border); border-radius: 10px;
                    background: var(--panel-2); overflow: hidden; transition: box-shadow .15s; }
  .qcm-card-wrap:hover { box-shadow: 0 2px 8px rgba(0,0,0,.25); }
  .qcm-card-header { display: flex; align-items: center; gap: 8px; padding: 10px 14px;
                      cursor: pointer; user-select: none; -webkit-tap-highlight-color: transparent;
                      transition: background .12s; }
  .qcm-card-header:hover { background: rgba(106,169,255,.06); }
  .qcm-card-header .arrow { flex-shrink: 0; width: 18px; height: 18px; display: inline-flex;
                             align-items: center; justify-content: center; font-size: 12px;
                             color: var(--muted); transition: transform .2s; }
  .qcm-card-header .arrow.open { transform: rotate(90deg); }
  .qcm-card-title { flex: 1; min-width: 0; font-size: 13px; font-weight: 600; color: var(--fg);
                     overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .qcm-card-body { display: none; padding: 0 14px 12px 40px; font-size: 12px;
                    color: var(--muted); line-height: 1.5; border-top: 1px solid var(--border); }
  .qcm-card-body.open { display: block; }
  .qcm-card-body .meta { display: flex; flex-wrap: wrap; gap: 6px 12px; margin-top: 6px; }
  .qcm-card-body .meta-item { font-size: 11px; font-family: var(--mono); color: var(--muted); }
"""


DARK_MODE_JS = r"""  // Dark mode toggle with localStorage
  function qcmApplyTheme(t) {
    document.documentElement.setAttribute('data-theme', t);
    var btn = document.getElementById('qcm-theme-btn');
    if (btn) btn.textContent = t === 'dark' ? '\u{1F319}' : '\u{2600}\u{FE0F}';
    try { localStorage.setItem('qcm-theme', t); } catch(e) {}
  }
  window.qcmToggleTheme = function qcmToggleTheme() {
    var cur = document.documentElement.getAttribute('data-theme') || 'dark';
    qcmApplyTheme(cur === 'dark' ? 'light' : 'dark');
    window.qcmNavToast(cur === 'dark' ? 'Tema claro ativado' : 'Tema escuro ativado', 'info');
  };
  (function() {
    var saved = localStorage.getItem('qcm-theme');
    if (saved === 'dark' || saved === 'light') {
      qcmApplyTheme(saved);
    }
  })();
"""
