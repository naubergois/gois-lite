  .dot.down { background: var(--bad); box-shadow: 0 0 16px rgba(255,90,95,.55); }
  .status .label { font-size: 22px; font-weight: 600; }
  .status .meta  { color: var(--muted); font-size: 12px; margin-top: 2px;
                   font-family: var(--mono); word-break: break-all; }
  .num { font-size: 28px; font-weight: 600; line-height: 1; }
