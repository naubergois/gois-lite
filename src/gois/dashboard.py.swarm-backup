    ("monitor", "/", "Monitor"),
  ("model_quotas", "/modelos", "Cotas"),
  ("model_costs", "/modelos/custos", "Custos"),
    ("active_agents", "/agentes", "Agentes ativos"),
    ("chat", "/chat", "Chat QClaw"),
    ("ruflo_chat", "/chat/ruflo", "Chat RuFlo"),
  ("ruflo_results", "/ruflo", "RuFlo Resultados"),
    ("errors", "/erros", "Erros"),
    ("roles", "/roles", "Papéis"),
    ("agent_create", "/agents/novo", "Criar agente"),
    ("cron_create", "/jobs/novo", "Criar job"),
    ("ide", "/ide", "IDE"),
    ("knowledge", "/conhecimento", "Conhecimento"),
    ("project_memory", "/memoria", "Memória"),
    ("teams", "/times", "Times"),
    ("kanban", "/kanban", "Kanban"),
