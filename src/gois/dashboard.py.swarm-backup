  .tools-dial-wrap { display: flex; flex-direction: column; align-items: center; margin: 6px 0 10px; }
  .tools-dial { --pct: 0; width: 84px; height: 84px; border-radius: 50%; flex-shrink: 0;
                background: conic-gradient(var(--accent) calc(var(--pct) * 1%), var(--border) 0);
                display: flex; align-items: center; justify-content: center; position: relative;
                transition: background .35s ease; }
  .tools-dial::before { content: ""; position: absolute; inset: 9px; border-radius: 50%;
                        background: var(--panel); }
  .tools-dial .dial-num { position: relative; z-index: 1; font-size: 24px; font-weight: 600;
                          line-height: 1; font-variant-numeric: tabular-nums; }
  .tools-dial.warn { background: conic-gradient(var(--warn) calc(var(--pct) * 1%), var(--border) 0); }
  .tools-dial.bad { background: conic-gradient(var(--bad) calc(var(--pct) * 1%), var(--border) 0); }
  .dial-caption { font-size: 11px; color: var(--muted); text-align: center; margin-top: -4px;
                  margin-bottom: 8px; font-family: var(--mono); }
  .badge { display: inline-block; padding: 2px 8px; border-radius: 999px;
           background: var(--panel-2); border: 1px solid var(--border);
           color: var(--muted); font-size: 11px; font-family: var(--mono); }
  .badge.ok  { color: var(--ok);  border-color: rgba(61,220,132,.35); background: rgba(61,220,132,.08); }
  .badge.bad { color: var(--bad); border-color: rgba(255,90,95,.35); background: rgba(255,90,95,.08); }
  table.agents { width: 100%; border-collapse: collapse; font-size: 13px; }
  table.agents th { text-align: left; font-weight: 500; color: var(--muted);
                    font-size: 11px; text-transform: uppercase; letter-spacing: .6px;
                    border-bottom: 1px solid var(--border); padding: 8px 6px; }
