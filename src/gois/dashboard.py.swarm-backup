  .chip .nm  { font-family: var(--mono); }
  .chip.running { color: var(--accent); border-color: var(--accent);
                  background: rgba(106,169,255,.12); }
  .chip.idle    { color: var(--ok); }
  .chip.fresh   { background: rgba(61,220,132,.10); border-color: rgba(61,220,132,.35); }
  .chip.dim     { color: var(--muted); opacity: .75; }
  .chip .pulse  { width: 8px; height: 8px; background: currentColor; }
  .chip .dot    { width: 8px; height: 8px; box-shadow: none; background: currentColor; }
  .chip .meta   { color: var(--muted); font-size: 11px; font-family: var(--mono); }
  .chips .none  { color: var(--muted); font-style: italic; font-size: 13px; }
  .step { color: var(--accent); font-family: var(--mono); font-size: 12px;
