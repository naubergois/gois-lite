  #hermes-cron-table td:nth-child(11) { min-width: 280px; }
  #hermes-cron-table th:nth-child(12),
  #hermes-cron-table td:nth-child(12) { min-width: 180px; }
  #hermes-cron-table th:nth-child(13),
  #hermes-cron-table td:nth-child(13) { min-width: 220px; }
  #hermes-cron-table th:nth-child(14),
  #hermes-cron-table td:nth-child(14) { min-width: 144px; }
  #hermes-cron-wrap .cron-toolbar {
    margin: 0 0 12px;
    padding: 10px 12px;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: var(--panel-2);
    gap: 10px;
  }
  .cron-toolbar h3 { margin: 0; font-size: 12px; font-weight: 600; color: var(--muted);
                     text-transform: uppercase; letter-spacing: .8px; }
  .cron-toolbar label { font-size: 12px; color: var(--muted); cursor: pointer;
                         display: inline-flex; align-items: center; gap: 6px; }
  .cron-toolbar select {
    min-height: 32px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--panel);
    color: var(--fg);
    padding: 6px 10px;
    font-size: 12px;
  }
  .cron-toolbar .meta { font-size: 11px; font-family: var(--mono); color: var(--muted); }
  .cron-toolbar input.cron-filter {
    min-width: 200px; max-width: 320px; flex: 1 1 200px;
    background: var(--panel); color: var(--fg); border: 1px solid var(--border);
    border-radius: 8px; padding: 7px 11px; font: inherit; font-size: 12px;
    font-family: var(--mono); }
  .cron-toolbar input.cron-filter::placeholder { color: var(--muted); }
  .cron-toolbar input.cron-filter:focus,
  .cron-toolbar select:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 2px rgba(106,169,255,.12);
  }
  .cron-toolbar button.cron-bulk-resume {
    font-size: 12px; padding: 7px 12px; border-radius: 8px; cursor: pointer;
    border: 1px solid rgba(61,220,132,.35); background: rgba(61,220,132,.08);
    color: var(--ok); font-weight: 600;
  }
  .cron-toolbar button.cron-bulk-resume:hover:not(:disabled) {
    background: rgba(61,220,132,.14);
  }
  .cron-toolbar button.cron-bulk-resume:disabled {
    opacity: .45; cursor: not-allowed; color: var(--muted); border-color: var(--border);
    background: var(--panel);
  }
  .agents td.cron-id { font-family: var(--mono); font-size: 11px; color: var(--muted);
                       max-width: 140px; word-break: break-all; vertical-align: top; }
  .agents td.cron-skills { max-width: 220px; vertical-align: top; }
  .cron-skills-wrap { display: flex; flex-wrap: wrap; gap: 4px; }
  .cron-skill-chip {
    display: inline-flex; align-items: center; padding: 2px 8px; border-radius: 999px;
    border: 1px solid rgba(92, 196, 255, .18); background: rgba(92, 196, 255, .08);
    color: var(--accent); font-size: 11px; font-family: var(--mono); line-height: 1.35;
  }
  .cron-skills-none { color: var(--muted); font-size: 11px; font-style: italic; }
  .cron-running-wrap { margin: 14px 0 4px; }
  .cron-running-card { background: var(--panel-2); border: 1px solid var(--border);
                        border-radius: 8px; padding: 12px 14px; margin-bottom: 10px; }
  .cron-running-head { display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
                       margin-bottom: 8px; }
  .cron-running-head .nm { font-weight: 600; font-size: 14px; }
  .cron-running-head .meta { font-size: 11px; font-family: var(--mono); color: var(--muted); }
  .cron-running-log { margin: 0; padding: 10px 12px; background: var(--panel);
                      border: 1px solid var(--border); border-radius: 6px;
                      font-family: var(--mono); font-size: 11px; line-height: 1.45;
                      color: var(--muted); white-space: pre-wrap; word-break: break-word;
                      max-height: 180px; overflow: auto; }
  .cron-edit-row td { background: var(--panel-2); padding: 12px 14px !important; }
  .cron-edit-form { display: grid; grid-template-columns: 1fr 1fr; gap: 10px 14px; }
  .cron-edit-form label { display: flex; flex-direction: column; gap: 4px;
                          font-size: 11px; color: var(--muted); text-transform: uppercase;
                          letter-spacing: .5px; }
  .cron-edit-form label.full { grid-column: 1 / -1; }
  .cron-edit-form input, .cron-edit-form textarea {
    background: var(--panel); color: var(--fg); border: 1px solid var(--border);
    border-radius: 6px; padding: 8px 10px; font: inherit; font-size: 13px; }
  .cron-edit-form textarea { min-height: 160px; resize: vertical; font-family: inherit; white-space: pre-wrap; }
  .cron-edit-form select { background: var(--panel); color: var(--fg); border: 1px solid var(--border);
                            border-radius: 6px; padding: 8px 10px; font: inherit; font-size: 13px; }
  .cron-sched-builder { grid-column: 1 / -1; display: flex; flex-direction: column; gap: 10px;
                        padding: 10px 12px; border: 1px solid var(--border); border-radius: 8px;
                        background: var(--panel); }
  .cron-sched-builder .sched-head { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
  .cron-sched-builder .sched-head .pill { font-size: 11px; text-transform: none; letter-spacing: 0; }
  .cron-sched-panel { display: none; gap: 10px; flex-wrap: wrap; align-items: flex-end; }
  .cron-sched-panel.active { display: flex; }
  .cron-sched-panel label { flex: 1; min-width: 120px; }
  .cron-sched-panel label.narrow { flex: 0 0 100px; min-width: 80px; }
  .cron-sched-preview { font-size: 12px; color: var(--muted); font-family: var(--mono); }
  .cron-sched-preview code { color: var(--accent); }
  .cron-edit-resume { grid-column: 1 / -1; flex-direction: row; align-items: center; gap: 8px;
                      text-transform: none; letter-spacing: 0; font-size: 13px; color: var(--fg); }
  .cron-edit-resume input { width: auto; margin: 0; }
  .cron-edit-actions { grid-column: 1 / -1; display: flex; gap: 8px; flex-wrap: wrap;
                       margin-top: 4px; }
  .cron-edit-actions button.save { background: var(--accent); color: #0b1220; border: 0;
                                    border-radius: 6px; padding: 8px 12px; font-weight: 600;
                                    cursor: pointer; }
  .cron-edit-actions button.cancel { background: transparent; color: var(--muted);
                                     border: 1px solid var(--border); border-radius: 6px;
                                     padding: 8px 12px; cursor: pointer; }
  button.ctrl.run, button.ctrl.cron-play { color: var(--ok); border-color: rgba(61,220,132,.35);
                                            font-size: 13px; min-width: 2rem; }
  button.ctrl.run:hover, button.ctrl.cron-play:hover { background: rgba(61,220,132,.10); }
  button.ctrl.view { color: var(--muted); }
  button.ctrl.view.active { color: var(--accent); border-color: rgba(106,169,255,.35); }
  button.ctrl.edit:hover { color: var(--accent); border-color: rgba(106,169,255,.35); }
  .agents td.result-preview { font-size: 12px; color: var(--muted); max-width: 260px;
                               word-break: break-word; vertical-align: top; }
  .agents td.result-preview.clickable { cursor: pointer; color: var(--fg); }
  .agents td.result-preview.clickable:hover { color: var(--accent); }
  .agents td.result-preview .empty-preview { font-style: italic; opacity: .7; }
  .cron-truncate {
    display: inline-block;
    max-width: 100%;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    vertical-align: top;
  }
  __HERMES_CRON_EXEC_CSS__
  .cron-exec-status { display: inline-flex; align-items: center; gap: 6px; }
  .cron-exec-status .pill { font-size: 11px; }
  .hermes-cron-scheduler {
    display: flex; align-items: flex-start; gap: 12px; flex-wrap: wrap;
    margin: 12px 0 4px; padding: 12px 14px; border-radius: 10px;
    border: 1px solid var(--border); background: var(--panel-2);
  }
  .hermes-cron-scheduler .dot { margin-top: 4px; flex-shrink: 0; }
  .hermes-cron-scheduler .label { font-size: 13px; font-weight: 600; }
  .hermes-cron-scheduler .meta { font-size: 11px; font-family: var(--mono);
    color: var(--muted); line-height: 1.45; margin-top: 4px; }
  .hermes-cron-scheduler.up { border-color: rgba(61,220,132,.35); }
  .hermes-cron-scheduler.down { border-color: rgba(255,90,95,.35); }
  .hermes-cron-scheduler .sched-pill {
    display: inline-block; font-size: 10px; font-weight: 600; text-transform: uppercase;
    letter-spacing: .04em; padding: 2px 8px; border-radius: 999px; margin-left: 8px;
    vertical-align: middle;
  }
  .hermes-cron-scheduler.up .sched-pill { background: rgba(61,220,132,.15); color: var(--ok); }
  .hermes-cron-scheduler.down .sched-pill { background: rgba(255,90,95,.12); color: var(--bad); }
  .hermes-cron-scheduler-actions { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 10px; }
  .hermes-cron-scheduler-actions button { font-size: 12px; padding: 6px 12px;
    border-radius: 6px; cursor: pointer; border: 1px solid var(--border);
    background: var(--panel); color: var(--text); }
  .hermes-cron-scheduler-actions button.primary { background: var(--accent); color: #0b1220;
    border-color: transparent; font-weight: 600; }
  .hermes-cron-scheduler-actions button:disabled { opacity: .5; cursor: wait; }
  .hermes-cron-diagnosis {
    margin-top: 12px; padding: 12px 14px; border-radius: 8px;
    border: 1px solid rgba(255,90,95,.25); background: rgba(255,90,95,.04);
  }
  .hermes-cron-diagnosis.healthy {
    border-color: rgba(61,220,132,.25); background: rgba(61,220,132,.04);
  }
  .hermes-cron-diagnosis-title {
    font-size: 12px; font-weight: 700; text-transform: uppercase;
    letter-spacing: .04em; color: var(--muted); margin-bottom: 6px;
  }
  .hermes-cron-diagnosis-headline {
    font-size: 13px; font-weight: 600; margin: 0 0 8px; line-height: 1.4;
  }
  .hermes-cron-diagnosis-issues,
  .hermes-cron-diagnosis-recs {
    margin: 0 0 8px; padding-left: 18px; font-size: 12px; line-height: 1.45;
  }
  .hermes-cron-diagnosis-issues li.sev-error { color: var(--bad); }
  .hermes-cron-diagnosis-issues li.sev-warning { color: var(--warn); }
  .hermes-cron-diagnosis-recs li { color: var(--muted); }
  .hermes-cron-diagnosis-agent {
    font-size: 11px; font-family: var(--mono); white-space: pre-wrap;
    max-height: 180px; overflow: auto; margin-top: 8px; padding-top: 8px;
    border-top: 1px solid var(--border); color: var(--text);
  }
  .swarm-sched-wrap {
    margin: 12px 0 6px;
    padding: 12px 14px;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: var(--panel-2);
  }
  .swarm-sched-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 8px;
  }
  .swarm-sched-head .title {
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .04em;
    color: var(--muted);
  }
  .swarm-sched-head .meta {
    font-size: 11px;
    font-family: var(--mono);
    color: var(--muted);
  }
  table.swarm-sched {
    width: 100%;
    border-collapse: collapse;
    font-size: 12px;
  }
  table.swarm-sched th,
  table.swarm-sched td {
    padding: 7px 8px;
    border-top: 1px solid var(--border);
    text-align: left;
    vertical-align: top;
  }
  table.swarm-sched th {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: .04em;
    color: var(--muted);
  }
  table.swarm-sched td.mono {
    font-family: var(--mono);
    white-space: nowrap;
  }
  .ruflo-agent-wrap {
    margin: 12px 0 6px;
    padding: 12px 14px;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: var(--panel-2);
  }
  .ruflo-agent-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 8px;
  }
  .ruflo-agent-head .title {
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .04em;
    color: var(--muted);
  }
  .ruflo-agent-head .meta {
    font-size: 11px;
    font-family: var(--mono);
    color: var(--muted);
  }
  table.ruflo-agent-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 12px;
  }
  table.ruflo-agent-table th,
  table.ruflo-agent-table td {
    padding: 7px 8px;
    border-top: 1px solid var(--border);
    text-align: left;
    vertical-align: top;
  }
  table.ruflo-agent-table th {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: .04em;
    color: var(--muted);
  }
  table.ruflo-agent-table td.mono {
    font-family: var(--mono);
    white-space: nowrap;
  }
  .ruflo-result-empty { color: var(--muted); font-style: italic; }
  .ruflo-jobs-wrap { margin-top: 12px; }
  table.ruflo-job-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 12px;
  }
  table.ruflo-job-table th,
  table.ruflo-job-table td {
    padding: 7px 8px;
    border-top: 1px solid var(--border);
    text-align: left;
    vertical-align: top;
  }
  table.ruflo-job-table th {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: .04em;
    color: var(--muted);
  }
  table.ruflo-job-table td.mono {
    font-family: var(--mono);
    white-space: nowrap;
  }
  .ruflo-sched-badge {
    display: inline-block;
    margin-left: 8px;
    padding: 1px 7px;
    border-radius: 999px;
    font-size: 10px;
    font-family: var(--mono);
    border: 1px solid var(--border);
    color: var(--muted);
    background: var(--panel-2);
    vertical-align: middle;
  }
  .ruflo-sched-badge.soon {
    color: #0f1115;
    border-color: rgba(255,180,84,.75);
    background: var(--warn);
  }
  .ruflo-sched-badge.today {
    color: var(--warn);
    border-color: rgba(255,180,84,.45);
    background: rgba(255,180,84,.12);
  }
  .ruflo-sched-badge.late {
    color: var(--bad);
    border-color: rgba(255,90,95,.45);
    background: rgba(255,90,95,.12);
  }
  .hermes-tabs {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin: 4px 0 12px;
  }
  .hermes-tabs .tab-btn {
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--panel-2);
    color: var(--muted);
    padding: 6px 12px;
    font-size: 12px;
    font-family: var(--mono);
    cursor: pointer;
  }
  .hermes-tabs .tab-btn.active {
    border-color: var(--accent);
    background: rgba(106,169,255,.12);
    color: var(--accent);
    font-weight: 600;
  }
  .hermes-pane-hidden { display: none !important; }
  table.swarm-sched tr.swarm-highlight td {
    background: rgba(106,169,255,.10);
  }
  .swarm-badge {
    display: inline-block;
    margin-left: 6px;
    padding: 1px 7px;
    border-radius: 999px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .03em;
    text-transform: uppercase;
    color: #9ec7ff;
    background: rgba(106,169,255,.16);
    border: 1px solid rgba(106,169,255,.35);
    vertical-align: middle;
  }
  #hermes-cron-table tr.swarm-highlight td {
    background: rgba(106,169,255,.08);
  }
  .agents td.actions { white-space: nowrap; text-align: right; }
  .agents td.actions .ctrl { margin-left: 4px; }
  .agents td.actions .cron-source-badge {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    border: 1px solid var(--border);
    padding: 2px 7px;
    margin-left: 4px;
    font-size: 10px;
    line-height: 1.2;
    letter-spacing: .04em;
    text-transform: uppercase;
    font-family: var(--mono);
    color: var(--muted);
    background: var(--panel-2);
    vertical-align: middle;
    cursor: pointer;
    user-select: none;
  }
  .agents td.actions .cron-source-badge:hover { border-color: var(--accent); }
  .agents td.actions .cron-source-badge:focus-visible {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 2px rgba(106,169,255,.18);
  }
  .agents td.actions .cron-source-badge.profile {
    color: #7dd3fc;
    border-color: rgba(125,211,252,.35);
    background: rgba(14,116,144,.14);
  }
  .agents td.actions .cron-source-badge.file {
    color: #86efac;
    border-color: rgba(134,239,172,.35);
    background: rgba(22,101,52,.14);
  }
  .agents td.actions .cron-source-badge.prompt {
    color: #fcd34d;
    border-color: rgba(252,211,77,.35);
    background: rgba(146,64,14,.16);
  }
  .agents td.actions .cron-source-badge.unknown {
    color: var(--muted);
    border-style: dashed;
  }
  .agents td.sched { font-family: var(--mono); font-size: 12px; white-space: nowrap; }
  .agents td.when  { font-family: var(--mono); font-size: 11px; color: var(--muted);
                     white-space: nowrap; }
  #hermes-cron-table tbody tr:hover td {
    background: rgba(106,169,255,.06);
  }
  #hermes-cron-wrap .table-scroll {
    max-height: none;
  }
  #hermes-cron-table thead th {
    backdrop-filter: blur(4px);
  }
  #hermes-cron-table td:nth-child(11),
  #hermes-cron-table td:nth-child(12),
  #hermes-cron-table td:nth-child(13) {
    line-height: 1.4;
    vertical-align: top;
  }
  #hermes-cron-table td:nth-child(2) {
    font-weight: 600;
  }
  #hermes-cron-wrap .cron-toolbar,
  #hermes-cron-running-wrap .cron-toolbar {
    box-shadow: inset 0 0 0 1px rgba(255,255,255,.02);
  }
  #hermes-recovery-panel,
  #hermes-cron-scheduler,
  #hermes-cron-running-wrap,
  #swarm-schedule-wrap,
  #hermes-profiles-wrap,
  #hermes-chat-launch,
  #hermes-cron-wrap {
    box-shadow: 0 10px 24px rgba(0,0,0,.16);
  }
  #hermes-cron-running-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 10px;
  }
  #hermes-cron-running-list .cron-running-card {
    margin-bottom: 0;
  }
  #hermes-cron-scheduler .hermes-cron-scheduler-actions {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(188px, 1fr));
    gap: 8px;
  }
  #hermes-cron-scheduler .hermes-cron-scheduler-actions button {
    width: 100%;
  }
  #hermes-section > #hermes-cron-scheduler,
  #hermes-section > #hermes-recovery-panel,
  #hermes-section > #hermes-cron-running-wrap,
  #hermes-section > #swarm-schedule-wrap,
  #hermes-section > #hermes-cron-wrap {
    scroll-margin-top: 14px;
  }
  @media (min-width: 1360px) {
    #hermes-cron-wrap {
      padding: 14px;
    }
    #hermes-cron-wrap .cron-toolbar {
      display: grid;
      grid-template-columns: minmax(250px, 1fr) minmax(170px, max-content) minmax(190px, max-content) minmax(180px, max-content) minmax(320px, 1.1fr);
      align-items: center;
      column-gap: 12px;
      row-gap: 8px;
      padding: 12px 14px;
    }
    #hermes-cron-wrap .cron-toolbar h3 {
      grid-column: 1;
      grid-row: 1;
    }
    #hermes-cron-wrap .cron-toolbar .meta {
      grid-column: 1;
      grid-row: 2;
    }
    #hermes-cron-wrap .cron-toolbar > label:first-of-type {
      grid-column: 2;
      grid-row: 1 / span 2;
      align-self: center;
    }
    #hermes-cron-wrap .cron-toolbar > label:last-of-type {
      grid-column: 3;
      grid-row: 1 / span 2;
      align-self: center;
    }
    #hermes-cron-wrap .cron-toolbar #hermes-cron-resume-all {
      grid-column: 4;
      grid-row: 1 / span 2;
      align-self: center;
      width: 100%;
      min-height: 34px;
    }
    #hermes-cron-wrap .cron-toolbar #hermes-cron-filter {
      grid-column: 5;
      grid-row: 1 / span 2;
      max-width: none;
      width: 100%;
      min-height: 34px;
    }
    #hermes-cron-wrap .table-scroll table.agents {
      min-width: 1420px;
    }
    #hermes-cron-table th,
    #hermes-cron-table td {
      padding-left: 8px;
      padding-right: 8px;
    }
    #hermes-cron-table th:nth-child(14),
    #hermes-cron-table td:nth-child(14) {
      position: sticky;
      right: 0;
      z-index: 3;
      background: linear-gradient(90deg, rgba(12, 15, 20, .82), rgba(12, 15, 20, .98));
      backdrop-filter: blur(3px);
    }
    #hermes-cron-table tbody tr:nth-child(even) td:nth-child(14),
    #hermes-cron-table tbody tr:hover td:nth-child(14) {
      background: linear-gradient(90deg, rgba(14, 18, 24, .9), rgba(14, 18, 24, .98));
    }
    #hermes-cron-wrap .table-scroll {
      max-height: none;
    }
  }
  @media (min-width: 1500px) {
    #hermes-section {
      display: grid;
      grid-template-columns: repeat(12, minmax(0, 1fr));
      gap: 12px;
      align-items: start;
    }
    #hermes-section > h2,
    #hermes-section > #hermes-tabs,
    #hermes-section > #hermes-status-card,
    #hermes-section > #hermes-cron-wrap,
    #hermes-section > #ruflo-agent-wrap,
    #hermes-section > #hermes-profiles-wrap,
    #hermes-section > #hermes-chat-launch {
      grid-column: 1 / -1;
    }
    #hermes-section > #hermes-cron-scheduler,
    #hermes-section > #hermes-recovery-panel,
    #hermes-section > #hermes-cron-running-wrap,
    #hermes-section > #swarm-schedule-wrap {
      grid-column: span 6;
      margin-top: 0;
    }
    #hermes-section > #hermes-cron-running-wrap,
    #hermes-section > #swarm-schedule-wrap {
      align-self: stretch;
    }
    #hermes-cron-wrap {
      margin-top: 2px;
    }
  }
  @media (max-width: 980px) {
    #hermes-cron-wrap { padding: 10px; }
    #hermes-cron-wrap .cron-toolbar {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 8px;
      padding: 10px;
    }
    #hermes-cron-wrap .cron-toolbar h3,
    #hermes-cron-wrap .cron-toolbar .meta,
    #hermes-cron-wrap .cron-toolbar input.cron-filter {
      grid-column: 1 / -1;
    }
    #hermes-cron-wrap .cron-toolbar label { min-width: 0; }
    #hermes-cron-wrap .cron-toolbar select,
    #hermes-cron-wrap .cron-toolbar button.cron-bulk-resume {
      width: 100%;
    }
  }
  @media (max-width: 680px) {
    #hermes-cron-wrap .cron-toolbar { grid-template-columns: 1fr; }
    #hermes-cron-wrap .table-scroll table.agents { min-width: 920px; }
  }
  .proc-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(min(260px, 100%), 1fr));
               gap: 10px; }
  .proc { display: flex; align-items: center; gap: 10px; padding: 10px 12px;
          background: var(--panel-2); border: 1px solid var(--border);
          border-radius: 8px; }
  .proc .role-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
  .proc .role-dot.main    { background: var(--accent); box-shadow: 0 0 8px rgba(106,169,255,.55); }
  .proc .role-dot.helper  { background: var(--ok); }
  .proc .role-dot.bridge  { background: var(--warn); }
  .proc .role-dot.gateway { background: #c08bff; }
  .proc .role-dot.other   { background: var(--muted); }
  .proc .info  { flex: 1; min-width: 0; }
  .proc .nm    { font-weight: 600; font-size: 13px; }
  .proc .meta  { color: var(--muted); font-family: var(--mono); font-size: 11px;
                 white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .proc .pid   { color: var(--muted); font-family: var(--mono); font-size: 11px;
                 white-space: nowrap; }
  .proc-count  { color: var(--muted); font-size: 12px; font-family: var(--mono); }
  .proc .rss   { color: var(--muted); font-family: var(--mono); font-size: 11px; }
  .mem-total   { font-family: var(--mono); color: var(--accent); margin-left: 6px; }
  .log-row     { padding: 8px 10px; background: var(--panel-2); border: 1px solid var(--border);
                 border-radius: 6px; font-family: var(--mono); font-size: 12px; margin-bottom: 6px; }
  .log-row .pat   { color: var(--warn); font-weight: 600; }
  .log-row .file  { color: var(--muted); font-size: 11px; }
  .log-row .ln    { color: var(--fg); margin-top: 4px; word-break: break-word; }
  .pill.paused  { color: var(--muted); background: var(--panel-2); }
  .chip.paused  { color: var(--muted); border-style: dashed; opacity: .7; }
  button.ctrl   { background: transparent; color: var(--muted); border: 1px solid var(--border);
                  border-radius: 6px; padding: 4px 10px; font-size: 11px;
                  font-family: var(--mono); cursor: pointer; }
  button.ctrl:hover  { color: var(--fg); border-color: var(--accent); }
  button.ctrl.resume { color: var(--ok); border-color: rgba(61,220,132,.35); }
  button.ctrl.resume:hover { background: rgba(61,220,132,.10); }
  button.ctrl.pause:hover  { background: rgba(255,180,84,.08); border-color: var(--warn); color: var(--warn); }
  button.ctrl.cron-delete { color: var(--bad); border-color: rgba(255,90,95,.35); }
  button.ctrl.cron-delete:hover { background: rgba(255,90,95,.12); border-color: var(--bad); color: var(--bad); }
  button.ctrl[disabled] { opacity: .5; cursor: progress; }
  .chat { margin-top: 16px; display: flex; flex-direction: column; gap: 10px; }
  .chat-log { min-height: 72px; max-height: 220px; overflow: auto; display: flex;
              flex-direction: column; gap: 8px; padding: 10px; background: var(--panel-2);
              border: 1px solid var(--border); border-radius: 8px; }
  .chat-msg { padding: 8px 10px; border-radius: 8px; font-size: 13px; line-height: 1.45;
              white-space: pre-wrap; word-break: break-word; }
  .chat-msg.user { background: rgba(106,169,255,.12); border: 1px solid rgba(106,169,255,.25); }
  .chat-msg.bot  { background: rgba(61,220,132,.08); border: 1px solid rgba(61,220,132,.22); }
  .chat-msg.err  { background: rgba(255,90,95,.10); border: 1px solid rgba(255,90,95,.30);
                   color: var(--bad); }
  .chat-msg .meta { display: block; margin-top: 6px; color: var(--muted);
                    font-family: var(--mono); font-size: 11px; }
  .chat-compose { display: flex; gap: 8px; align-items: flex-end; }
  .chat-compose textarea { flex: 1; min-height: 56px; max-height: 140px; resize: vertical;
                           background: var(--panel-2); color: var(--fg); border: 1px solid var(--border);
                           border-radius: 8px; padding: 10px 12px; font: inherit; }
  .chat-compose textarea:focus { outline: none; border-color: var(--accent); }
  .chat-compose button { background: var(--accent); color: #0b1220; border: 0; border-radius: 8px;
                          padding: 10px 14px; font-size: 12px; font-weight: 600; cursor: pointer; }
  .chat-compose button:hover { filter: brightness(1.05); }
  .chat-compose button[disabled] { opacity: .55; cursor: progress; }
  .chat-compose .voice-btn { background: var(--panel-2); color: var(--fg);
                              border: 1px solid var(--border); }
  .chat-compose .voice-btn:hover { filter: none; border-color: var(--accent); }
  .chat-compose .voice-btn.listening { background: rgba(255,90,95,.12); color: var(--bad);
                                       border-color: rgba(255,90,95,.35); }
  .chat-hint { color: var(--muted); font-size: 12px; }
  .chat-options { display: flex; flex-wrap: wrap; gap: 10px; align-items: flex-end; }
  .chat-options label { display: flex; flex-direction: column; gap: 4px;
                         font-size: 11px; color: var(--muted); min-width: 140px; }
  .chat-options input { background: var(--panel-2); color: var(--fg);
                        border: 1px solid var(--border); border-radius: 6px;
                        padding: 8px 10px; font: inherit; font-size: 13px; }
  .skills-panel { margin-top: 8px; padding: 10px 12px; background: var(--panel-2);
                  border: 1px solid var(--border); border-radius: 8px;
                  max-height: 200px; overflow: auto; font-size: 12px; line-height: 1.5; }
  .skills-panel h4 { margin: 0 0 8px; font-size: 11px; color: var(--muted);
                     text-transform: uppercase; letter-spacing: .6px; }
  .skills-panel ul { margin: 0 0 8px 16px; padding: 0; }
  .skills-panel li { margin-bottom: 4px; }
  .skills-panel code { font-family: var(--mono); font-size: 11px; color: var(--accent); }
  .hermes-recovery-panel { margin: 14px 0 4px; padding: 12px 14px;
                           background: var(--panel-2); border: 1px solid var(--border);
                           border-radius: 8px; }
  .hermes-recovery-panel h3 { margin: 0 0 8px; font-size: 12px; font-weight: 600;
                              color: var(--muted); text-transform: uppercase;
                              letter-spacing: .8px; }
  .hermes-recovery-actions { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 10px; }
  .hermes-recovery-actions button { font-size: 12px; padding: 8px 12px; border-radius: 6px;
                                    border: 1px solid var(--border); background: var(--panel);
                                    color: var(--text); cursor: pointer; }
  .hermes-recovery-actions button.primary { background: var(--accent); color: #0b1220;
                                            border-color: transparent; font-weight: 600; }
  .hermes-recovery-actions button:disabled { opacity: .5; cursor: wait; }
  .chip.recovery { border-color: var(--accent); }
  .hermes-profiles { margin-top: 14px; }
  .hermes-profiles h3 { margin: 0 0 8px; font-size: 12px; font-weight: 600;
                        color: var(--muted); text-transform: uppercase; letter-spacing: .8px; }
  .hermes-chat-launch { margin-top: 16px; display: flex; flex-wrap: wrap;
                        align-items: center; justify-content: space-between; gap: 12px;
                        padding: 14px 16px; background: var(--panel-2);
                        border: 1px solid var(--border); border-radius: 8px; }
  .chat-open-btn { background: var(--accent); color: #0b1220; border: 0;
                   border-radius: 8px; padding: 12px 18px; font-size: 13px;
                   font-weight: 600; cursor: pointer; white-space: nowrap; }
  .chat-open-btn:hover { filter: brightness(1.05); }
  .retry-now-btn { margin-top: 8px; padding: 6px 10px; border-radius: 8px;
                   border: 1px solid var(--border); background: var(--panel-2);
                   color: var(--fg); font-size: 12px; cursor: pointer; }
  .retry-now-btn:hover { border-color: var(--accent); }
  .retry-now-btn[hidden] { display: none; }
  .chat-modal { position: fixed; inset: 0; z-index: 1000; display: flex;
                align-items: center; justify-content: center; padding: 24px; }
  .chat-modal[hidden] { display: none; }
  .chat-modal-backdrop { position: absolute; inset: 0; background: rgba(0,0,0,.55);
                         backdrop-filter: blur(2px); }
  .chat-modal-dialog { position: relative; width: min(960px, 96vw); height: min(88vh, 820px);
                       display: flex; flex-direction: column; background: var(--panel);
                       border: 1px solid var(--border); border-radius: 12px;
                       box-shadow: 0 24px 48px rgba(0,0,0,.45); overflow: hidden; }
  .chat-modal-header { display: flex; align-items: flex-start; justify-content: space-between;
                       gap: 12px; padding: 16px 20px; border-bottom: 1px solid var(--border);
                       flex-shrink: 0; }
  .chat-modal-header h2 { margin: 0; font-size: 18px; }
  .chat-modal-header .chat-hint { margin: 4px 0 0; }
  .chat-modal-close { background: transparent; border: 0; color: var(--muted);
                      font-size: 28px; line-height: 1; cursor: pointer; padding: 0 4px; }
  .chat-modal-close:hover { color: var(--fg); }
  .chat-modal-body { flex: 1; min-height: 0; padding: 16px 20px 20px;
                      display: flex; flex-direction: column; overflow: hidden; }
  .chat-modal-body .chat { margin-top: 0; flex: 1; min-height: 0; }
  .chat-modal-body .chat-log { flex: 1; min-height: 200px; max-height: none; }
  .chat-modal-body .skills-panel { max-height: 140px; flex-shrink: 0; }
  .chat-modal-body .chat-compose textarea { min-height: 80px; max-height: 180px; }
  .auth-notice { margin: 14px 0 0; padding: 10px 12px; border-radius: 8px;
                 border: 1px solid rgba(255,180,84,.4); background: rgba(255,180,84,.10);
                 color: var(--warn); font-size: 12px; font-family: var(--mono); display: none; }
  .auth-notice.show { display: block; }
  footer.monitor-footer { flex-shrink: 0; padding: 12px clamp(14px, 2.5vw, 32px);
                           color: var(--muted); font-size: 11px; text-align: center;
                           border-top: 1px solid var(--border); background: var(--panel); }
</style>
</head>
<body>
__APP_NAV__

<main class="monitor-shell">
  <div class="auth-notice" id="auth-notice"></div>
  <div class="monitor-grid">
    <div class="card span-12">
      <div class="status" id="status-card">
        <span class="dot" id="status-dot"></span>
        <div>
          <div class="label" id="status-label">…</div>
          <div class="meta" id="status-meta"></div>
          <div style="margin-top:4px;display:flex;gap:8px;flex-wrap:wrap;">
            <button type="button" id="status-retry-now" class="retry-now-btn" hidden>
              tentar novamente agora
            </button>
            <span id="alerts-badge" class="badge bad" style="display:none;font-size:12px;cursor:help;" title="Alertas ativos"></span>
          </div>
        </div>
      </div>
    </div>

    <div class="card span-12 diag-card" id="diagnosis-card" hidden>
      <h2>Diagnóstico — por que o QClaw caiu?</h2>
      <p class="diag-headline" id="diagnosis-headline">—</p>
      <p class="diag-likely" id="diagnosis-likely"></p>
      <div class="diag-meta" id="diagnosis-meta"></div>
      <ul class="diag-causes" id="diagnosis-causes"></ul>
      <ul class="diag-hints" id="diagnosis-hints"></ul>
      <div class="diag-checks" id="diagnosis-checks"></div>
    </div>

    <div class="card span-12" id="alerts-card" hidden>
      <div style="display:flex;align-items:center;gap:12px;margin-bottom:8px;">
        <h2 style="margin:0;">🔔 Alertas</h2>
        <span class="badge" id="alerts-count-badge" style="font-size:13px;"></span>
        <button type="button" class="ctrl" id="alerts-clear-btn" onclick="clearAlerts()" style="margin-left:auto;">
          🧹 Limpar histórico
        </button>
      </div>
      <div class="table-scroll">
        <table class="agents" id="alerts-table">
          <thead>
            <tr>
              <th>regra</th>
              <th>timestamp</th>
              <th>mensagem</th>
              <th>canais</th>
            </tr>
          </thead>
          <tbody id="alerts-body">
            <tr><td colspan="4" class="empty" style="padding:12px;color:var(--muted);">no alerts</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <div class="card span-12" id="services-section" style="display:none">
      <h2>services</h2>
      <div class="chips" id="services-up"></div>
    </div>

    <div class="card span-12" id="hermes-section" style="display:none">
      <h2>hermes</h2>
      <div class="hermes-tabs" id="hermes-tabs">
        <button type="button" class="tab-btn" data-hermes-tab="overview">visão geral</button>
        <button type="button" class="tab-btn" data-hermes-tab="ruflo">ruflo resultados</button>
        <button type="button" class="tab-btn" data-hermes-tab="cron">cron/hermes</button>
      </div>
      <div class="status" id="hermes-status-card">
        <span class="dot" id="hermes-status-dot"></span>
        <div>
          <div class="label" id="hermes-status-label">…</div>
          <div class="meta" id="hermes-status-meta"></div>
        </div>
        <div class="actions">
          <a class="dash-link" id="hermes-dashboard-link" href="#" target="_blank" rel="noopener">
            abrir dashboard →
          </a>
        </div>
      </div>
      <div class="hermes-cron-scheduler down" id="hermes-cron-scheduler" hidden>
        <span class="dot down" id="hermes-cron-scheduler-dot"></span>
        <div style="flex:1;min-width:200px;">
          <div class="label" id="hermes-cron-scheduler-label">
            Cron scheduler<span class="sched-pill" id="hermes-cron-scheduler-pill">…</span>
          </div>
          <div class="meta" id="hermes-cron-scheduler-meta">aguardando /status…</div>
          <div class="hermes-cron-diagnosis" id="hermes-cron-diagnosis" hidden>
            <div class="hermes-cron-diagnosis-title">Diagnóstico — por que os crons não executam?</div>
            <p class="hermes-cron-diagnosis-headline" id="hermes-cron-diagnosis-headline">—</p>
            <ul class="hermes-cron-diagnosis-issues" id="hermes-cron-diagnosis-issues"></ul>
            <ul class="hermes-cron-diagnosis-recs" id="hermes-cron-diagnosis-recs"></ul>
            <div class="hermes-cron-diagnosis-agent" id="hermes-cron-diagnosis-agent"></div>
          </div>
          <div class="hermes-cron-scheduler-actions">
            <button type="button" class="primary" id="hermes-cron-ensure-gateway">
              subir gateway cron
            </button>
            <button type="button" id="hermes-cron-run-agent" title="Disparo manual; com auto_recover o agente corre sozinho">
              agente recuperar cron (manual)
            </button>
            <button type="button" id="hermes-cron-ensure-profile">
              perfil hermes-cron-recovery
            </button>
            <button type="button" id="hermes-cron-diagnose">
              diagnosticar crons
            </button>
            <button type="button" id="hermes-cron-diagnose-agent">
              agente diagnóstico (LLM)
            </button>
            <button type="button" id="hermes-cron-diagnose-profile">
              perfil hermes-cron-diagnostic
            </button>
          </div>
          <pre class="meta" id="hermes-cron-diagnose-out"
               style="display:none;margin-top:10px;white-space:pre-wrap;max-height:220px;overflow:auto;"></pre>
      </div>
      </div>
      <div class="hermes-recovery-panel" id="hermes-recovery-panel">
        <h3>agente de recuperação Hermes</h3>
        <div class="meta" id="hermes-recovery-meta">carregando…</div>
        <div class="hermes-recovery-actions">
          <button type="button" class="primary" id="hermes-recovery-open-dash">
            abrir dashboard Hermes
          </button>
          <button type="button" id="hermes-recovery-restart-dash">
            reiniciar dashboard
          </button>
          <button type="button" id="hermes-recovery-restart-gw">
            reiniciar gateway
          </button>
          <button type="button" id="hermes-recovery-ensure-profile">
            instalar perfil hermes-recovery
          </button>
          <a class="dash-link" id="hermes-recovery-profile-link" href="#" target="_blank"
             rel="noopener" style="align-self:center;font-size:12px;">perfil no Hermes →</a>
        </div>
        <div class="meta" id="hermes-recovery-result" style="margin-top:8px;display:none;"></div>
      </div>
      <div id="hermes-cron-running-wrap" class="cron-running-wrap" style="display:none">
        <div class="cron-toolbar">
          <h3>jobs em execução</h3>
          <span class="meta" id="hermes-cron-running-meta">—</span>
        </div>
        <div id="hermes-cron-running-list"></div>
      </div>
      <div id="swarm-schedule-wrap" class="swarm-sched-wrap" style="display:none">
        <div class="swarm-sched-head">
          <span class="title">agentes do swarm (agendados)</span>
          <span class="meta" id="swarm-schedule-meta">—</span>
        </div>
        <div class="table-scroll">
          <table class="swarm-sched">
            <thead>
              <tr>
                <th>agente</th>
                <th>perfil</th>
                <th>schedule</th>
                <th>próxima</th>
                <th>estado</th>
                <th>resultado</th>
              </tr>
            </thead>
            <tbody id="swarm-schedule-body">
              <tr><td colspan="6" class="empty" style="padding:12px;color:var(--muted);">—</td></tr>
            </tbody>
          </table>
        </div>
      </div>
      <div id="ruflo-agent-wrap" class="ruflo-agent-wrap" style="display:none">
        <div class="ruflo-agent-head">
          <span class="title">resultados por agente ruflo</span>
          <span class="meta" id="ruflo-agent-meta">—</span>
        </div>
        <div class="table-scroll">
          <table class="ruflo-agent-table">
            <thead>
              <tr>
                <th>agente</th>
                <th>papel</th>
                <th>estado</th>
                <th>último resultado</th>
                <th>tarefa</th>
              </tr>
            </thead>
            <tbody id="ruflo-agent-body">
              <tr><td colspan="5" class="empty" style="padding:12px;color:var(--muted);">aguardando /ruflo/status…</td></tr>
            </tbody>
          </table>
        </div>
        <div class="ruflo-jobs-wrap" id="ruflo-jobs-wrap">
          <div class="ruflo-agent-head" style="margin-top:10px;">
            <span class="title">jobs ruflo agendados</span>
            <span class="meta" id="ruflo-jobs-meta">—</span>
          </div>
          <div class="table-scroll">
            <table class="ruflo-job-table">
              <thead>
                <tr>
                  <th>job</th>
                  <th>perfil</th>
                  <th>schedule</th>
                  <th>próxima</th>
                  <th>estado</th>
                </tr>
              </thead>
              <tbody id="ruflo-jobs-body">
                <tr><td colspan="5" class="empty" style="padding:12px;color:var(--muted);">aguardando /status…</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
      <div id="hermes-cron-wrap" style="display:none">
        <div class="cron-toolbar">
          <h3>cron jobs (schedule)</h3>
          <span class="meta" id="hermes-cron-meta">—</span>
          <label><input type="checkbox" id="hermes-cron-show-paused"> mostrar pausados</label>
          <label>estado
            <select id="hermes-cron-state-filter" aria-label="Filtrar por estado do cron">
              <option value="all">todos</option>
              <option value="running">executando</option>
              <option value="scheduled">agendado</option>
              <option value="done">concluído</option>
              <option value="error">erro</option>
              <option value="skipped">ignorado</option>
              <option value="paused">pausado</option>
              <option value="disabled">desligado</option>
            </select>
          </label>
          <button type="button" class="cron-bulk-resume" id="hermes-cron-resume-all"
                  title="Retomar todos os cron jobs em estado pausado" disabled>
            despausar todos
          </button>
          <button type="button" class="cron-bulk-resume" id="hermes-cron-resolve-problematic"
                  title="Disparar o agente para tentar resolver todos os jobs com erro" disabled>
            resolver problemáticos (agente)
          </button>
          <button type="button" class="cron-bulk-resume" id="hermes-cron-force-remove"
                  title="Remover job a força em todos os perfis Hermes">
            remover na forca bruta
          </button>
          <input type="search" class="cron-filter" id="hermes-cron-filter"
               placeholder="filtrar por id, nome, perfil ou prompt…" autocomplete="off"
                 aria-label="Filtrar cron jobs">
        </div>
        <div class="table-scroll">
        <table class="agents" id="hermes-cron-table">
          <thead>
            <tr>
              <th>id</th>
              <th>nome</th>
              <th>modelo</th>
              <th>skills</th>
              <th>tokens (média)</th>
              <th>schedule</th>
              <th>estado</th>
              <th>próxima</th>
              <th>última</th>
              <th>status</th>
              <th>prompt</th>
              <th>WhatsApp</th>
              <th>resultado</th>
              <th style="text-align:right;">ações</th>
            </tr>
          </thead>
          <tbody id="hermes-cron-body">
            <tr><td colspan="14" class="empty" style="padding:14px;color:var(--muted);">—</td></tr>
          </tbody>
        </table>
        </div>
      </div>
      <div class="hermes-profiles" id="hermes-profiles-wrap">
        <h3>perfis Hermes <span class="meta" id="hermes-profiles-meta"></span></h3>
        <div class="chips" id="hermes-profiles-list">
          <span class="none">carregando…</span>
        </div>
      </div>
      <div class="hermes-chat-launch" id="hermes-chat-launch">
        <div class="chat-hint">
          Descreva o requisito de programação — o monitor cria um perfil Hermes,
          escolhe skills de desenvolvimento e agenda um cron no Hermes.
        </div>
        <button type="button" class="chat-open-btn" id="hermes-chat-open">
          Abrir chat — criar agente Hermes
        </button>
      </div>
    </div>

    <div class="card span-12">
      <h2>agents up</h2>
      <div class="chips" id="agents-up">
        <span class="none">connecting…</span>
      </div>
    </div>

    <div class="card span-6" id="kanban-card" style="display:none">
      <h2>Kanban</h2>
      <div class="kv"><span class="k">projeto padrão</span><span class="v" id="kanban-default-team">—</span></div>
      <div class="kv"><span class="k">abrir</span><span class="v"><a id="kanban-open-link" href="/kanban">/kanban</a></span></div>
    </div>

    <div class="card span-12">
      <h2>qclaw processes
        <span class="proc-count" id="proc-count"></span>
        <span class="mem-total" id="mem-total"></span>
      </h2>
      <div class="proc-grid" id="proc-grid">
        <span class="none" style="color:var(--muted);">connecting…</span>
      </div>
    </div>

    <div class="card span-12">
      <h2>log scanner  <span class="proc-count" id="log-meta"></span></h2>
      <div id="log-matches">
        <span class="empty" style="color:var(--muted);">no matches yet</span>
      </div>
    </div>

    <div class="card span-12">
      <h2>agents (live)</h2>
      <div class="table-scroll">
      <table class="agents">
        <thead>
          <tr>
            <th style="width: 11%">name</th>
            <th style="width: 20%">role</th>
            <th style="width: 14%">state / step</th>
            <th style="width: 11%">last run</th>
            <th style="width: 9%">duration</th>
            <th style="width: 7%">runs</th>
            <th>last result</th>
            <th style="width: 10%; text-align: right;">control</th>
          </tr>
        </thead>
        <tbody id="agents-body">
          <tr><td colspan="8" class="empty" style="padding:14px; color:var(--muted);">connecting…</td></tr>
        </tbody>
      </table>
      </div>
    </div>

    <div class="card span-3">
      <h2>failures</h2>
      <div class="num"><span id="fail-cur">—</span><small> / <span id="fail-max">—</span></small></div>
      <div class="bar" id="fail-bar"><div style="width:0%"></div></div>
    </div>

    <div class="card span-3">
      <h2>recovery (this run)</h2>
      <div class="num"><span id="rec-cur">—</span><small> / <span id="rec-max">—</span></small></div>
      <div class="bar" id="rec-bar"><div style="width:0%"></div></div>
    </div>

    <div class="card span-3">
      <h2>tick interval</h2>
      <div class="num"><span id="interval">—</span><small> s</small></div>
    </div>

    <div class="card span-3">
      <h2>cooldown</h2>
      <div class="num"><span id="cooldown">—</span><small> s</small></div>
    </div>

    <div class="card span-3" id="openclaw-tools-card" style="display:none">
      <h2>OpenClaw — ferramentas</h2>
      <div class="tools-dial-wrap">
        <div class="tools-dial" id="openclaw-tools-dial" style="--pct: 0"
             title="Ferramentas habilitadas pelo perfil / catálogo OpenClaw">
          <span class="dial-num" id="openclaw-tools-dial-num">—</span>
        </div>
        <div class="dial-caption" id="openclaw-tools-dial-caption">habilitadas</div>
      </div>
      <div class="kv"><span class="k">catálogo</span><span class="v" id="oc-catalog-line">—</span></div>
      <div class="kv"><span class="k">perfil</span><span class="v" id="oc-profile-line">—</span></div>
      <div class="kv"><span class="k">limite turnos</span><span class="v" id="chat-max-tools">—</span></div>
      <div class="kv"><span class="k">fonte catálogo</span><span class="v" id="oc-catalog-source">—</span></div>
    </div>

    <div class="card span-6">
      <h2>timeline</h2>
      <div class="kv"><span class="k">last OK</span>      <span class="v" id="t-ok">—</span></div>
      <div class="kv"><span class="k">last failure</span> <span class="v" id="t-fail">—</span></div>
      <div class="kv"><span class="k">last recovery</span><span class="v" id="t-rec">—</span></div>
    </div>

    <div class="card span-6">
      <h2>watch target</h2>
      <div class="kv"><span class="k">name</span>          <span class="v" id="cfg-name">—</span></div>
      <div class="kv"><span class="k">process_pattern</span><span class="v" id="cfg-proc">—</span></div>
      <div class="kv"><span class="k">health_url</span>    <span class="v" id="cfg-url">—</span></div>
    </div>

    <div class="card span-12">
      <h2>zombie / orphan reaper</h2>
      <div class="row" style="gap:14px;">
        <div class="span-3">
          <div class="kv"><span class="k">last run</span><span class="v" id="rp-last">—</span></div>
          <div class="kv"><span class="k">interval</span><span class="v"><span id="rp-int">—</span> s</span></div>
          <div class="kv"><span class="k">enabled</span><span class="v" id="rp-en">—</span></div>
        </div>
        <div class="span-3">
          <div class="num"><span id="rp-zombies">0</span><small> zombies</small></div>
          <div class="num"><span id="rp-orphans">0</span><small> orphans</small></div>
          <div class="num"><span id="rp-killed">0</span><small> killed</small></div>
        </div>
        <div class="span-6">
          <div class="kv"><span class="k">pattern</span><span class="v" id="rp-pat">—</span></div>
          <div class="kv"><span class="k">summary</span><span class="v" id="rp-sum">—</span></div>
          <pre id="rp-details" class="empty" style="margin-top:8px;">no kills yet</pre>
        </div>
      </div>
    </div>

    <div class="card span-6">
      <h2>last failure summary</h2>
      <pre id="last-fail" class="empty">none</pre>
    </div>

    <div class="card span-6">
      <h2>last recovery report</h2>
      <pre id="last-rec" class="empty">none</pre>
    </div>
  </div>
</main>

<footer class="monitor-footer">gois • polling /status every <span id="poll">3</span> s</footer>

<div class="chat-modal" id="hermes-chat-modal" hidden aria-hidden="true">
  <div class="chat-modal-backdrop" id="hermes-chat-backdrop"></div>
  <div class="chat-modal-dialog" role="dialog" aria-modal="true" aria-labelledby="hermes-chat-title">
    <header class="chat-modal-header">
      <div>
        <h2 id="hermes-chat-title">Criar agente Hermes</h2>
        <p class="chat-hint">Descreva o requisito — escolhemos skills e agendamos um cron.</p>
      </div>
      <button type="button" class="chat-modal-close" id="hermes-chat-close" aria-label="Fechar">×</button>
    </header>
    <div class="chat-modal-body">
      <div class="chat" id="hermes-agent-chat">
        <div class="skills-panel" id="hermes-skills-panel">
          <h4>Skills de desenvolvimento</h4>
          <span class="none" style="color:var(--muted);">carregando…</span>
        </div>
        <div class="chat-log" id="hermes-chat-log">
          <div class="chat-msg bot">Carregando skills…</div>
        </div>
        <div class="chat-options">
          <label>agendamento (opcional)
            <input type="text" id="hermes-chat-schedule" placeholder="every 24h">
          </label>
          <label>diretório do projeto (opcional)
            <input type="text" id="hermes-chat-workdir" placeholder="/caminho/do/repo">
          </label>
        </div>
        <div class="chat-compose">
          <textarea id="hermes-chat-input" rows="4"
            placeholder="Ex.: Implementar módulo de agendamento no WhatsApp Consulta — analisar repo, escrever testes, abrir PR…"></textarea>
          <button type="button" id="hermes-chat-voice" class="voice-btn" title="Ditado por voz">🎙️ Falar</button>
          <button type="button" id="hermes-chat-send">Criar e agendar</button>
        </div>
      </div>
    </div>
  </div>
</div>

__HERMES_CRON_EXEC_MODAL__

<script>
const POLL_MS = 3000;
const HERMES_DASHBOARD_URL = __HERMES_DASHBOARD_URL__;
const HERMES_DEFAULT_TAB = __HERMES_DEFAULT_TAB__;
const DASHBOARD_RENDER_CONFIG = __DASHBOARD_RENDER_CONFIG__;
let lastFetchOK = null;

function renderCfgNumber(key, fallback) {
  const cfg = DASHBOARD_RENDER_CONFIG || {};
  const val = Number(cfg[key]);
  return Number.isFinite(val) ? val : fallback;
}

function renderCfgBool(key, fallback) {
  const cfg = DASHBOARD_RENDER_CONFIG || {};
  const val = cfg[key];
  if (typeof val === "boolean") return val;
  return fallback;
}

const DEFAULT_RENDER_DYNAMIC = renderCfgBool("dynamic_chunking", true);
const DEFAULT_RENDER_FRAME_BUDGET_MS = Math.max(4, renderCfgNumber("frame_budget_ms", 9));
const DEFAULT_RENDER_BASE_CHUNK = Math.max(1, Math.round(renderCfgNumber("base_chunk_size", 40)));
const RENDER_CHUNK_AGENTS = Math.max(1, Math.round(renderCfgNumber("agents_chunk_size", 35)));
const RENDER_CHUNK_RUFLO_AGENTS = Math.max(1, Math.round(renderCfgNumber("ruflo_agents_chunk_size", 30)));
const RENDER_CHUNK_CRON = Math.max(1, Math.round(renderCfgNumber("cron_chunk_size", 25)));

function fmtAgo(epoch, nowEpoch) {
  if (!epoch) return "never";
  const s = Math.max(0, Math.round(nowEpoch - epoch));
  if (s < 60) return s + "s ago";
  if (s < 3600) return Math.round(s / 60) + "m ago";
  if (s < 86400) return Math.round(s / 3600) + "h ago";
  return Math.round(s / 86400) + "d ago";
}

function fmtAbs(epoch) {
  if (!epoch) return "—";
  const d = new Date(epoch * 1000);
  return d.toLocaleString();
}

function el(id) { return document.getElementById(id); }
function closestFromEvent(ev, selector) {
  let node = ev && ev.target;
  if (!(node instanceof Element)) node = node && node.parentElement;
  return node instanceof Element ? node.closest(selector) : null;
}

function monitorFetchError(e, url) {
  const msg = String((e && e.message) || e || "");
  if (msg === "Failed to fetch" || (e && e.name === "TypeError")) {
    return (
      "Não foi possível contactar o monitor em " + window.location.origin +
      ". Verifique se o gois está rodando (./scripts/start.sh --launchd) e recarregue a página."
    );
  }
  if (e && e.name === "AbortError") {
    return "Tempo esgotado aguardando " + url + ".";
  }
  return msg || "erro de rede";
}

async function monitorFetchJson(url, opt, timeoutMs) {
  const timeout = timeoutMs != null ? timeoutMs : 30000;
  const ctrl = new AbortController();
  const timer = setTimeout(() => ctrl.abort(), timeout);
  let r;
  try {
    r = await fetch(url, Object.assign({}, opt || {}, { signal: ctrl.signal, cache: "no-cache" }));
    clearTimeout(timer);
  } catch (e) {
    clearTimeout(timer);
    throw new Error(monitorFetchError(e, url));
  }
  let data = {};
  try {
    data = await r.json();
  } catch (_) {
    throw new Error("Resposta inválida de " + url + " (HTTP " + r.status + ")");
  }
  if (!r.ok || data.ok === false) {
    throw new Error(data.error || data.reason || data.summary || ("HTTP " + r.status));
  }
  return data;
}

const _renderFp = {};
function _memo(key, value, fn) {
  let fp;
  try { fp = JSON.stringify(value); } catch (e) { fp = String(Math.random()); }
  if (_renderFp[key] === fp) return;
  _renderFp[key] = fp;
  fn();
}

const _chunkRenderTokens = Object.create(null);

function _renderNowMs() {
  if (typeof performance !== "undefined" && performance && typeof performance.now === "function") {
    return performance.now();
  }
  return Date.now();
}

function resolveAdaptiveChunkSize(totalRows, requestedChunk) {
  const asked = Math.max(1, Number(requestedChunk) || 40);
  if (!Number.isFinite(totalRows) || totalRows <= 0) return asked;

  let adaptive = asked;
  if (totalRows > 3000) adaptive = Math.min(adaptive, 8);
  else if (totalRows > 1500) adaptive = Math.min(adaptive, 12);
  else if (totalRows > 800) adaptive = Math.min(adaptive, 18);
  else if (totalRows > 300) adaptive = Math.min(adaptive, 24);
  else adaptive = Math.min(adaptive, 36);

  const cores = Number((typeof navigator !== "undefined" && navigator && navigator.hardwareConcurrency) || 0);
  if (cores > 0 && cores <= 4) adaptive = Math.max(6, Math.floor(adaptive * 0.65));

  const reducedMotion =
    typeof window !== "undefined" &&
    window.matchMedia &&
    window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  if (reducedMotion) adaptive = Math.max(6, Math.floor(adaptive * 0.7));

  return Math.max(4, adaptive);
}

function renderRowsInParts(tbody, list, renderRow, opts) {
  opts = opts || {};
  if (!tbody) return;
  const emptyHtml = opts.emptyHtml ||
    '<tr><td colspan="1" class="empty" style="padding:14px;color:var(--muted);">sem dados</td></tr>';
  if (!Array.isArray(list) || !list.length || typeof renderRow !== "function") {
    tbody.innerHTML = emptyHtml;
    return;
  }

  const baseChunkSize = Math.max(1, Number(opts.chunkSize) || DEFAULT_RENDER_BASE_CHUNK);
  const dynamicChunking =
    typeof opts.dynamicChunking === "boolean" ? opts.dynamicChunking : DEFAULT_RENDER_DYNAMIC;
  const chunkSize = dynamicChunking
    ? resolveAdaptiveChunkSize(list.length, baseChunkSize)
    : baseChunkSize;
  const frameBudgetMs = Math.max(4, Number(opts.frameBudgetMs) || DEFAULT_RENDER_FRAME_BUDGET_MS);
  const colspan = Math.max(1, Number(opts.colspan) || 1);
  const progressLabel = opts.progressLabel || "Carregando em partes…";
  const jobKey = opts.jobKey || tbody.id || "rows";
  const token = Math.random().toString(36).slice(2, 10);
  _chunkRenderTokens[jobKey] = token;

  tbody.innerHTML =
    '<tr><td colspan="' + colspan + '" class="empty" style="padding:14px;color:var(--muted);">' +
    escapeHtml(progressLabel) + " 0/" + list.length + "</td></tr>";

  let idx = 0;
  let firstPaint = true;
  const onDone = typeof opts.onDone === "function" ? opts.onDone : null;

  function pump() {
    if (_chunkRenderTokens[jobKey] !== token) return;
    const startedAt = _renderNowMs();
    const minPerFrame = Math.max(3, Math.floor(chunkSize / 3));
    let rendered = 0;
    let html = "";
    while (idx < list.length && rendered < chunkSize) {
      html += renderRow(list[idx], idx);
      idx += 1;
      rendered += 1;
      if (rendered >= minPerFrame && (_renderNowMs() - startedAt) >= frameBudgetMs) {
        break;
      }
    }
    if (firstPaint) {
      tbody.innerHTML = html;
      firstPaint = false;
    } else {
      tbody.insertAdjacentHTML("beforeend", html);
    }

    if (idx < list.length) {
      requestAnimationFrame(pump);
      return;
    }
    if (onDone) onDone();
  }

  requestAnimationFrame(pump);
}

function renderAuthNoticeFromRedirect() {
  const box = el("auth-notice");
  if (!box || typeof window === "undefined" || !window.sessionStorage) return;
  const reason = sessionStorage.getItem("qcm_auth_redirect_reason") || "";
  const source = sessionStorage.getItem("qcm_auth_redirect_from") || "";
  if (reason === "roles_not_authenticated" && source === "/roles") {
    box.textContent = "Sessão expirada. Faça login para acessar papéis.";
    box.classList.add("show");
  }
  sessionStorage.removeItem("qcm_auth_redirect_reason");
  sessionStorage.removeItem("qcm_auth_redirect_from");
}

function fmtBytes(b) {
  if (b == null || isNaN(b)) return "—";
  const u = ["B","KB","MB","GB","TB"];
  let i = 0; let n = b;
  while (n >= 1024 && i < u.length - 1) { n /= 1024; i++; }
  return n.toFixed(n < 10 && i > 0 ? 1 : 0) + " " + u[i];
}

function fmtDuration(s) {
  if (s == null) return "—";
  if (s < 1)    return s.toFixed(2) + "s";
  if (s < 60)   return s.toFixed(1) + "s";
  if (s < 3600) return Math.round(s/60) + "m" + Math.round(s%60) + "s";
  return Math.round(s/3600) + "h";
}

function escapeHtml(str) {
  return String(str).replace(/[&<>"']/g, c => (
    {"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;"}[c]));
}

function replaceConnectingPlaceholder(id, html) {
  const node = el(id);
  if (!node) return;
  const text = String(node.textContent || "").toLowerCase();
  if (text.includes("connecting")) {
    node.innerHTML = html;
  }
}

function renderOfflineConnectingFallback(reason) {
  const why = escapeHtml(reason || "falha ao carregar /status");
  replaceConnectingPlaceholder(
    "agents-up",
    '<span class="none" style="color:var(--bad);">offline: ' + why + '</span>'
  );
  replaceConnectingPlaceholder(
    "proc-grid",
    '<span class="none" style="color:var(--bad);">offline: ' + why + '</span>'
  );
  replaceConnectingPlaceholder(
    "agents-body",
    '<tr><td colspan="8" class="empty" style="padding:14px; color:var(--bad);">offline: ' + why + '</td></tr>'
  );
}

function renderAgentsUp(list, now) {
  const strip = document.getElementById("agents-up");
  if (!list || !list.length) {
    strip.innerHTML = '<span class="none">no agents registered</span>';
    return;
  }
  // "up" = enabled and not in error state.
  const up      = list.filter(a => a.enabled !== false && a.state !== "error");
  const paused  = list.filter(a => a.enabled === false);
  const errored = list.filter(a => a.state === "error" && a.enabled !== false);
  if (!up.length && !paused.length) {
    strip.innerHTML = '<span class="none">all agents down</span>';
    return;
  }
  up.sort((a, b) => {
    if (a.state === b.state) return 0;
    return a.state === "running" ? -1 : 1;
  });
  const parts = up.length ? ['<span class="label">up:</span>'] : [];
  for (const a of up) {
    let cls = "chip";
    let meta = "";
    let dot;
    const stepHtml = a.current_step
      ? '<span class="step">' + escapeHtml(a.current_step) + '</span>'
      : '';
    if (a.state === "running") {
      cls += " running";
      dot = '<span class="pulse"></span>';
      meta = a.started_at
        ? '<span class="meta">' + fmtDuration(now - a.started_at) + '</span>'
        : '';
    } else if (a.runs_total === 0) {
      cls += " dim";
      dot = '<span class="dot"></span>';
      meta = '<span class="meta">ready</span>';
    } else {
      // fresh = ran within the last 2 monitor ticks (heuristic: 60s)
      const ageS = a.last_finished_at ? (now - a.last_finished_at) : Infinity;
      cls += ageS < 60 ? " idle fresh" : " idle";
      dot = '<span class="dot"></span>';
      meta = '<span class="meta">' + fmtAgo(a.last_started_at, now) + '</span>';
    }
    parts.push(
      '<span class="' + cls + '" title="' + escapeHtml(a.description || '') + '">' +
        dot +
        '<span class="nm">' + escapeHtml(a.name) + '</span>' +
        stepHtml + meta +
      '</span>'
    );
  }
  if (errored.length) {
    parts.push('<span class="label" style="margin-left:12px;">errored:</span>');
    for (const a of errored) {
      parts.push(
        '<span class="chip" style="color:var(--bad);border-color:var(--bad);">' +
        '<span class="dot"></span>' +
        '<span class="nm">' + escapeHtml(a.name) + '</span>' +
        '<span class="meta">' + escapeHtml((a.last_error || "error").slice(0, 50)) + '</span>' +
        '</span>'
      );
    }
  }
  if (paused.length) {
    parts.push('<span class="label" style="margin-left:12px;">paused:</span>');
    for (const a of paused) {
      parts.push(
        '<span class="chip paused" title="' + escapeHtml(a.description || '') + '">' +
          '<span class="dot"></span>' +
          '<span class="nm">' + escapeHtml(a.name) + '</span>' +
        '</span>'
      );
    }
  }
  strip.innerHTML = parts.join("");
}

function renderAgents(list, now) {
  const tbody = document.getElementById("agents-body");
  renderRowsInParts(tbody, list || [], (a) => {
    const paused = a.enabled === false;
    let cls = paused ? "paused"
            : a.state === "running" ? "running"
            : a.state === "error" ? "error" : "idle";
    const dot = paused
      ? '<span class="dot" style="width:8px;height:8px;box-shadow:none;background:var(--muted);"></span>'
      : (a.state === "running"
          ? '<span class="pulse"></span>'
          : '<span class="dot ' + (a.state === "error" ? "down" : "up") +
            '" style="width:8px;height:8px;box-shadow:none;"></span>');
    const stateLabel = paused ? "paused" : a.state;
    const lastRun = a.last_started_at ? fmtAgo(a.last_started_at, now) : "—";
    const dur = a.state === "running" && a.started_at
      ? fmtDuration(now - a.started_at) + " (live)"
      : fmtDuration(a.last_duration_seconds);
    const result = a.last_error
      ? '<span style="color:var(--bad);">' + escapeHtml(a.last_error) + '</span>'
      : (a.last_result ? escapeHtml(a.last_result) : '<span class="empty">—</span>');
    const step = a.current_step
      ? '<div class="step" style="margin-left:0;margin-top:4px;">' + escapeHtml(a.current_step) + '</div>'
      : (a.last_step
          ? '<div style="color:var(--muted);font-size:11px;margin-top:4px;font-family:var(--mono);">last: ' + escapeHtml(a.last_step) + '</div>'
          : '');
    const btn = paused
      ? '<button class="ctrl resume" data-action="enable"  data-name="' + escapeHtml(a.name) + '">▶ resume</button>'
      : '<button class="ctrl pause"  data-action="disable" data-name="' + escapeHtml(a.name) + '">⏸ pause</button>';
    return (
      '<tr>' +
        '<td><strong>' + escapeHtml(a.name) + '</strong></td>' +
        '<td class="desc">' + escapeHtml(a.description || '—') + '</td>' +
        '<td><span class="pill ' + cls + '">' + dot + ' ' + stateLabel + '</span>' + step + '</td>' +
        '<td>' + lastRun + '</td>' +
        '<td class="num">' + dur + '</td>' +
        '<td class="num">' + (a.runs_total ?? 0) + '</td>' +
        '<td class="result">' + result + '</td>' +
        '<td style="text-align:right;">' + btn + '</td>' +
      '</tr>'
    );
  }, {
    jobKey: "agents-body",
    chunkSize: RENDER_CHUNK_AGENTS,
    colspan: 8,
    progressLabel: "Carregando agentes",
    emptyHtml: '<tr><td colspan="8" class="empty" style="padding:14px;color:var(--muted);">no agents registered</td></tr>',
  });
}

document.addEventListener("click", async (ev) => {
  const btn = closestFromEvent(ev, "button.ctrl");
  if (!btn) return;
  const name   = btn.dataset.name;
  const action = btn.dataset.action;
  if (!name || !action) return;
  btn.disabled = true;
  const oldText = btn.textContent;
  btn.textContent = "…";
  try {
    const r = await fetch(`/agents/${encodeURIComponent(name)}/${encodeURIComponent(action)}`,
                         { method: "POST" });
    if (!r.ok) throw new Error("HTTP " + r.status);
    await poll();  // re-render immediately with the new state
  } catch (e) {
    btn.textContent = "✕ " + e.message;
    setTimeout(() => { btn.textContent = oldText; btn.disabled = false; }, 2500);
  }
});

function renderProcesses(list, now) {
  const grid = document.getElementById("proc-grid");
  const counter = document.getElementById("proc-count");
  if (!list || !list.length) {
    grid.innerHTML = '<span class="none" style="color:var(--muted);">no QClaw processes detected</span>';
    counter.textContent = "";
    return;
  }
  // group by role for the count summary
  const byRole = {};
  for (const p of list) byRole[p.role] = (byRole[p.role] || 0) + 1;
  const order = ["main", "helper", "bridge", "gateway", "other"];
  counter.textContent = order
    .filter(r => byRole[r])
    .map(r => byRole[r] + " " + r)
    .join("  ·  ");
  grid.innerHTML = list.map(p => {
    const rss = (p.rss_kb || 0) * 1024;
    return (
      '<div class="proc" title="' + escapeHtml(p.command || '') + '">' +
        '<span class="role-dot ' + escapeHtml(p.role) + '"></span>' +
        '<div class="info">' +
          '<div class="nm">' + escapeHtml(p.name) + '</div>' +
          '<div class="meta">up ' + fmtDuration(p.age_seconds) + '  ·  ppid ' + p.ppid + '</div>' +
        '</div>' +
        '<div class="pid">pid ' + p.pid + '</div>' +
        '<div class="rss">' + fmtBytes(rss) + '</div>' +
      '</div>'
    );
  }).join("");
}

function renderMemory(mem) {
  const total = mem ? mem.total_bytes : 0;
  document.getElementById("mem-total").textContent = "RSS " + fmtBytes(total);
}

function renderLogScanner(scanner, now) {
  const meta = document.getElementById("log-meta");
  const box  = document.getElementById("log-matches");
  if (!scanner) { meta.textContent = ""; box.innerHTML = '<span class="empty" style="color:var(--muted);">disabled</span>'; return; }
  const lastRun = scanner.last_ts ? fmtAgo(scanner.last_ts, now) : "never";
  const metaParts = [
    "last scan " + lastRun,
    scanner.paths.length + " path(s)",
    scanner.patterns.length + " pattern(s)",
  ];
  if (scanner.trigger_recovery) metaParts.push("auto-recovery on");
  if (!scanner.enabled) metaParts.push("disabled");
  meta.textContent = metaParts.join("  ·  ");
  const details = scanner.last_details || [];
  if (!details.length) {
    box.innerHTML = '<span class="empty" style="color:var(--muted);">no matches in the last scan</span>';
    return;
  }
  box.innerHTML = details.map(m => (
    '<div class="log-row">' +
      '<div><span class="pat">' + escapeHtml(m.pattern) + '</span>  ' +
           '<span class="file">' + escapeHtml(m.file) + '</span></div>' +
      '<div class="ln">' + escapeHtml(m.line) + '</div>' +
    '</div>'
  )).join("");
}

function setBar(barId, current, max, warnFrac=0.6, badFrac=0.9) {
  const pct = max > 0 ? Math.min(100, (current / max) * 100) : 0;
  const bar = el(barId);
  bar.classList.remove("warn", "bad");
  if (current / max >= badFrac) bar.classList.add("bad");
  else if (current / max >= warnFrac) bar.classList.add("warn");
  bar.firstElementChild.style.width = pct + "%";
}

function renderOpenclawToolsDial(occ) {
  const card = el("openclaw-tools-card");
  if (!card) return;
  if (!occ || occ.enabled === false) {
    card.style.display = "none";
    return;
  }
  card.style.display = "";
  const total = Number(occ.catalog_total) || 0;
  const enabled = Number(occ.tools_enabled ?? occ.tools_available) || 0;
  const profile = String(occ.tools_profile || "full");
  const dial = el("openclaw-tools-dial");
  const dialNum = el("openclaw-tools-dial-num");
  const caption = el("openclaw-tools-dial-caption");
  const ratio = total > 0 ? enabled / total : (enabled > 0 ? 1 : 0);
  const pctRing = total > 0 ? Math.round(ratio * 100) : (enabled > 0 ? 100 : 0);
  if (dial) {
    dial.style.setProperty("--pct", String(pctRing));
    dial.classList.remove("warn", "bad");
    if (occ.scan_error && !occ.gateway_catalog) dial.classList.add("bad");
    else if (total > 0 && ratio < 0.5) dial.classList.add("warn");
  }
  if (dialNum) dialNum.textContent = String(enabled);
  if (caption) {
    caption.textContent = occ.scan_error && !occ.gateway_catalog
      ? "gateway offline — estimativa"
      : enabled + " / " + (total || "?") + " no catálogo";
  }
  const catalogLine = el("oc-catalog-line");
  if (catalogLine) {
    catalogLine.textContent = total ? String(total) + " ferramentas" : "—";
  }
  const profileLine = el("oc-profile-line");
  if (profileLine) {
    profileLine.textContent = profile + (occ.tools_profile_source
      ? " (" + occ.tools_profile_source + ")"
      : "");
  }
  const maxTools = el("chat-max-tools");
  if (maxTools) {
    maxTools.textContent = String(occ.max_tool_iterations_effective ?? occ.max_tool_iterations ?? "—");
  }
  const catalogSource = el("oc-catalog-source");
  if (catalogSource) {
    catalogSource.textContent = occ.gateway_catalog ? "gateway ao vivo" : "estático (sem gateway)";
  }
}

function renderServices(s) {
  const section = el("services-section");
  const strip = el("services-up");
  const parts = [];
  const qUp = !!s.up;
  parts.push(
    '<span class="chip ' + (qUp ? "idle fresh" : "") + '" style="' +
      (qUp ? "" : "color:var(--bad);border-color:var(--bad);") + '">' +
      '<span class="dot ' + (qUp ? "up" : "down") + '" style="width:8px;height:8px;box-shadow:none;"></span>' +
      '<span class="nm">QClaw</span>' +
      '<span class="meta">' + (qUp ? "ativo" : "inativo") + '</span>' +
    '</span>'
  );
  if (s.hermes) {
    const hUp = !!(s.hermes.active ?? s.hermes.up);
    const pid = (s.hermes.processes && s.hermes.processes[0])
      ? " pid=" + s.hermes.processes[0].pid : "";
    parts.push(
      '<span class="chip ' + (hUp ? "idle fresh" : "") + '" style="' +
        (hUp ? "" : "color:var(--bad);border-color:var(--bad);") + '">' +
        '<span class="dot ' + (hUp ? "up" : "down") + '" style="width:8px;height:8px;box-shadow:none;"></span>' +
        '<span class="nm">Hermes</span>' +
        '<span class="meta">' + (hUp ? "ativo" + pid : "inativo") + '</span>' +
      '</span>'
    );
    section.style.display = "";
  } else {
    section.style.display = "none";
  }
  strip.innerHTML = parts.join("");
}

const HERMES_OFFLINE_MSG = "Dashboard offline — rode: hermes dashboard --no-open";
let hermesDashboardUp = null;

function bindOfflineNavLink(link, online, url) {
  if (!link) return;
  link.href = online ? url : "#";
  link.style.display = "";
  link.classList.toggle("offline", !online);
  if (online) {
    link.removeAttribute("aria-disabled");
    link.removeAttribute("title");
    link.onclick = null;
    return;
  }
  link.setAttribute("aria-disabled", "true");
  link.removeAttribute("title");
  link.onclick = (ev) => {
    ev.preventDefault();
    if (window.qcmNavToast) window.qcmNavToast(HERMES_OFFLINE_MSG);
    else alert(HERMES_OFFLINE_MSG);
  };
}

function applyHermesLinks(url, dashboardUp) {
  if (!url) return;
  const cardLink = el("hermes-dashboard-link");
  const hdr = el("hdr-hermes");
  const online = dashboardUp !== false;
  bindOfflineNavLink(hdr, online, url);
  if (cardLink) {
    cardLink.href = online ? url : "#";
    cardLink.style.display = "";
    cardLink.classList.toggle("offline", !online);
    cardLink.removeAttribute("title");
    if (!online) {
      cardLink.setAttribute("aria-disabled", "true");
      cardLink.onclick = (ev) => {
        ev.preventDefault();
        if (window.qcmNavToast) window.qcmNavToast(HERMES_OFFLINE_MSG);
        else alert(HERMES_OFFLINE_MSG);
      };
    } else {
      cardLink.removeAttribute("aria-disabled");
      cardLink.onclick = null;
    }
    cardLink.textContent = online ? "abrir dashboard →" : "dashboard offline";
  }
}

let _hermesRecoveryBound = false;

function renderHermesCronScheduler(s) {
  const box = el("hermes-cron-scheduler");
  const dot = el("hermes-cron-scheduler-dot");
  const pill = el("hermes-cron-scheduler-pill");
  const label = el("hermes-cron-scheduler-label");
  const meta = el("hermes-cron-scheduler-meta");
  if (!box || !meta) return;
  if (!s || !s.hermes) {
    box.hidden = true;
    return;
  }
  box.hidden = false;
  const cr = s.hermes_cron_recovery || {};
  const csa = s.hermes_cron_scheduler_agent || {};
  const cda = s.hermes_cron_diagnostic_agent || {};
  if (csa.profile_id) window._hermesCronRecoveryProfileId = csa.profile_id;
  if (cda.profile_id) window._hermesCronDiagnosticProfileId = cda.profile_id;
  const sched = cr.scheduler || s.hermes.cron_scheduler || null;
  const jobsPath = cr.jobs_path || (sched && sched.jobs_path) || "";
  let ok = s.hermes.cron_scheduler_ok;
  if (ok === undefined || ok === null) {
    ok = sched ? !!sched.ok : null;
  }
  const gatewayRunning = sched && sched.gateway_running;
  const activeJobs = sched && sched.active_jobs != null
    ? sched.active_jobs
    : (s.hermes.cron && s.hermes.cron.active_count);
  const home = (sched && sched.hermes_home) || "";
  const summary = (sched && sched.summary) || "";
  const ensureOk = cr.gateway_ensure_last_ok;
  const ensureSummary = cr.gateway_ensure_last_summary || "";
  const ensureAgo = cr.gateway_ensure_last_ts
    ? fmtAgo(cr.gateway_ensure_last_ts, s.now || Date.now() / 1000)
    : "";

  if (ok === true) {
    box.classList.remove("down");
    box.classList.add("up");
    if (dot) dot.className = "dot up";
    if (pill) pill.textContent = "a disparar";
  } else if (ok === false) {
    box.classList.remove("up");
    box.classList.add("down");
    if (dot) dot.className = "dot down";
    if (pill) pill.textContent = "parado";
  } else {
    box.classList.remove("up", "down");
    if (dot) dot.className = "dot";
    if (pill) pill.textContent = "…";
  }

  const lines = [];
  if (ok === false) {
    lines.push("Gateway ausente para o HERMES_HOME dos crons — jobs não executam até o gateway subir.");
  } else if (ok === true) {
    lines.push("Gateway ativo; jobs agendados disparam no próximo tick.");
  }
  if (home) lines.push("HERMES_HOME: " + home);
  if (jobsPath) lines.push("jobs: " + jobsPath);
  if (activeJobs != null) lines.push(String(activeJobs) + " job(s) ativos");
  if (summary && !/^\d{4}-\d{2}-\d{2}[T ]/.test(summary.trim())) {
    lines.push(summary.trim());
  } else if (gatewayRunning === false) {
    lines.push("hermes cron status: gateway não está a correr");
  }
  if (ensureSummary || ensureOk != null) {
    lines.push(
      "gateway automático: " +
      (ensureOk ? "ok" : "falhou") +
      (ensureAgo ? " (" + ensureAgo + ")" : "") +
      (ensureSummary ? " — " + ensureSummary : "")
    );
  }
  if (csa.enabled && csa.auto_recover && csa.llm_enabled) {
    const agentAgo = csa.last_ts
      ? fmtAgo(csa.last_ts, s.now || Date.now() / 1000)
      : "";
    lines.push(
      "agente cron automático: " +
      (csa.last_ok === true ? "ok" : csa.last_ok === false ? "falhou" : "aguardando") +
      (agentAgo ? " (" + agentAgo + ")" : "")
    );
  }
  meta.textContent = lines.length ? lines.join(" · ") : "sem dados do scheduler";
  renderHermesCronDiagnosis(s);
}

function renderHermesCronDiagnosis(s) {
  const box = el("hermes-cron-diagnosis");
  const headline = el("hermes-cron-diagnosis-headline");
  const issuesEl = el("hermes-cron-diagnosis-issues");
  const recsEl = el("hermes-cron-diagnosis-recs");
  const agentEl = el("hermes-cron-diagnosis-agent");
  const diagOut = el("hermes-cron-diagnose-out");
  if (!box || !headline) return;
  const d = (s && s.hermes_cron_diagnostic) || {};
  const hasIssues = d.issues && d.issues.length;
  const hasRecs = d.recommendations && d.recommendations.length;
  const hasLlm = d.llm_report;
  const hasRecovery = d.scheduler_agent_report;
  const show = d.healthy === false || hasIssues || hasLlm || hasRecovery;
  if (!show) {
    box.hidden = true;
    if (diagOut && !diagOut.textContent) diagOut.style.display = "none";
    return;
  }
  box.hidden = false;
  box.classList.toggle("healthy", d.healthy === true);
  headline.textContent = d.headline || "Analisando scheduler e jobs…";
  if (issuesEl) {
    issuesEl.innerHTML = "";
    (d.issues || []).forEach((i) => {
      const li = document.createElement("li");
      li.className = "sev-" + (i.severity || "info");
      const code = i.code ? "[" + i.code + "] " : "";
      li.textContent = code + (i.message || "");
      issuesEl.appendChild(li);
    });
  }
  if (recsEl) {
    recsEl.innerHTML = "";
    (d.recommendations || []).forEach((r) => {
      const li = document.createElement("li");
      li.textContent = r;
      recsEl.appendChild(li);
    });
    recsEl.style.display = hasRecs ? "" : "none";
  }
  if (agentEl) {
    const parts = [];
    if (hasLlm) {
      const ago = d.llm_ts ? fmtAgo(d.llm_ts, s.now || Date.now() / 1000) : "";
      parts.push("=== Agente diagnóstico (LLM)" + (ago ? " · " + ago : "") + " ===\n" + d.llm_report);
    }
    if (hasRecovery) {
      const ago = d.scheduler_agent_ts
        ? fmtAgo(d.scheduler_agent_ts, s.now || Date.now() / 1000)
        : "";
      parts.push(
        "=== Agente recuperação cron" + (ago ? " · " + ago : "") + " ===\n" +
        d.scheduler_agent_report
      );
    }
    agentEl.textContent = parts.join("\n\n");
    agentEl.style.display = parts.length ? "" : "none";
    if (diagOut && parts.length) {
      diagOut.style.display = "";
      diagOut.textContent = parts.join("\n\n").slice(0, 8000);
    }
  }
}

async function postHermesRecoveryAction(action) {
  const r = await fetch("/hermes/recovery", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ action }),
  });
  const data = await r.json().catch(() => ({}));
  if (!r.ok || data.ok === false) {
    throw new Error(data.error || data.reason || data.summary || ("HTTP " + r.status));
  }
  return data;
}

function bindHermesCronSchedulerButtons() {
  if (window._hermesCronSchedulerButtonsBound) return;
  window._hermesCronSchedulerButtonsBound = true;
  const ensureBtn = el("hermes-cron-ensure-gateway");
  const agentBtn = el("hermes-cron-run-agent");
  const profBtn = el("hermes-cron-ensure-profile");
  const run = async (action, btn) => {
    const old = btn ? btn.textContent : "";
    if (btn) { btn.disabled = true; btn.textContent = "…"; }
    try {
      const data = await postHermesRecoveryAction(action);
      showHermesRecoveryResult(
        (data.report || data.summary || JSON.stringify(data)).slice(0, 1200),
        data.ok !== false
      );
      await refreshHermesRecovery();
      await poll();
    } catch (e) {
      showHermesRecoveryResult(e.message, false);
    } finally {
      if (btn) { btn.disabled = false; btn.textContent = old; }
    }
  };
  if (ensureBtn) ensureBtn.addEventListener("click", () => run("ensure_cron_scheduler", ensureBtn));
  if (agentBtn) agentBtn.addEventListener("click", () => run("run_cron_scheduler_agent", agentBtn));
  if (profBtn) profBtn.addEventListener("click", () => run("ensure_cron_profile", profBtn));
  const diagBtn = el("hermes-cron-diagnose");
  const diagAgentBtn = el("hermes-cron-diagnose-agent");
  const diagProfBtn = el("hermes-cron-diagnose-profile");
  const diagOut = el("hermes-cron-diagnose-out");
  const showDiag = (text) => {
    if (!diagOut) return;
    diagOut.style.display = text ? "" : "none";
    diagOut.textContent = text || "";
  };
  const runDiag = async (url, body, btn) => {
    const old = btn ? btn.textContent : "";
    if (btn) { btn.disabled = true; btn.textContent = "…"; }
    showDiag("a analisar…");
    try {
      const opts = body
        ? { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify(body) }
        : { cache: "no-cache" };
      const r = await fetch(url, opts);
      const data = await r.json().catch(() => ({}));
      if (!r.ok || data.ok === false) {
        throw new Error(data.error || "falhou");
      }
      const rep = data.report || data.structured || data;
      let text = "";
      if (data.llm_report) {
        text = "=== LLM ===\n" + data.llm_report + "\n\n";
      }
      if (rep && rep.issues) {
        text += "=== issues ===\n";
        (rep.issues || []).forEach((i) => {
          text += "[" + (i.severity || "?") + "] " + (i.code || "") + ": " + (i.message || "") + "\n";
        });
        if (rep.recommendations && rep.recommendations.length) {
          text += "\n=== recomendações ===\n" + rep.recommendations.join("\n");
        }
      } else {
        text += JSON.stringify(rep, null, 2).slice(0, 4000);
      }
      showDiag(text.slice(0, 8000));
    } catch (e) {
      showDiag("erro: " + e.message);
    } finally {
      if (btn) { btn.disabled = false; btn.textContent = old; }
    }
  };
  if (diagBtn) {
    diagBtn.addEventListener("click", () => runDiag("/hermes/cron/diagnose", null, diagBtn));
  }
  if (diagAgentBtn) {
    diagAgentBtn.addEventListener("click", () =>
      runDiag("/hermes/cron/diagnose", { action: "run_agent" }, diagAgentBtn));
  }
  if (diagProfBtn) {
    diagProfBtn.addEventListener("click", () =>
      postHermesRecoveryAction("ensure_cron_diagnostic_profile").then((data) => {
        showHermesRecoveryResult(JSON.stringify(data).slice(0, 800), data.ok !== false);
      }).catch((e) => showHermesRecoveryResult(e.message, false)));
  }
}

function renderHermesRecoveryPanel(data) {
  const meta = el("hermes-recovery-meta");
  const profLink = el("hermes-recovery-profile-link");
  if (!meta) return;
  if (!data || data.ok === false) {
    meta.textContent = data && data.error ? String(data.error) : "indisponível";
    return;
  }
  const dash = data.dashboard_up ? "online" : "offline";
  const gw = data.gateway_up ? "ativo" : "inativo";
  const prof = data.profile_installed ? "instalado" : "ausente";
  meta.textContent =
    "dashboard " + dash + "  ·  gateway " + gw +
    "  ·  perfil " + (data.profile_id || "hermes-recovery") + " " + prof;
  if (profLink && data.profile_url) {
    profLink.href = data.profile_url;
    profLink.style.display = "";
  }
  if (data.dashboard_url) hermesDashboardUrl = data.dashboard_url;
}

async function refreshHermesRecovery() {
  try {
    const r = await fetch("/hermes/recovery/status", { cache: "no-cache" });
    const data = await r.json();
    renderHermesRecoveryPanel(data);
  } catch (e) {
    renderHermesRecoveryPanel({ ok: false, error: "erro ao consultar recuperação" });
  }
}

function setHermesRecoveryBusy(busy) {
  ["hermes-recovery-restart-dash", "hermes-recovery-restart-gw",
   "hermes-recovery-ensure-profile"].forEach((id) => {
    const b = el(id);
    if (b) b.disabled = !!busy;
  });
}

function showHermesRecoveryResult(text, ok) {
  const box = el("hermes-recovery-result");
  if (!box) return;
  box.style.display = text ? "" : "none";
  box.textContent = text || "";
  box.style.color = ok === false ? "var(--bad)" : "var(--muted)";
}

async function hermesRecoveryAction(action) {
  setHermesRecoveryBusy(true);
  showHermesRecoveryResult("executando " + action + "…", true);
  try {
    const r = await fetch("/hermes/recovery", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ action: action }),
    });
    const data = await r.json();
    const ok = !!(data.ok || (action === "restart_dashboard" && data.dashboard_up));
    showHermesRecoveryResult(
      ok ? "ok: " + action : (data.error || "falhou: " + action),
      ok,
    );
    await refreshHermesRecovery();
    await refreshHermesProfiles();
  } catch (e) {
    showHermesRecoveryResult("erro de rede: " + e, false);
  } finally {
    setHermesRecoveryBusy(false);
  }
}

function bindHermesRecoveryButtons() {
  if (_hermesRecoveryBound) return;
  _hermesRecoveryBound = true;
  const openBtn = el("hermes-recovery-open-dash");
  if (openBtn) {
    openBtn.addEventListener("click", () => {
      const url = hermesDashboardUrl || HERMES_DASHBOARD_URL;
      if (!url) {
        showHermesRecoveryResult(HERMES_OFFLINE_MSG, false);
        return;
      }
      if (hermesDashboardUp === false) {
        hermesRecoveryAction("restart_dashboard");
        return;
      }
      window.open(url, "_blank", "noopener");
    });
  }
  const dashBtn = el("hermes-recovery-restart-dash");
  if (dashBtn) dashBtn.addEventListener("click", () => hermesRecoveryAction("restart_dashboard"));
  const gwBtn = el("hermes-recovery-restart-gw");
  if (gwBtn) gwBtn.addEventListener("click", () => hermesRecoveryAction("restart_gateway"));
  const profBtn = el("hermes-recovery-ensure-profile");
  if (profBtn) profBtn.addEventListener("click", () => hermesRecoveryAction("ensure_profile"));
}

bindHermesCronSchedulerButtons();

function initHermesFromConfig() {
  if (!HERMES_DASHBOARD_URL) return;
  hermesDashboardUrl = HERMES_DASHBOARD_URL;
  el("hermes-section").style.display = "";
  applyHermesLinks(HERMES_DASHBOARD_URL, null);
  el("hermes-status-label").textContent = "…";
  el("hermes-status-meta").textContent = HERMES_DASHBOARD_URL;
  bindHermesRecoveryButtons();
  refreshHermesRecovery();
  initHermesAgentChat();
  refreshHermesProfiles();
}

function renderHermesProfiles(profiles, dashboardUrl) {
  const strip = el("hermes-profiles-list");
  const meta = el("hermes-profiles-meta");
  if (!strip) return;
  if (dashboardUrl) hermesDashboardUrl = dashboardUrl;
  if (!profiles || !profiles.length) {
    strip.innerHTML = '<span class="none">nenhum perfil (crie um abaixo)</span>';
    if (meta) meta.textContent = "";
    return;
  }
  const named = profiles.filter(p => p.name && p.name !== "default");
  let show = named.length ? named : profiles;
  const recoveryId = (window._hermesRecoveryProfileId || "hermes-recovery").toLowerCase();
  const cronDiagId = (window._hermesCronDiagnosticProfileId || "hermes-cron-diagnostic").toLowerCase();
  const cronRecId = (window._hermesCronRecoveryProfileId || "hermes-cron-recovery").toLowerCase();
  const pinIds = new Set([recoveryId, cronDiagId, cronRecId].filter(Boolean));
  show = show.slice().sort((a, b) => {
    const an = (a.name || "").toLowerCase();
    const bn = (b.name || "").toLowerCase();
    const ar = pinIds.has(an) ? -1 : 0;
    const br = pinIds.has(bn) ? -1 : 0;
    return ar - br || an.localeCompare(bn);
  });
  if (meta) meta.textContent = "(" + show.length + ")";
  strip.innerHTML = show.map(p => {
    const nm = escapeHtml(p.name || "?");
    const desc = p.description ? escapeHtml(String(p.description).slice(0, 80)) : "";
    const href = hermesDashboardUrl
      ? hermesDashboardUrl.replace(/\/$/, "") + "/profiles"
      : "#";
    const title = desc || (p.model ? p.model : "");
    const pn = (p.name || "").toLowerCase();
    const isRecovery = pn === recoveryId || pn === cronDiagId || pn === cronRecId;
    const chipCls = isRecovery ? "chip idle recovery" : "chip idle";
    return (
      '<a class="' + chipCls + '" href="' + href + '" target="_blank" rel="noopener" ' +
        'title="' + (isRecovery ? "agente SRE de recuperação · " : "") + title + '">' +
        '<span class="dot up" style="width:8px;height:8px;box-shadow:none;"></span>' +
        '<span class="nm">' + nm + (isRecovery ? " ★" : "") + '</span>' +
        (desc ? '<span class="meta">' + desc + '</span>' : '') +
      '</a>'
    );
  }).join("");
}

async function refreshHermesProfiles() {
  const strip = el("hermes-profiles-list");
  if (!strip) return;
  try {
    const r = await fetch("/hermes/profiles", { cache: "no-cache" });
    const data = await r.json();
    if (!r.ok || data.ok === false) {
      strip.innerHTML = '<span class="none" style="color:var(--muted);">' +
        escapeHtml(data.error || "indisponível") + '</span>';
      return;
    }
    renderHermesProfiles(data.profiles || [], data.dashboard_url || hermesDashboardUrl);
  } catch (e) {
    strip.innerHTML = '<span class="none" style="color:var(--muted);">erro ao listar</span>';
  }
}

function appendHermesChat(role, text, meta) {
  const box = el("hermes-chat-log");
  if (!box) return;
  const div = document.createElement("div");
  div.className = "chat-msg " + role;
  const body = role === "bot" ? "Gois: " + String(text || "") : String(text || "");
  div.textContent = body;
  if (meta) {
    const m = document.createElement("span");
    m.className = "meta";
    m.textContent = meta;
    div.appendChild(m);
  }
  box.appendChild(div);
  box.scrollTop = box.scrollHeight;
}

function appendHermesChatHtml(role, html) {
  const box = el("hermes-chat-log");
  if (!box) return;
  const div = document.createElement("div");
  div.className = "chat-msg " + role;
  if (role === "bot") {
    div.innerHTML = '<strong>Gois:</strong> ' + String(html || "");
  } else {
    div.innerHTML = html;
  }
  box.appendChild(div);
  box.scrollTop = box.scrollHeight;
  return div;
}

function appendHermesChatLoading(text) {
  const div = appendHermesChatHtml("bot", escapeHtml(text || "Processando…"));
  if (div) div.classList.add("hermes-chat-loading");
  return div;
}

function removeHermesChatNode(node) {
  if (node && node.parentNode) node.remove();
}

function renderHermesSkillsPanel(catalog) {
  const panel = el("hermes-skills-panel");
  if (!panel) return;
  const skills = (catalog && catalog.skills) || [];
  const rec = (catalog && catalog.recommended) || [];
  if (!skills.length) {
    panel.innerHTML = '<h4>Skills de desenvolvimento</h4>' +
      '<span class="none" style="color:var(--muted);">nenhuma skill listada</span>';
    return;
  }
  const byCat = {};
  for (const s of skills) {
    const c = s.category || "outros";
    if (!byCat[c]) byCat[c] = [];
    byCat[c].push(s);
  }
  let html = '<h4>Skills de desenvolvimento (' + skills.length + ')</h4>';
  for (const cat of Object.keys(byCat).sort()) {
    html += '<div><strong>' + escapeHtml(cat) + '</strong><ul>';
    for (const s of byCat[cat]) {
      const desc = (s.description || "").slice(0, 100);
      html += '<li><code>' + escapeHtml(s.name) + '</code>' +
        (desc ? " — " + escapeHtml(desc) : "") + '</li>';
    }
    html += '</ul></div>';
  }
  if (rec.length) {
    html += '<span class="meta">Recomendadas: ' +
      rec.map(s => '<code>' + escapeHtml(s) + '</code>').join(", ") + '</span>';
  }
  panel.innerHTML = html;
}

async function refreshHermesSkills() {
  const panel = el("hermes-skills-panel");
  const log = el("hermes-chat-log");
  try {
    const r = await fetch("/hermes/skills", { cache: "no-cache" });
    const data = await r.json();
    if (!r.ok || data.ok === false) {
      if (panel) panel.innerHTML = '<h4>Skills</h4><span class="none">' +
        escapeHtml(data.error || "indisponível") + '</span>';
      if (log && log.children.length === 1) {
        log.innerHTML = '<div class="chat-msg bot">Descreva o requisito para criar agente + cron.</div>';
      }
      return null;
    }
    window._hermesSkillsCatalog = data;
    renderHermesSkillsPanel(data);
    if (log && log.querySelector(".chat-msg.bot") && log.children.length === 1) {
      log.innerHTML = '<div class="chat-msg bot">Skills carregadas. Descreva o requisito de programação — ' +
        'o agente escolhe skills e agenda no Hermes.</div>';
    }
    return data;
  } catch (e) {
    if (panel) panel.innerHTML = '<h4>Skills</h4><span class="none">erro ao carregar</span>';
    return null;
  }
}

async function sendHermesAgentCreate() {
  const input = el("hermes-chat-input");
  const btn = el("hermes-chat-send");
  const schedIn = el("hermes-chat-schedule");
  const workIn = el("hermes-chat-workdir");
  const defaultTeamEl = el("kanban-default-team");
  if (!input || !btn) return;
  const text = input.value.trim();
  if (!text) return;
  if (hermesDashboardUp === false) {
    appendHermesChat("err", HERMES_OFFLINE_MSG);
    return;
  }
  btn.disabled = true;
  stopHermesVoiceInput();
  appendHermesChat("user", text);
  input.value = "";
  const payload = { text };
  let teamId = "";
  try {
    teamId = String(localStorage.getItem("qcm_kanban_last_team") || "").trim();
  } catch (_) {
    teamId = "";
  }
  if (!teamId) {
    const fromUrl = new URLSearchParams(window.location.search).get("team") || "";
    teamId = String(fromUrl).trim();
  }
  if (!teamId) {
    const defaultTeamId = defaultTeamEl
      ? String(defaultTeamEl.textContent || "").trim()
      : "";
    if (defaultTeamId && defaultTeamId !== "—") teamId = defaultTeamId;
  }
  if (teamId) payload.team_id = teamId;
  if (schedIn && schedIn.value.trim()) payload.schedule = schedIn.value.trim();
  if (workIn && workIn.value.trim()) payload.workdir = workIn.value.trim();
  const loading = appendHermesChatLoading(
    "A analisar o requisito e a criar perfil no Hermes (pode demorar 1–3 min)…"
  );
  try {
    const data = await monitorFetchJson("/hermes/agents/create", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(payload),
    }, 480000);
    removeHermesChatNode(loading);
    const renamed = data.renamed
      ? " (nome ajustado de " + escapeHtml(data.requested_name) + ")"
      : "";
    const dash = data.dashboard_url || hermesDashboardUrl || "";
    const profilesLink = dash
      ? '<a href="' + dash.replace(/\/$/, "") + '/profiles" target="_blank" rel="noopener">perfis</a>'
      : "";
    const cron = data.cron || {};
    const skillsUsed = (data.skills_used || data.skills || []).map(
      s => '<code>' + escapeHtml(s) + '</code>'
    ).join(", ");
    let html =
      "<strong>Perfil:</strong> " + escapeHtml(data.name) + renamed + "<br>" +
      (data.description ? escapeHtml(data.description) + "<br>" : "") +
      (skillsUsed ? "<strong>Skills:</strong> " + skillsUsed + "<br>" : "") +
      (data.schedule ? "<strong>Agenda:</strong> " + escapeHtml(data.schedule) + "<br>" : "") +
      (cron.job_id ? "<strong>Cron:</strong> " + escapeHtml(cron.job_id) +
        (cron.summary ? " — " + escapeHtml(cron.summary) : "") + "<br>" : "") +
      (data.workdir ? "<strong>Workdir:</strong> " + escapeHtml(data.workdir) + "<br>" : "") +
      (profilesLink ? profilesLink : "");
    if (data.requirement_preview) {
      html += '<span class="meta">Prompt: ' + escapeHtml(data.requirement_preview) + "</span>";
    }
    try {
      const kb = data.kanban || {};
      const createdTeam = String(kb.team_id || data.team_id || "").trim();
      if (createdTeam) {
        localStorage.setItem("qcm_kanban_last_team", createdTeam);
        const kbLink = el("kanban-open-link");
        if (kbLink) kbLink.href = "/kanban?team=" + encodeURIComponent(createdTeam);
      }
    } catch (_) {}
    appendHermesChatHtml("bot", html);
    refreshHermesProfiles();
    poll();
  } catch (e) {
    removeHermesChatNode(loading);
    appendHermesChat("err", "Falha: " + e.message);
  } finally {
    btn.disabled = false;
    input.focus();
  }
}

let hermesChatModalOpen = false;
let hermesVoiceRecognizer = null;
let hermesVoiceListening = false;
let hermesVoiceBaseText = "";

function hermesVoiceSupported() {
  return typeof window !== "undefined" &&
    ("SpeechRecognition" in window || "webkitSpeechRecognition" in window);
}

function updateHermesVoiceButton() {
  const btn = el("hermes-chat-voice");
  if (!btn) return;
  if (!hermesVoiceSupported()) {
    btn.disabled = true;
    btn.textContent = "🎙️ Indisponível";
    btn.title = "Ditado indisponível neste navegador";
    return;
  }
  btn.disabled = false;
  btn.textContent = hermesVoiceListening ? "⏹️ Parar" : "🎙️ Falar";
  btn.classList.toggle("listening", hermesVoiceListening);
  btn.title = hermesVoiceListening ? "Parar ditado" : "Ditado por voz";
}

function stopHermesVoiceInput() {
  if (!hermesVoiceRecognizer || !hermesVoiceListening) return;
  try {
    hermesVoiceRecognizer.stop();
  } catch (_) {
    hermesVoiceListening = false;
    updateHermesVoiceButton();
  }
}

function toggleHermesVoiceInput() {
  const input = el("hermes-chat-input");
  if (!input) return;
  if (!hermesVoiceSupported()) {
    appendHermesChat("err", "Ditado por voz indisponível neste navegador.");
    return;
  }
  const Ctor = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (!hermesVoiceRecognizer) {
    hermesVoiceRecognizer = new Ctor();
    hermesVoiceRecognizer.lang = "pt-BR";
    hermesVoiceRecognizer.interimResults = true;
    hermesVoiceRecognizer.continuous = false;
    hermesVoiceRecognizer.onresult = (ev) => {
      let finalTxt = "";
      let interimTxt = "";
      for (let i = ev.resultIndex; i < ev.results.length; i++) {
        const text = String(ev.results[i][0].transcript || "");
        if (ev.results[i].isFinal) finalTxt += text;
        else interimTxt += text;
      }
      const base = hermesVoiceBaseText ? (hermesVoiceBaseText + " ") : "";
      input.value = (base + finalTxt + interimTxt).trim();
    };
    hermesVoiceRecognizer.onend = () => {
      hermesVoiceListening = false;
      updateHermesVoiceButton();
    };
    hermesVoiceRecognizer.onerror = (ev) => {
      hermesVoiceListening = false;
      updateHermesVoiceButton();
      if (ev && ev.error !== "no-speech" && ev.error !== "aborted") {
        appendHermesChat("err", "Falha no ditado: " + String(ev.error || "erro"));
      }
    };
  }
  if (hermesVoiceListening) {
    stopHermesVoiceInput();
    return;
  }
  hermesVoiceBaseText = input.value.trim();
  try {
    hermesVoiceRecognizer.start();
    hermesVoiceListening = true;
    updateHermesVoiceButton();
  } catch (e) {
    appendHermesChat("err", "Não foi possível iniciar o ditado.");
  }
}

function openHermesChatModal() {
  const modal = el("hermes-chat-modal");
  if (!modal || hermesChatModalOpen) return;
  modal.hidden = false;
  modal.setAttribute("aria-hidden", "false");
  hermesChatModalOpen = true;
  document.body.style.overflow = "hidden";
  if (location.hash !== "#hermes-agent-chat") {
    history.replaceState(null, "", "#hermes-agent-chat");
  }
  const input = el("hermes-chat-input");
  if (input) setTimeout(() => input.focus(), 50);
}

function closeHermesChatModal() {
  const modal = el("hermes-chat-modal");
  if (!modal || !hermesChatModalOpen) return;
  modal.hidden = true;
  modal.setAttribute("aria-hidden", "true");
  stopHermesVoiceInput();
  hermesChatModalOpen = false;
  document.body.style.overflow = "";
  if (location.hash === "#hermes-agent-chat") {
    history.replaceState(null, "", location.pathname + location.search);
  }
}

function initHermesChatModal() {
  const openBtn = el("hermes-chat-open");
  const closeBtn = el("hermes-chat-close");
  const backdrop = el("hermes-chat-backdrop");
  if (openBtn) openBtn.addEventListener("click", openHermesChatModal);
  if (closeBtn) closeBtn.addEventListener("click", closeHermesChatModal);
  if (backdrop) backdrop.addEventListener("click", closeHermesChatModal);
  document.addEventListener("keydown", (ev) => {
    if (ev.key === "Escape" && hermesChatModalOpen) closeHermesChatModal();
  });
  window.addEventListener("hashchange", () => {
    if (location.hash === "#hermes-agent-chat") openHermesChatModal();
    else if (hermesChatModalOpen) closeHermesChatModal();
  });
  if (location.hash === "#hermes-agent-chat") openHermesChatModal();
}

function initHermesAgentChat() {
  const btn = el("hermes-chat-send");
  const input = el("hermes-chat-input");
  const voiceBtn = el("hermes-chat-voice");
  if (!btn || !input) return;
  btn.addEventListener("click", sendHermesAgentCreate);
  if (voiceBtn) {
    voiceBtn.addEventListener("click", toggleHermesVoiceInput);
    updateHermesVoiceButton();
  }
  input.addEventListener("keydown", (ev) => {
    if (ev.key === "Enter" && !ev.shiftKey) {
      ev.preventDefault();
      sendHermesAgentCreate();
    }
  });
  initHermesChatModal();
  refreshHermesSkills();
}

let hermesCronShowPaused = true;
let hermesCronFilter = "";
let hermesCronStateFilter = "all";
let hermesDashboardUrl = HERMES_DASHBOARD_URL || "";
let hermesCronEditingId = null;
let hermesCronEditJob = null;
let hermesCronRowsFingerprint = "";

__HERMES_CRON_EXEC_JS__

function fmtCronWhen(iso) {
  if (!iso) return "—";
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return iso;
  return d.toLocaleString();
}

function fmtCronAvgTokens(job) {
  const avg = Number(job && job.avg_tokens);
  if (!Number.isFinite(avg) || avg <= 0) return '<span class="meta">—</span>';
  let label;
  if (avg >= 1000) {
    label = (avg / 1000).toFixed(avg >= 10000 ? 0 : 1) + "k";
  } else {
    label = String(avg);
  }
  const runs = Number(job.token_runs) || 0;
  const max = Number(job.token_max) || 0;
  const tipParts = [avg.toLocaleString() + " tokens (média)"];
  if (runs) tipParts.push(runs + " execu\u00e7\u00f5es amostradas");
  if (max) tipParts.push("máx " + max.toLocaleString());
  if (job.token_model) tipParts.push("modelo " + job.token_model);
  const tip = escapeHtml(tipParts.join(" \u00b7 "));
  const runsSuffix = runs ? ' <span class="meta">(' + runs + ')</span>' : "";
  return '<span title="' + tip + '">' + escapeHtml(label) + "</span>" + runsSuffix;
}

function cronSkillsCell(job) {
  const raw = (job && (job.skills || job.prompt_skills)) || [];
  let skills = [];
  if (Array.isArray(raw)) {
    skills = raw;
  } else if (typeof raw === "string") {
    skills = raw.split(/[\n,;]/);
  }
  const normalized = [];
  const seen = new Set();
  skills.forEach((item) => {
    const value = String(item || "").trim();
    if (!value) return;
    const key = value.toLowerCase();
    if (seen.has(key)) return;
    seen.add(key);
    normalized.push(value);
  });
  if (!normalized.length) {
    return '<span class="cron-skills-none">—</span>';
  }
  return '<div class="cron-skills-wrap">' +
    normalized.map((skill) => '<span class="cron-skill-chip">' + escapeHtml(skill) + '</span>').join("") +
    "</div>";
}

function cronStatePill(job) {
  if (job.running) {
    return '<span class="pill running"><span class="pulse"></span>a correr</span>';
  }
  const nextMs = job.next_run_at ? new Date(job.next_run_at).getTime() : NaN;
  const soonScheduled =
    job.active && Number.isFinite(nextMs) && nextMs > Date.now() && nextMs - Date.now() <= 120000;
  if (soonScheduled) {
    return '<span class="pill running"><span class="pulse"></span>agendado</span>';
  }
  const st = job.last_status;
  if (st === "error") return '<span class="pill error"><span class="pulse"></span>erro</span>';
  if (st === "skipped") return '<span class="pill" style="opacity:.85">ignorado</span>';
  if (st === "ok" || job.last_result_at) {
    return '<span class="pill idle">concluído</span>';
  }
  if (job.active) {
    return '<span class="pill running"><span class="pulse"></span>agendado</span>';
  }
  if (!job.enabled) return '<span class="pill" style="opacity:.7">desligado</span>';
  return '<span class="pill" style="opacity:.7">' + escapeHtml(job.state || "pausado") + '</span>';
}

function cronActionButtons(j) {
  const id = escapeHtml(j.id || "");
  const idUrl = encodeURIComponent(String(j.id || ""));
  const playBtn =
    '<button type="button" class="ctrl run cron-play cron-act" data-action="run" data-id="' + id +
    '" title="Executar agora" aria-label="Executar agora">▶</button>';
  const pauseResume = j.active
    ? '<button type="button" class="ctrl pause cron-act" data-action="pause" data-id="' + id +
      '" title="Pausar" aria-label="Pausar">⏸</button>'
    : '<button type="button" class="ctrl resume cron-act" data-action="resume" data-id="' + id +
      '" title="Retomar" aria-label="Retomar">▶</button>';
  const viewActive = hermesCronResultId === j.id ? " active" : "";
  const viewDisabled = (j.last_result_preview || j.last_run_at) ? "" : " disabled";
  const sourceBadge = cronSourceOriginBadge(j);
  return (
    playBtn +
    sourceBadge +
    '<a class="ctrl" href="/hermes/cron/' + idUrl + '/source?raw=1" target="_blank" rel="noopener" title="Ver código-fonte do agente">fonte</a>' +
    '<button type="button" class="ctrl view cron-result' + viewActive + '"' +
      ' data-id="' + id + '"' + viewDisabled + ' title="Ver resultado">resultado</button>' +
    '<button type="button" class="ctrl edit cron-edit" data-id="' + id + '">editar</button>' +
    pauseResume +
    '<button type="button" class="ctrl cron-delete cron-act" data-action="remove" data-id="' + id +
      '" title="Apagar job">apagar</button>'
  );
}

function cronSourceOriginBadge(job) {
  const sourceProfile = String((job && job.source_profile) || "").trim();
  if (sourceProfile && sourceProfile !== "default") {
    return '<span class="cron-source-badge profile" role="button" tabindex="0" title="Fonte do agente resolvida via profile" aria-label="Abrir detalhes da fonte (profile)">profile</span>';
  }
  const prompt = String((job && job.prompt) || "").trim();
  const hasFileRef = prompt && /(?:~|\.{1,2}|\/)?[A-Za-z0-9_./-]+\.(?:py|mjs|cjs|js|ts|tsx|sh|bash|zsh|ps1|rb|go|rs|java|kt|php)\b/i.test(prompt);
  if (hasFileRef && !/https?:\/\//i.test(prompt)) {
    return '<span class="cron-source-badge file" role="button" tabindex="0" title="Fonte do agente inferida por caminho de arquivo no prompt" aria-label="Abrir detalhes da fonte (arquivo)">arquivo</span>';
  }
  if (prompt) {
    return '<span class="cron-source-badge prompt" role="button" tabindex="0" title="Fonte do agente inferida pelo prompt do cron" aria-label="Abrir detalhes da fonte (prompt)">prompt</span>';
  }
  return '<span class="cron-source-badge unknown" role="button" tabindex="0" title="Origem da fonte ainda não determinada" aria-label="Abrir detalhes da fonte (indefinida)">indef.</span>';
}

function cronResultPreviewCell(j) {
  const preview = (j.last_result_preview || "").trim();
  if (!preview) return '<span class="empty-preview">—</span>';
  const short = preview.length > 90 ? preview.slice(0, 89) + "…" : preview;
  return '<span class="cron-truncate" title="' + escapeHtml(preview) + '">' + escapeHtml(short) + '</span>';
}

function cronPromptCell(j) {
  const prompt = String(j.prompt || "").trim();
  if (!prompt) return '<span class="empty-preview">—</span>';
  const short = prompt.length > 120 ? prompt.slice(0, 119) + "…" : prompt;
  return '<span class="cron-truncate" title="' + escapeHtml(prompt) + '">' + escapeHtml(short) + '</span>';
}

function cronWhatsappCell(j) {
  if (!j.whatsapp_sends) {
    return '<span class="empty-preview">—</span>';
  }
  const targets = Array.isArray(j.whatsapp_to) ? j.whatsapp_to : [];
  let body = "";
  if (targets.length) {
    body = targets.map((t) => {
      const raw = String(t || "");
      const isGroup = /@g\.us$/i.test(raw);
      const cls = isGroup ? "cron-wa-to grp" : "cron-wa-to";
      const prefix = isGroup ? "grupo " : "";
      return '<div class="' + cls + '" title="' + escapeHtml(raw) + '">' +
        escapeHtml(prefix + raw) + "</div>";
    }).join("");
  } else {
    body = '<span class="meta">envio no prompt</span>';
  }
  const srcList = Array.isArray(j.whatsapp_sources)
    ? j.whatsapp_sources
    : (j.whatsapp_sources ? [j.whatsapp_sources] : []);
  const src = srcList.map((item) => String(item || "")).filter(Boolean).join(", ");
  const title = src ? "fontes: " + src : "envia WhatsApp";
  return (
    '<div class="cron-wa-cell" title="' + escapeHtml(title) + '">' +
      '<span class="cron-wa-check" aria-label="envia WhatsApp">✓</span>' +
      body +
    "</div>"
  );
}

function cronJobMatchesFilter(row) {
  const idRaw = String(row.id || row.job_id || "");
  if (isSuppressedHermesCronJobId(idRaw)) return false;
  const q = (hermesCronFilter || "").trim().toLowerCase();
  if (!q) return true;
  const id = idRaw.toLowerCase();
  const name = String(row.name || "").toLowerCase();
  const prompt = String(row.prompt || "").toLowerCase();
  const profile = String(row.profile || "").toLowerCase();
  const sourceProfile = String(row.source_profile || "").toLowerCase();
  const model = String(row.modelLabel || row.modelId || "").toLowerCase();
  const sched = String(row.schedule_display || "").toLowerCase();
  const skills = Array.isArray(row.skills)
    ? row.skills.map((item) => String(item || "").toLowerCase()).join(" ")
    : String(row.skills || "").toLowerCase();
  const wa = (row.whatsapp_to || []).join(" ").toLowerCase();
  return id.includes(q) || name.includes(q) || prompt.includes(q) || profile.includes(q) ||
    sourceProfile.includes(q) || model.includes(q) || skills.includes(q) ||
    sched.includes(q) || wa.includes(q);
}

function cronJobStateKey(job) {
  if (job.running) return "running";
  if (!job.enabled) return "disabled";
  if (!job.active) return "paused";
  const st = String(job.last_status || "").toLowerCase();
  if (st === "error") return "error";
  if (st === "skipped") return "skipped";
  if (st === "ok" || job.last_result_at) return "done";
  return "scheduled";
}

function cronJobMatchesStateFilter(job) {
  const wanted = String(hermesCronStateFilter || "all").toLowerCase();
  if (!wanted || wanted === "all") return true;
  return cronJobStateKey(job) === wanted;
}

function cronJobById(jobId) {
  if (typeof qcmCronJobById === "function") return qcmCronJobById(jobId);
  const cron = window._lastHermesCron;
  if (!cron || !cron.jobs) return null;
  return cron.jobs.find((j) => j.id === jobId) || null;
}

function initHermesCronFilterFromUrl() {
  try {
    const p = new URLSearchParams(window.location.search);
    const c = (p.get("cron") || p.get("job_id") || p.get("id") || "").trim();
    if (c) hermesCronFilter = c;
    const state = (p.get("cron_state") || p.get("state") || "").trim().toLowerCase();
    const allowed = new Set(["all", "running", "scheduled", "done", "error", "skipped", "paused", "disabled"]);
    if (allowed.has(state)) hermesCronStateFilter = state;
  } catch (_) {}
}
initHermesCronFilterFromUrl();

function cronJobDisplayName(jobId) {
  const job = cronJobById(jobId);
  return job ? (job.name || job.id || jobId) : jobId;
}

function cronJobIdMatch(a, b) {
  return String(a || "") === String(b || "");
}

function getSuppressedCronJobIds() {
  if (!window._suppressedHermesCronJobIds || typeof window._suppressedHermesCronJobIds !== "object") {
    window._suppressedHermesCronJobIds = {};
  }
  return window._suppressedHermesCronJobIds;
}

function suppressHermesCronJobId(jobId) {
  const id = String(jobId || "").trim();
  if (!id) return;
  const bucket = getSuppressedCronJobIds();
  bucket[id] = Date.now();
}

function isSuppressedHermesCronJobId(jobId) {
  const id = String(jobId || "").trim();
  if (!id) return false;
  const bucket = getSuppressedCronJobIds();
  return !!bucket[id];
}

function cronRowsFingerprint(rows) {
  if (!Array.isArray(rows) || !rows.length) return "empty";
  return rows.map((j) => [
    String(j.id || ""),
    j.active ? "1" : "0",
    j.enabled ? "1" : "0",
    j.running ? "1" : "0",
    String(j.last_status || ""),
    String(j.next_run_at || ""),
    String(j.last_run_at || j.last_result_at || ""),
    String(j.last_result_preview || ""),
  ].join("|")).join("||");
}

function cronSchedulePresetOptionsHtml(selected) {
  const presets = [
    ["hourly", "De hora em hora"],
    ["every_2h", "A cada 2 horas"],
    ["daily_6", "Todos os dias às 06:00"],
    ["daily_8", "Todos os dias às 08:00"],
    ["daily_9", "Todos os dias às 09:00"],
    ["daily_12", "Todos os dias às 12:00"],
    ["daily_18", "Todos os dias às 18:00"],
    ["daily_20", "Todos os dias às 20:00"],
    ["weekdays_9", "Seg–sex às 09:00"],
    ["weekdays_18", "Seg–sex às 18:00"],
    ["weekly_mon_9", "Toda segunda às 09:00"],
    ["custom", "Personalizado (expressão cron)"],
  ];
  return presets.map(([id, label]) => {
    const sel = id === selected ? " selected" : "";
    return '<option value="' + id + '"' + sel + ">" + escapeHtml(label) + "</option>";
  }).join("");
}

function cronScheduleFromBuilder(form) {
  const kind = (form.sched_kind && form.sched_kind.value) || "interval";
  if (kind === "interval") {
    const n = Math.max(1, parseInt(form.interval_value.value, 10) || 60);
    const unit = (form.interval_unit && form.interval_unit.value) || "m";
    if (unit === "d") return "every " + n + "d";
    if (unit === "h") return "every " + n + "h";
    return "every " + n + "m";
  }
  if (kind === "cron") {
    const preset = (form.cron_preset && form.cron_preset.value) || "hourly";
    const presets = {
      hourly: "0 * * * *",
      every_2h: "0 */2 * * *",
      daily_6: "0 6 * * *",
      daily_8: "0 8 * * *",
      daily_9: "0 9 * * *",
      daily_12: "0 12 * * *",
      daily_18: "0 18 * * *",
      daily_20: "0 20 * * *",
      weekdays_9: "0 9 * * 1-5",
      weekdays_18: "0 18 * * 1-5",
      weekly_mon_9: "0 9 * * 1",
    };
    if (preset !== "custom" && presets[preset]) return presets[preset];
    return String((form.cron_expr && form.cron_expr.value) || "").trim();
  }
  return "once";
}

function syncCronSchedulePreview(form) {
  const hidden = form.querySelector('input[name="schedule"]');
  const preview = form.querySelector(".cron-sched-preview code");
  if (!hidden) return;
  let expr = "";
  try {
    expr = cronScheduleFromBuilder(form);
  } catch (_) {
    expr = "";
  }
  hidden.value = expr;
  if (preview) preview.textContent = expr || "—";
  const preset = form.cron_preset ? form.cron_preset.value : "";
  const customWrap = form.querySelector(".cron-sched-custom");
  if (customWrap) customWrap.style.display = preset === "custom" ? "flex" : "none";
}

function bindCronScheduleBuilder(form) {
  if (!form || form.dataset.schedBound === "1") return;
  form.dataset.schedBound = "1";
  const panels = form.querySelectorAll(".cron-sched-panel");
  const showPanel = () => {
    const kind = (form.sched_kind && form.sched_kind.value) || "interval";
    panels.forEach((p) => {
      p.classList.toggle("active", p.dataset.schedPanel === kind);
    });
    syncCronSchedulePreview(form);
  };
  form.querySelectorAll("select, input").forEach((el) => {
    if (el.name === "schedule") return;
    el.addEventListener("change", showPanel);
    el.addEventListener("input", showPanel);
  });
  showPanel();
}

function populateCronScheduleBuilder(form, job) {
  if (!form || !job) return;
  const kind = job.builder_kind || "interval";
  if (form.sched_kind) form.sched_kind.value = kind === "once" ? "interval" : kind;
  if (form.interval_value) form.interval_value.value = String(job.interval_value != null ? job.interval_value : 60);
  if (form.interval_unit) form.interval_unit.value = job.interval_unit || "m";
  if (form.cron_preset) form.cron_preset.value = job.cron_preset || "custom";
  if (form.cron_expr) {
    form.cron_expr.value = job.cron_expr || job.schedule_string || job.schedule_display || "";
  }
  const resumeCb = form.querySelector('input[name="resume_after_save"]');
  const resumeWrap = form.querySelector(".cron-edit-resume");
  if (resumeCb && resumeWrap) {
    resumeWrap.hidden = !!job.active;
    resumeCb.checked = !!job.paused;
  }
  bindCronScheduleBuilder(form);
}

function cronEditRowHtml(job) {
  const src = (hermesCronEditJob && cronJobIdMatch(hermesCronEditJob.id, job.id))
    ? hermesCronEditJob
    : job;
  const id = escapeHtml(src.id || job.id || "");
  const name = escapeHtml(src.name || job.name || "");
  const profile = escapeHtml(src.profile || job.profile || "");
  const prompt = escapeHtml(src.prompt || "");
  const paused = src.paused || (!src.active && src.enabled !== false);
  const pausedPill = paused
    ? '<span class="pill" style="opacity:.9">pausado — pode editar e retomar</span>'
    : '<span class="pill idle">ativo</span>';
  return (
    '<tr class="cron-edit-row" data-edit-for="' + id + '">' +
      '<td colspan="14">' +
        '<form class="cron-edit-form" data-id="' + id + '">' +
          '<label>nome<input name="name" value="' + name + '"></label>' +
          '<label>perfil<input name="profile" value="' + profile + '" placeholder="default"></label>' +
          '<div class="cron-sched-builder">' +
            '<div class="sched-head">' +
              '<span style="font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;">periodicidade</span>' +
              pausedPill +
            '</div>' +
            '<label class="full" style="text-transform:none;letter-spacing:0;font-size:13px;color:var(--fg);">tipo' +
              '<select name="sched_kind">' +
                '<option value="interval">A cada X tempo</option>' +
                '<option value="cron">Horário fixo (cron)</option>' +
              '</select>' +
            '</label>' +
            '<div class="cron-sched-panel" data-sched-panel="interval">' +
              '<label class="narrow">valor<input type="number" name="interval_value" min="1" value="60"></label>' +
              '<label class="narrow">unidade<select name="interval_unit">' +
                '<option value="m">minutos</option>' +
                '<option value="h">horas</option>' +
                '<option value="d">dias</option>' +
              '</select></label>' +
            '</div>' +
            '<div class="cron-sched-panel" data-sched-panel="cron">' +
              '<label class="full" style="min-width:200px;">horário<select name="cron_preset">' +
                cronSchedulePresetOptionsHtml("daily_9") +
              '</select></label>' +
              '<label class="full cron-sched-custom" style="display:none;min-width:200px;">expressão cron' +
                '<input name="cron_expr" placeholder="0 9 * * *" autocomplete="off"></label>' +
            '</div>' +
            '<div class="cron-sched-preview">Será enviado ao Hermes: <code>—</code></div>' +
            '<input type="hidden" name="schedule" value="">' +
          '</div>' +
          '<label class="full cron-edit-resume">' +
            '<input type="checkbox" name="resume_after_save" checked> Retomar job após salvar' +
          '</label>' +
          '<label class="full">prompt<textarea name="prompt">' + prompt + '</textarea></label>' +
          '<div class="cron-edit-actions">' +
            '<button type="button" class="cancel cron-edit-delete" data-id="' + id +
              '" style="margin-right:auto;color:var(--bad);">apagar job</button>' +
            '<button type="submit" class="save">salvar</button>' +
            '<button type="button" class="cancel cron-edit-cancel">cancelar</button>' +
          '</div>' +
        '</form>' +
      '</td>' +
    '</tr>'
  );
}

async function loadCronEditForm(jobId) {
  const r = await fetch("/hermes/cron/" + encodeURIComponent(jobId), { cache: "no-cache" });
  const data = await r.json();
  if (!r.ok || !data.ok) throw new Error(data.error || ("HTTP " + r.status));
  return data.job;
}

function refreshCronEditRow(jobId) {
  const row = document.querySelector(
    'tr.cron-edit-row[data-edit-for="' + CSS.escape(String(jobId)) + '"]'
  );
  const stub = (window._lastHermesCron?.jobs || []).find(
    (j) => cronJobIdMatch(j.id, jobId)
  ) || { id: jobId };
  if (row) {
    row.outerHTML = cronEditRowHtml(stub);
    const form = document.querySelector(
      'form.cron-edit-form[data-id="' + CSS.escape(String(jobId)) + '"]'
    );
    if (form && hermesCronEditJob) populateCronScheduleBuilder(form, hermesCronEditJob);
    else if (form) bindCronScheduleBuilder(form);
    return;
  }
  renderHermesCron(window._lastHermesCron, { rebuildTable: true });
}

async function openCronEdit(jobId) {
  hermesCronEditingId = jobId;
  hermesCronEditJob = null;
  renderHermesCron(window._lastHermesCron, { rebuildTable: true });
  const earlyForm = document.querySelector(
    'form.cron-edit-form[data-id="' + CSS.escape(String(jobId)) + '"]'
  );
  if (earlyForm) bindCronScheduleBuilder(earlyForm);
  try {
    hermesCronEditJob = await loadCronEditForm(jobId);
    refreshCronEditRow(jobId);
  } catch (e) {
    alert("Não foi possível carregar o job: " + e.message);
    hermesCronEditingId = null;
    hermesCronEditJob = null;
    renderHermesCron(window._lastHermesCron, { rebuildTable: true });
  }
}

async function saveCronEdit(form) {
  const jobId = form.dataset.id;
  syncCronSchedulePreview(form);
  const schedule = cronScheduleFromBuilder(form);
  if (!schedule) {
    alert("Defina a periodicidade antes de salvar.");
    return;
  }
  const payload = {
    name: form.name.value,
    schedule: schedule,
    builder_kind: form.sched_kind ? form.sched_kind.value : "interval",
    interval_value: form.interval_value ? form.interval_value.value : "",
    interval_unit: form.interval_unit ? form.interval_unit.value : "m",
    cron_preset: form.cron_preset ? form.cron_preset.value : "",
    cron_expr: form.cron_expr ? form.cron_expr.value : "",
    profile: form.profile.value,
    prompt: form.prompt.value,
  };
  const resumeCb = form.querySelector('input[name="resume_after_save"]');
  if (resumeCb && resumeCb.checked && !resumeCb.closest(".cron-edit-resume")?.hidden) {
    payload.resume_after_save = true;
  }
  const btn = form.querySelector("button.save");
  btn.disabled = true;
  btn.textContent = "…";
  try {
    const r = await fetch("/hermes/cron/" + encodeURIComponent(jobId) + "/edit", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(payload),
    });
    const data = await r.json();
    if (!r.ok || !data.ok) throw new Error(data.summary || data.reason || data.error || ("HTTP " + r.status));
    hermesCronEditingId = null;
    hermesCronEditJob = null;
    await poll();
  } catch (e) {
    alert("Falha ao salvar: " + e.message);
    btn.disabled = false;
    btn.textContent = "salvar";
  }
}

function pruneHermesCronJobFromCache(jobId) {
  const cron = window._lastHermesCron;
  suppressHermesCronJobId(jobId);
  if (!cron || !Array.isArray(cron.jobs)) return;
  const jobs = cron.jobs.filter((j) => !cronJobIdMatch(j.id, jobId));
  const running = Array.isArray(cron.running)
    ? cron.running.filter((j) => !cronJobIdMatch(j.id || j.job_id, jobId))
    : [];
  if (jobs.length === cron.jobs.length && (!Array.isArray(cron.running) || running.length === cron.running.length)) return;
  let active = 0;
  let paused = 0;
  for (const j of jobs) {
    if (j.active) active += 1;
    else paused += 1;
  }
  window._lastHermesCron = Object.assign({}, cron, {
    jobs: jobs,
    running: running,
    total: jobs.length,
    active_count: active,
    paused_count: paused,
    running_count: running.length,
  });
}

function isCronDeleteNotFoundError(message) {
  const text = String(message || "").toLowerCase();
  return (text.includes("job with id or name") && text.includes("not found"))
    || text.includes("já está ausente")
    || text.includes("already absent")
    || text.includes("não encontrado");
}

async function resumeAllPausedCronJobs(btn) {
  const cron = window._lastHermesCron;
  const n = (cron && cron.paused_count) || 0;
  if (!n) return;
  if (!confirm("Retomar " + n + " cron job(s) pausado(s)?")) return;
  const old = btn ? btn.textContent : "";
  if (btn) {
    btn.disabled = true;
    btn.textContent = "…";
  }
  try {
    const data = await monitorFetchJson(
      "/hermes/cron/resume-all",
      { method: "POST", credentials: "same-origin" }
    );
    const resumed = data.resumed_count != null ? data.resumed_count : n;
    if (!data.ok && data.failures && data.failures.length) {
      alert(
        "Alguns jobs falharam ao retomar (" + data.failures.length + "). " +
        "Retomados: " + resumed + "."
      );
    }
    hermesCronShowPaused = false;
    const toggle = el("hermes-cron-show-paused");
    if (toggle) toggle.checked = false;
    await poll();
  } catch (e) {
    alert("Falha ao despausar: " + e.message);
  } finally {
    if (btn && btn.isConnected) {
      btn.textContent = old || "despausar todos";
      const paused = (window._lastHermesCron && window._lastHermesCron.paused_count) || 0;
      btn.disabled = paused < 1;
    }
  }
}

async function resolveProblematicCronJobsWithAgent(btn) {
  const cron = window._lastHermesCron;
  const n = (cron && cron.error_count) || 0;
  if (!n) return;
  if (!confirm("Executar agente para resolver " + n + " cron job(s) problemático(s)?")) return;
  const old = btn ? btn.textContent : "";
  if (btn) {
    btn.disabled = true;
    btn.textContent = "…";
  }
  showHermesRecoveryResult("executando agente de recovery para jobs problemáticos…", true);
  try {
    const data = await postHermesRecoveryAction("run_cron_problematic_jobs_agent");
    const txt = (data.report || data.summary || JSON.stringify(data)).slice(0, 1200);
    showHermesRecoveryResult(txt, data.ok !== false);
    await refreshHermesRecovery();
    await poll();
  } catch (e) {
    showHermesRecoveryResult("Falha ao executar agente: " + e.message, false);
  } finally {
    if (btn && btn.isConnected) {
      btn.textContent = old || "resolver problemáticos (agente)";
      const errN = (window._lastHermesCron && window._lastHermesCron.error_count) || 0;
      btn.disabled = errN < 1;
    }
  }
}

async function forceRemoveCronJobGlobally(btn) {
  const typed = String(window.prompt("ID (ou nome exato) do cron para remover na forca bruta:", "") || "").trim();
  if (!typed) return;
  const warned =
    "Isso vai remover o job em todos os jobs.json encontrados (home e perfis Hermes).\n\n" +
    "Referencia: " + typed + "\n\n" +
    "Continuar?";
  if (!window.confirm(warned)) return;

  const old = btn ? btn.textContent : "";
  if (btn) {
    btn.disabled = true;
    btn.textContent = "…";
  }
  try {
    const data = await monitorFetchJson(
      "/hermes/cron/force-remove",
      {
        method: "POST",
        credentials: "same-origin",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ job_id: typed }),
      }
    );

    const removedIds = Array.isArray(data.removed_job_ids) ? data.removed_job_ids : [];
    if (removedIds.length) {
      removedIds.forEach((jid) => {
        pruneHermesCronJobFromCache(jid);
      });
      if (hermesCronEditingId && removedIds.some((jid) => cronJobIdMatch(jid, hermesCronEditingId))) {
        hermesCronEditingId = null;
        hermesCronEditJob = null;
      }
      if (hermesCronResultId && removedIds.some((jid) => cronJobIdMatch(jid, hermesCronResultId))) {
        closeCronResultModal();
      }
      renderHermesCron(window._lastHermesCron, { rebuildTable: true });
    }

    const removedN = Number(data.removed_count || 0);
    if (removedN > 0) {
      alert("Remocao forcada concluida: " + removedN + " ocorrencia(s) removida(s).");
    } else {
      alert(data.message || "Nenhum job correspondente encontrado nos arquivos varridos.");
    }
    await poll();
  } catch (e) {
    alert("Falha na remocao forcada: " + e.message);
  } finally {
    if (btn && btn.isConnected) {
      btn.disabled = false;
      btn.textContent = old || "remover na forca bruta";
    }
  }
}

async function cronJobAction(jobId, action, btn) {
  jobId = String(jobId || "").trim();
  if (!jobId) {
    alert("Falha: id do job inválido");
    return;
  }
  let apiAction = action;
  if (apiAction === "remove" || apiAction === "delete" || apiAction === "rm") {
    const name = cronJobDisplayName(jobId);
    if (!confirm("Apagar o cron job \"" + name + "\"?\n\nEsta ação não pode ser desfeita.")) return;
    apiAction = "remove";
    // Force-hide immediately to avoid stale rows flashing back while backend syncs.
    pruneHermesCronJobFromCache(jobId);
    renderHermesCron(window._lastHermesCron, { rebuildTable: true });
  }
  if (apiAction === "run") {
    await cronRunWithExecDialog(jobId, btn);
    return;
  }
  const old = btn ? btn.textContent : "";
  if (btn) {
    btn.disabled = true;
    btn.textContent = "…";
  }
  try {
    await monitorFetchJson(
      "/hermes/cron/" + encodeURIComponent(jobId) + "/" + encodeURIComponent(apiAction),
      { method: "POST", credentials: "same-origin" }
    );
    if (apiAction === "remove") {
      if (hermesCronEditingId && cronJobIdMatch(hermesCronEditingId, jobId)) {
        hermesCronEditingId = null;
        hermesCronEditJob = null;
      }
      if (hermesCronResultId && cronJobIdMatch(hermesCronResultId, jobId)) {
        closeCronResultModal();
      }
      pruneHermesCronJobFromCache(jobId);
    }
    renderHermesCron(window._lastHermesCron, { rebuildTable: true });
    await poll();
  } catch (e) {
    if (apiAction === "remove" && isCronDeleteNotFoundError(e && e.message)) {
      pruneHermesCronJobFromCache(jobId);
      renderHermesCron(window._lastHermesCron, { rebuildTable: true });
      try { await poll(); } catch (_) {}
      return;
    }
    if (btn && btn.isConnected) {
      btn.textContent = "✕";
      alert("Falha: " + e.message);
      setTimeout(() => {
        if (btn.isConnected) {
          btn.textContent = old || "apagar";
          btn.disabled = false;
        }
      }, 1500);
    } else {
      alert("Falha: " + e.message);
    }
  } finally {
    if (btn && btn.isConnected && btn.textContent === "…") {
      btn.textContent = old || "apagar";
      btn.disabled = false;
    }
  }
}

function renderHermesCronRunning(cron) {
  const wrap = el("hermes-cron-running-wrap");
  const list = el("hermes-cron-running-list");
  const meta = el("hermes-cron-running-meta");
  if (!wrap || !list) return;
  const running = (cron && cron.running) || [];
  if (!running.length) {
    wrap.style.display = "none";
    list.innerHTML = "";
    return;
  }
  wrap.style.display = "";
  const filtered = running.filter((job) => cronJobMatchesFilter(job));
  if (!filtered.length) {
    wrap.style.display = hermesCronFilter.trim() ? "" : "none";
    list.innerHTML = hermesCronFilter.trim()
      ? '<p class="meta" style="padding:8px 0;">nenhum job em execução para este filtro</p>'
      : "";
    meta.textContent = hermesCronFilter.trim()
      ? "0 com filtro · " + running.length + " total"
      : running.length + " ativo(s) · tail agent.log";
    return;
  }
  wrap.style.display = "";
  meta.textContent = filtered.length + " ativo(s) · tail agent.log";
  list.innerHTML = filtered.map((job) => {
    const modelEnabled = !(job.modelId || job.modelLabel)
      || (typeof isModelEnabled !== "function"
        ? true
        : isModelEnabled(job.modelId || job.modelLabel));
    const name = escapeHtml(job.name || job.job_id || "?");
    const jobId = job.job_id
      ? ' <span class="meta cron-id">id ' + escapeHtml(job.job_id) + "</span>"
      : "";
    const sourceProfile = job.source_profile
      ? ' <span class="meta">[' + escapeHtml(job.source_profile) + "]</span>"
      : "";
    const profile = (job.profileLabel || job.profile)
      ? ' <span class="meta">(' + escapeHtml(job.profileLabel || job.profile) + ")</span>"
      : "";
    const model = job.modelLabel || job.modelId
      ? ' <span class="meta">· ' + escapeHtml(job.modelLabel || job.modelId) + "</span>"
      : "";
    const started = job.started_at ? escapeHtml(fmtCronWhen(job.started_at)) : "—";
    const ago = job.seconds_since_activity != null
      ? job.seconds_since_activity + "s atrás"
      : "—";
    const session = escapeHtml(job.session_id || "");
    const logLines = (job.log_tail || []).map((line) => escapeHtml(line)).join("\n");
    return (
      '<div class="cron-running-card">' +
        '<div class="cron-running-head">' +
          (modelEnabled
            ? '<span class="pill running"><span class="pulse"></span>executando</span>'
            : '<span class="pill paused">modelo pausado</span>') +
          '<span class="nm">' + name + "</span>" + jobId + sourceProfile + profile + model +
          '<span class="meta">início ' + started + " · última atividade " + ago + "</span>" +
        "</div>" +
        '<div class="meta" style="margin-bottom:6px;">' + session + "</div>" +
        '<pre class="cron-running-log">' + (logLines || escapeHtml(job.last_message || "—")) + "</pre>" +
      "</div>"
    );
  }).join("");
}

function isSwarmScheduledJob(job) {
  const name = String((job && job.name) || "").toLowerCase();
  const profile = String((job && job.profile) || "").toLowerCase();
  return /swarm|orelhao|orelhão/.test(name) || /swarm|orelhao|orelhão/.test(profile);
}

function renderSwarmSchedule(cron) {
  const wrap = el("swarm-schedule-wrap");
  const body = el("swarm-schedule-body");
  const meta = el("swarm-schedule-meta");
  if (!wrap || !body || !meta) return;
  if (!cron || !Array.isArray(cron.jobs) || !cron.jobs.length) {
    wrap.style.display = "none";
    return;
  }

  const scheduled = cron.jobs
    .filter((j) => !!j && (j.active || j.enabled || j.next_run_at));
  const swarmRows = scheduled.filter((j) => isSwarmScheduledJob(j));
  const rows = swarmRows.length ? swarmRows : scheduled
    .sort((a, b) => {
      const an = Date.parse(String(a.next_run_at || ""));
      const bn = Date.parse(String(b.next_run_at || ""));
      if (!Number.isNaN(an) && !Number.isNaN(bn)) return an - bn;
      if (!Number.isNaN(an)) return -1;
      if (!Number.isNaN(bn)) return 1;
      return String(a.name || a.id || "").localeCompare(String(b.name || b.id || ""));
    });

  if (!rows.length) {
    wrap.style.display = "none";
    return;
  }

  wrap.style.display = "";
  if (swarmRows.length) {
    meta.textContent = swarmRows.length + " agente(s) swarm agendado(s)";
  } else {
    meta.textContent = rows.length + " agente(s) agendado(s)";
  }
  body.innerHTML = rows.map((j) => {
    const agent = escapeHtml((j.name || j.id || "?").slice(0, 72));
    const profile = escapeHtml(j.profile || "—");
    const sched = escapeHtml(j.schedule_display || "—");
    const next = escapeHtml(fmtCronWhen(j.next_run_at));
    const state = escapeHtml(j.state || (j.active ? "scheduled" : "paused"));
    const result = escapeHtml((j.last_result_preview || j.last_status || "—").slice(0, 140));
    const hi = isSwarmScheduledJob(j) ? ' class="swarm-highlight"' : "";
    return (
      "<tr" + hi + ">" +
        "<td>" + agent + (isSwarmScheduledJob(j) ? '<span class="swarm-badge">swarm</span>' : "") + "</td>" +
        '<td class="mono">' + profile + "</td>" +
        '<td class="mono">' + sched + "</td>" +
        '<td class="mono">' + next + "</td>" +
        "<td>" + state + "</td>" +
        '<td class="mono">' + result + "</td>" +
      "</tr>"
    );
  }).join("");
}

function isRufloScheduledJob(job) {
  const name = String((job && job.name) || "").toLowerCase();
  const profile = String((job && job.profile) || "").toLowerCase();
  const sourceProfile = String((job && job.source_profile) || "").toLowerCase();
  return /ruflo|swarm|hive|orelhao|orelhão/.test(name) || /ruflo|swarm|hive|orelhao|orelhão/.test(profile) || /ruflo|swarm|hive|orelhao|orelhão/.test(sourceProfile);
}

function renderRufloSchedules(statusData) {
  const body = el("ruflo-jobs-body");
  const meta = el("ruflo-jobs-meta");
  if (!body || !meta) return;

  const jobs = ((statusData || {}).hermes || {}).cron && Array.isArray(((statusData || {}).hermes || {}).cron.jobs)
    ? ((statusData || {}).hermes || {}).cron.jobs
    : [];
  const rufloJobs = jobs.filter((j) => isRufloScheduledJob(j));

  if (!jobs.length) {
    meta.textContent = "sem cron disponível";
    body.innerHTML = '<tr><td colspan="5" class="empty" style="padding:12px;color:var(--muted);">cron do Hermes indisponível</td></tr>';
    return;
  }

  if (!rufloJobs.length) {
    meta.textContent = "0 job(s) RuFlo";
    body.innerHTML = '<tr><td colspan="5" class="empty" style="padding:12px;color:var(--muted);">nenhum job RuFlo/Swarm/Hive agendado</td></tr>';
    return;
  }

  rufloJobs.sort((a, b) => {
    const an = Date.parse(String(a.next_run_at || ""));
    const bn = Date.parse(String(b.next_run_at || ""));
    if (!Number.isNaN(an) && !Number.isNaN(bn)) return an - bn;
    if (!Number.isNaN(an)) return -1;
    if (!Number.isNaN(bn)) return 1;
    return String(a.name || a.id || "").localeCompare(String(b.name || b.id || ""));
  });

  function scheduleBadge(job) {
    const state = String(job.state || (job.active ? "scheduled" : "paused")).toLowerCase();
    const nextText = String(job.next_run_at || "").trim();
    const nextMs = Date.parse(nextText);
    if (state === "paused") {
      return '<span class="ruflo-sched-badge late">pausado</span>';
    }
    if (state === "completed") {
      return '<span class="ruflo-sched-badge">concluido</span>';
    }
    if (Number.isNaN(nextMs)) {
      return '<span class="ruflo-sched-badge">sem horario</span>';
    }
    const deltaMin = Math.round((nextMs - Date.now()) / 60000);
    if (deltaMin < 0) {
      return '<span class="ruflo-sched-badge late">atrasado</span>';
    }
    if (deltaMin <= 10) {
      return '<span class="ruflo-sched-badge soon">em breve</span>';
    }
    if (deltaMin <= 120) {
      return '<span class="ruflo-sched-badge today">hoje</span>';
    }
    return '<span class="ruflo-sched-badge">agendado</span>';
  }

  meta.textContent = rufloJobs.length + " job(s) RuFlo";
  body.innerHTML = rufloJobs.map((j) => {
    const job = escapeHtml((j.name || j.id || "?").slice(0, 90));
    const sourceProfile = j.source_profile
      ? ' <span class="meta">[' + escapeHtml(j.source_profile) + "]</span>"
      : "";
    const profile = j.profile
      ? ' <span class="meta">(' + escapeHtml(j.profile) + ")</span>"
      : "";
    const sched = escapeHtml(j.schedule_display || "—");
    const next = escapeHtml(fmtCronWhen(j.next_run_at));
    const badge = scheduleBadge(j);
    const state = escapeHtml(j.state || (j.active ? "scheduled" : "paused"));
    return (
      "<tr>" +
        "<td>" + job + "</td>" +
        '<td class="mono">' + sourceProfile + profile + "</td>" +
        '<td class="mono">' + sched + "</td>" +
        '<td class="mono">' + next + badge + "</td>" +
        "<td>" + state + "</td>" +
      "</tr>"
    );
  }).join("");
}

function renderRufloAgentResults(data, statusData) {
  const wrap = el("ruflo-agent-wrap");
  const body = el("ruflo-agent-body");
  const meta = el("ruflo-agent-meta");
  if (!wrap || !body || !meta) return;

  if (!data || data.ok === false) {
    wrap.style.display = "";
    meta.textContent = "ruflo indisponível";
    body.innerHTML = '<tr><td colspan="5" class="empty" style="padding:12px;color:var(--bad);">' +
      escapeHtml((data && data.error) || "não foi possível ler /ruflo/status") +
      "</td></tr>";
    renderRufloSchedules(statusData || null);
    return;
  }

  const agents = Array.isArray(data.agents) ? data.agents : [];
  const hiveWorkers = Array.isArray(data.hive_workers) ? data.hive_workers : [];
  const combined = agents.slice();
  hiveWorkers.forEach((w) => {
    combined.push({
      id: w.id || w.name || "?",
      name: w.name || w.id || "?",
      role: "hive:" + (w.type || "worker"),
      status: w.status || "unknown",
      last_result: w.current_task || "",
      last_task_id: "hive",
      last_task_status: w.current_task ? "running" : "idle",
      last_task_result: String(w.tasks_completed || 0) + " tarefa(s) concluída(s)",
      last_task_updated_at: "",
    });
  });
  wrap.style.display = "";
  meta.textContent = (data.agents_total != null ? data.agents_total : agents.length) +
    " agente(s) RuFlo · " +
    (data.hive_workers_total != null ? data.hive_workers_total : hiveWorkers.length) +
    " worker(s) Hive · " +
    (data.tasks_total != null ? data.tasks_total : 0) + " tarefa(s)";

  if (!combined.length) {
    body.innerHTML = '<tr><td colspan="5" class="empty" style="padding:12px;color:var(--muted);">' +
      "sem agentes ativos no RuFlo/Hive neste workspace" +
      "</td></tr>";
    renderRufloSchedules(statusData || null);
    return;
  }

  renderRowsInParts(body, combined, (a) => {
    const id = escapeHtml(a.id || a.name || "?");
    const name = escapeHtml(a.name || a.id || "?");
    const role = escapeHtml(a.role || "—");
    const status = escapeHtml(a.status || "unknown");
    const taskStatus = escapeHtml(a.last_task_status || "—");
    const taskId = escapeHtml(a.last_task_id || "—");
    const resultRaw = String(a.last_result || a.last_task_result || "").trim();
    const result = resultRaw
      ? escapeHtml(resultRaw)
      : '<span class="ruflo-result-empty">sem resultado ainda</span>';
    return (
      "<tr>" +
        '<td><span class="nm">' + name + "</span><div class=\"meta\">" + id + "</div></td>" +
        "<td>" + role + "</td>" +
        '<td class="mono">' + status + "</td>" +
        "<td>" + result + "</td>" +
        '<td class="mono">' + taskStatus + " · " + taskId + "</td>" +
      "</tr>"
    );
  }, {
    jobKey: "ruflo-agent-body",
    chunkSize: RENDER_CHUNK_RUFLO_AGENTS,
    colspan: 5,
    progressLabel: "Carregando agentes RuFlo",
    emptyHtml: '<tr><td colspan="5" class="empty" style="padding:12px;color:var(--muted);">sem agentes ativos no RuFlo/Hive neste workspace</td></tr>',
  });
  renderRufloSchedules(statusData || null);
}

async function pollRufloAgentResults() {
  try {
    const [data, statusData] = await Promise.all([
      monitorFetchJson("/ruflo/status", {}, 20000),
      monitorFetchJson("/status", {}, 12000),
    ]);
    renderRufloAgentResults(data, statusData);
  } catch (e) {
    renderRufloAgentResults({ ok: false, error: e.message }, null);
  }
}

const HERMES_TAB_IDS = {
  overview: [
    "hermes-status-card",
    "hermes-cron-scheduler",
    "hermes-recovery-panel",
    "hermes-cron-running-wrap",
    "swarm-schedule-wrap",
  ],
  ruflo: [
    "ruflo-agent-wrap",
  ],
  cron: [
    "hermes-cron-wrap",
    "hermes-profiles-wrap",
    "hermes-chat-launch",
  ],
};

let hermesActiveTab = "ruflo";

function getInitialHermesTab() {
  try {
    const qs = new URLSearchParams(window.location.search || "");
    const fromUrl = (qs.get("hermes_tab") || "").trim().toLowerCase();
    if (HERMES_TAB_IDS[fromUrl]) return fromUrl;
  } catch (e) {
  }
  const fromConfig = String(HERMES_DEFAULT_TAB || "").trim().toLowerCase();
  if (HERMES_TAB_IDS[fromConfig]) return fromConfig;
  return "ruflo";
}

function setHermesTab(tab) {
  const next = HERMES_TAB_IDS[tab] ? tab : "ruflo";
  hermesActiveTab = next;
  Object.entries(HERMES_TAB_IDS).forEach(([key, ids]) => {
    const visible = key === next;
    ids.forEach((id) => {
      const node = el(id);
      if (!node) return;
      node.classList.toggle("hermes-pane-hidden", !visible);
    });
  });
  const tabs = Array.from(document.querySelectorAll("#hermes-tabs .tab-btn"));
  tabs.forEach((btn) => {
    btn.classList.toggle("active", btn.dataset.hermesTab === next);
  });
}

function initHermesTabs() {
  const tabsWrap = el("hermes-tabs");
  if (!tabsWrap || tabsWrap.dataset.bound === "1") return;
  tabsWrap.dataset.bound = "1";
  const tabs = Array.from(tabsWrap.querySelectorAll(".tab-btn"));
  tabs.forEach((btn) => {
    btn.addEventListener("click", () => {
      setHermesTab(btn.dataset.hermesTab || "ruflo");
    });
  });
  setHermesTab(getInitialHermesTab());
}

function renderHermesCron(cron, opts) {
  opts = opts || {};
  renderHermesCronRunning(cron);
  renderSwarmSchedule(cron);
  const wrap = el("hermes-cron-wrap");
  const body = el("hermes-cron-body");
  const meta = el("hermes-cron-meta");
  const toggle = el("hermes-cron-show-paused");
  const stateFilter = el("hermes-cron-state-filter");
  const filterInput = el("hermes-cron-filter");
  if (!wrap || !body) return;
  if (!cron || !cron.jobs || !cron.jobs.length) {
    wrap.style.display = "none";
    return;
  }
  wrap.style.display = "";
  if (filterInput && !filterInput._bound) {
    filterInput._bound = true;
    filterInput.value = hermesCronFilter;
    filterInput.addEventListener("input", () => {
      hermesCronFilter = filterInput.value;
      renderHermesCron(window._lastHermesCron, { rebuildTable: true });
    });
  } else if (filterInput) {
    filterInput.value = hermesCronFilter;
  }
  if (toggle && !toggle._bound) {
    toggle._bound = true;
    toggle.checked = hermesCronShowPaused;
    toggle.addEventListener("change", () => {
      hermesCronShowPaused = toggle.checked;
      if (hermesCronStateFilter === "all" && !hermesCronShowPaused) {
        // "Todos" sempre inclui pausados; evita estado contraditório de UI.
        hermesCronShowPaused = true;
        toggle.checked = true;
      }
      renderHermesCron(window._lastHermesCron, { rebuildTable: true });
    });
  }
  if (stateFilter && !stateFilter._bound) {
    stateFilter._bound = true;
    stateFilter.value = hermesCronStateFilter;
    stateFilter.addEventListener("change", () => {
      hermesCronStateFilter = stateFilter.value || "all";
      if (hermesCronStateFilter === "all") {
        hermesCronShowPaused = true;
        if (toggle) toggle.checked = true;
      }
      renderHermesCron(window._lastHermesCron, { rebuildTable: true });
    });
  } else if (stateFilter) {
    stateFilter.value = hermesCronStateFilter;
  }
  const resumeAllBtn = el("hermes-cron-resume-all");
  if (resumeAllBtn && !resumeAllBtn._bound) {
    resumeAllBtn._bound = true;
    resumeAllBtn.addEventListener("click", () => resumeAllPausedCronJobs(resumeAllBtn));
  }
  const resolveProblematicBtn = el("hermes-cron-resolve-problematic");
  if (resolveProblematicBtn && !resolveProblematicBtn._bound) {
    resolveProblematicBtn._bound = true;
    resolveProblematicBtn.addEventListener("click", () =>
      resolveProblematicCronJobsWithAgent(resolveProblematicBtn));
  }
  const forceRemoveBtn = el("hermes-cron-force-remove");
  if (forceRemoveBtn && !forceRemoveBtn._bound) {
    forceRemoveBtn._bound = true;
    forceRemoveBtn.addEventListener("click", () => forceRemoveCronJobGlobally(forceRemoveBtn));
  }
  if (resumeAllBtn) {
    const pausedN = cron.paused_count || 0;
    resumeAllBtn.disabled = pausedN < 1;
    resumeAllBtn.title = pausedN < 1
      ? "Nenhum cron pausado"
      : "Retomar " + pausedN + " cron job(s) pausado(s)";
  }
  if (resolveProblematicBtn) {
    const errN = cron.error_count || 0;
    resolveProblematicBtn.disabled = errN < 1;
    resolveProblematicBtn.title = errN < 1
      ? "Nenhum cron com erro"
      : "Executar agente para resolver " + errN + " cron job(s) com erro";
  }
  window._lastHermesCron = cron;
  const err = cron.error_count || 0;
  meta.textContent =
    (cron.active_count || 0) + " ativos · " +
    (cron.paused_count || 0) + " pausados · " +
    (cron.total || 0) + " total" +
    (err ? " · " + err + " com erro" : "") +
    (cron.updated_at ? " · atualizado " + fmtCronWhen(cron.updated_at) : "");

  // Keep the open edit panel intact during background /status polling only.
  if (!opts.rebuildTable && hermesCronEditingId) {
    const openForm = document.querySelector(
      'form.cron-edit-form[data-id="' + CSS.escape(String(hermesCronEditingId)) + '"]'
    );
    if (openForm) return;
  }
  let rows = cron.jobs.slice();
  // Quando o estado é explícito, ele prevalece sobre o toggle de pausados.
  if (hermesCronStateFilter !== "all") {
    rows = rows.filter((j) => cronJobMatchesStateFilter(j));
  } else if (!hermesCronShowPaused) {
    // Recupera coerência em casos de estado antigo/cached.
    hermesCronShowPaused = true;
    if (toggle) toggle.checked = true;
  }
  if (hermesCronFilter.trim()) {
    rows = rows.filter((j) => cronJobMatchesFilter(j));
  }
  const nextFp = cronRowsFingerprint(rows) +
    "::" + String(hermesCronShowPaused) +
    "::" + String(hermesCronStateFilter) +
    "::" + String(hermesCronFilter || "");
  if (!opts.rebuildTable && hermesCronRowsFingerprint === nextFp) {
    return;
  }
  hermesCronRowsFingerprint = nextFp;
  if (!rows.length) {
    const msg = hermesCronFilter.trim()
      ? "nenhum cron corresponde ao filtro"
      : "nenhum job ativo (marque “mostrar pausados”)";
    body.innerHTML = '<tr><td colspan="14" class="empty" style="padding:14px;color:var(--muted);">' +
      escapeHtml(msg) + "</td></tr>";
    return;
  }
  renderRowsInParts(body, rows, (j) => {
    const isSwarm = isSwarmScheduledJob(j);
    const dim = j.active ? "" : ' style="opacity:.55"';
    const rowCls = isSwarm ? ' class="swarm-highlight"' : "";
    const cronId = escapeHtml(String(j.id || "—"));
    const name = escapeHtml((j.name || j.id || "?").slice(0, 48));
    const sched = escapeHtml(j.schedule_display || "—");
    const modelCell = escapeHtml(j.modelLabel || j.modelId || "—");
    const tokensCell = fmtCronAvgTokens(j);
    const sourceProfile = j.source_profile ? ' <span class="meta">[' + escapeHtml(j.source_profile) + ']</span>' : "";
    const prof = j.profile ? ' <span class="meta">(' + escapeHtml(j.profile) + ')</span>' : "";
    const hasPreview = !!(j.last_result_preview || j.last_run_at || j.last_result_at);
    const previewClass = hasPreview ? " result-preview clickable cron-result-preview" : " result-preview";
    const previewAttrs = hasPreview
      ? ' data-id="' + escapeHtml(j.id || "") + '" title="ver resultado completo"'
      : "";
    let rowHtml =
      '<tr' + rowCls + dim + ' data-id="' + escapeHtml(String(j.id || "")) + '">' +
        '<td class="cron-id" title="' + cronId + '">' + cronId + '</td>' +
        '<td><span class="nm">' + name + "</span>" + (isSwarm ? '<span class="swarm-badge">swarm</span>' : '') + sourceProfile + prof + '</td>' +
        '<td class="mono">' + modelCell + '</td>' +
        '<td class="cron-skills">' + cronSkillsCell(j) + '</td>' +
        '<td class="num">' + tokensCell + '</td>' +
        '<td class="sched">' + sched + '</td>' +
        '<td>' + cronStatePill(j) + '</td>' +
        '<td class="when">' + escapeHtml(fmtCronWhen(j.next_run_at)) + '</td>' +
        '<td class="when">' + escapeHtml(fmtCronWhen(j.last_run_at || j.last_result_at)) + '</td>' +
        '<td class="num">' + escapeHtml(j.last_status || (j.last_result_at ? "ok" : "—")) + '</td>' +
        '<td class="desc cron-prompt-preview" data-id="' + escapeHtml(j.id || "") +
          '" title="abrir detalhes do agente">' + cronPromptCell(j) + '</td>' +
        '<td>' + cronWhatsappCell(j) + '</td>' +
        '<td class="' + previewClass.trim() + '"' + previewAttrs + '>' + cronResultPreviewCell(j) + '</td>' +
        '<td class="actions">' + cronActionButtons(j) + '</td>' +
      '</tr>';
    if (hermesCronEditingId && cronJobIdMatch(j.id, hermesCronEditingId)) {
      rowHtml += cronEditRowHtml(j);
    }
    return rowHtml;
  }, {
    jobKey: "hermes-cron-body",
    chunkSize: RENDER_CHUNK_CRON,
    colspan: 14,
    progressLabel: "Carregando jobs cron",
    onDone: () => {
      if (typeof bindCronPlayButtons === "function") bindCronPlayButtons(body);
    },
  });
}

document.addEventListener("click", async (ev) => {
  const resultBtn = closestFromEvent(ev, "button.cron-result");
  if (resultBtn) {
    ev.preventDefault();
    if (resultBtn.disabled) return;
    await openCronResult(resultBtn.dataset.id);
    return;
  }
  const sourceBadge = closestFromEvent(ev, ".cron-source-badge");
  if (sourceBadge) {
    ev.preventDefault();
    const row = closestFromEvent(ev, "#hermes-cron-table tbody tr[data-id]");
    const rowId = row ? String(row.dataset.id || "").trim() : "";
    if (rowId) await openCronResult(rowId, { focusDetails: true });
    return;
  }
  const previewCell = closestFromEvent(ev, "td.cron-result-preview");
  if (previewCell) {
    ev.preventDefault();
    await openCronResult(previewCell.dataset.id);
    return;
  }
  const promptCell = closestFromEvent(ev, "td.cron-prompt-preview");
  if (promptCell) {
    ev.preventDefault();
    await openCronResult(promptCell.dataset.id, { focusDetails: true });
    return;
  }
  const cronRow = closestFromEvent(ev, "#hermes-cron-table tbody tr[data-id]");
  if (cronRow) {
    const interactive = closestFromEvent(ev, "a,button,input,textarea,select,label,form");
    if (!interactive) {
      ev.preventDefault();
      const rowId = String(cronRow.dataset.id || "").trim();
      if (rowId) await openCronResult(rowId);
      return;
    }
  }
  const resultPick = closestFromEvent(ev, "button.cron-result-pick");
  if (resultPick) {
    ev.preventDefault();
    await pickCronResultRun(resultPick.dataset.id, resultPick.dataset.run);
    return;
  }
  const editBtn = closestFromEvent(ev, "button.cron-edit");
  if (editBtn) {
    ev.preventDefault();
    await openCronEdit(editBtn.dataset.id);
    return;
  }
  const cancelBtn = closestFromEvent(ev, "button.cron-edit-cancel");
  if (cancelBtn) {
    hermesCronEditingId = null;
    hermesCronEditJob = null;
    renderHermesCron(window._lastHermesCron, { rebuildTable: true });
    return;
  }
  const deleteBtn = closestFromEvent(ev, "button.cron-edit-delete");
  if (deleteBtn) {
    ev.preventDefault();
    await cronJobAction(deleteBtn.dataset.id, "remove", deleteBtn);
    return;
  }
  const actBtn = closestFromEvent(ev, "button.cron-act");
  if (actBtn) {
    ev.preventDefault();
    await cronJobAction(actBtn.dataset.id, actBtn.dataset.action, actBtn);
  }
});

document.addEventListener("keydown", async (ev) => {
  const sourceBadge = closestFromEvent(ev, ".cron-source-badge");
  if (!sourceBadge) return;
  const key = ev.key || "";
  if (key !== "Enter" && key !== " ") return;
  ev.preventDefault();
  const row = sourceBadge.closest("tr[data-id]");
  const rowId = row ? String(row.getAttribute("data-id") || "").trim() : "";
  if (rowId) await openCronResult(rowId, { focusDetails: true });
});

document.addEventListener("submit", async (ev) => {
  const form = closestFromEvent(ev, "form.cron-edit-form");
  if (!form) return;
  ev.preventDefault();
  await saveCronEdit(form);
});

function renderDiagnosis(s, now) {
  const card = el("diagnosis-card");
  if (!card) return;
  const diag = s.diagnosis;
  if (s.up || !diag) {
    card.hidden = true;
    return;
  }
  card.hidden = false;
  el("diagnosis-headline").textContent = diag.headline || "QClaw indisponível";
  const likely = el("diagnosis-likely");
  likely.textContent = diag.likely_cause || "";
  likely.style.display = diag.likely_cause ? "" : "none";
  const fails = diag.consecutive_failures ?? s.consecutive_failures ?? 0;
  const thr = diag.failure_threshold ?? s.failure_threshold ?? "—";
  const metaParts = [
    fails + " falha(s) consecutiva(s) (limite " + thr + ")",
  ];
  if (diag.last_health_fail_ts) {
    metaParts.push("última falha " + fmtAgo(diag.last_health_fail_ts, now));
  }
  if (diag.last_health_ok_ts) {
    metaParts.push("último OK " + fmtAgo(diag.last_health_ok_ts, now));
  }
  el("diagnosis-meta").textContent = metaParts.join(" · ");
  const causes = Array.isArray(diag.causes) ? diag.causes : [];
  const causesEl = el("diagnosis-causes");
  if (!causes.length) {
    causesEl.innerHTML = '<li><strong>Sem detalhes</strong><span>Aguardando próximo health check.</span></li>';
  } else {
    causesEl.innerHTML = causes.map((c) =>
      '<li><strong>' + escapeHtml(c.label || "?") + '</strong>' +
      '<span>' + escapeHtml(c.detail || "") + '</span></li>'
    ).join("");
  }
  const hints = Array.isArray(diag.hints) ? diag.hints : [];
  const hintsEl = el("diagnosis-hints");
  hintsEl.innerHTML = hints.length
    ? hints.map((h) => "<li>" + escapeHtml(h) + "</li>").join("")
    : "";
  hintsEl.style.display = hints.length ? "" : "none";
  const checks = Array.isArray(diag.checks) ? diag.checks : [];
  const checksEl = el("diagnosis-checks");
  if (!checks.length) {
    checksEl.textContent = "";
    checksEl.style.display = "none";
  } else {
    checksEl.style.display = "";
    checksEl.innerHTML = "Checks: " + checks.map((c) => {
      const cls = c.ok ? "ok" : "bad";
      return '<span class="' + cls + '">' + escapeHtml(c.label) + ": " +
        escapeHtml(c.detail) + "</span>";
    }).join(" · ");
  }
}

function renderHermes(h, now) {
  const section = el("hermes-section");
  const fallbackUrl = HERMES_DASHBOARD_URL || "";
  if (!h) {
    if (fallbackUrl) {
      section.style.display = "";
      applyHermesLinks(fallbackUrl, null);
      el("hermes-status-label").textContent = "…";
      el("hermes-status-meta").textContent = fallbackUrl + "  ·  aguardando /status";
    } else {
      section.style.display = "none";
    }
    renderHermesCron(null);
    return;
  }
  section.style.display = "";
  const up = !!(h.active ?? h.up);
  const dashUp = h.dashboard_up;
  const card = el("hermes-status-card");
  const hermesStateClass = up ? "up" : "down";
  if (!card.classList.contains(hermesStateClass)) {
    card.classList.remove("up", "down");
    card.classList.add(hermesStateClass);
  }
  const hermesDot = el("hermes-status-dot");
  const hermesDotClass = "dot " + hermesStateClass;
  if (hermesDot.className !== hermesDotClass) {
    hermesDot.className = hermesDotClass;
  }
  el("hermes-status-label").textContent = up ? "ATIVO" : "INATIVO";
  const pidInfo = (h.processes && h.processes.length)
    ? "  ·  pid " + h.processes.map(p => p.pid).join(", ")
    : (h.process_alive ? "  ·  processo detectado" : "  ·  processo ausente");
  el("hermes-status-meta").textContent =
    (h.process_pattern || h.health_url || "(no target configured)") +
    pidInfo +
    "  ·  " + (h.consecutive_failures || 0) + " falhas  ·  ok " +
    fmtAgo(h.last_health_ok_ts, now) +
    (h.dashboard_url
      ? "  ·  dashboard " + (dashUp === false ? "offline" : dashUp ? "online" : "…") +
        " " + h.dashboard_url
      : "");
  hermesDashboardUp = dashUp;
  applyHermesLinks(h.dashboard_url || fallbackUrl, dashUp);
  if (h.dashboard_url) hermesDashboardUrl = h.dashboard_url;
  if (h.recovery_profile_id) {
    window._hermesRecoveryProfileId = h.recovery_profile_id;
    const pl = el("hermes-recovery-profile-link");
    if (pl && h.recovery_profile_url) pl.href = h.recovery_profile_url;
  }
  bindHermesRecoveryButtons();
  renderHermesRecoveryPanel({
    ok: true,
    profile_id: h.recovery_profile_id || "hermes-recovery",
    profile_installed: true,
    dashboard_url: h.dashboard_url,
    dashboard_up: dashUp,
    gateway_up: up,
    profile_url: h.recovery_profile_url,
  });
  renderHermesCron(h.cron || null);
}

function render(s) {
  const now = s.now || (Date.now() / 1000);
  const up  = !!s.up;

  const hermesLink = el("hdr-hermes");
  if (s.hermes) {
    hermesDashboardUp = s.hermes.dashboard_up;
    applyHermesLinks(
      s.hermes.dashboard_url || HERMES_DASHBOARD_URL,
      s.hermes.dashboard_up,
    );
  } else if (HERMES_DASHBOARD_URL) {
    hermesDashboardUp = null;
    applyHermesLinks(HERMES_DASHBOARD_URL, null);
  } else if (hermesLink) {
    hermesLink.style.display = "none";
  }

  renderServices(s);

  // big status
  const card = el("status-card");
  const stateClass = up ? "up" : "down";
  if (!card.classList.contains(stateClass)) {
    card.classList.remove("up", "down");
    card.classList.add(stateClass);
  }
  const statusDot = el("status-dot");
  const statusDotClass = "dot " + stateClass;
  if (statusDot.className !== statusDotClass) {
    statusDot.className = statusDotClass;
  }
  el("status-label").textContent = up ? "UP" : "DOWN";
  el("status-meta").textContent  = s.process_pattern || s.health_url || "(no target configured)";

  renderDiagnosis(s, now);
  renderHermesCronScheduler(s);
  renderHermes(s.hermes, now);

  // counters
  el("fail-cur").textContent = s.consecutive_failures ?? 0;
  el("fail-max").textContent = s.failure_threshold ?? "—";
  setBar("fail-bar", s.consecutive_failures || 0, s.failure_threshold || 1);

  el("rec-cur").textContent = s.recovery_attempts_this_run ?? 0;
  el("rec-max").textContent = s.max_recovery_attempts ?? "—";
  setBar("rec-bar", s.recovery_attempts_this_run || 0, s.max_recovery_attempts || 1);

  el("interval").textContent = s.monitor_interval_seconds ?? "—";
  el("cooldown").textContent = s.cooldown_seconds ?? "—";

  renderOpenclawToolsDial(s.openclaw_chat || null);

  const kb = s.kanban || {};
  const kbCard = el("kanban-card");
  if (kbCard && kb.default_team_id) {
    kbCard.style.display = "";
    el("kanban-default-team").textContent = kb.default_team_id;
    const kbLink = el("kanban-open-link");
    if (kbLink) kbLink.href = kb.url || ("/kanban?team=" + encodeURIComponent(kb.default_team_id));
  } else if (kbCard) {
    kbCard.style.display = "none";
  }

  // timeline
  el("t-ok").textContent   = fmtAgo(s.last_health_ok_ts, now)   + "  ·  " + fmtAbs(s.last_health_ok_ts);
  el("t-fail").textContent = fmtAgo(s.last_health_fail_ts, now) + "  ·  " + fmtAbs(s.last_health_fail_ts);
  el("t-rec").textContent  = fmtAgo(s.last_recovery_ts, now)    + "  ·  " + fmtAbs(s.last_recovery_ts);

  // config
  el("cfg-name").textContent = s.name || "—";
  el("cfg-proc").textContent = s.process_pattern || "(not set)";
  el("cfg-url").textContent  = s.health_url || "(not set)";

  // agents (live)
  renderAgentsUp(s.agents || [], now);
  _memo("procs", s.qclaw_processes || [], () => renderProcesses(s.qclaw_processes || [], now));
  _memo("memory", s.qclaw_memory || {}, () => renderMemory(s.qclaw_memory || {}));
  _memo("logsc", s.log_scanner || null, () => renderLogScanner(s.log_scanner || null, now));
  _memo("agents", s.agents || [], () => renderAgents(s.agents || [], now));

  // reaper
  const rp = s.reaper || {};
  el("rp-last").textContent = fmtAgo(rp.last_ts, now) + (rp.last_ts ? "  ·  " + fmtAbs(rp.last_ts) : "");
  el("rp-int").textContent  = rp.interval_seconds ?? "—";
  el("rp-en").textContent   = rp.enabled ? "yes" : "no";
  el("rp-zombies").textContent = rp.last_zombies ?? 0;
  el("rp-orphans").textContent = rp.last_orphans ?? 0;
  el("rp-killed").textContent  = rp.last_killed ?? 0;
  el("rp-pat").textContent = rp.target_pattern || "—";
  el("rp-sum").textContent = rp.last_summary || "—";
  const dt = el("rp-details");
  const details = rp.last_details || [];
  if (details.length) {
    dt.textContent = details.map(k => `${(k.signal||"?").padEnd(4)} pid=${k.pid}  ${k.command}`).join("\n");
    dt.classList.remove("empty");
  } else {
    dt.textContent = "no kills yet";
    dt.classList.add("empty");
  }

  // textual blocks
  const f = el("last-fail");
  const r = el("last-rec");
  if (s.last_failure_summary) { f.textContent = s.last_failure_summary; f.classList.remove("empty"); }
  else                         { f.textContent = "none"; f.classList.add("empty"); }
  if (s.last_recovery_report) { r.textContent = s.last_recovery_report; r.classList.remove("empty"); }
  else                         { r.textContent = "none"; r.classList.add("empty"); }

  // alerts
  _memo("alerts", s.alerting || null, () => renderAlerts(s.alerting || null, now));
}

function renderAlerts(alerting, now) {
  const card = el("alerts-card");
  const badge = el("alerts-badge");
  const tbody = el("alerts-body");
  const countBadge = el("alerts-count-badge");
  if (!alerting || !alerting.enabled || !alerting.alerts || !alerting.alerts.length) {
    if (card) card.hidden = true;
    if (badge) badge.style.display = "none";
    return;
  }
  card.hidden = false;
  const activeCount = alerting.active_alerts || 0;
  const alerts = alerting.alerts || [];
  if (badge) {
    badge.textContent = "🔔 " + activeCount;
    badge.style.display = "inline";
    badge.title = activeCount + " alerta(s) ativo(s)";
  }
  if (countBadge) {
    countBadge.textContent = activeCount + " ativo(s)  ·  últimos " + alerts.length + " exibidos";
  }
  tbody.innerHTML = alerts.map(function(a) {
    const ts = a.ts ? fmtAbs(a.ts) + " (" + fmtAgo(a.ts, now) + ")" : "—";
    const channels = [];
    if (a.channel_whatsapp) channels.push("📱");
    if (a.channel_webhook) channels.push("🔗");
    if (a.channel_log) channels.push("📝");
    const ch = channels.length ? channels.join(" ") : "—";
    const msg = escapeHtml(a.message || "");
    const rule = escapeHtml(a.rule || "?");
    const rowClass = a.cleared ? ' style="opacity:.5;"' : '';
    return '<tr' + rowClass + '>' +
      '<td><strong>' + rule + '</strong></td>' +
      '<td style="font-family:var(--mono);font-size:11px;color:var(--muted);white-space:nowrap;">' + ts + '</td>' +
      '<td style="font-family:var(--mono);font-size:12px;">' + msg + '</td>' +
      '<td>' + ch + '</td>' +
    '</tr>';
  }).join("");
}

async function clearAlerts() {
  try {
    const r = await fetch("/api/alerting/clear", { method: "POST" });
    if (!r.ok) throw new Error("HTTP " + r.status);
    if (window.qcmNavToast) window.qcmNavToast("Histórico de alertas limpo.");
    await poll();
  } catch (e) {
    if (window.qcmNavToast) window.qcmNavToast("Falha ao limpar alertas: " + e.message);
  }
}

let countdown = POLL_MS / 1000;
const RUFLO_POLL_MS = 15000;
let lastRufloPollAt = 0;

let pollInFlight = false;
let pollTimer = null;

function setStatusRetryVisible(visible) {
  const btn = el("status-retry-now");
  if (!btn) return;
  btn.hidden = !visible;
}

async function poll() {
  if (pollInFlight) return;
  if (document.hidden) { countdown = POLL_MS / 1000; return; }
  pollInFlight = true;
  try {
    // Guard against hanging connections so the dashboard does not stay in
    // perpetual "connecting" state with pollInFlight locked.
    const data = await monitorFetchJson("/status", {}, 12000);
    setStatusRetryVisible(false);
    render(data);
    const nowMs = Date.now();
    if (nowMs - lastRufloPollAt >= RUFLO_POLL_MS) {
      lastRufloPollAt = nowMs;
      void pollRufloAgentResults();
    }
    lastFetchOK = Date.now();
  } catch (e) {
    setStatusRetryVisible(true);
    renderOfflineConnectingFallback(e && e.message ? e.message : "erro de rede");
    const card = el("status-card");
    if (card) {
      card.classList.remove("up");
      card.classList.add("down");
    }
    const dot = el("status-dot");
    if (dot) dot.className = "dot down";
    const label = el("status-label");
    if (label) label.textContent = "OFFLINE";
    const meta = el("status-meta");
    if (meta) meta.textContent = "lost contact with monitor (" + e.message + ")";
    const diagCard = el("diagnosis-card");
    if (diagCard) diagCard.hidden = true;
  } finally {
    countdown = POLL_MS / 1000;
    pollInFlight = false;
  }
}

function schedulePoll() {
  if (pollTimer) clearTimeout(pollTimer);
  pollTimer = setTimeout(async () => {
    await poll();
    schedulePoll();
  }, POLL_MS);
}

document.addEventListener("visibilitychange", () => {
  if (!document.hidden) poll();
});

const statusRetryNowBtn = el("status-retry-now");
if (statusRetryNowBtn) {
  statusRetryNowBtn.addEventListener("click", async () => {
    if (pollInFlight) return;
    setStatusRetryVisible(false);
    await poll();
  });
}

el("poll").textContent = POLL_MS / 1000;
initHermesFromConfig();
initHermesTabs();
renderAuthNoticeFromRedirect();
poll();
void pollRufloAgentResults();
schedulePoll();
</script>
</body>
</html>
"""


def build_dashboard_html(
  hermes_dashboard_url: Optional[str] = None,
  *,
  active_nav: str = "monitor",
  default_hermes_tab: str = "ruflo",
  dashboard_render_config: Optional[dict] = None,
) -> str:
    """Embed static Hermes dashboard URL so the link works before /status is polled."""
    render_cfg = {
        "dynamic_chunking": True,
        "frame_budget_ms": 9,
        "base_chunk_size": 40,
        "agents_chunk_size": 35,
        "ruflo_agents_chunk_size": 30,
        "cron_chunk_size": 25,
    }
    if dashboard_render_config:
        render_cfg.update(dashboard_render_config)
    html = inject_hermes_cron_exec(
        HTML.replace(
            "__HERMES_DASHBOARD_URL__",
            json.dumps(hermes_dashboard_url or ""),
    ).replace(
      "__HERMES_DEFAULT_TAB__",
      json.dumps(default_hermes_tab or "ruflo"),
    ).replace(
      "__DASHBOARD_RENDER_CONFIG__",
      json.dumps(render_cfg),
    )
    )
    return _inject_app_nav(
        html,
    active_nav,
        hermes_dashboard_url=hermes_dashboard_url,
        show_monitor_extras=True,
    )


LOGIN_PAGE = r"""<!doctype html>
<html lang="pt-br">
<head>
<meta charset="utf-8">
<title>gois — login</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<style>
  :root {
    --bg: #0f1115; --panel: #171a21; --panel-2: #1e222c; --border: #262b36;
    --fg: #e6e8ee; --muted: #8a93a6; --bad: #ff5a5f; --accent: #6aa9ff;
    --mono: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }
  * { box-sizing: border-box; }
  html, body { margin: 0; min-height: 100%; background: var(--bg); color: var(--fg);
               font: 14px/1.45 -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; }
  main { min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 24px; }
  .login-card { width: min(400px, 100%); background: var(--panel); border: 1px solid var(--border);
                border-radius: 12px; padding: 28px 24px; }
  .login-brand { display: flex; align-items: center; gap: 12px; margin-bottom: 20px; }
  .login-brand svg { width: 48px; height: 48px; flex-shrink: 0; }
  .login-brand h1 { margin: 0; font-size: 20px; }
  .login-brand p { margin: 4px 0 0; color: var(--muted); font-size: 12px; }
  label { display: block; margin-bottom: 12px; font-size: 12px; color: var(--muted); }
  input { width: 100%; margin-top: 6px; padding: 10px 12px; border-radius: 8px;
          border: 1px solid var(--border); background: var(--panel-2); color: var(--fg); font: inherit; }
  input:focus { outline: none; border-color: var(--accent); }
  button { width: 100%; margin-top: 8px; padding: 12px; border: 0; border-radius: 8px;
           background: var(--accent); color: #0f1115; font-weight: 600; cursor: pointer; }
  button:hover { filter: brightness(1.05); }
  button[disabled] { opacity: .6; cursor: progress; }
  .msg { margin-top: 12px; font-size: 12px; font-family: var(--mono); color: var(--muted); min-height: 1.2em; }
  .msg.err { color: var(--bad); }
</style>
</head>
<body>
<main>
  <div class="login-card">
    <div class="login-brand">
      __GOIS_MASCOT_INLINE__
      <div>
        <h1>Gois</h1>
        <p>Entrar no gois</p>
      </div>
    </div>
    <form id="login-form">
      <label>Usuário
        <input type="text" name="username" id="login-user" autocomplete="username" required>
      </label>
      <label>Senha
        <input type="password" name="password" id="login-pass" autocomplete="current-password" required>
      </label>
      <button type="submit" id="login-btn">Entrar</button>
      <div class="msg" id="login-msg"></div>
    </form>
  </div>
</main>
<script>
(function () {
  const params = new URLSearchParams(window.location.search);
  const next = params.get("next") || "/";
  const form = document.getElementById("login-form");
  const msg = document.getElementById("login-msg");
  const btn = document.getElementById("login-btn");
  fetch("/auth/bootstrap", { cache: "no-cache" })
    .then((r) => r.json())
    .then((data) => {
      if (data && data.enabled === false) {
        window.location.replace(next);
      }
    })
    .catch(() => {});
  form.addEventListener("submit", async (ev) => {
    ev.preventDefault();
    btn.disabled = true;
    msg.className = "msg";
    msg.textContent = "Entrando…";
    try {
      const r = await fetch("/auth/login", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          username: document.getElementById("login-user").value.trim(),
          password: document.getElementById("login-pass").value.trim(),
        }),
      });
      const data = await r.json();
      if (!r.ok || data.ok === false) throw new Error(data.error || ("HTTP " + r.status));
      window.location.replace(next);
    } catch (e) {
      msg.className = "msg err";
      msg.textContent = e.message || "Falha no login";
      btn.disabled = false;
    }
  });
})();
</script>
</body>
</html>
"""


def build_login_html() -> str:
    return LOGIN_PAGE.replace("__GOIS_MASCOT_INLINE__", GOIS_MASCOT_SVG)


CHAT_PAGE = r"""<!doctype html>
<html lang="pt-br">
<head>
<meta charset="utf-8">
<title>gois — chat QClaw</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<style>
  :root {
    --bg: #0f1115;
    --panel: #171a21;
    --panel-2: #1e222c;
    --border: #262b36;
    --fg: #e6e8ee;
    --muted: #8a93a6;
    --ok: #3ddc84;
    --bad: #ff5a5f;
    --warn: #ffb454;
    --accent: #6aa9ff;
    --accent-dim: rgba(106,169,255,.12);
    --mono: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }
  @media (prefers-color-scheme: light) {
    :root { --bg:#f5f6fa; --panel:#fff; --panel-2:#f0f2f7; --border:#e1e4ec;
            --fg:#15171c; --muted:#5b6477; }
  }
  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; height: 100%; background: var(--bg); color: var(--fg);
               font: 14px/1.45 -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; }
  body { display: flex; flex-direction: column; overflow: hidden; }
  __APP_NAV_CSS__
  .layout { display: flex; flex: 1; min-height: 0; overflow: hidden; }
  .sidebar { width: 280px; flex-shrink: 0; background: var(--panel);
             border-right: 1px solid var(--border); display: flex; flex-direction: column; }
  .sidebar-head { padding: 14px 16px; border-bottom: 1px solid var(--border); }
  .sidebar-head h2 { margin: 0 0 4px; font-size: 12px; font-weight: 600;
                      color: var(--muted); text-transform: uppercase; letter-spacing: .8px; }
  .sidebar-head .sub { color: var(--muted); font-size: 12px; }
  .sidebar-tools { padding: 8px 12px; display: flex; gap: 8px; border-bottom: 1px solid var(--border); }
  button.ctrl { background: transparent; color: var(--muted); border: 1px solid var(--border);
                border-radius: 6px; padding: 6px 10px; font-size: 11px;
                font-family: var(--mono); cursor: pointer; }
  button.ctrl:hover { color: var(--fg); border-color: var(--accent); }
  button.ctrl.active { color: var(--accent); border-color: rgba(106,169,255,.35);
                      background: rgba(106,169,255,.10); }
  button.ctrl.danger { color: var(--bad); border-color: rgba(255,90,95,.35); }
  button.ctrl.danger:hover { color: var(--bad); border-color: var(--bad);
                             background: rgba(255,90,95,.10); }
  button.ctrl.danger[disabled] { opacity: .5; cursor: not-allowed; }
  .sidebar-tools button { flex: 1; }
  .sidebar-tools.secondary { padding-top: 0; }
  .session-search-wrap { padding: 8px 12px 0; border-bottom: 1px solid var(--border); }
  .session-search { width: 100%; background: var(--panel-2); color: var(--fg);
                     border: 1px solid var(--border); border-radius: 6px; padding: 8px 10px;
                     font: inherit; font-size: 12px; }
  .session-search:focus { outline: none; border-color: var(--accent); }
  .session-list { flex: 1; overflow: auto; padding: 6px 8px; }
  .session-row { display: flex; align-items: stretch; gap: 6px; margin-bottom: 4px; }
  .session-item { display: block; width: 100%; text-align: left; background: transparent;
                  border: 1px solid transparent; border-radius: 8px; color: var(--fg);
                  padding: 10px 12px; cursor: pointer; }
  .session-item:hover { background: var(--panel-2); border-color: var(--border); }
  .session-item.active { background: var(--accent-dim); border-color: rgba(106,169,255,.35); }
  .session-item.pending { border-color: rgba(255,193,7,.35); background: rgba(255,193,7,.06); }
  .session-item.pending:hover { border-color: rgba(255,193,7,.5); }
  .session-del { flex-shrink: 0; width: 34px; border: 1px solid transparent; border-radius: 8px;
                 background: transparent; color: var(--muted); cursor: pointer; }
  .session-del:hover { border-color: rgba(255,90,95,.35); color: var(--bad);
                       background: rgba(255,90,95,.10); }
  .session-del[disabled] { opacity: .5; cursor: progress; }
  .session-item .title { font-weight: 500; font-size: 13px; word-break: break-word; }
  .session-pending { display: inline-block; margin-top: 4px; padding: 2px 8px; border-radius: 999px;
                     font-size: 10px; font-family: var(--mono); color: #e6b84d;
                     border: 1px solid rgba(255,193,7,.35); background: rgba(255,193,7,.08); }
  .session-item .meta { margin-top: 4px; color: var(--muted); font-size: 11px; font-family: var(--mono); }
  .session-item .kind { display: inline-block; margin-top: 4px; padding: 2px 8px;
                        border-radius: 999px; font-size: 11px; font-family: var(--mono);
                        border: 1px solid var(--border); color: var(--muted);
                        background: var(--panel-2); }
  .main { flex: 1; display: flex; flex-direction: column; min-width: 0; background: var(--bg); }
  .main-head { padding: 14px 20px; border-bottom: 1px solid var(--border);
               display: flex; align-items: center; gap: 12px; flex-wrap: wrap; background: var(--panel); }
  .main-head .chat-title-wrap { display: flex; align-items: center; gap: 10px; flex: 1;
                                min-width: 120px; }
  .main-head h2 { margin: 0; font-size: 16px; font-weight: 600; flex: 1; min-width: 0;
                  word-break: break-word; }
  .main-head .chat-head-mascot { width: 40px; height: 40px; flex-shrink: 0;
                                 filter: drop-shadow(0 2px 6px rgba(0,0,0,.35)); }
  .main-head .chat-head-mascot svg { width: 100%; height: 100%; display: block; }
  .main-head .meta { color: var(--muted); font-size: 11px; font-family: var(--mono); }
  a.dash-link { color: var(--accent); text-decoration: none; font-size: 12px;
                font-weight: 600; padding: 4px 10px; border: 1px solid var(--accent);
                border-radius: 6px; white-space: nowrap; }
  a.dash-link:hover { background: rgba(106,169,255,.12); }
  .daily-cost-badge { display: inline-flex; align-items: center; gap: 4px;
                      padding: 4px 10px; border-radius: 6px; font-size: 12px;
                      font-family: var(--mono); font-weight: 600;
                      border: 1px solid var(--border); background: var(--panel-2);
                      color: var(--ok); white-space: nowrap; cursor: default;
                      transition: color .3s, border-color .3s; }
  .daily-cost-badge.warn { color: var(--warn); border-color: rgba(255,180,84,.35); }
  .daily-cost-badge.over { color: var(--bad); border-color: rgba(255,90,95,.35); }
  .daily-cost-icon { font-size: 13px; font-weight: 700; }
  .daily-cost-value { font-size: 12px; }
  .agent-select { background: var(--panel-2); color: var(--fg); border: 1px solid var(--border);
                  border-radius: 6px; padding: 6px 10px; font-size: 12px; font-family: var(--mono); }
  .agent-select:focus { outline: none; border-color: var(--accent); }
  .chat-log { flex: 1; overflow: auto; padding: 16px 20px; display: flex;
              flex-direction: column; gap: 8px; background: var(--panel-2);
              border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .chat-msg { max-width: 92%; padding: 8px 10px; border-radius: 8px; font-size: 13px;
              line-height: 1.45; white-space: pre-wrap; word-break: break-word; }
  .chat-msg.user { align-self: flex-end;
                   background: rgba(106,169,255,.12); border: 1px solid rgba(106,169,255,.25); }
  .chat-msg.bot { align-self: flex-start; display: flex; gap: 10px; align-items: flex-start;
                  max-width: min(92%, 680px); padding: 0; background: transparent; border: 0; }
  .chat-msg.bot .mascot-avatar { width: 36px; height: 36px; flex-shrink: 0;
                                 filter: drop-shadow(0 2px 4px rgba(0,0,0,.25)); }
  .chat-msg.bot .mascot-avatar svg { width: 100%; height: 100%; display: block; }
  .chat-msg.bot .bubble { flex: 1; min-width: 0; padding: 8px 10px; border-radius: 8px;
                          background: rgba(61,220,132,.08); border: 1px solid rgba(61,220,132,.22); }
  .chat-msg.bot .speaker { display: block; font-size: 11px; font-weight: 600; color: var(--muted);
                           margin-bottom: 4px; }
  .chat-msg.bot .body { white-space: pre-wrap; word-break: break-word; }
  .skill-badge { display: inline-flex; flex-wrap: wrap; gap: 4px; margin-bottom: 6px; }
  .skill-tag { display: inline-flex; align-items: center; gap: 3px;
               font-size: 10px; font-weight: 600; color: var(--accent);
               background: rgba(106,169,255,.12); border: 1px solid rgba(106,169,255,.30);
               border-radius: 10px; padding: 2px 8px; white-space: nowrap;
               letter-spacing: .2px; }
  .wacli-qr-wrap { margin-top: 12px; padding-top: 12px; border-top: 1px dashed var(--border); }
  .wacli-qr-wrap img.wacli-qr {
    display: block; width: min(220px, 100%); height: auto; margin: 0 auto;
    border-radius: 10px; background: #fff; padding: 10px;
    box-shadow: 0 4px 20px rgba(0,0,0,.25);
  }
  .wacli-pairing-ok { color: var(--ok) !important; }
  .wacli-qr-hint { margin: 10px 0 0; font-size: 11px; color: var(--muted); line-height: 1.45;
                   text-align: center; }
  .desktop-shot-wrap { margin-top: 12px; padding-top: 12px; border-top: 1px dashed var(--border); }
  .desktop-shot-wrap img.desktop-shot {
    display: block; max-width: 100%; max-height: 360px; border-radius: 8px;
    border: 1px solid var(--border); background: var(--panel-2); }
  .desktop-shot-caption { margin: 8px 0 0; font-size: 11px; color: var(--muted); }
  .chat-msg.status { align-self: center; max-width: 92%; font-size: 12px; line-height: 1.45;
                     color: var(--muted); background: rgba(106,169,255,.06);
                     border: 1px dashed rgba(106,169,255,.22); border-radius: 8px;
                     padding: 8px 12px; font-style: italic; white-space: pre-line; }
  .chat-msg.status.task-step { display: flex; flex-wrap: wrap; align-items: flex-start;
                               gap: 8px 10px; font-style: normal; }
  .chat-msg.status.task-step .task-body { flex: 1; min-width: 0; white-space: pre-line;
                                          font-style: italic; }
  .task-state { flex-shrink: 0; font-size: 10px; font-weight: 700; letter-spacing: .03em;
                text-transform: uppercase; padding: 3px 8px; border-radius: 999px;
                font-style: normal; line-height: 1.2; }
  .task-state--running { background: rgba(106,169,255,.22); color: #8ec0ff;
                         border: 1px solid rgba(106,169,255,.35); }
  .task-state--done { background: rgba(61,220,132,.14); color: var(--ok);
                      border: 1px solid rgba(61,220,132,.28); }
  .task-state--paused { background: rgba(255,196,80,.14); color: #e8b84a;
                        border: 1px solid rgba(255,196,80,.32); }
  .task-model { flex-shrink: 0; font-size: 10px; font-weight: 600; letter-spacing: .02em;
                padding: 3px 8px; border-radius: 999px; font-style: normal; line-height: 1.2;
                background: rgba(140,120,255,.16); color: #b8a8ff;
                border: 1px solid rgba(140,120,255,.28); }
  .tool-jobs-bar { font-size: 12px; color: var(--muted); padding: 6px 14px;
                   border-bottom: 1px solid var(--border); line-height: 1.45; }
  .tool-jobs-bar strong { color: var(--fg); font-style: normal; }
  .chat-msg.err { align-self: stretch; background: rgba(255,90,95,.10);
                  border: 1px solid rgba(255,90,95,.30); color: var(--bad); }
  .chat-msg .ts { display: block; margin-top: 6px; font-size: 11px; color: var(--muted);
                  font-family: var(--mono); }
  .chat-compose { padding: 14px 20px 18px; display: flex; flex-direction: column; gap: 8px;
                  background: var(--panel); }
  .chat-compose-row { display: flex; gap: 8px; align-items: flex-end; width: 100%; }
  .chat-compose textarea { flex: 1; min-height: 56px; max-height: 160px; resize: vertical;
                           background: var(--panel-2); color: var(--fg);
                           border: 1px solid var(--border); border-radius: 8px; padding: 10px 12px; font: inherit; }
  .chat-compose textarea:focus { outline: none; border-color: var(--accent); }
  .chat-compose button { background: var(--accent); color: #0b1220; border: 0;
                         border-radius: 8px; padding: 10px 14px; font-size: 12px;
                         font-weight: 600; cursor: pointer; }
  .chat-compose button.secondary { background: var(--panel-2); color: var(--fg);
                                   border: 1px solid var(--border); }
  .chat-compose button:hover { filter: brightness(1.05); }
  .chat-compose button[disabled] { opacity: .55; cursor: progress; }
  .chat-voice-btn.listening { background: rgba(255,90,95,.12) !important;
                              border-color: rgba(255,90,95,.35) !important;
                              color: var(--bad) !important; }
  .chat-conv-btn.active { background: rgba(61,220,132,.10) !important;
                          border-color: rgba(61,220,132,.35) !important;
                          color: var(--ok) !important; }
  .chat-compose-toolbar { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; width: 100%; }
  .chat-model-picker { display: inline-flex; align-items: center; gap: 8px; font-size: 12px;
                       flex: 1 1 220px; min-width: 0; }
  .chat-model-picker-label { color: var(--muted); font-weight: 600; white-space: nowrap; }
  .chat-model-picker .model-select { flex: 1; min-width: 10rem; max-width: min(320px, 100%); }
  .model-select { background: var(--panel-2); color: var(--fg); border: 1px solid var(--border);
                   border-radius: 6px; padding: 6px 8px; font: inherit; font-size: 12px; max-width: 100%; }
  .model-select:focus { outline: none; border-color: var(--accent); }
  .chat-attachments { display: flex; flex-wrap: wrap; gap: 6px; width: 100%; }
  .chat-attachment-chip { display: inline-flex; align-items: center; gap: 6px; font-size: 11px;
                          font-family: var(--mono); background: var(--panel-2); color: var(--muted);
                          border: 1px solid var(--border); border-radius: 999px; padding: 4px 8px; }
  .chat-attachment-chip button { background: transparent; border: 0; color: var(--bad); cursor: pointer;
                                  font-size: 14px; line-height: 1; padding: 0 2px; }
  .chat-msg .attachment-list { margin-top: 8px; font-size: 11px; color: var(--muted);
                               font-family: var(--mono); }
  .chat-msg .attachment-list span { display: inline-block; margin-right: 8px; }
  .empty { color: var(--muted); font-style: italic; font-size: 13px; padding: 20px; text-align: center; }
  .status-bar { font-size: 11px; color: var(--muted); font-family: var(--mono);
                padding: 6px 20px 0; background: var(--panel); }
  /* Team badge & modal */
  .session-team-badge { display: inline-block; margin-top: 3px; padding: 2px 7px; border-radius: 999px;
                        font-size: 10px; font-family: var(--mono); color: var(--accent);
                        border: 1px solid rgba(106,169,255,.3); background: rgba(106,169,255,.08); }
  .session-team-badge.unassigned { color: var(--warn); border-color: rgba(255,180,84,.35);
                                   background: rgba(255,180,84,.08); }
  .chat-team-indicator { display: inline-flex; align-items: center; gap: 6px; font-size: 12px;
                         color: var(--accent); font-family: var(--mono); cursor: pointer;
                         padding: 4px 10px; border: 1px solid rgba(106,169,255,.3); border-radius: 6px; }
  .chat-team-indicator:hover { background: rgba(106,169,255,.08); }
  .chat-team-indicator.warn { color: var(--warn); border-color: rgba(255,180,84,.35); }
  .chat-team-indicator.warn:hover { background: rgba(255,180,84,.08); }
  .team-modal-overlay { position: fixed; inset: 0; z-index: 9999; background: rgba(0,0,0,.55);
                        display: flex; align-items: center; justify-content: center; }
  .team-modal { background: var(--panel); border: 1px solid var(--border); border-radius: 12px;
                padding: 24px; width: 90%; max-width: 400px; box-shadow: 0 8px 40px rgba(0,0,0,.5); }
  .team-modal h3 { margin: 0 0 12px; font-size: 16px; }
  .team-modal p { color: var(--muted); font-size: 13px; margin: 0 0 16px; }
  .team-modal .team-list { max-height: 200px; overflow-y: auto; margin-bottom: 12px; }
  .team-modal .team-option { display: block; width: 100%; text-align: left; background: transparent;
                             border: 1px solid var(--border); border-radius: 8px; padding: 10px 14px;
                             color: var(--fg); cursor: pointer; margin-bottom: 6px; font-size: 13px; }
  .team-modal .team-option:hover { background: var(--accent-dim); border-color: rgba(106,169,255,.35); }
  .team-modal .team-create-row { display: flex; gap: 8px; margin-top: 8px; }
  .team-modal .team-create-row input { flex: 1; background: var(--panel-2); color: var(--fg);
                                        border: 1px solid var(--border); border-radius: 6px;
                                        padding: 8px 10px; font: inherit; font-size: 12px; }
  .team-modal .team-create-row input:focus { outline: none; border-color: var(--accent); }
  .team-modal-footer { display: flex; gap: 8px; justify-content: flex-end; margin-top: 12px; }
  .skills-panel { width: 300px; flex-shrink: 0; background: var(--panel);
                  border-left: 1px solid var(--border); display: flex; flex-direction: column; }
  .skills-head { padding: 14px 16px; border-bottom: 1px solid var(--border); }
  .skills-head h3 { margin: 0 0 8px; font-size: 12px; font-weight: 600;
                     color: var(--muted); text-transform: uppercase; letter-spacing: .8px; }
  .skills-head .count { color: var(--muted); font-size: 11px; font-family: var(--mono); margin-bottom: 8px; }
  .skills-search { width: 100%; background: var(--panel-2); color: var(--fg);
                    border: 1px solid var(--border); border-radius: 6px; padding: 8px 10px;
                    font: inherit; font-size: 12px; margin-bottom: 8px; }
  .skills-search:focus { outline: none; border-color: var(--accent); }
  .skills-filter { display: flex; gap: 6px; }
  .skills-filter button { flex: 1; }
  .skills-used-panel {
    margin: 0 8px 8px; padding: 10px 12px; border-radius: 8px;
    background: rgba(61,220,132,.06); border: 1px solid rgba(61,220,132,.30);
    font-size: 11px; line-height: 1.4;
  }
  .skills-used-panel h4 { margin: 0 0 6px; font-size: 11px; color: var(--ok);
                          text-transform: uppercase; letter-spacing: .6px; font-weight: 600; }
  .skills-used-panel .skills-used-count { color: var(--muted); font-size: 10px;
                                          font-family: var(--mono); margin-bottom: 6px; }
  .skills-used-list { display: flex; flex-wrap: wrap; gap: 4px; }
  .skills-used-tag { display: inline-flex; align-items: center; gap: 4px; padding: 3px 8px;
                     border-radius: 999px; background: rgba(61,220,132,.10);
                     border: 1px solid rgba(61,220,132,.30); color: var(--ok);
                     font-size: 10px; font-family: var(--mono); font-weight: 500;
                     cursor: default; transition: background .15s; }
  .skills-used-tag:hover { background: rgba(61,220,132,.18); }
  .skills-used-tag .uses { color: var(--muted); font-weight: 400; margin-left: 2px; }
  .skill-suggestions {
    margin: 0 8px 8px; padding: 10px 12px; border-radius: 8px;
    background: rgba(106,169,255,.08); border: 1px solid rgba(106,169,255,.35);
    font-size: 11px; line-height: 1.4;
  }
  .skill-suggestions[hidden] { display: none !important; }
  .skill-suggestions h4 { margin: 0 0 6px; font-size: 11px; color: var(--accent); }
  .skill-suggestions .hint { color: var(--muted); margin-bottom: 8px; }
  .skill-suggestion-item {
    display: flex; gap: 8px; align-items: flex-start; padding: 6px 0;
    border-top: 1px solid rgba(106,169,255,.15);
  }
  .skill-suggestion-item:first-of-type { border-top: none; padding-top: 0; }
  .skill-suggestion-item .meta { flex: 1; min-width: 0; }
  .skill-suggestion-item .name { font-family: var(--mono); color: var(--fg); font-weight: 600; }
  .skill-suggestion-item .reason { color: var(--muted); margin-top: 2px; }
  .skill-suggestion-actions { display: flex; gap: 6px; margin-top: 8px; flex-wrap: wrap; }
  .skill-suggestion-actions button { font-size: 11px; padding: 4px 8px; }
  .skills-list { flex: 1; overflow: auto; padding: 6px 8px; }
  .skill-item { display: block; width: 100%; text-align: left; background: transparent;
                border: 1px solid transparent; border-radius: 8px; color: var(--fg);
                padding: 8px 10px; cursor: pointer; margin-bottom: 4px; }
  .skill-item:hover { background: var(--panel-2); border-color: var(--border); }
  .skill-item .name { font-size: 11px; font-weight: 500; font-family: var(--mono); color: var(--accent); }
  .skill-item .desc { margin-top: 3px; font-size: 11px; color: var(--muted); line-height: 1.35;
                      display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .badge { display: inline-block; margin-top: 4px; padding: 2px 8px; border-radius: 999px;
           background: var(--panel-2); border: 1px solid var(--border);
           color: var(--muted); font-size: 11px; font-family: var(--mono); }
  .badge.ok { color: var(--ok); border-color: rgba(61,220,132,.35); background: rgba(61,220,132,.08); }
  /* Memory modal */
  .memory-modal { position: fixed; inset: 0; z-index: 1100; display: flex;
                  align-items: center; justify-content: center; }
  .memory-modal[hidden] { display: none; }
  .memory-modal-backdrop { position: absolute; inset: 0; background: rgba(0,0,0,.55); }
  .memory-modal-dialog { position: relative; width: min(880px, 96vw); height: min(86vh, 760px);
                         background: var(--panel); border: 1px solid var(--border);
                         border-radius: 12px; display: flex; flex-direction: column;
                         box-shadow: 0 10px 40px rgba(0,0,0,.45); overflow: hidden; }
  .memory-modal-header { display: flex; align-items: center; justify-content: space-between;
                         padding: 14px 18px; border-bottom: 1px solid var(--border); gap: 10px; }
  .memory-modal-header h2 { margin: 0; font-size: 16px; }
  .memory-modal-header .sub { color: var(--muted); font-size: 12px; }
  .memory-modal-close { background: transparent; border: 0; color: var(--muted);
                        font-size: 22px; cursor: pointer; line-height: 1; padding: 4px 8px; }
  .memory-modal-close:hover { color: var(--fg); }
  .memory-modal-body { flex: 1; min-height: 0; padding: 14px 18px 18px; overflow-y: auto;
                       display: flex; flex-direction: column; gap: 12px; }
  .memory-stat { font-size: 14px; color: var(--fg); }
  .memory-stat strong { color: var(--accent); }
  .memory-kinds { display: flex; flex-wrap: wrap; gap: 6px; }
  .memory-chip { background: var(--panel-2); border: 1px solid var(--border);
                 color: var(--muted); border-radius: 999px; padding: 2px 8px;
                 font-size: 11px; font-family: var(--mono); }
  .memory-status { font-size: 12px; color: var(--muted); font-family: var(--mono); }
  .memory-sessions { display: flex; flex-direction: column; gap: 8px; }
  .memory-session { background: var(--panel-2); border: 1px solid var(--border);
                    border-radius: 8px; padding: 8px 12px; }
  .memory-session > summary { cursor: pointer; list-style: none; display: flex;
                              align-items: baseline; gap: 10px; flex-wrap: wrap; }
  .memory-session > summary::-webkit-details-marker { display: none; }
  .memory-session > summary::before { content: '\25B8'; color: var(--muted); margin-right: 4px;
                                      transition: transform .15s ease; display: inline-block; }
  .memory-session[open] > summary::before { transform: rotate(90deg); }
  .memory-session-title { font-weight: 600; color: var(--fg); }
  .memory-session-meta { color: var(--muted); font-size: 11px; font-family: var(--mono); }
  .memory-facts { margin-top: 8px; display: flex; flex-direction: column; gap: 6px; }
  .memory-fact { display: flex; gap: 8px; align-items: flex-start;
                 padding: 6px 8px; background: var(--panel); border: 1px solid var(--border);
                 border-radius: 6px; }
  .memory-fact-kind { background: rgba(106,169,255,.12); color: var(--accent);
                      border-radius: 4px; padding: 1px 6px; font-size: 10px;
                      font-family: var(--mono); flex-shrink: 0; text-transform: uppercase; }
  .memory-fact-text { font-size: 12px; color: var(--fg); white-space: pre-wrap; word-break: break-word; }
  .memory-fact-more { color: var(--muted); font-size: 11px; font-style: italic; padding: 4px 6px; }
  .memory-refresh { background: var(--panel-2); color: var(--accent);
                    border: 1px solid var(--border); border-radius: 6px; padding: 4px 10px;
                    font-size: 11px; font-family: var(--mono); cursor: pointer; }
  .memory-refresh:hover { border-color: var(--accent); }
  .project-fact-delete { flex-shrink: 0; background: transparent; border: 0;
                         color: var(--muted); font-size: 18px; cursor: pointer;
                         line-height: 1; padding: 0 4px; }
  .project-fact-delete:hover { color: var(--err, #e55); }
  @media (max-width: 900px) {
    .skills-panel { display: none; }
  }
</style>
</head>
<body>
__APP_NAV__
<div class="layout">
  <aside class="sidebar" id="openclaw-section">
    <div class="sidebar-head">
      <h2>OpenClaw</h2>
      <div class="sub">Sessões do agente</div>
    </div>
    <div class="sidebar-tools">
      <button type="button" class="ctrl" id="btn-refresh-sessions">Atualizar</button>
      <button type="button" class="ctrl" id="btn-new-chat">Nova conversa</button>
      <button type="button" class="ctrl" id="btn-open-memory" title="Ver memória armazenada sobre você">Memória</button>
      <button type="button" class="ctrl" id="btn-open-project" title="Memória do projeto (todas as conversas)">Projeto</button>
    </div>
    <div class="sidebar-tools secondary">
      <button type="button" class="ctrl danger" id="btn-delete-old-sessions"
              title="Apaga conversas sem atividade há mais de 30 dias">Deletar antigas</button>
      <button type="button" class="ctrl danger" id="btn-delete-all-sessions"
              title="Apaga todas as conversas da lista (sessões protegidas são mantidas)">Deletar todas</button>
    </div>
    <div class="session-search-wrap">
      <input type="search" class="session-search" id="session-search"
             placeholder="Buscar conversa…" autocomplete="off">
    </div>
    <div class="session-list" id="session-list">
      <div class="empty">Carregando sessões…</div>
    </div>
  </aside>
  <section class="main">
    <header class="main-head">
      <div class="chat-title-wrap">
        <span class="chat-head-mascot" id="chat-head-mascot" aria-hidden="false" aria-label="Gois">__GOIS_MASCOT_INLINE__</span>
        <h2 id="chat-title">OpenClaw — selecione uma conversa</h2>
      </div>
      <select class="agent-select" id="agent-select" title="Agente OpenClaw">
        <option value="main">main</option>
      </select>
      <span class="meta" id="chat-meta"></span>
      <span class="meta" id="chat-backend"></span>
      <span class="meta" id="chat-tools-config" title="Limite de chamadas de ferramentas por mensagem"></span>
      <span class="chat-team-indicator warn" id="chat-team-indicator" hidden title="Time alocado a esta conversa">⚠ Sem time</span>
      <span class="daily-cost-badge" id="daily-cost-badge" title="Consumo diário estimado em USD">
        <span class="daily-cost-icon">$</span>
        <span class="daily-cost-value" id="daily-cost-value">—</span>
      </span>
      <a href="#" class="dash-link" id="openclaw-control" target="_blank" rel="noopener" style="display:none">OpenClaw UI</a>
    </header>
    <div class="status-bar" id="chat-status"></div>
    <div class="tool-jobs-bar" id="chat-tool-jobs" hidden></div>
    <div class="chat-log" id="chat-log">
      <div class="empty">Escolha uma sessão à esquerda ou inicie uma nova conversa.</div>
    </div>
    <div class="chat-compose">
      <div class="chat-compose-toolbar">
        <label class="chat-model-picker" for="chat-team-select">
          <span class="chat-model-picker-label">Time</span>
          <select class="model-select" id="chat-team-select" title="Time alocado a esta conversa">
            <option value="">Sem time</option>
          </select>
        </label>
        <label class="chat-model-picker" id="chat-model-picker-wrap" for="model-select">
          <span class="chat-model-picker-label">Modelo</span>
          <select class="model-select" id="model-select" title="Escolher modelo LLM">
            <option value="deepseek-chat">DeepSeek Chat</option>
          </select>
        </label>
        <label class="chat-model-picker" for="chat-brief-target">
          <span class="chat-model-picker-label">Saída</span>
          <select class="model-select" id="chat-brief-target" title="Estruturar a resposta para um alvo">
            <option value="auto">Auto</option>
            <option value="agent">Agente</option>
            <option value="kanban">Kanban</option>
            <option value="task">Task</option>
          </select>
        </label>
        <input type="file" id="chat-attachment-input" multiple hidden
               accept="image/*,audio/*,.mp3,.m4a,.wav,.webm,.ogg,.aac,.flac,.txt,.md,.json,.yaml,.yml,.py,.js,.ts,.tsx,.jsx,.sh,.sql,.html,.css,.xml,.csv,.log,.pdf">
        <button type="button" class="secondary" id="chat-attach-btn" title="Anexar ficheiros de texto, imagem ou áudio">Anexar</button>
        <button type="button" class="secondary" id="chat-tts-toggle" title="Ler respostas em voz alta">Fala: off</button>
        <span class="meta" id="chat-model-hint">Anexe áudio longo para transcrever e transformar em instruções.</span>
      </div>
      <div class="chat-attachments" id="chat-attachments" hidden></div>
      <div class="chat-compose-row">
        <textarea id="chat-input" rows="3" placeholder="Descreva a tarefa — pode anexar imagens, áudio ou ficheiros de texto…"></textarea>
        <button type="button" class="secondary chat-conv-btn" id="chat-conversation-mode"
                title="Ditado com envio automático">Modo conversa: off</button>
        <button type="button" class="secondary chat-voice-btn" id="chat-voice-btn"
                title="Falar com microfone">🎙️ Falar</button>
        <button type="button" id="chat-send">Enviar</button>
      </div>
    </div>
  </section>
  <aside class="skills-panel">
    <div class="skills-head">
      <h3>Skills OpenClaw</h3>
      <div class="count" id="skills-count">carregando…</div>
      <input type="search" class="skills-search" id="skills-search" placeholder="Buscar skill…">
      <div class="skills-filter">
        <button type="button" class="ctrl active" data-filter="all">Todas</button>
        <button type="button" class="ctrl" data-filter="assigned">Do agente</button>
      </div>
    </div>
    <div class="skills-used-panel" id="skills-used-panel">
      <h4>🧩 Usadas neste chat</h4>
      <div class="skills-used-count" id="skills-used-count">nenhuma ainda</div>
      <div class="skills-used-list" id="skills-used-list"></div>
    </div>
    <div class="skill-suggestions" id="skill-suggestions" hidden>
      <h4>Sugestões de skills</h4>
      <div class="hint" id="skill-suggestions-hint">Novas skills encontradas para o seu stack.</div>
      <div id="skill-suggestions-list"></div>
      <div class="skill-suggestion-actions">
        <button type="button" class="ctrl" id="skill-suggestions-refresh">Atualizar agora</button>
        <button type="button" class="ctrl" id="skill-suggestions-dismiss-all">Dispensar todas</button>
      </div>
    </div>
    <div class="skills-list" id="skills-list">
      <div class="empty">Carregando skills…</div>
    </div>
  </aside>
</div>
<script>
const DEFAULT_GOIS_MASCOT_SVG = __GOIS_MASCOT_SVG__;
const HERMES_DASHBOARD_URL = __HERMES_DASHBOARD_URL__;
const el = (id) => document.getElementById(id);
const _renderFp = {};
function _memo(key, value, fn) {
  let fp;
  try { fp = JSON.stringify(value); } catch (e) { fp = String(Math.random()); }
  if (_renderFp[key] === fp) return;
  _renderFp[key] = fp;
  fn();
}

function invalidateMessagesCache() {
  delete _renderFp["messages"];
}

function invalidateSessionsCache() {
  delete _renderFp["sessions"];
}

function normalizeSessionsList(raw) {
  if (Array.isArray(raw)) return raw.slice();
  return [];
}

function showChatBootstrapError(msg) {
  const text = String(msg || "Falha ao iniciar o chat");
  const list = el("session-list");
  const skills = el("skills-list");
  const status = el("chat-status");
  if (list) {
    list.innerHTML = '<div class="empty">' + escapeHtml(text) + "</div>";
  }
  if (skills) {
    skills.innerHTML = '<div class="empty">' + escapeHtml(text) + "</div>";
  }
  if (status) status.textContent = "";
  const count = el("skills-count");
  if (count) count.textContent = "";
}

let sessions = [];
let skills = [];
let skillsFilter = "all";
let skillsQuery = "";
let activeKey = null;
let activeAgent = "main";
let defaultSessionKey = null;
let defaultAgent = "main";
let knownAgents = ["main"];
let mascotSvgById = {};
let chatBackend = "deepseek";
let chatModels = [];
let activeModelId = "deepseek-chat";
const CHAT_DEFAULT_MODEL = "deepseek-chat";
const V4_FLASH_MODEL = "deepseek-v4-flash";
let userExplicitModelPick = false;
let chatAttachments = [];
let maxChatAttachments = 6;
let maxChatAttachmentBytes = 8388608;
let sessionSource = "openclaw";
let hermesDashboardUrl = HERMES_DASHBOARD_URL || "";
let controlUrl = null;
let pollTimer = null;
let chatPollInFlight = false;
let chatPollTick = 0;
let newChatBusy = false;
let sessionQuery = "";
let chatConversationMode = false;
let chatVoiceRecognizer = null;
let chatVoiceListening = false;
let lastChatSkillsUsed = null;
const chatSkillsUsedMap = new Map(); // skill_name -> usage_count for current session
let chatVoiceBaseText = "";
let chatVoiceManualStop = false;
let chatVoiceRestartTimer = null;
let chatTtsEnabled = false;
let chatLastSpokenFingerprint = "";

// --- Team allocation for chat sessions ---
let chatTeams = []; // [{id, name, ...}]
let chatTeamsLoaded = false;

async function loadChatTeams() {
  if (chatTeamsLoaded) return chatTeams;
  try {
    const { data } = await chatFetchJson("/teams", { method: "GET" }, 10000);
    if (data.ok && Array.isArray(data.teams)) {
      chatTeams = data.teams.sort((a, b) => (a.name || "").localeCompare(b.name || ""));
      chatTeamsLoaded = true;
      renderChatTeamSelect();
    }
  } catch (_) {}
  return chatTeams;
}

function getSessionTeamName(session) {
  if (!session || !session.team_id) return null;
  const t = chatTeams.find(t => t.id === session.team_id);
  return t ? t.name : session.team_id;
}

function renderChatTeamSelect() {
  const sel = el("chat-team-select");
  if (!sel) return;
  const current = sel.value;
  sel.innerHTML = '<option value="">Sem time</option>' +
    chatTeams.map(t =>
      '<option value="' + escapeHtml(t.id) + '">' + escapeHtml(t.name) + '</option>'
    ).join("");
  // Sync with active session's team
  const sess = sessions.find(s => s.key === activeKey);
  if (sess && sess.team_id) {
    sel.value = sess.team_id;
  } else if (current) {
    sel.value = current;
  }
}

function getSelectedChatTeamId() {
  const sel = el("chat-team-select");
  return sel ? sel.value || null : null;
}

function showTeamModal(sessionKey, opts) {
  opts = opts || {};
  const onAssign = opts.onAssign || function() {};
  const overlay = document.createElement("div");
  overlay.className = "team-modal-overlay";
  overlay.innerHTML = '<div class="team-modal">' +
    '<h3>Alocar conversa a um time</h3>' +
    '<p>Toda conversa precisa pertencer a um time. Escolha um time existente ou crie um novo.</p>' +
    '<div class="team-list" id="team-modal-list">Carregando times…</div>' +
    '<div class="team-create-row">' +
    '<input type="text" id="team-modal-new-name" placeholder="Nome do novo time…" />' +
    '<button type="button" class="ctrl" id="team-modal-create-btn">Criar</button>' +
    '</div>' +
    '<div class="team-modal-footer">' +
    '<button type="button" class="ctrl" id="team-modal-cancel">Cancelar</button>' +
    '</div>' +
    '</div>';
  document.body.appendChild(overlay);

  overlay.querySelector("#team-modal-cancel").addEventListener("click", () => {
    overlay.remove();
  });
  overlay.addEventListener("click", (e) => {
    if (e.target === overlay) overlay.remove();
  });

  loadChatTeams().then((teams) => {
    const listEl = overlay.querySelector("#team-modal-list");
    if (!teams.length) {
      listEl.innerHTML = '<div class="empty">Nenhum time encontrado. Crie um abaixo.</div>';
    } else {
      listEl.innerHTML = teams.map(t =>
        '<button type="button" class="team-option" data-team-id="' + escapeHtml(t.id) + '">' +
        escapeHtml(t.name) + '</button>'
      ).join("");
      listEl.querySelectorAll(".team-option").forEach(btn => {
        btn.addEventListener("click", async () => {
          await assignTeamToSession(sessionKey, btn.dataset.teamId);
          overlay.remove();
          onAssign(btn.dataset.teamId);
        });
      });
    }
  });

  overlay.querySelector("#team-modal-create-btn").addEventListener("click", async () => {
    const nameInput = overlay.querySelector("#team-modal-new-name");
    const name = (nameInput.value || "").trim();
    if (!name) { nameInput.focus(); return; }
    try {
      const { data } = await chatFetchJson("/teams", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ name: name }),
      }, 15000);
      if (data.ok && data.team) {
        chatTeams.push(data.team);
        await assignTeamToSession(sessionKey, data.team.id);
        overlay.remove();
        onAssign(data.team.id);
      } else {
        alert(data.error || "Erro ao criar time");
      }
    } catch (e) {
      alert("Erro: " + (e.message || e));
    }
  });
}

async function assignTeamToSession(sessionKey, teamId) {
  try {
    const { data } = await chatFetchJson("/openclaw/session/assign-team", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ session_key: sessionKey, team_id: teamId }),
    }, 10000);
    if (data.ok) {
      // Update local session data
      const sess = sessions.find(s => s.key === sessionKey);
      if (sess) sess.team_id = teamId;
      renderSessions();
      updateChatTeamIndicator();
    }
    return data;
  } catch (e) {
    return { ok: false, error: e.message };
  }
}

function updateChatTeamIndicator() {
  const indicator = el("chat-team-indicator");
  if (!indicator) return;
  const sess = sessions.find(s => s.key === activeKey);
  if (!sess) { indicator.hidden = true; return; }
  indicator.hidden = false;
  if (sess.team_id) {
    const name = getSessionTeamName(sess) || sess.team_id;
    indicator.textContent = "🏷 " + name;
    indicator.className = "chat-team-indicator";
  } else {
    indicator.textContent = "⚠ Sem time — clique para alocar";
    indicator.className = "chat-team-indicator warn";
  }
  renderChatTeamSelect();
}
let chatTtsAudio = null;
let chatTtsObjectUrl = null;
const pendingSends = new Map();
const pendingOptimisticBySession = new Map();
const OPTIMISTIC_NEW_CHAT = "__pending_new_chat__";
const lastMessagesByKey = new Map();
const chatJobPolls = new Set();
const PENDING_STORAGE_KEY = "qcm_chat_pending";
const PENDING_MAX_AGE_MS = 2 * 60 * 60 * 1000;
const CHAT_POLL_BUSY_MS = 2500;
const CHAT_JOB_POLL_MS = 900;
const CHAT_MSG_RELOAD_MS = 2500;
const CHAT_POLL_WHATSAPP_MS = 4000;
const CHAT_POLL_HIDDEN_MS = 20000;
const CHAT_HTTP_MAX = 3;
let lastGlobalToolJobsCount = 0;
let whatsappWatchKey = null;
const messagesLoadInFlight = new Set();
let messagesLoadSeq = 0;
let chatHttpInFlight = 0;
const chatHttpWaiters = [];

function isWhatsappSessionKey(key) {
  if (!key) return false;
  if (String(key).includes(":whatsapp:")) return true;
  return !!(whatsappWatchKey && key === whatsappWatchKey);
}

function chatPollIntervalMs() {
  if (pendingSends.size > 0 || lastGlobalToolJobsCount > 0) return CHAT_POLL_BUSY_MS;
  if (activeKey && isWhatsappSessionKey(activeKey)) return CHAT_POLL_WHATSAPP_MS;
  return CHAT_POLL_BUSY_MS;
}

function renderToolJobsBar(toolPayload) {
  const bar = el("chat-tool-jobs");
  if (!bar) return;
  const jobs = (toolPayload && toolPayload.jobs) || [];
  if (!jobs.length) {
    bar.hidden = true;
    bar.textContent = "";
    return;
  }
  bar.hidden = false;
  const parts = jobs.map((j) => {
    const name = escapeHtml(String(j.label || j.sessionKey || "?"));
    const model = j.modelLabel
      ? " <span class=\"task-model\">" + escapeHtml(String(j.modelLabel)) + "</span>"
      : "";
    const turn = Number(j.turn) || 0;
    const max = Number(j.maxTurns) || "?";
    return name + model + " " + turn + "/" + max;
  });
  bar.innerHTML = "<strong>Ferramentas em execução</strong> — " + parts.join(" · ");
}

async function pollGlobalToolJobs() {
  try {
    const { data } = await chatFetchJson("/openclaw/tool-jobs", {}, 12000);
    if (!data.ok) return;
    renderToolJobsBar(data);
    const count = Number(data.activeCount) || 0;
    if (lastGlobalToolJobsCount > 0 && count < lastGlobalToolJobsCount) {
      const msg = count
        ? "Ferramentas libertadas — " + count + " job(s) ainda em execução."
        : "Ferramentas disponíveis — nenhum job a usar ferramentas agora.";
      if (activeKey && (isSessionPending(activeKey) || pendingSends.size > 0)) {
        void loadMessages(activeKey, activeAgent, { silent: true }).catch(() => {});
      } else if (window.qcmNavToast) {
        window.qcmNavToast(msg);
      }
    }
    lastGlobalToolJobsCount = count;
  } catch (_) { /* ignore */ }
}

// After send timeout (11 min) + buffer — unlock Enviar if the browser never got a reply.
const PENDING_STALE_MS = 12 * 60 * 1000;
function loadPendingFromStorage() {
  try {
    const raw = localStorage.getItem(PENDING_STORAGE_KEY);
    if (!raw) return;
    const obj = JSON.parse(raw);
    if (!obj || typeof obj !== "object") return;
    const now = Date.now();
    const rows = [];
    for (const [key, meta] of Object.entries(obj)) {
      if (!key || !meta || typeof meta !== "object") continue;
      const startedAt = Number(meta.startedAt) || 0;
      if (startedAt && now - startedAt > PENDING_MAX_AGE_MS) continue;
      rows.push({
        key,
        startedAt: startedAt || now,
        preview: String(meta.preview || "").slice(0, 200),
        agent: meta.agent ? String(meta.agent) : "",
        jobId: meta.jobId ? String(meta.jobId) : "",
      });
    }
    rows.sort((a, b) => b.startedAt - a.startedAt);
    for (const row of rows.slice(0, 3)) {
      pendingSends.set(row.key, {
        preview: row.preview,
        startedAt: row.startedAt,
        agent: row.agent,
        jobId: row.jobId || "",
      });
    }
    savePendingToStorage();
  } catch (_) {
    // ignore corrupt storage
  }
}

function savePendingToStorage() {
  try {
    const obj = {};
    for (const [key, meta] of pendingSends) {
      obj[key] = meta;
    }
    if (!Object.keys(obj).length) {
      localStorage.removeItem(PENDING_STORAGE_KEY);
      return;
    }
    localStorage.setItem(PENDING_STORAGE_KEY, JSON.stringify(obj));
  } catch (_) {
    // private mode / quota
  }
}

function markSessionPending(key, agent, preview, jobId) {
  if (!key) return;
  const prev = pendingSends.get(key) || {};
  pendingSends.set(key, {
    preview: String(preview || prev.preview || "").slice(0, 200),
    startedAt: Number(prev.startedAt) || Date.now(),
    agent: agent || prev.agent || "",
    jobId: jobId ? String(jobId) : (prev.jobId || ""),
  });
  savePendingToStorage();
  ensureMessagesPoll();
}

function clearSessionPending(key) {
  if (!key || !pendingSends.delete(key)) return;
  savePendingToStorage();
  stopMessagesPollIfIdle();
  if (chatConversationMode && key === activeKey) {
    scheduleChatVoiceStart(600);
  }
}

function isSessionPending(key) {
  const meta = pendingSends.get(key);
  if (!meta) return false;
  const age = Date.now() - (Number(meta.startedAt) || 0);
  if (age > PENDING_STALE_MS) {
    clearSessionPending(key);
    return false;
  }
  return true;
}

function updateSendButtonState() {
  const btn = el("chat-send");
  if (!btn) return;
  const pending = !!(activeKey && isSessionPending(activeKey));
  const input = el("chat-input");
  const hasText = !!(input && (input.value || "").trim());
  const hasAttachments = chatAttachments.length > 0;
  btn.disabled = pending || (!hasText && !hasAttachments);
}

function chatVoiceSupported() {
  return typeof window !== "undefined" &&
    ("SpeechRecognition" in window || "webkitSpeechRecognition" in window);
}

function updateChatVoiceUi() {
  const voiceBtn = el("chat-voice-btn");
  const convBtn = el("chat-conversation-mode");
  const pending = !!(activeKey && isSessionPending(activeKey));
  if (voiceBtn) {
    if (!chatVoiceSupported()) {
      voiceBtn.disabled = true;
      voiceBtn.textContent = "🎙️ Indisponível";
      voiceBtn.title = "Ditado indisponível neste navegador";
      voiceBtn.classList.remove("listening");
    } else {
      voiceBtn.disabled = pending;
      voiceBtn.textContent = chatVoiceListening ? "⏹️ Parar" : "🎙️ Falar";
      voiceBtn.title = chatVoiceListening ? "Parar ditado" : "Falar com microfone";
      voiceBtn.classList.toggle("listening", chatVoiceListening);
    }
  }
  if (convBtn) {
    const ok = chatVoiceSupported();
    convBtn.disabled = !ok || pending;
    convBtn.classList.toggle("active", chatConversationMode);
    convBtn.textContent = "Modo conversa: " + (chatConversationMode ? "on" : "off");
    convBtn.title = ok ? "Ditado com envio automático" : "Modo conversa indisponível neste navegador";
  }
  const ttsBtn = el("chat-tts-toggle");
  if (ttsBtn) {
    const supported = typeof window !== "undefined" && "speechSynthesis" in window;
    ttsBtn.disabled = !supported;
    ttsBtn.textContent = "Fala: " + (chatTtsEnabled ? "on" : "off");
    ttsBtn.classList.toggle("active", chatTtsEnabled);
    ttsBtn.title = supported
      ? "Ler respostas (voz neural edge-tts, fallback browser)"
      : "Síntese de voz indisponível neste navegador";
  }
}

function chatTtsTextFromMessage(text) {
  const raw = String(text || "");
  if (!raw.trim()) return "";
  return raw
    .replace(/```[\s\S]*?```/g, " bloco de código ")
    .replace(/`[^`]*`/g, " ")
    .replace(/\[[^\]]*\]\([^)]+\)/g, " ")
    .replace(/https?:\/\/\S+/g, " ")
    .replace(/\s+/g, " ")
    .trim();
}

let chatTtsVoice = null;
let chatTtsVoiceReady = false;

function pickBestChatTtsVoice() {
  if (typeof window === "undefined" || !("speechSynthesis" in window)) return null;
  const voices = window.speechSynthesis.getVoices() || [];
  if (!voices.length) return null;
  const scoreVoice = (v) => {
    const name = String(v.name || "").toLowerCase();
    const lang = String(v.lang || "").toLowerCase();
    let score = 0;
    if (lang === "pt-br") score += 80;
    else if (lang.startsWith("pt")) score += 60;
    if (name.includes("neural") || name.includes("premium") || name.includes("natural")) score += 30;
    if (name.includes("luciana") || name.includes("brasil") || name.includes("portuguese")) score += 20;
    if (v.default) score += 10;
    return score;
  };
  let best = null;
  let bestScore = -1;
  for (const v of voices) {
    const s = scoreVoice(v);
    if (s > bestScore) {
      best = v;
      bestScore = s;
    }
  }
  return best;
}

function ensureChatTtsVoice() {
  if (chatTtsVoiceReady) return;
  chatTtsVoiceReady = true;
  const refresh = () => { chatTtsVoice = pickBestChatTtsVoice(); };
  refresh();
  if (typeof window !== "undefined" && "speechSynthesis" in window) {
    window.speechSynthesis.onvoiceschanged = refresh;
  }
}

function stopChatTtsPlayback() {
  if (chatTtsAudio) {
    try { chatTtsAudio.pause(); } catch (_) {}
    chatTtsAudio = null;
  }
  if (chatTtsObjectUrl) {
    try { URL.revokeObjectURL(chatTtsObjectUrl); } catch (_) {}
    chatTtsObjectUrl = null;
  }
  if (typeof window !== "undefined" && "speechSynthesis" in window) {
    try { window.speechSynthesis.cancel(); } catch (_) {}
  }
}

function speakChatTextBrowser(cleaned) {
  if (typeof window === "undefined" || !("speechSynthesis" in window)) return;
  ensureChatTtsVoice();
  try {
    window.speechSynthesis.cancel();
    const utter = new SpeechSynthesisUtterance(cleaned);
    utter.lang = "pt-BR";
    if (chatTtsVoice) utter.voice = chatTtsVoice;
    utter.rate = 0.94;
    utter.pitch = 1.02;
    utter.volume = 1.0;
    window.speechSynthesis.speak(utter);
  } catch (_) {
    // ignore browser TTS failures
  }
}

async function speakChatText(text) {
  if (!chatTtsEnabled) return;
  const cleaned = chatTtsTextFromMessage(text);
  if (!cleaned) return;
  const fp = String(activeKey || "") + "|" + cleaned.slice(0, 400);
  if (fp === chatLastSpokenFingerprint) return;
  chatLastSpokenFingerprint = fp;
  stopChatTtsPlayback();
  try {
    const r = await fetch("/chat/tts", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      credentials: "same-origin",
      body: JSON.stringify({ text: cleaned }),
    });
    const data = await r.json().catch(() => ({}));
    if (data && data.ok && data.audio_base64) {
      const bin = atob(data.audio_base64);
      const bytes = new Uint8Array(bin.length);
      for (let i = 0; i < bin.length; i++) bytes[i] = bin.charCodeAt(i);
      const blob = new Blob([bytes], { type: data.mime || "audio/mpeg" });
      chatTtsObjectUrl = URL.createObjectURL(blob);
      chatTtsAudio = new Audio(chatTtsObjectUrl);
      chatTtsAudio.onended = () => stopChatTtsPlayback();
      await chatTtsAudio.play();
      return;
    }
  } catch (_) {
    // fallback to browser voice
  }
  speakChatTextBrowser(cleaned);
}

function toggleChatTts() {
  chatTtsEnabled = !chatTtsEnabled;
  if (!chatTtsEnabled) stopChatTtsPlayback();
  updateChatVoiceUi();
}

function stopChatVoiceInput(manual = true) {
  if (chatVoiceRestartTimer) {
    clearTimeout(chatVoiceRestartTimer);
    chatVoiceRestartTimer = null;
  }
  chatVoiceManualStop = manual;
  if (!chatVoiceRecognizer || !chatVoiceListening) {
    chatVoiceListening = false;
    updateChatVoiceUi();
    return;
  }
  try {
    chatVoiceRecognizer.stop();
  } catch (_) {
    chatVoiceListening = false;
    updateChatVoiceUi();
  }
}

function scheduleChatVoiceStart(delayMs = 300) {
  if (!chatConversationMode || !chatVoiceSupported()) return;
  if (chatVoiceRestartTimer) clearTimeout(chatVoiceRestartTimer);
  chatVoiceRestartTimer = setTimeout(() => {
    chatVoiceRestartTimer = null;
    startChatVoiceInput();
  }, delayMs);
}

function startChatVoiceInput() {
  if (!chatVoiceSupported()) return;
  const input = el("chat-input");
  if (!input || chatVoiceListening) return;
  if (activeKey && isSessionPending(activeKey)) return;
  const Ctor = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (!chatVoiceRecognizer) {
    chatVoiceRecognizer = new Ctor();
    chatVoiceRecognizer.lang = "pt-BR";
    chatVoiceRecognizer.interimResults = true;
    chatVoiceRecognizer.continuous = false;
    chatVoiceRecognizer.onresult = (ev) => {
      let finalTxt = "";
      let interimTxt = "";
      for (let i = ev.resultIndex; i < ev.results.length; i++) {
        const text = String(ev.results[i][0].transcript || "");
        if (ev.results[i].isFinal) finalTxt += text;
        else interimTxt += text;
      }
      const base = chatVoiceBaseText ? (chatVoiceBaseText + " ") : "";
      input.value = (base + finalTxt + interimTxt).trim();
      updateSendButtonState();
    };
    chatVoiceRecognizer.onerror = (ev) => {
      chatVoiceListening = false;
      updateChatVoiceUi();
      const code = String((ev && ev.error) || "");
      if (code && code !== "no-speech" && code !== "aborted") {
        appendLocal("err", "Falha no ditado: " + code);
      }
    };
    chatVoiceRecognizer.onend = () => {
      const shouldAuto = chatConversationMode && !chatVoiceManualStop;
      chatVoiceListening = false;
      updateChatVoiceUi();
      if (!shouldAuto) return;
      const hasPending = !!(activeKey && isSessionPending(activeKey));
      const text = String((input.value || "").trim());
      if (!hasPending && text) {
        sendMessage()
          .then(() => scheduleChatVoiceStart(700))
          .catch(() => scheduleChatVoiceStart(1000));
        return;
      }
      if (!hasPending) scheduleChatVoiceStart(500);
    };
  }
  chatVoiceManualStop = false;
  chatVoiceBaseText = String((input.value || "").trim());
  try {
    chatVoiceRecognizer.start();
    chatVoiceListening = true;
    updateChatVoiceUi();
  } catch (_) {
    chatVoiceListening = false;
    updateChatVoiceUi();
  }
}

function toggleChatVoiceInput() {
  if (chatVoiceListening) {
    stopChatVoiceInput(true);
    return;
  }
  startChatVoiceInput();
}

function toggleChatConversationMode() {
  chatConversationMode = !chatConversationMode;
  if (!chatConversationMode) {
    stopChatVoiceInput(true);
    updateChatVoiceUi();
    return;
  }
  scheduleChatVoiceStart(100);
  updateChatVoiceUi();
}

function renderChatAttachments() {
  const box = el("chat-attachments");
  if (!box) return;
  if (!chatAttachments.length) {
    box.hidden = true;
    box.innerHTML = "";
    updateSendButtonState();
    return;
  }
  box.hidden = false;
  box.innerHTML = chatAttachments.map((att, idx) =>
    '<span class="chat-attachment-chip" title="' + escapeHtml(att.path || "") + '">' +
    escapeHtml(att.name) + " (" + formatBytes(att.size) + ')' +
    (att.path ? ' <span class="muted">→ disco</span>' : "") +
    '<button type="button" data-idx="' + idx + '" title="Remover">×</button></span>'
  ).join("");
  box.querySelectorAll("button[data-idx]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const i = Number(btn.getAttribute("data-idx"));
      if (!Number.isNaN(i)) {
        chatAttachments.splice(i, 1);
        renderChatAttachments();
      }
    });
  });
  updateSendButtonState();
}

function formatBytes(n) {
  const v = Number(n) || 0;
  if (v < 1024) return v + " B";
  if (v < 1024 * 1024) return (v / 1024).toFixed(1) + " KB";
  return (v / (1024 * 1024)).toFixed(1) + " MB";
}

function readFileAsBase64(file) {
  return new Promise((resolve, reject) => {
    const reader = new FileReader();
    reader.onload = () => {
      const raw = String(reader.result || "");
      const comma = raw.indexOf(",");
      resolve(comma >= 0 ? raw.slice(comma + 1) : raw);
    };
    reader.onerror = () => reject(reader.error || new Error("falha ao ler ficheiro"));
    reader.readAsDataURL(file);
  });
}

async function uploadChatAttachment(file) {
  if (!activeKey) await startNewChatAsync();
  const sessionKey = activeKey;
  if (!sessionKey) throw new Error("sem sessão ativa");
  const data_base64 = await readFileAsBase64(file);
  const { data } = await chatFetchJson("/openclaw/attachments/upload", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({
      session_key: sessionKey,
      name: file.name || "anexo",
      mime_type: file.type || "application/octet-stream",
      data_base64,
    }),
  }, 120000);
  if (!data.ok) throw new Error(data.error || "upload falhou");
  if (data.transcribed && window.qcmNavToast) {
    window.qcmNavToast("Áudio transcrito para texto.");
  }
  return {
    name: data.name || file.name || "anexo",
    mime_type: data.mime_type || file.type || "application/octet-stream",
    path: data.path,
    size: data.size != null ? Number(data.size) : file.size,
  };
}

async function addChatAttachmentFiles(fileList) {
  const files = Array.from(fileList || []);
  if (!files.length) return;
  for (const file of files) {
    if (chatAttachments.length >= maxChatAttachments) {
      if (window.qcmNavToast) window.qcmNavToast("Máximo " + maxChatAttachments + " anexo(s).");
      break;
    }
    if (file.size > maxChatAttachmentBytes) {
      if (window.qcmNavToast) {
        window.qcmNavToast(file.name + " excede " + formatBytes(maxChatAttachmentBytes));
      }
      continue;
    }
    try {
      const att = await uploadChatAttachment(file);
      chatAttachments.push(att);
      if (window.qcmNavToast && att.path) {
        window.qcmNavToast("Anexo em " + att.path);
      }
    } catch (e) {
      if (window.qcmNavToast) window.qcmNavToast("Erro ao anexar: " + e.message);
    }
  }
  renderChatAttachments();
}

function updateModelPickerUi() {
  const wrap = el("chat-model-picker-wrap");
  const sel = el("model-select");
  const hint = el("chat-model-hint");
  const meta = el("chat-meta");
  const defaultHint = "Anexe áudio longo para transcrever e transformar em instruções.";
  const hermesMode = sessionSource === "hermes";
  if (wrap) wrap.hidden = hermesMode;
  if (sel) sel.disabled = hermesMode;
  const cur = chatModels.find((m) => m.id === activeModelId);
  if (hint) {
    if (hermesMode) {
      hint.textContent = "modelo fixo (sessão Hermes)";
    } else if (cur && cur.coding) {
      hint.textContent = "modo programação";
    } else if (cur && !cur.available) {
      hint.textContent = "sem chave API";
    } else {
      hint.textContent = defaultHint;
    }
  }
  if (meta && !hermesMode) {
    meta.textContent = cur ? ("LLM: " + (cur.label || cur.id)) : ("LLM: " + activeModelId);
  }
}

function effectiveDefaultModelId(id) {
  const x = String(id || "").trim();
  if (!x || x === V4_FLASH_MODEL) return CHAT_DEFAULT_MODEL;
  return x;
}

function renderChatModels(models, defaultId) {
  chatModels = Array.isArray(models) ? models.slice() : [];
  const fallbackId = effectiveDefaultModelId(defaultId);
  if (!userExplicitModelPick) activeModelId = fallbackId;
  const sel = el("model-select");
  if (!sel) return;
  if (!chatModels.length) {
    sel.innerHTML = '<option value="deepseek-chat">DeepSeek Chat</option>';
    sel.disabled = sessionSource === "hermes";
    updateModelPickerUi();
    return;
  }
  const groups = {};
  chatModels.forEach((m) => {
    const g = m.group || "geral";
    if (!groups[g]) groups[g] = [];
    groups[g].push(m);
  });
  const order = ["programacao", "geral"];
  const labels = { programacao: "Programação", geral: "Geral" };
  let html = "";
  order.concat(Object.keys(groups).filter((g) => !order.includes(g))).forEach((g) => {
    const items = groups[g];
    if (!items || !items.length) return;
    html += '<optgroup label="' + escapeHtml(labels[g] || g) + '">';
    html += items.map((m) => {
      const suffix = m.available ? "" : " (sem chave)";
      return '<option value="' + escapeHtml(m.id) + '"' +
        (m.id === activeModelId ? " selected" : "") +
        (m.available ? "" : " disabled") + ">" +
        escapeHtml(m.label || m.id) + suffix + "</option>";
    }).join("");
    html += "</optgroup>";
  });
  sel.innerHTML = html;
  sel.disabled = sessionSource === "hermes";
  const picked = chatModels.find((m) => m.id === activeModelId && m.available);
  const preferred = picked
    || chatModels.find((m) => m.id === fallbackId && m.available)
    || chatModels.find((m) => m.id === CHAT_DEFAULT_MODEL && m.available);
  if (preferred) {
    activeModelId = preferred.id;
    sel.value = preferred.id;
  }
  updateModelPickerUi();
}

async function loadChatModels() {
  try {
    const { data } = await chatFetchJson("/openclaw/models", { cache: "no-cache" }, 15000);
    if (!data.ok) return;
    if (data.max_attachments) maxChatAttachments = Number(data.max_attachments) || maxChatAttachments;
    if (data.max_attachment_bytes) {
      maxChatAttachmentBytes = Number(data.max_attachment_bytes) || maxChatAttachmentBytes;
    }
    renderChatModels(data.models || [], data.default_model_id || CHAT_DEFAULT_MODEL);
  } catch (_) {
    /* optional */
  }
}

function filteredSessions() {
  let rows = sessions.slice();
  rows.sort((a, b) => {
    const ap = isSessionPending(a.key) ? 0 : 1;
    const bp = isSessionPending(b.key) ? 0 : 1;
    if (ap !== bp) return ap - bp;
    return (b.updatedAt || 0) - (a.updatedAt || 0);
  });
  const q = sessionQuery.trim().toLowerCase();
  if (!q) return rows;
  return rows.filter((s) => {
    const pending = pendingSends.get(s.key);
    const hay = [
      s.title,
      s.key,
      s.agentId,
      s.kind,
      pending && pending.preview,
    ].filter(Boolean).join(" ").toLowerCase();
    return hay.includes(q);
  });
}

async function refreshPendingSession(key, agent) {
  if (!key || !isSessionPending(key)) return;
  const q = new URLSearchParams({ key });
  q.set("limit", "200");
  if (agent) q.set("agent", agent);
  try {
    const { data } = await chatFetchJson("/openclaw/messages?" + q.toString(), {}, 45000);
    if (!data.ok) return;
    const msgs = data.messages || [];
    const last = msgs.length ? msgs[msgs.length - 1] : null;
    if (last && last.role !== "user" && last.role !== "status") {
      clearSessionPending(key);
      renderSessions();
      const title = data.title || key;
      if (window.qcmNavToast) {
        window.qcmNavToast("Resposta pronta: " + title);
      }
    } else if (last && last.role === "status" && key === activeKey) {
      await loadMessages(key, agent || "", { silent: true });
    }
  } catch (_) {
    // keep pending; next poll will retry
  }
}

function chatPollNeeded() {
  if (pendingSends.size > 0 || lastGlobalToolJobsCount > 0) return true;
  if (!document.hidden && activeKey && isWhatsappSessionKey(activeKey)) return true;
  return false;
}

function stopMessagesPollIfIdle() {
  if (chatPollNeeded()) return;
  if (pollTimer) {
    clearTimeout(pollTimer);
    pollTimer = null;
  }
}

function ensureMessagesPoll() {
  if (!chatPollNeeded()) return;
  if (pollTimer) return;
  chatPollTick = 0;
  pollTimer = setTimeout(chatPollLoop, chatPollIntervalMs());
}

async function chatPollLoop() {
  pollTimer = null;
  if (!chatPollNeeded()) return;
  if (document.hidden) {
    pollTimer = setTimeout(chatPollLoop, CHAT_POLL_HIDDEN_MS);
    return;
  }
  if (chatPollInFlight) {
    pollTimer = setTimeout(chatPollLoop, 1500);
    return;
  }
  chatPollInFlight = true;
  chatPollTick += 1;
  try {
    if (activeKey) {
      const pendingHere = isSessionPending(activeKey);
      if (!pendingHere || chatPollTick % 3 === 0) {
        await loadMessages(activeKey, activeAgent, { silent: true });
      }
    }
    if (chatPollTick % 4 === 0) {
      for (const [key, meta] of pendingSends) {
        if (key !== activeKey) await refreshPendingSession(key, meta.agent || "");
      }
    }
    if (chatPollTick % 2 === 0) {
      await pollGlobalToolJobs();
    }
  } catch (_) {
    // ignore transient poll errors
  } finally {
    chatPollInFlight = false;
  }
  if (chatPollNeeded()) {
    pollTimer = setTimeout(chatPollLoop, chatPollIntervalMs());
  }
}

function scheduleMessagesPoll() {
  ensureMessagesPoll();
}

function escapeHtml(s) {
  return String(s).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;");
}

function chatFetchError(e, url) {
  const msg = String((e && e.message) || e || "");
  if (msg === "Failed to fetch" || (e && e.name === "TypeError")) {
    return (
      "Não foi possível contactar o monitor em " + window.location.origin +
      ". Verifique se o gois está rodando (./scripts/start.sh --launchd) e recarregue a página."
    );
  }
  if (e && e.name === "AbortError") {
    return "Tempo esgotado aguardando " + url + ".";
  }
  return msg || "erro de rede";
}

function acquireChatHttpSlot() {
  if (chatHttpInFlight < CHAT_HTTP_MAX) {
    chatHttpInFlight += 1;
    return Promise.resolve();
  }
  return new Promise((resolve) => chatHttpWaiters.push(resolve));
}

function releaseChatHttpSlot() {
  chatHttpInFlight = Math.max(0, chatHttpInFlight - 1);
  const next = chatHttpWaiters.shift();
  if (next) {
    chatHttpInFlight += 1;
    next();
  }
}

async function chatFetch(url, opt, timeoutMs) {
  await acquireChatHttpSlot();
  try {
    const options = Object.assign({ credentials: "same-origin" }, opt || {});
    const timeout = timeoutMs != null ? timeoutMs : 30000;
    const retries = options.retries != null ? options.retries : 1;
    delete options.retries;
    let lastErr = null;
    for (let attempt = 0; attempt <= retries; attempt++) {
      const ctrl = new AbortController();
      const timer = setTimeout(() => ctrl.abort(), timeout);
      try {
        const r = await fetch(url, Object.assign({}, options, { signal: ctrl.signal }));
        clearTimeout(timer);
        return r;
      } catch (e) {
        clearTimeout(timer);
        lastErr = e;
        if (attempt < retries) continue;
        throw new Error(chatFetchError(e, url));
      }
    }
    throw new Error(chatFetchError(lastErr, url));
  } finally {
    releaseChatHttpSlot();
  }
}

async function chatFetchJson(url, opt, timeoutMs) {
  const r = await chatFetch(url, opt, timeoutMs);
  let data = {};
  try {
    data = await r.json();
  } catch (_) {
    throw new Error("Resposta inválida de " + url + " (HTTP " + r.status + ")");
  }
  return { r, data };
}

function formatTs(ts) {
  if (!ts) return "";
  const d = new Date(ts);
  if (isNaN(d.getTime())) return ts;
  return d.toLocaleString("pt-BR", { hour: "2-digit", minute: "2-digit", day: "2-digit", month: "2-digit" });
}

function formatUpdated(ms) {
  if (!ms) return "";
  const d = new Date(ms);
  if (isNaN(d.getTime())) return "";
  return d.toLocaleString("pt-BR", { day: "2-digit", month: "short", hour: "2-digit", minute: "2-digit" });
}

// Same Gois mascot as the app nav brand on the home/monitor screen.
function mascotIdForAgent(agentId) {
  return "gois";
}

function mascotSpeakerName(agentId) {
  return "Gois";
}

function mascotSvgForAgent(agentId) {
  return mascotSvgById.gois || DEFAULT_GOIS_MASCOT_SVG || "";
}

function ensureBrandMascot() {
  if (DEFAULT_GOIS_MASCOT_SVG) mascotSvgById.gois = DEFAULT_GOIS_MASCOT_SVG;
}

function mascotAvatarHtml(agentId) {
  const svg = mascotSvgForAgent(agentId);
  if (!svg) return "";
  const label = mascotSpeakerName(agentId);
  return '<span class="mascot-avatar" role="img" aria-label="' +
    escapeHtml(label) + '">' + svg + "</span>";
}

function desktopScreenshotBlockHtml(shot) {
  if (!shot || !shot.image_data_url) return "";
  const caption = escapeHtml(String(shot.caption || "Captura de ecrã"));
  const pathHint = shot.image_path
    ? '<p class="desktop-shot-caption">' + escapeHtml(String(shot.image_path)) + "</p>"
    : "";
  return '<div class="desktop-shot-wrap">' +
    '<img class="desktop-shot" src="' + String(shot.image_data_url) + '" alt="Desktop screenshot">' +
    '<p class="desktop-shot-caption">' + caption + "</p>" + pathHint + "</div>";
}

function wacliQrBlockHtml(wacliQr) {
  if (!wacliQr || !wacliQr.qr_image_data_url) return "";
  const hint = escapeHtml(
    String(wacliQr.instructions || "Escaneie no WhatsApp → Dispositivos conectados")
  );
  const note = wacliQr.note
    ? '<p class="wacli-qr-hint">' + escapeHtml(String(wacliQr.note)) + "</p>"
    : "";
  return '<div class="wacli-qr-wrap">' +
    '<img class="wacli-qr" src="' + String(wacliQr.qr_image_data_url) + '" alt="QR WhatsApp wacli">' +
    '<p class="wacli-qr-hint">' + hint + "</p>" + note + "</div>";
}

function botMessageInnerHtml(text, agentId, timestamp, extras) {
  const body = escapeHtml(String(text || ""));
  const name = escapeHtml(mascotSpeakerName(agentId));
  const ts = timestamp
    ? '<span class="ts">' + escapeHtml(formatTs(timestamp)) + "</span>"
    : "";
  const wacliQr = extras && extras.wacliQr ? extras.wacliQr : null;
  const desktopShot = extras && extras.desktopScreenshot ? extras.desktopScreenshot : null;
  const skills = extras && Array.isArray(extras.skillsUsed) && extras.skillsUsed.length
    ? extras.skillsUsed : null;
  const skillBadge = skills
    ? '<span class="skill-badge" title="Skills usadas nesta resposta">' +
      skills.map(s => '<span class="skill-tag">🧩 ' + escapeHtml(s) + '</span>').join("") +
      '</span>'
    : "";
  return mascotAvatarHtml(agentId) +
    '<div class="bubble"><span class="speaker">' + name + '</span>' + skillBadge +
    '<div class="body">' + body + "</div>" + wacliQrBlockHtml(wacliQr) +
    desktopScreenshotBlockHtml(desktopShot) + ts + "</div>";
}

function injectDesktopScreenshotIntoLastBotMessage(shot) {
  if (!shot || !shot.image_data_url) return;
  const box = el("chat-log");
  if (!box) return;
  const bots = box.querySelectorAll(".chat-msg.bot");
  const last = bots[bots.length - 1];
  if (!last || last.querySelector(".desktop-shot-wrap")) return;
  const bubble = last.querySelector(".bubble");
  if (!bubble) return;
  const wrap = document.createElement("div");
  wrap.innerHTML = desktopScreenshotBlockHtml(shot);
  while (wrap.firstChild) bubble.appendChild(wrap.firstChild);
}

function injectWacliQrIntoLastBotMessage(wacliQr) {
  if (!wacliQr || !wacliQr.qr_image_data_url) return;
  const box = el("chat-log");
  if (!box) return;
  const bots = box.querySelectorAll(".chat-msg.bot");
  const last = bots[bots.length - 1];
  if (!last || last.querySelector(".wacli-qr-wrap")) return;
  const bubble = last.querySelector(".bubble");
  if (!bubble) return;
  const wrap = document.createElement("div");
  wrap.innerHTML = wacliQrBlockHtml(wacliQr);
  while (wrap.firstChild) bubble.appendChild(wrap.firstChild);
  if (wacliQr.poll_auth) pollWacliUntilPaired(last);
}

function injectSkillBadgeIntoLastBotMessage(skills) {
  if (!Array.isArray(skills) || !skills.length) return;
  const box = el("chat-log");
  if (!box) return;
  const bots = box.querySelectorAll(".chat-msg.bot");
  const last = bots[bots.length - 1];
  if (!last || last.querySelector(".skill-badge")) return;
  const bubble = last.querySelector(".bubble");
  if (!bubble) return;
  const speaker = bubble.querySelector(".speaker");
  const badge = document.createElement("span");
  badge.className = "skill-badge";
  badge.title = "Skills usadas nesta resposta";
  badge.innerHTML = skills.map(function(s) {
    return '<span class="skill-tag">\u{1F9E9} ' + escapeHtml(s) + '</span>';
  }).join("");
  if (speaker && speaker.nextSibling) {
    speaker.parentNode.insertBefore(badge, speaker.nextSibling);
  } else if (speaker) {
    speaker.parentNode.appendChild(badge);
  } else {
    bubble.insertBefore(badge, bubble.firstChild);
  }
}

let wacliPairPollToken = 0;

async function pollWacliUntilPaired(botMsgEl) {
  const token = ++wacliPairPollToken;
  const status = el("chat-status");
  const waitSec = 120;
  if (status) status.textContent = "Aguardando escaneamento do QR no celular…";
  let pairingNote = botMsgEl && botMsgEl.querySelector(".wacli-pairing-status");
  if (botMsgEl && !pairingNote) {
    pairingNote = document.createElement("p");
    pairingNote.className = "wacli-qr-hint wacli-pairing-status";
    pairingNote.textContent = "Aguardando pareamento…";
    const qrWrap = botMsgEl.querySelector(".wacli-qr-wrap");
    if (qrWrap) qrWrap.appendChild(pairingNote);
  }
  try {
    const { data } = await chatFetchJson(
      "/wacli/auth/wait?timeout=" + String(waitSec),
      {},
      (waitSec + 20) * 1000
    );
    if (token !== wacliPairPollToken) return;
    if (data.ok && data.authenticated) {
      const jid = data.linked_jid ? " (" + data.linked_jid + ")" : "";
      const testOk = data.send_test && data.send_test.ok;
      const testNote = testOk
        ? " Mensagem de teste enviada."
        : data.send_test && data.send_test.error
          ? " Envio de teste: " + data.send_test.error
          : "";
      const msg =
        "WhatsApp autenticado — wacli pronto." + jid + testNote;
      if (pairingNote) {
        pairingNote.textContent = msg;
        pairingNote.classList.add("wacli-pairing-ok");
      }
      if (status) status.textContent = msg;
      appendLocal("status", msg);
      return;
    }
    const err = data.error || "pareamento não concluído";
    if (pairingNote) pairingNote.textContent = err;
    if (status) status.textContent = err;
  } catch (e) {
    if (token !== wacliPairPollToken) return;
    if (pairingNote) pairingNote.textContent = e.message || String(e);
    if (status) status.textContent = "";
  }
}

function renderChatToolsConfig(cfg) {
  const box = el("chat-tools-config");
  if (!box) return;
  if (!cfg || cfg.enabled === false) {
    box.textContent = "";
    return;
  }
  const maxTools = cfg.max_tool_iterations_effective ?? cfg.max_tool_iterations ?? "—";
  const parts = ["max tools: " + maxTools];
  if (cfg.qclaw_tools_enabled) parts.push("qclaw tools");
  if (cfg.heygen_mcp_enabled) parts.push("heygen mcp");
  if (cfg.shell_enabled) parts.push("shell");
  box.textContent = " · " + parts.join(" · ");
}

function updateChatHeaderMascot() {
  const box = el("chat-head-mascot");
  if (!box) return;
  const svg = mascotSvgForAgent(activeAgent);
  if (!svg) {
    box.innerHTML = "";
    box.setAttribute("aria-hidden", "true");
    return;
  }
  box.innerHTML = svg;
  box.setAttribute("aria-hidden", "false");
  box.setAttribute("aria-label", mascotSpeakerName(activeAgent));
}

function renderSessions() {
  const rows = filteredSessions();
  _memo("sessions", {
    sessions,
    activeKey,
    sessionQuery,
    pending: [...pendingSends.keys()].sort(),
  }, () => {
    const box = el("session-list");
    if (!sessions.length) {
      box.innerHTML = '<div class="empty">Nenhuma sessão encontrada.</div>';
      return;
    }
    if (!rows.length) {
      box.innerHTML = '<div class="empty">Nenhuma conversa corresponde à busca.</div>';
      return;
    }
    box.innerHTML = rows.map((s) => {
      const active = s.key === activeKey ? " active" : "";
      const pending = pendingSends.get(s.key);
      const pendingCls = pending ? " pending" : "";
      const canDelete = sessionSource !== "hermes";
      const pendingBadge = pending
        ? '<span class="session-pending">aguardando resposta</span>'
        : "";
      const preview = pending && pending.preview
        ? '<div class="meta">' + escapeHtml(pending.preview.slice(0, 80)) + "</div>"
        : "";
      return '<div class="session-row">' +
        '<button type="button" class="session-item' + active + pendingCls + '" data-key="' +
        escapeHtml(s.key) + '" data-agent="' + escapeHtml(s.agentId || "") + '">' +
        '<div class="title">' + escapeHtml(s.title || s.key) + '</div>' +
        pendingBadge +
        (s.team_id
          ? '<span class="session-team-badge">' + escapeHtml(getSessionTeamName(s) || s.team_id) + '</span>'
          : '<span class="session-team-badge unassigned">sem time</span>') +
        '<span class="kind">' + escapeHtml(s.kind || "other") + '</span>' +
        preview +
        '<div class="meta">' + escapeHtml(s.agentId || "") + " · " + formatUpdated(s.updatedAt) + '</div>' +
        '</button>' +
        (canDelete
          ? '<button type="button" class="session-del" data-action="delete" data-key="' + escapeHtml(s.key) +
            '" data-agent="' + escapeHtml(s.agentId || "") + '" title="Apagar conversa" aria-label="Apagar conversa">×</button>'
          : '') +
        '</div>';
    }).join("");
    box.querySelectorAll(".session-item").forEach((btn) => {
      btn.addEventListener("click", () => selectSession(btn.dataset.key, btn.dataset.agent));
    });
    box.querySelectorAll(".session-del").forEach((btn) => {
      btn.addEventListener("click", async (ev) => {
        ev.stopPropagation();
        await deleteChatSession(btn.dataset.key, btn.dataset.agent, btn);
      });
    });
  });
}

async function deleteChatSession(key, agentId, btn) {
  const sessionKey = String(key || "").trim();
  if (!sessionKey) return;
  if (sessionSource === "hermes") {
    alert("No modo Hermes, remova o perfil no dashboard Hermes.");
    return;
  }
  const sess = sessions.find((s) => s.key === sessionKey);
  const label = (sess && (sess.title || sessionKey)) || sessionKey;
  if (!window.confirm('Apagar a conversa "' + label + '"? Esta ação não pode ser desfeita.')) {
    return;
  }
  const prevDisabled = btn ? !!btn.disabled : false;
  if (btn) btn.disabled = true;
  try {
    const payload = { session_key: sessionKey };
    if (agentId) payload.agent = agentId;
    await chatFetchJson("/openclaw/session/delete", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(payload),
    }, 20000);
    clearSessionPending(sessionKey);
    clearOptimisticUser(sessionKey);
    delete historyOpenByKey[sessionKey];
    if (activeKey === sessionKey) {
      activeKey = null;
      liveProgressNode = null;
      el("chat-log").innerHTML = '<div class="empty">Selecione uma conversa.</div>';
      el("chat-title").textContent = "OpenClaw — selecione uma conversa";
      el("chat-meta").textContent = "";
      updateChatHeaderMascot();
    }
    await loadSessions({ refresh: true, skipAutoSelect: true });
    if (!activeKey && sessions.length) {
      const pick = sessions.find((s) => s.key === defaultSessionKey) || sessions[0];
      selectSession(pick.key, pick.agentId);
    }
  } catch (e) {
    alert("Não foi possível apagar: " + (e && e.message ? e.message : String(e)));
  } finally {
    if (btn) btn.disabled = prevDisabled;
  }
}

function filteredSkills() {
  let rows = skills.slice();
  if (skillsFilter === "assigned") {
    rows = rows.filter((s) => s.assigned);
  }
  const q = skillsQuery.trim().toLowerCase();
  if (q) {
    rows = rows.filter((s) =>
      (s.name || "").toLowerCase().includes(q) ||
      (s.description || "").toLowerCase().includes(q) ||
      (s.slug || "").toLowerCase().includes(q)
    );
  }
  return rows;
}

function renderSkills() {
  const box = el("skills-list");
  const rows = filteredSkills();
  el("skills-count").textContent = rows.length + " de " + skills.length + " skill(s)";
  if (!rows.length) {
    box.innerHTML = '<div class="empty">Nenhuma skill encontrada.</div>';
    return;
  }
  box.innerHTML = rows.map((s) => {
    const badge = s.assigned
      ? '<span class="badge ok">agente</span>'
      : (s.enabled === false ? '<span class="badge">off</span>' : "");
    return '<button type="button" class="skill-item" data-name="' + escapeHtml(s.name) + '">' +
      '<div class="name">' + escapeHtml(s.name) + '</div>' +
      (s.description ? '<div class="desc">' + escapeHtml(s.description) + '</div>' : '') +
      badge + '</button>';
  }).join("");
  box.querySelectorAll(".skill-item").forEach((btn) => {
    btn.addEventListener("click", () => insertSkill(btn.dataset.name));
  });
}

function insertSkill(name) {
  const input = el("chat-input");
  if (!input || !name) return;
  const hint = "Use a skill `" + name + "` para: ";
  if (!input.value.trim()) {
    input.value = hint;
  } else if (!input.value.includes(name)) {
    input.value = input.value.trimEnd() + "\n\nUse a skill `" + name + "`.";
  }
  input.focus();
}

function trackSkillsUsed(skillNames) {
  if (!Array.isArray(skillNames) || !skillNames.length) return;
  for (const name of skillNames) {
    const key = name.trim();
    if (!key) continue;
    chatSkillsUsedMap.set(key, (chatSkillsUsedMap.get(key) || 0) + 1);
  }
  renderSkillsUsedPanel();
}

function resetSkillsUsedPanel() {
  chatSkillsUsedMap.clear();
  renderSkillsUsedPanel();
}

// Tool-to-skill inference map (mirrors backend _TOOL_TO_SKILL_MAP)
const _toolToSkillMap = {
  "qclaw_run_shell": "qclaw-run-shell",
  "qclaw_health_check": "qclaw-monitor-health",
  "qclaw_list_teams": "qclaw-teams",
  "qclaw_process_status": "qclaw-monitor-health",
  "qclaw_read_log_tail": "qclaw-monitor-health",
  "qclaw_monitor_snapshot": "qclaw-monitor-health",
  "qclaw_team_kanban": "qclaw-team-kanban",
  "qclaw_hermes_cron_health": "qclaw-hermes-cron-health",
  "qclaw_list_chat_models": "qclaw-chat-models",
  "qclaw_nano_banana_generate": "qclaw-nano-banana-generate",
  "qclaw_wacli_auth_qr": "qclaw-whatsapp-wacli",
  "qclaw_wacli_unlock": "qclaw-whatsapp-wacli",
  "qclaw_send_whatsapp": "qclaw-whatsapp-wacli",
  "qclaw_team_whatsapp": "qclaw-team-whatsapp-associate",
  "qclaw_create_hermes_agent": "qclaw-hermes-agent",
  "qclaw_create_openai_swarm": "qclaw-openai-swarm",
  "qclaw_create_team": "qclaw-team-create",
  "qclaw_create_kanban_card": "qclaw-kanban-create-card",
  "qclaw_desktop_screenshot": "qclaw-desktop-control",
  "qclaw_desktop_click": "qclaw-desktop-control",
  "qclaw_desktop_type": "qclaw-desktop-control",
  "qclaw_desktop_key": "qclaw-desktop-control",
  "qclaw_desktop_scroll": "qclaw-desktop-control",
  "qclaw_desktop_list_windows": "qclaw-desktop-control",
  "qclaw_desktop_open_app": "qclaw-desktop-control",
  "qclaw_desktop_screen_info": "qclaw-desktop-control",
  "qclaw_heygen_via_openclaw": "qclaw-heygen-mcp",
  "ask_qclaw_agent": "qclaw-openclaw-agent",
  "qclaw_save_project_note": "qclaw-project-memory",
  "qclaw_allowlist_list": "qclaw-allowlist",
  "qclaw_allowlist_add": "qclaw-allowlist",
  "qclaw_allowlist_remove": "qclaw-allowlist",
  "qclaw_allowlist_toggle": "qclaw-allowlist",
  "web_search": "qclaw-web-search",
};

function inferSkillsFromTools(toolsUsed) {
  if (!Array.isArray(toolsUsed) || !toolsUsed.length) return [];
  const seen = new Set();
  const result = [];
  for (const tool of toolsUsed) {
    const mapped = _toolToSkillMap[tool];
    if (mapped && !seen.has(mapped)) {
      seen.add(mapped);
      result.push(mapped);
    }
  }
  return result;
}

function renderSkillsUsedPanel() {
  const panel = el("skills-used-panel");
  const list = el("skills-used-list");
  const countEl = el("skills-used-count");
  if (!panel || !list) return;
  if (!chatSkillsUsedMap.size) {
    list.innerHTML = "";
    if (countEl) countEl.textContent = "nenhuma ainda";
    return;
  }
  const entries = Array.from(chatSkillsUsedMap.entries())
    .sort((a, b) => b[1] - a[1]);
  const total = entries.reduce((sum, e) => sum + e[1], 0);
  if (countEl) {
    countEl.textContent = entries.length + " skill(s) · " + total + " uso(s)";
  }
  list.innerHTML = entries.map(([name, count]) => {
    const countHtml = count > 1 ? ' <span class="uses">×' + count + '</span>' : '';
    return '<span class="skills-used-tag" title="' + escapeHtml(name) + ' — usado ' + count + 'x">' +
      '🧩 ' + escapeHtml(name) + countHtml + '</span>';
  }).join("");
}

let skillSuggestions = [];

function renderSkillSuggestions() {
  const box = el("skill-suggestions");
  const list = el("skill-suggestions-list");
  if (!box || !list) return;
  if (!skillSuggestions.length) {
    box.hidden = true;
    list.innerHTML = "";
    return;
  }
  box.hidden = false;
  list.innerHTML = skillSuggestions.map((s) => {
    const name = escapeHtml(s.name || s.slug || "?");
    const reason = escapeHtml(s.reason || s.description || "");
    const sid = escapeHtml(s.id || "");
    return '<div class="skill-suggestion-item" data-id="' + sid + '">' +
      '<div class="meta"><div class="name">' + name + '</div>' +
      (reason ? '<div class="reason">' + reason + '</div>' : '') +
      '</div>' +
      '<button type="button" class="ctrl" data-use="' + sid + '">Usar</button>' +
      '<button type="button" class="ctrl" data-dismiss="' + sid + '">×</button>' +
      '</div>';
  }).join("");
  list.querySelectorAll("[data-use]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const row = skillSuggestions.find((s) => s.id === btn.dataset.use);
      if (row) insertSkill(row.slug || row.name);
    });
  });
  list.querySelectorAll("[data-dismiss]").forEach((btn) => {
    btn.addEventListener("click", () => { dismissSkillSuggestion(btn.dataset.dismiss); });
  });
}

async function loadSkillSuggestions() {
  try {
    const { data } = await chatFetchJson("/skills/suggestions", { cache: "no-cache" }, 15000);
    if (!data.ok) return;
    skillSuggestions = Array.isArray(data.pending) ? data.pending : [];
    renderSkillSuggestions();
  } catch (_) {
    /* optional panel */
  }
}

async function dismissSkillSuggestion(id) {
  const sid = String(id || "").trim();
  if (!sid) return;
  try {
    await chatFetchJson("/skills/suggestions/dismiss", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ id: sid }),
    }, 15000);
    skillSuggestions = skillSuggestions.filter((s) => s.id !== sid);
    renderSkillSuggestions();
  } catch (e) {
    console.warn("dismiss skill suggestion:", e);
  }
}

async function scanSkillSuggestions(btn) {
  if (btn) btn.disabled = true;
  const old = btn ? btn.textContent : "";
  if (btn) btn.textContent = "…";
  try {
    await chatFetchJson("/skills/suggestions/scan", { method: "POST" }, 120000);
    await loadSkillSuggestions();
    await loadSkills({ timeoutMs: 20000 });
  } catch (e) {
    console.warn("skill scan:", e);
  } finally {
    if (btn) {
      btn.disabled = false;
      btn.textContent = old || "Atualizar agora";
    }
  }
}

const skillSuggRefresh = el("skill-suggestions-refresh");
if (skillSuggRefresh) {
  skillSuggRefresh.addEventListener("click", () => { scanSkillSuggestions(skillSuggRefresh); });
}
const skillSuggDismissAll = el("skill-suggestions-dismiss-all");
if (skillSuggDismissAll) {
  skillSuggDismissAll.addEventListener("click", async () => {
    const ids = skillSuggestions.map((s) => s.id).filter(Boolean);
    for (const id of ids) await dismissSkillSuggestion(id);
  });
}

function isHermesSessionKey(key) {
  return String(key || "").startsWith("hermes:");
}

function applySessionSource(data) {
  sessionSource = data.source === "hermes" || data.fallback ? "hermes" : "openclaw";
  if (data.dashboard_url) hermesDashboardUrl = data.dashboard_url;
  const section = el("openclaw-section");
  if (section) {
    const sub = section.querySelector(".sub");
    if (sub) {
      sub.textContent = sessionSource === "hermes"
        ? "Perfis Hermes (fallback)"
        : "Sessões do agente";
    }
  }
  const skillsHead = document.querySelector(".skills-panel h3");
  if (skillsHead) {
    skillsHead.textContent = sessionSource === "hermes"
      ? "Skills Hermes"
      : "Skills OpenClaw";
  }
  const hermesLink = el("openclaw-control");
  if (hermesLink && sessionSource === "hermes" && hermesDashboardUrl) {
    hermesLink.href = hermesDashboardUrl;
    hermesLink.textContent = "Hermes dashboard →";
    hermesLink.style.display = "";
  }
  updateModelPickerUi();
}

async function loadSkills(opts) {
  opts = opts || {};
  const timeoutMs = opts.timeoutMs != null ? opts.timeoutMs : 20000;
  try {
    if (sessionSource === "hermes") {
      const { data } = await chatFetchJson("/hermes/skills", { cache: "no-cache" }, timeoutMs);
      if (!data.ok) throw new Error(data.error || "falha");
      skills = (data.skills || []).map((s) => ({
        name: s.name || s.slug || "?",
        slug: s.slug || s.name || "",
        description: s.description || "",
        assigned: true,
        enabled: true,
      }));
      renderSkills();
      return;
    }
    const q = new URLSearchParams({ agent: activeAgent || defaultAgent });
    const { data } = await chatFetchJson("/openclaw/skills?" + q.toString(), {}, timeoutMs);
    if (!data.ok) throw new Error(data.error || "falha");
    skills = Array.isArray(data.skills) ? data.skills.slice() : [];
    renderSkills();
  } catch (e) {
    el("skills-list").innerHTML = '<div class="empty">Erro: ' + escapeHtml(e.message) + '</div>';
    el("skills-count").textContent = "";
  }
}

async function loadSessions(opts) {
  opts = opts || {};
  const timeoutMs = opts.timeoutMs != null ? opts.timeoutMs : 25000;
  const retries = opts.retries != null ? opts.retries : 1;
  el("chat-status").textContent = "Carregando sessões…";
  try {
    const q = opts.refresh ? "?refresh=1" : "";
    const { r, data } = await chatFetchJson(
      "/openclaw/sessions" + q,
      { retries: retries },
      timeoutMs
    );
    if (!data.ok) throw new Error(data.error || "falha ao listar");
    sessions = normalizeSessionsList(data.sessions);
    if (data.whatsapp && data.whatsapp.session_key) {
      whatsappWatchKey = data.whatsapp.session_key;
    }
    defaultSessionKey = data.default_session_key || null;
    defaultAgent = data.default_agent || "main";
    knownAgents = data.agents || knownAgents;
    chatBackend = data.backend || chatBackend;
    controlUrl = data.control_url || null;
    applySessionSource(data);
    if (controlUrl && sessionSource !== "hermes") {
      const link = el("openclaw-control");
      link.href = controlUrl;
      link.textContent = "OpenClaw UI";
      link.style.display = "";
    }
    const backendEl = el("chat-backend");
    if (backendEl) {
      let label = chatBackend;
      if (sessionSource === "hermes") label = "Hermes (perfis)";
      else if (chatBackend === "openclaw_cli") label = "agente OpenClaw (CLI)";
      else if (chatBackend === "deepseek") label = "DeepSeek + skills";
      backendEl.textContent = " · " + label;
    }
    renderChatToolsConfig(data.openclaw_chat || null);
    if (data.openclaw_chat) {
      if (data.openclaw_chat.max_attachments) {
        maxChatAttachments = Number(data.openclaw_chat.max_attachments) || maxChatAttachments;
      }
      if (data.openclaw_chat.max_attachment_bytes) {
        maxChatAttachmentBytes = Number(data.openclaw_chat.max_attachment_bytes) || maxChatAttachmentBytes;
      }
      if (Array.isArray(data.openclaw_chat.models) && data.openclaw_chat.models.length) {
        renderChatModels(
          data.openclaw_chat.models,
          effectiveDefaultModelId(data.openclaw_chat.default_model_id)
        );
      }
    }
    const agents = [...new Set([
      ...knownAgents,
      ...sessions.map((s) => s.agentId).filter(Boolean),
    ])];
    if (!agents.includes(defaultAgent)) agents.unshift(defaultAgent);
    if (!agents.includes(activeAgent)) activeAgent = defaultAgent;
    const sel = el("agent-select");
    if (sel) {
      sel.innerHTML = agents.map((a) =>
        '<option value="' + escapeHtml(a) + '"' + (a === activeAgent ? " selected" : "") + '>' +
        escapeHtml(a) + '</option>'
      ).join("");
      sel.disabled = sessionSource === "hermes";
      sel.title = sessionSource === "hermes"
        ? "Agente = perfil Hermes selecionado"
        : "Agente OpenClaw";
    }
    invalidateSessionsCache();
    renderSessions();
    let status = sessions.length + " sessão(ões)";
    if (data.fallback && data.warning) status += " — " + data.warning;
    el("chat-status").textContent = status;
    if (!activeKey && sessions.length && !opts.skipAutoSelect) {
      const pick = sessions.find((s) => s.key === defaultSessionKey) || sessions[0];
      selectSession(pick.key, pick.agentId);
    }
  } catch (e) {
    try {
      const { r: r2, data: data2 } = await chatFetchJson(
        "/hermes/profiles",
        { cache: "no-cache" },
        15000
      );
      if (r2.ok && data2.ok && (data2.profiles || []).length) {
        sessions = (data2.profiles || []).map((p) => ({
          key: "hermes:" + (p.name || ""),
          agentId: p.name || "",
          title: p.display_name || p.name || "?",
          kind: "hermes",
          updatedAt: p.last_chat_at || 0,
        })).filter((s) => s.key !== "hermes:");
        sessions.sort((a, b) => (b.updatedAt || 0) - (a.updatedAt || 0));
        applySessionSource({ source: "hermes", fallback: true, dashboard_url: data2.dashboard_url });
        defaultAgent = sessions[0]?.agentId || "main";
        activeAgent = defaultAgent;
        invalidateSessionsCache();
        renderSessions();
        el("chat-status").textContent = sessions.length + " perfil(is) Hermes (fallback)";
        await loadSkills();
        return;
      }
    } catch (_) { /* ignore secondary fallback errors */ }
    const isNetErr = /abort|timeout|network|fetch/i.test(e.message);
    const hint = isNetErr
      ? "Servidor indisponível — tente recarregar a página (Cmd+Shift+R)."
      : escapeHtml(e.message);
    el("session-list").innerHTML =
      '<div class="empty">' + hint +
      '<br><button type="button" class="ctrl" style="margin-top:8px" ' +
      'onclick="location.reload()">↻ Recarregar</button></div>';
    el("chat-status").textContent = "";
  }
}

const TASK_STEP_RE = /Ferramentas:\s*passo\s*(\d+)\s*\/\s*(\d+)/i;
const TASK_LIMIT_RE = /Limite de ferramentas atingido/i;
const TASK_MODEL_PREFIX_RE = /^(.+?)\s·\s(.+)$/;
const TASK_STATE_LABELS = {
  running: "Em execução",
  done: "Concluída",
  paused: "Pausada",
};

function parseStatusModel(text) {
  const raw = String(text || "");
  const firstLine = raw.split("\n")[0];
  const m = firstLine.match(TASK_MODEL_PREFIX_RE);
  if (!m) return { model: null, body: raw };
  const rest = raw.slice(firstLine.length);
  return { model: m[1].trim(), body: m[2].trim() + rest };
}

function parseTaskStepText(text) {
  const parsed = parseStatusModel(text);
  const m = parsed.body.match(TASK_STEP_RE);
  if (!m) return null;
  return { model: parsed.model, step: parseInt(m[1], 10), max: parseInt(m[2], 10) };
}

function statusMessageBody(text) {
  const parsed = parseStatusModel(text);
  return parsed.model ? parsed.body : String(text || "");
}

function statusMessageInnerHtml(text, state) {
  const parsed = parseStatusModel(text);
  const label = state ? TASK_STATE_LABELS[state] : "";
  const stateBadge = state
    ? '<span class="task-state task-state--' + state + '">' + escapeHtml(label) + "</span>"
    : "";
  const modelBadge = parsed.model
    ? '<span class="task-model">' + escapeHtml(parsed.model) + "</span>"
    : "";
  const body = '<span class="task-body">' + escapeHtml(statusMessageBody(text)) + "</span>";
  return stateBadge + modelBadge + body;
}

function computeTaskStepContext(msgs, sessionKey) {
  let lastToolStep = 0;
  let hasToolStatusAtEnd = false;
  const rows = msgs || [];
  const last = rows.length ? rows[rows.length - 1] : null;
  for (const m of rows) {
    if (m.role !== "status") continue;
    const info = parseTaskStepText(m.text);
    if (info) lastToolStep = Math.max(lastToolStep, info.step);
  }
  if (last && last.role === "status") {
    const txt = String(last.text || "");
    hasToolStatusAtEnd = !!(
      parseTaskStepText(txt) ||
      TASK_LIMIT_RE.test(statusMessageBody(txt)) ||
      TASK_LIMIT_RE.test(txt)
    );
  }
  const sessionPending = !!(sessionKey && isSessionPending(sessionKey));
  const toolsActive = lastGlobalToolJobsCount > 0;
  let activeState = "none";
  if (hasToolStatusAtEnd && sessionPending) {
    activeState = toolsActive ? "running" : "paused";
  }
  return { lastToolStep, activeState, sessionPending };
}

function taskStateForMessage(text, ctx) {
  const info = parseTaskStepText(text);
  const body = statusMessageBody(text);
  if (!info) {
    if (TASK_LIMIT_RE.test(body) || TASK_LIMIT_RE.test(String(text || ""))) {
      return ctx.activeState === "running" ? "running" : "done";
    }
    return null;
  }
  if (info.step < ctx.lastToolStep) return "done";
  if (info.step === ctx.lastToolStep) {
    if (ctx.activeState === "running") return "running";
    if (ctx.activeState === "paused") return "paused";
    return "done";
  }
  return "done";
}

function liveTaskStateForText(text) {
  const body = statusMessageBody(text);
  if (!parseTaskStepText(text) && !TASK_LIMIT_RE.test(body) && !TASK_LIMIT_RE.test(String(text || ""))) {
    return null;
  }
  if (activeKey && isSessionPending(activeKey)) {
    return lastGlobalToolJobsCount > 0 ? "running" : "paused";
  }
  return "running";
}

function statusMessageHtml(text, tsHtml, state) {
  const extra = state ? " task-step" : "";
  return '<div class="chat-msg status' + extra + '">' +
    statusMessageInnerHtml(text, state) + tsHtml + "</div>";
}


function normalizeOptimisticText(text) {
  return String(text || "").trim().replace(/\s+/g, " ");
}

function optimisticUserIdentity(msg) {
  const role = String((msg && msg.role) || "").toLowerCase();
  if (role !== "user") return "";
  return normalizeOptimisticText(msg.text);
}

function incomingConsumesOptimistic(incoming, optimistic) {
  const incomingId = optimisticUserIdentity(incoming);
  const optimisticId = optimisticUserIdentity(optimistic);
  return !!(incomingId && optimisticId && incomingId === optimisticId);
}

function mergeOptimisticMessages(key, msgs) {
  const incoming = Array.isArray(msgs) ? msgs.slice() : [];
  const opt = pendingOptimisticBySession.get(key);
  if (!opt) return incoming;
  const optimistic = {
    role: "user",
    text: opt.text || "",
    timestamp: opt.timestamp || new Date().toISOString(),
    attachments: opt.attachments,
    optimistic: true,
  };
  if (incoming.some((m) => incomingConsumesOptimistic(m, optimistic))) {
    clearOptimisticUser(key);
    return incoming;
  }
  return incoming.concat([optimistic]);
}

function setOptimisticUser(key, text, extras) {
  if (!key) return;
  pendingOptimisticBySession.set(key, {
    text: String(text || ""),
    timestamp: new Date().toISOString(),
    attachments: extras && extras.attachments ? extras.attachments.slice() : undefined,
  });
  const renderKey = key === OPTIMISTIC_NEW_CHAT ? (activeKey || key) : key;
  if (renderKey === activeKey || (!activeKey && key === OPTIMISTIC_NEW_CHAT)) {
    invalidateMessagesCache();
    const base = lastMessagesByKey.get(renderKey) || lastMessagesByKey.get(key) || [];
    const merged = mergeOptimisticMessages(renderKey, base);
    if (merged.length) {
      renderMessages(base, activeAgent, renderKey);
    } else {
      appendLocal("user", text, extras);
    }
  }
}

function migrateOptimisticUser(fromKey, toKey) {
  if (!fromKey || !toKey || fromKey === toKey) return;
  const opt = pendingOptimisticBySession.get(fromKey);
  if (!opt) return;
  pendingOptimisticBySession.delete(fromKey);
  pendingOptimisticBySession.set(toKey, opt);
  const base = lastMessagesByKey.get(fromKey) || [];
  lastMessagesByKey.set(toKey, base);
  lastMessagesByKey.delete(fromKey);
}

function clearOptimisticUser(key) {
  if (!key) return;
  if (!pendingOptimisticBySession.delete(key)) return;
  if (key === activeKey || key === OPTIMISTIC_NEW_CHAT) {
    invalidateMessagesCache();
    const base = lastMessagesByKey.get(activeKey || key) || [];
    renderMessages(base, activeAgent, activeKey || key);
  }
}

function appendLocal(role, text, extras) {
  const box = el("chat-log");
  if (box.querySelector(".empty")) box.innerHTML = "";
  const div = document.createElement("div");
  const cssRole = role === "status" ? "status" : role;
  let className = "chat-msg " + cssRole;
  if (role === "bot") {
    div.className = className;
    div.innerHTML = botMessageInnerHtml(text, activeAgent, null, extras);
    speakChatText(text);
  } else if (role === "status") {
    const state = liveTaskStateForText(text);
    if (state) className += " task-step";
    div.className = className;
    div.innerHTML = statusMessageInnerHtml(text, state);
  } else {
    div.className = className;
    let body = escapeHtml(String(text || ""));
    const atts = extras && extras.attachments;
    if (Array.isArray(atts) && atts.length) {
      body += '<div class="attachment-list">' +
        atts.map((a) => '<span>📎 ' + escapeHtml(a.name || "anexo") + "</span>").join("") +
        "</div>";
    }
    div.innerHTML = body;
  }
  box.appendChild(div);
  box.scrollTop = box.scrollHeight;
}

function renderMessages(msgs, agentId, sessionKey) {
  const mascotId = mascotIdForAgent(agentId);
  const key = sessionKey || activeKey || "";
  const mergedMsgs = mergeOptimisticMessages(key, msgs);
  if (Array.isArray(msgs)) lastMessagesByKey.set(key, msgs.slice());
  const taskCtx = computeTaskStepContext(mergedMsgs, key);
  _memo("messages", {
    key,
    msgs: mergedMsgs || [],
    agentId,
    mascotId,
    pending: taskCtx.sessionPending,
    tools: lastGlobalToolJobsCount,
    lastStep: taskCtx.lastToolStep,
  }, () => {
    const box = el("chat-log");
    if (!mergedMsgs || !mergedMsgs.length) {
      box.innerHTML = '<div class="empty">Sem mensagens nesta sessão.</div>';
      chatSkillsUsedMap.clear();
      renderSkillsUsedPanel();
      return;
    }
    // Rebuild skills-used panel from full history
    chatSkillsUsedMap.clear();
    for (const m of mergedMsgs) {
      if (Array.isArray(m.skillsUsed) && m.skillsUsed.length) {
        for (const s of m.skillsUsed) {
          const sk = (s || "").trim();
          if (sk) chatSkillsUsedMap.set(sk, (chatSkillsUsedMap.get(sk) || 0) + 1);
        }
      } else if (Array.isArray(m.toolsUsed) && m.toolsUsed.length) {
        // Fallback: infer skills from tools for historical messages
        const inferred = inferSkillsFromTools(m.toolsUsed);
        for (const sk of inferred) {
          if (sk) chatSkillsUsedMap.set(sk, (chatSkillsUsedMap.get(sk) || 0) + 1);
        }
      }
    }
    renderSkillsUsedPanel();
    box.innerHTML = mergedMsgs.map((m) => {
      const ts = m.timestamp
        ? '<span class="ts">' + escapeHtml(formatTs(m.timestamp)) + "</span>"
        : "";
      if (m.role === "status") {
        const state = taskStateForMessage(m.text, taskCtx);
        return statusMessageHtml(m.text, ts, state);
      }
      const role = m.role === "user" ? "user" : "bot";
      if (role === "bot") {
        const extras = {};
        if (m.skillsUsed) extras.skillsUsed = m.skillsUsed;
        return '<div class="chat-msg bot">' +
          botMessageInnerHtml(m.text || "", agentId, m.timestamp, Object.keys(extras).length ? extras : undefined) + "</div>";
      }
      return '<div class="chat-msg user">' + escapeHtml(String(m.text || "")) + ts + "</div>";
    }).join("");
    box.scrollTop = box.scrollHeight;
    for (let i = mergedMsgs.length - 1; i >= 0; i--) {
      if (String(mergedMsgs[i].role || "") === "assistant" || String(mergedMsgs[i].role || "") === "bot") {
        speakChatText(mergedMsgs[i].text || "");
        break;
      }
    }
  });
}

async function loadMessages(key, agent, opts) {
  opts = opts || {};
  const silent = !!opts.silent;
  const force = !!opts.force;
  const retryCount = opts._retry || 0;
  if (!key) return;
  const loadTag = key + "|" + (agent || activeAgent || "");
  if (messagesLoadInFlight.has(loadTag)) {
    if (silent && !force) return;
  }
  const seq = ++messagesLoadSeq;
  messagesLoadInFlight.add(loadTag);
  const statusEl = el("chat-status");
  const prevStatus = statusEl ? statusEl.textContent : "";
  if (!silent && statusEl) statusEl.textContent = "Carregando mensagens…";
  const q = new URLSearchParams({ key });
  if (agent) q.set("agent", agent);
  const msgTimeout = silent ? 15000 : 45000;
  try {
    const { data } = await chatFetchJson(
      "/openclaw/messages?" + q.toString(),
      {},
      msgTimeout
    );
    if (seq !== messagesLoadSeq || key !== activeKey) return;
    if (!data.ok) throw new Error(data.error || "falha");
    el("chat-title").textContent = data.title || key;
    const metaParts = [data.agentId || ""];
    if (data.source === "hermes" || isHermesSessionKey(key)) {
      metaParts.push("hermes");
      if (data.hermes_dashboard_url) {
        const dash = el("openclaw-control");
        if (dash) {
          dash.href = data.hermes_dashboard_url;
          dash.textContent = "abrir no Hermes →";
          dash.style.display = "";
        }
      }
    } else if (data.sessionId) {
      metaParts.push(String(data.sessionId).slice(0, 8) + "…");
    }
    el("chat-meta").textContent = metaParts.filter(Boolean).join(" · ");
    const resolvedAgent = data.agentId || agent || activeAgent;
    if (resolvedAgent) activeAgent = resolvedAgent;
    updateChatHeaderMascot();
    const msgs = data.messages || [];
    if (force) invalidateMessagesCache();
    const keepOptimistic = pendingOptimisticBySession.has(key);
    if (!msgs.length && data.hint && !keepOptimistic) {
      el("chat-log").innerHTML = '<div class="empty">' + escapeHtml(data.hint) + '</div>';
    } else {
      renderMessages(msgs, resolvedAgent, key);
    }
    if (statusEl) {
      if (!silent) {
        statusEl.textContent = msgs.length + " mensagem(ns)";
      } else if (!force && prevStatus && prevStatus !== "Carregando mensagens…") {
        statusEl.textContent = prevStatus;
      }
    }
  } catch (e) {
    if (seq !== messagesLoadSeq || key !== activeKey) return;
    // Auto-retry once on network errors (monitor restart, timeout).
    if (retryCount < 1 && !silent && /abort|timeout|network|fetch/i.test(e.message)) {
      messagesLoadInFlight.delete(loadTag);
      if (statusEl) statusEl.textContent = "Reconectando…";
      await new Promise((r) => setTimeout(r, 1500));
      if (key === activeKey) {
        return loadMessages(key, agent, { ...opts, _retry: retryCount + 1 });
      }
      return;
    }
    if (!silent) {
      el("chat-log").innerHTML =
        '<div class="chat-msg err">' + escapeHtml(e.message) +
        '<br><button type="button" class="ctrl" onclick="loadMessages(\'' +
        escapeHtml(key).replace(/'/g, "\\'") + "', '" +
        escapeHtml(agent || activeAgent || "").replace(/'/g, "\\'") +
        "', {force:true})\">↻ Tentar novamente</button></div>";
      if (statusEl) statusEl.textContent = "";
    }
  } finally {
    messagesLoadInFlight.delete(loadTag);
  }
}

function selectSession(key, agent) {
  messagesLoadSeq += 1;
  activeKey = key;
  activeAgent = agent || activeAgent || defaultAgent;
  invalidateMessagesCache();
  const sel = el("agent-select");
  if (sel && activeAgent) sel.value = activeAgent;
  updateChatHeaderMascot();
  renderSessions();
  updateSendButtonState();
  updateChatTeamIndicator();
  el("chat-log").innerHTML = '<div class="empty">Carregando mensagens…</div>';
  loadMessages(key, activeAgent);
  loadSkills();
  if (isWhatsappSessionKey(key)) ensureMessagesPoll();
}

function startNewChat() {
  return startNewChatAsync();
}

async function startNewChatAsync(opts) {
  opts = opts || {};
  const skipSelect = !!opts.skipSelect;
  if (newChatBusy) return;
  if (sessionSource === "hermes") {
    const msg = "No modo Hermes, escolha um perfil à esquerda ou crie um em Papéis.";
    if (window.qcmNavToast) window.qcmNavToast(msg);
    else el("chat-status").textContent = msg;
    return;
  }
  newChatBusy = true;
  const btn = el("btn-new-chat");
  if (btn) btn.disabled = true;
  activeAgent = el("agent-select")?.value || defaultAgent;
  el("chat-status").textContent = "Preparando nova conversa…";
  let created = null;
  try {
    const { data } = await chatFetchJson("/openclaw/session/new", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ agent: activeAgent }),
    }, 60000);
    created = data;
    if (!created.ok) throw new Error(created.error || "falha ao criar sessão");
    activeKey = created.session_key;
    if (created.agentId) activeAgent = created.agentId;
    const row = {
      key: activeKey,
      agentId: activeAgent,
      title: created.title || "Nova conversa",
      kind: created.kind || "webchat",
      updatedAt: Date.now(),
      team_id: created.team_id || null,
    };
    sessions = [row, ...sessions.filter((s) => s.key !== activeKey)];
    invalidateSessionsCache();
    renderSessions();
    if (skipSelect) {
      const sel = el("agent-select");
      if (sel && activeAgent) sel.value = activeAgent;
      updateChatHeaderMascot();
      el("chat-title").textContent = row.title || "Nova conversa";
      el("chat-meta").textContent = activeAgent || "";
      updateSendButtonState();
    } else {
      selectSession(activeKey, activeAgent);
    }
    await loadSessions({ refresh: true, skipAutoSelect: true });
    if (!sessions.find((s) => s.key === activeKey)) {
      sessions = [row, ...sessions];
      invalidateSessionsCache();
      renderSessions();
    }
    el("chat-status").textContent = "Sessão OpenClaw criada";
    el("chat-input").focus();
    loadSkills();
  } catch (e) {
    el("chat-status").textContent = "";
    el("chat-log").innerHTML = '<div class="chat-msg err">' + escapeHtml(e.message) + '</div>';
  } finally {
    newChatBusy = false;
    if (btn) btn.disabled = false;
  }
}

async function applyChatSendResult(data, sendKey, sendAgent) {
  const tools = data.qclawToolsUsed;
  const skills = data.skillsUsed;
  if (activeKey === sendKey) {
    const parts = [];
    if (Array.isArray(skills) && skills.length) {
      parts.push("🧩 Skills: " + skills.join(", "));
    }
    if (Array.isArray(tools) && tools.length) {
      parts.push("Ferramentas: " + tools.join(", "));
    }
    el("chat-status").textContent = parts.length ? parts.join(" · ") : "";
  }
  // Store skills in the last message extras for rendering
  if (Array.isArray(skills) && skills.length) {
    lastChatSkillsUsed = skills.slice();
    trackSkillsUsed(skills);
  } else if (Array.isArray(tools) && tools.length) {
    // Fallback: infer skills from tools when LLM did not emit the tag
    const inferred = inferSkillsFromTools(tools);
    if (inferred.length) {
      lastChatSkillsUsed = inferred.slice();
      trackSkillsUsed(inferred);
    } else {
      lastChatSkillsUsed = null;
    }
  } else {
    lastChatSkillsUsed = null;
  }
  const resolvedKey = data.sessionKey || sendKey;
  if (data.title) {
    for (const k of [resolvedKey, sendKey]) {
      const row = sessions.find((s) => s.key === k);
      if (row) row.title = data.title;
    }
  }
  await loadSessions({ refresh: true, skipAutoSelect: true });
  if (data.title) {
    for (const k of [resolvedKey, sendKey]) {
      const row = sessions.find((s) => s.key === k);
      if (row) row.title = data.title;
    }
    invalidateSessionsCache();
  }
  if (data.sessionKey) {
    if (activeKey === sendKey) activeKey = data.sessionKey;
    const match = sessions.find((s) => s.key === resolvedKey);
    if (match && activeKey === resolvedKey) activeAgent = match.agentId;
  }
  const titleKey = activeKey === sendKey ? resolvedKey : activeKey;
  if (data.title && (activeKey === sendKey || activeKey === resolvedKey)) {
    el("chat-title").textContent = data.title;
  }
  updateChatHeaderMascot();
  renderSessions();
  if (activeKey === sendKey || activeKey === resolvedKey) {
    await loadMessages(activeKey, activeAgent, { force: true, silent: true });
    if (data.wacliQr) injectWacliQrIntoLastBotMessage(data.wacliQr);
    if (data.desktopScreenshot) injectDesktopScreenshotIntoLastBotMessage(data.desktopScreenshot);
    if (data.skillsUsed) injectSkillBadgeIntoLastBotMessage(data.skillsUsed);
  }
  stopMessagesPollIfIdle();
}

async function pollChatSendJob(sendKey, sendAgent, jobId) {
  const deadline = Date.now() + 660000;
  let pollStep = 0;
  let lastProgressShown = "";
  let lastProgressAt = Date.now();
  let lastMsgReloadAt = 0;
  ensureMessagesPoll();
  while (Date.now() < deadline) {
    pollStep += 1;
    const { data } = await chatFetchJson(
      "/openclaw/send/status?job_id=" + encodeURIComponent(jobId),
      {},
      8000
    );
    if (!data.ok) throw new Error(data.error || "job não encontrado");
    if (data.toolJobs) renderToolJobsBar({ jobs: data.toolJobs });
    const progressLine = (data.lastProgress || "").split("\n")[0];
    const progressChanged = !!(progressLine && progressLine !== lastProgressShown);
    const now = Date.now();
    if (
      activeKey === sendKey &&
      (progressChanged || now - lastMsgReloadAt >= CHAT_MSG_RELOAD_MS)
    ) {
      lastMsgReloadAt = now;
      void loadMessages(sendKey, sendAgent, { silent: true }).catch(() => {});
    }
    if (pollStep % 4 === 1) {
      void pollGlobalToolJobs().catch(() => {});
    }
    if (activeKey === sendKey) {
      const modelPrefix = data.modelLabel ? data.modelLabel + " · " : "";
      const elapsed = data.elapsedSeconds != null
        ? Number(data.elapsedSeconds)
        : (data.startedAt ? Math.max(0, Math.floor(Date.now() / 1000 - data.startedAt)) : 0);
      if (progressChanged) {
        lastProgressShown = progressLine;
        lastProgressAt = Date.now();
        if (progressLine) {
          appendLocal("status", modelPrefix + progressLine);
        }
      }
      let statusText = "";
      if (data.toolMax > 0) {
        statusText =
          modelPrefix +
          "Ferramentas: passo " + (data.toolTurn || 0) + "/" + data.toolMax +
          (progressLine ? " — " + progressLine : "");
      } else if (progressLine) {
        statusText = modelPrefix + progressLine;
      } else {
        statusText = modelPrefix + "Agente a trabalhar…";
      }
      if (elapsed > 0 && Date.now() - lastProgressAt > 10000) {
        statusText += " (" + elapsed + "s, ainda a processar…)";
      } else if (elapsed > 0 && !progressLine) {
        statusText += " (" + elapsed + "s)";
      }
      el("chat-status").textContent = statusText;
    }
    if (data.status === "done") {
      const result = data.result || {};
      if (!result.ok) throw new Error(result.error || "envio falhou");
      clearSessionPending(sendKey);
      await applyChatSendResult(result, sendKey, sendAgent);
      return;
    }
    if (data.status === "error") {
      const result = data.result || {};
      throw new Error(data.error || result.error || "envio falhou");
    }
    await new Promise((resolve) => setTimeout(resolve, CHAT_JOB_POLL_MS));
  }
  throw new Error("Tempo esgotado aguardando o agente.");
}

async function resumeChatJobPoll(sendKey, sendAgent, jobId) {
  if (!jobId || chatJobPolls.has(jobId)) return;
  chatJobPolls.add(jobId);
  try {
    await pollChatSendJob(sendKey, sendAgent, jobId);
  } catch (e) {
    if (isSessionPending(sendKey)) {
      clearSessionPending(sendKey);
      if (activeKey === sendKey) {
        appendLocal("err", e.message);
        el("chat-status").textContent = "";
      } else if (window.qcmNavToast) {
        window.qcmNavToast("Erro na conversa: " + e.message);
      }
      renderSessions();
    }
  } finally {
    chatJobPolls.delete(jobId);
    updateSendButtonState();
  }
}

async function syncPendingJobsFromServer() {
  try {
    const { data } = await chatFetchJson("/openclaw/send/pending", {}, 20000);
    if (!data.ok || !Array.isArray(data.jobs)) return;
    for (const j of data.jobs) {
      if (j.status !== "running") continue;
      const key = j.sessionKey || j.sendSessionKey;
      const jobId = j.jobId;
      if (!key || !jobId) continue;
      markSessionPending(key, j.agentId || "", j.preview || j.lastProgress || "");
      const meta = pendingSends.get(key);
      if (meta) {
        meta.jobId = jobId;
        savePendingToStorage();
      }
      resumeChatJobPoll(key, j.agentId || "", jobId);
    }
  } catch (_) {
    // monitor offline or endpoint unavailable
  }
}

async function sendMessage() {
  const input = el("chat-input");
  stopChatVoiceInput(false);
  const text = (input.value || "").trim();
  const attachmentsPayload = chatAttachments.map((a) => (
    a.path
      ? { name: a.name, mime_type: a.mime_type, path: a.path }
      : { name: a.name, mime_type: a.mime_type, data_base64: a.data_base64 }
  ));
  const briefTarget = el("chat-brief-target")?.value || "auto";
  if (!text && !attachmentsPayload.length) return;
  activeAgent = el("agent-select")?.value || activeAgent || defaultAgent;
  activeModelId = el("model-select")?.value || activeModelId || CHAT_DEFAULT_MODEL;
  let optimisticKey = activeKey || OPTIMISTIC_NEW_CHAT;
  if (activeKey && isSessionPending(activeKey)) {
    el("chat-status").textContent =
      "Esta conversa ainda está aguardando resposta — use a busca à esquerda para voltar depois.";
    return;
  }
  const attachmentExtras = chatAttachments.slice();
  setOptimisticUser(optimisticKey, text, { attachments: attachmentExtras });
  input.value = "";
  const sentAttachments = attachmentsPayload.slice();
  chatAttachments = [];
  renderChatAttachments();
  let sendKey = activeKey;
  const sendAgent = activeAgent;
  try {
    if (!sendKey) {
      await startNewChatAsync({ skipSelect: true });
      sendKey = activeKey;
      if (!sendKey) throw new Error("sem sessão ativa");
      migrateOptimisticUser(OPTIMISTIC_NEW_CHAT, sendKey);
      optimisticKey = sendKey;
      await loadMessages(sendKey, sendAgent, { silent: true });
    }
    if (isSessionPending(sendKey)) {
      clearOptimisticUser(optimisticKey);
      el("chat-status").textContent =
        "Esta conversa ainda está aguardando resposta — use a busca à esquerda para voltar depois.";
      return;
    }
    markSessionPending(sendKey, sendAgent, text || ("[" + sentAttachments.length + " anexo(s)]"));
    renderSessions();
    updateSendButtonState();
    el("chat-status").textContent =
      "Agente a trabalhar… pode trocar de conversa; o progresso aparece aqui.";
    // Always include the team_id from the team combo so the backend
    // uses the correct team context for this conversation.
    const sendSess = sessions.find(s => s.key === sendKey);
    const sendTeamId = getSelectedChatTeamId() || sendSess?.team_id || null;
    const { data } = await chatFetchJson("/openclaw/send", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        message: text,
        session_key: sendKey,
        agent: sendAgent || undefined,
        model_id: activeModelId,
        brief_target: briefTarget !== "auto" ? briefTarget : undefined,
        attachments: sentAttachments.length ? sentAttachments : undefined,
        team_id: sendTeamId || undefined,
      }),
    }, 45000);
    if (!data.ok) throw new Error(data.error || "envio falhou");
    if (data.async && data.jobId) {
      const meta = pendingSends.get(sendKey);
      if (meta) {
        meta.jobId = data.jobId;
        savePendingToStorage();
      }
      resumeChatJobPoll(sendKey, sendAgent, data.jobId);
      return;
    }
    clearSessionPending(sendKey);
    await applyChatSendResult(data, sendKey, sendAgent);
    if (isSessionPending(sendKey)) {
      await refreshPendingSession(sendKey, sendAgent);
    }
  } catch (e) {
    if (sendKey) clearSessionPending(sendKey);
    clearOptimisticUser(sendKey || optimisticKey);
    if (activeKey === sendKey) {
      appendLocal("err", e.message);
      el("chat-status").textContent = "";
      void loadMessages(sendKey, sendAgent, { silent: true, force: true }).catch(() => {});
    } else if (window.qcmNavToast) {
      window.qcmNavToast("Erro na conversa: " + e.message);
    }
    renderSessions();
  } finally {
    updateSendButtonState();
    updateChatVoiceUi();
    if (activeKey === sendKey) input.focus();
  }
}

el("btn-refresh-sessions").addEventListener("click", () => {
  loadSessions({ refresh: true }).then(() => loadSkills());
});

function protectedSessionKeys() {
  const keys = new Set();
  if (whatsappWatchKey) keys.add(whatsappWatchKey);
  if (defaultSessionKey) keys.add(defaultSessionKey);
  for (const key of pendingSends.keys()) keys.add(key);
  if (activeKey) keys.add(activeKey);
  return keys;
}

async function purgeChatSessions(mode) {
  const olderDays = 30;
  const msg = mode === "all"
    ? "Apagar todas as conversas da lista?\n\n" +
      "Sessões WhatsApp, cron, principal e conversas com envio pendente serão preservadas."
    : "Apagar conversas sem atividade nos últimos " + olderDays + " dias?\n\n" +
      "A conversa ativa e sessões protegidas serão preservadas.";
  if (!confirm(msg)) return;
  const btnOld = el("btn-delete-old-sessions");
  const btnAll = el("btn-delete-all-sessions");
  const buttons = [btnOld, btnAll].filter(Boolean);
  const oldText = buttons.map((b) => b.textContent);
  buttons.forEach((b) => { b.disabled = true; b.textContent = "…"; });
  const statusEl = el("chat-status");
  const prevStatus = statusEl ? statusEl.textContent : "";
  if (statusEl) statusEl.textContent = "Apagando sessões…";
  try {
    const { data } = await chatFetchJson("/openclaw/sessions/purge", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        mode: mode,
        older_than_days: olderDays,
        agent: activeAgent || defaultAgent,
        protect_keys: [...protectedSessionKeys()],
      }),
    }, 120000);
    if (!data.ok) throw new Error(data.error || "falha ao apagar");
    const n = Number(data.deleted_count) || 0;
    invalidateSessionsCache();
    const deletedSet = new Set(
      (Array.isArray(data.deleted) ? data.deleted : []).map((k) => String(k))
    );
    for (const key of [...pendingSends.keys()]) {
      if (deletedSet.has(key)) clearSessionPending(key);
    }
    if (activeKey && deletedSet.has(activeKey)) {
      activeKey = null;
      el("chat-log").innerHTML =
        '<div class="empty">Escolha uma sessão à esquerda ou inicie uma nova conversa.</div>';
      el("chat-title").textContent = "OpenClaw — selecione uma conversa";
      if (el("chat-meta")) el("chat-meta").textContent = "";
    }
    await loadSessions({ refresh: true });
    if (statusEl) {
      statusEl.textContent = n
        ? n + " conversa(s) apagada(s)."
        : "Nenhuma conversa elegível para apagar.";
    }
    if (window.qcmNavToast) {
      window.qcmNavToast(
        n ? n + " conversa(s) apagada(s)." : "Nenhuma conversa elegível para apagar."
      );
    }
  } catch (e) {
    if (statusEl) statusEl.textContent = prevStatus;
    alert("Falha ao apagar: " + e.message);
  } finally {
    buttons.forEach((b, i) => {
      b.disabled = false;
      b.textContent = oldText[i] || b.textContent;
    });
  }
}

const btnDeleteOldSessions = el("btn-delete-old-sessions");
if (btnDeleteOldSessions) {
  btnDeleteOldSessions.addEventListener("click", () => {
    purgeChatSessions("old").catch((e) => alert(e.message));
  });
}
const btnDeleteAllSessions = el("btn-delete-all-sessions");
if (btnDeleteAllSessions) {
  btnDeleteAllSessions.addEventListener("click", () => {
    purgeChatSessions("all").catch((e) => alert(e.message));
  });
}

(function bindNewChatButton() {
  const btn = el("btn-new-chat");
  if (!btn || btn._qcmNewChatBound) return;
  btn._qcmNewChatBound = true;
  btn.addEventListener("click", () => {
    startNewChat().catch((e) => {
      newChatBusy = false;
      btn.disabled = false;
      el("chat-status").textContent = "";
      el("chat-log").innerHTML = '<div class="chat-msg err">' + escapeHtml(e.message) + '</div>';
    });
  });
})();
el("session-search").addEventListener("input", (ev) => {
  sessionQuery = ev.target.value || "";
  renderSessions();
});
el("chat-send").addEventListener("click", sendMessage);
el("chat-voice-btn").addEventListener("click", toggleChatVoiceInput);
el("chat-conversation-mode").addEventListener("click", toggleChatConversationMode);
el("chat-tts-toggle").addEventListener("click", toggleChatTts);
el("chat-input").addEventListener("keydown", (ev) => {
  if (ev.key === "Enter" && !ev.shiftKey) { ev.preventDefault(); sendMessage(); }
});
el("skills-search").addEventListener("input", (ev) => {
  skillsQuery = ev.target.value || "";
  renderSkills();
});
document.querySelectorAll(".skills-filter button").forEach((btn) => {
  btn.addEventListener("click", () => {
    document.querySelectorAll(".skills-filter button").forEach((b) => b.classList.remove("active"));
    btn.classList.add("active");
    skillsFilter = btn.dataset.filter || "all";
    renderSkills();
  });
});
el("agent-select").addEventListener("change", (ev) => {
  activeAgent = ev.target.value || defaultAgent;
  updateChatHeaderMascot();
  loadSkills();
});
(function bindChatComposeExtras() {
  const attachBtn = el("chat-attach-btn");
  const fileInput = el("chat-attachment-input");
  const modelSel = el("model-select");
  if (attachBtn && fileInput && !attachBtn._qcmAttachBound) {
    attachBtn._qcmAttachBound = true;
    attachBtn.addEventListener("click", () => fileInput.click());
    fileInput.addEventListener("change", () => {
      addChatAttachmentFiles(fileInput.files).finally(() => { fileInput.value = ""; });
    });
  }
  if (modelSel && !modelSel._qcmModelBound) {
    modelSel._qcmModelBound = true;
    modelSel.addEventListener("change", () => {
      userExplicitModelPick = true;
      activeModelId = modelSel.value || activeModelId;
      updateModelPickerUi();
    });
  }
})();

const chatParams = new URLSearchParams(window.location.search);
if (chatParams.get("agent")) {
  activeAgent = chatParams.get("agent");
}
const pendingSkill = chatParams.get("skill");

async function loadChatConfigFromStatus() {
  try {
    const r = await fetch("/status", { cache: "no-cache" });
    if (!r.ok) return;
    const data = await r.json();
    renderChatToolsConfig(data.openclaw_chat || null);
  } catch (_) {
    // optional; sessions list also carries openclaw_chat
  }
}

async function initChatPage() {
  try {
    if (typeof window.qcmAuthGate === "function") {
      const auth = await window.qcmAuthGate();
      if (!auth || auth.ok === false) {
        showChatBootstrapError("Faça login para usar o chat.");
        return;
      }
    }
    loadPendingFromStorage();
    loadChatConfigFromStatus();
    ensureBrandMascot();
    updateChatHeaderMascot();
    // Parallel fetch: sessions, models, pending jobs, and skills all at once.
    const [, , sessResult] = await Promise.all([
      syncPendingJobsFromServer(),
      loadChatModels(),
      loadSessions({ refresh: true, timeoutMs: 25000, retries: 1 }),
    ]);
    // Load teams for team allocation feature
    loadChatTeams().then(() => { renderSessions(); updateChatTeamIndicator(); });
    // Team indicator click handler
    const teamInd = el("chat-team-indicator");
    if (teamInd) {
      teamInd.addEventListener("click", () => {
        if (!activeKey) return;
        showTeamModal(activeKey, { onAssign: () => { renderSessions(); updateChatTeamIndicator(); } });
      });
    }
    // Team combo change: assign team to current session
    const teamSel = el("chat-team-select");
    if (teamSel) {
      teamSel.addEventListener("change", async () => {
        const tid = teamSel.value;
        if (!activeKey) return;
        if (tid) {
          await assignTeamToSession(activeKey, tid);
        }
        const sess = sessions.find(s => s.key === activeKey);
        if (sess) sess.team_id = tid || null;
        renderSessions();
        updateChatTeamIndicator();
      });
    }
    for (const [key, meta] of pendingSends) {
      if (meta && meta.jobId && isSessionPending(key)) {
        resumeChatJobPoll(key, meta.agent || "", meta.jobId);
      }
    }
    for (const key of [...pendingSends.keys()]) {
      if (!isSessionPending(key)) { /* stale entries cleared inside */ }
    }
    updateSendButtonState();
    updateChatVoiceUi();
    if (pendingSends.size) {
      const search = el("session-search");
      if (search) search.focus();
      ensureMessagesPoll();
    }
    // Skills load in background — don't block chat interaction.
    loadSkills({ timeoutMs: 20000 }).then(() => loadSkillSuggestions()).catch(() => {});
    if (chatParams.get("agent")) {
      const sel = el("agent-select");
      if (sel) sel.value = activeAgent;
      updateChatHeaderMascot();
    }
    if (pendingSkill) {
      await startNewChatAsync();
      const input = el("chat-input");
      if (input) {
        input.value = "Use a skill `" + pendingSkill + "` para: ";
        input.focus();
      }
    }
    if (chatParams.get("whatsapp") && whatsappWatchKey) {
      selectSession(whatsappWatchKey, defaultAgent);
    } else if (activeKey && isWhatsappSessionKey(activeKey)) {
      ensureMessagesPoll();
    }
  } catch (e) {
    showChatBootstrapError(e.message || String(e));
  }
}

initChatPage();
document.addEventListener("visibilitychange", () => {
  if (!document.hidden && activeKey && !isSessionPending(activeKey)) {
    loadMessages(activeKey, activeAgent, { silent: true });
  }
});

// --- Daily cost badge (consumo diário em USD) -----------------------------
(function initDailyCostBadge() {
  const badge = document.getElementById("daily-cost-badge");
  const valueEl = document.getElementById("daily-cost-value");
  if (!badge || !valueEl) return;

  async function refreshDailyCost() {
    try {
      const ctrl = new AbortController();
      const timer = setTimeout(() => ctrl.abort(), 10000);
      const resp = await fetch("/modelos/cotas", {
        cache: "no-store",
        credentials: "same-origin",
        signal: ctrl.signal,
      });
      clearTimeout(timer);
      if (!resp.ok) return;
      const data = await resp.json();
      if (!data || !data.ok) return;
      const models = (data.usage && data.usage.models) || [];
      let totalUsd = 0;
      for (const row of models) {
        if (row && typeof row.usd_used === "number") totalUsd += row.usd_used;
      }
      const formatted = totalUsd >= 1 ? totalUsd.toFixed(2) : totalUsd.toFixed(4);
      valueEl.textContent = "US$ " + formatted + " hoje";
      badge.title = "Consumo diário: US$ " + formatted + " (" + data.day + ")";
      badge.classList.remove("warn", "over");
      if (totalUsd > 5) badge.classList.add("over");
      else if (totalUsd > 1) badge.classList.add("warn");
    } catch (_) { /* silent */ }
  }

  // First fetch after page + auth are ready; then every 60s
  setTimeout(refreshDailyCost, 2000);
  setInterval(refreshDailyCost, 60000);
})();

// --- Memory modal ---------------------------------------------------------
let memoryModalOpen = false;

function renderMemoryStats(data) {
  const total = data.total_facts || 0;
  const sess = data.total_sessions || 0;
  const byKind = data.by_kind || {};
  const kindLine = Object.keys(byKind).sort().map(
    (k) => '<span class="memory-chip">' + escapeHtml(k) + ': ' + byKind[k] + '</span>'
  ).join('');
  el("memory-stats").innerHTML =
    '<div class="memory-stat"><strong>' + total + '</strong> fatos em <strong>' +
    sess + '</strong> sessão(ões)</div>' +
    (kindLine ? '<div class="memory-kinds">' + kindLine + '</div>' : '');
}

function renderMemorySessions(data) {
  const box = el("memory-sessions");
  const sessions = data.sessions || [];
  if (!sessions.length) {
    box.innerHTML = '<div class="empty">Nenhuma memória armazenada ainda. Converse no chat e os fatos extraídos aparecerão aqui.</div>';
    return;
  }
  box.innerHTML = sessions.map((s) => {
    const facts = (s.facts || []).map((f) => (
      '<div class="memory-fact">' +
        '<span class="memory-fact-kind">' + escapeHtml(f.kind || 'note') + '</span>' +
        '<span class="memory-fact-text">' + escapeHtml(f.content || '') + '</span>' +
      '</div>'
    )).join('');
    const shownFacts = (s.facts || []).length;
    const moreLine = (s.fact_count > shownFacts)
      ? '<div class="memory-fact-more">+' + (s.fact_count - shownFacts) +
        ' fato(s) mais antigos não mostrados</div>'
      : '';
    return (
      '<details class="memory-session" open>' +
        '<summary>' +
          '<span class="memory-session-title">' + escapeHtml(s.title || s.session_key) + '</span>' +
          '<span class="memory-session-meta">' +
            escapeHtml(s.agent_id || '') + ' · ' +
            escapeHtml((s.updated_at || '').replace('T', ' ').slice(0, 16)) + ' · ' +
            (s.fact_count || 0) + ' fato(s)' +
          '</span>' +
        '</summary>' +
        '<div class="memory-facts">' + (facts || '<div class="empty">Sem fatos.</div>') + moreLine + '</div>' +
      '</details>'
    );
  }).join('');
}

async function loadMemory() {
  el("memory-status").textContent = "Carregando memória…";
  el("memory-sessions").innerHTML = '';
  el("memory-stats").innerHTML = '';
  try {
    const r = await fetch("/openclaw/memory", { headers: { "Accept": "application/json" } });
    const data = await r.json();
    if (!data.ok) throw new Error(data.error || "falha ao ler memória");
    renderMemoryStats(data);
    renderMemorySessions(data);
    el("memory-status").textContent = "";
  } catch (e) {
    el("memory-status").textContent = "";
    el("memory-sessions").innerHTML =
      '<div class="chat-msg err">' + escapeHtml(e.message) + '</div>';
  }
}

function openMemoryModal() {
  const modal = el("memory-modal");
  if (!modal || memoryModalOpen) return;
  modal.hidden = false;
  modal.setAttribute("aria-hidden", "false");
  memoryModalOpen = true;
  loadMemory();
}

function closeMemoryModal() {
  const modal = el("memory-modal");
  if (!modal || !memoryModalOpen) return;
  modal.hidden = true;
  modal.setAttribute("aria-hidden", "true");
  memoryModalOpen = false;
}

(function initMemoryModal() {
  const openBtn = el("btn-open-memory");
  const closeBtn = el("memory-modal-close");
  const backdrop = el("memory-modal-backdrop");
  const refreshBtn = el("memory-refresh");
  if (openBtn) openBtn.addEventListener("click", openMemoryModal);
  if (closeBtn) closeBtn.addEventListener("click", closeMemoryModal);
  if (backdrop) backdrop.addEventListener("click", closeMemoryModal);
  if (refreshBtn) refreshBtn.addEventListener("click", loadMemory);
  document.addEventListener("keydown", (ev) => {
    if (ev.key === "Escape" && memoryModalOpen) closeMemoryModal();
  });
})();

let projectModalOpen = false;
let projectFacts = [];

function renderProjectFacts() {
  const wrap = el("project-facts-list");
  if (!wrap) return;
  if (!projectFacts.length) {
    wrap.innerHTML = '<div class="empty">Nenhum fato guardado.</div>';
    return;
  }
  wrap.innerHTML = projectFacts.map((f, i) => {
    const kind = escapeHtml(f.kind || "note");
    const text = escapeHtml(f.content || "");
    const fid = escapeHtml(f.id || "");
    return (
      '<div class="memory-fact" data-fact-id="' + fid + '">' +
        '<span class="memory-fact-kind">' + kind + '</span>' +
        '<span class="memory-fact-text">' + text + '</span>' +
        '<button type="button" class="project-fact-delete" data-index="' + i + '" title="Remover">×</button>' +
      '</div>'
    );
  }).join("");
  wrap.querySelectorAll(".project-fact-delete").forEach((btn) => {
    btn.addEventListener("click", () => {
      const idx = parseInt(btn.getAttribute("data-index") || "-1", 10);
      if (idx >= 0 && idx < projectFacts.length) {
        projectFacts.splice(idx, 1);
        renderProjectFacts();
      }
    });
  });
}

async function loadProjectMemory() {
  const status = el("project-status");
  if (status) status.textContent = "Carregando…";
  try {
    const r = await fetch("/openclaw/project-memory", { headers: { "Accept": "application/json" } });
    const data = await r.json();
    if (!data.ok) throw new Error(data.error || "falha ao ler memória do projeto");
    const briefEl = el("project-brief");
    if (briefEl) briefEl.value = data.brief || "";
    projectFacts = Array.isArray(data.facts) ? data.facts.slice() : [];
    renderProjectFacts();
    if (status) status.textContent = (data.fact_count || 0) + " fato(s)";
  } catch (e) {
    if (status) status.textContent = "";
    const wrap = el("project-facts-list");
    if (wrap) wrap.innerHTML = '<div class="chat-msg err">' + escapeHtml(e.message) + '</div>';
  }
}

async function saveProjectMemory() {
  const status = el("project-status");
  if (status) status.textContent = "A guardar…";
  const briefEl = el("project-brief");
  const body = {
    brief: briefEl ? briefEl.value : "",
    facts: projectFacts,
  };
  try {
    const r = await fetch("/openclaw/project-memory", {
      method: "PUT",
      headers: { "Content-Type": "application/json", "Accept": "application/json" },
      body: JSON.stringify(body),
    });
    const data = await r.json();
    if (!data.ok) throw new Error(data.error || "falha ao guardar");
    projectFacts = Array.isArray(data.facts) ? data.facts.slice() : projectFacts;
    renderProjectFacts();
    if (status) status.textContent = "Guardado (" + (data.fact_count || 0) + " fatos)";
  } catch (e) {
    if (status) status.textContent = "";
    alert(e.message || String(e));
  }
}

function openProjectModal() {
  const modal = el("project-modal");
  if (!modal || projectModalOpen) return;
  modal.hidden = false;
  modal.setAttribute("aria-hidden", "false");
  projectModalOpen = true;
  loadProjectMemory();
}

function closeProjectModal() {
  const modal = el("project-modal");
  if (!modal || !projectModalOpen) return;
  modal.hidden = true;
  modal.setAttribute("aria-hidden", "true");
  projectModalOpen = false;
}

(function initProjectModal() {
  const openBtn = el("btn-open-project");
  const closeBtn = el("project-modal-close");
  const backdrop = el("project-modal-backdrop");
  const saveBtn = el("project-save");
  const refreshBtn = el("project-refresh");
  if (openBtn) openBtn.addEventListener("click", openProjectModal);
  if (closeBtn) closeBtn.addEventListener("click", closeProjectModal);
  if (backdrop) backdrop.addEventListener("click", closeProjectModal);
  if (saveBtn) saveBtn.addEventListener("click", saveProjectMemory);
  if (refreshBtn) refreshBtn.addEventListener("click", loadProjectMemory);
  document.addEventListener("keydown", (ev) => {
    if (ev.key === "Escape" && projectModalOpen) closeProjectModal();
  });
})();
</script>

<div class="memory-modal" id="memory-modal" hidden aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="memory-modal-title">
  <div class="memory-modal-backdrop" id="memory-modal-backdrop"></div>
  <div class="memory-modal-dialog">
    <header class="memory-modal-header">
      <div>
        <h2 id="memory-modal-title">Memória armazenada sobre você</h2>
        <div class="sub">Fatos extraídos das suas conversas (intenções, URLs, paths, ferramentas usadas).</div>
      </div>
      <div style="display: flex; gap: 8px; align-items: center;">
        <button type="button" class="memory-refresh" id="memory-refresh">Atualizar</button>
        <button type="button" class="memory-modal-close" id="memory-modal-close" aria-label="Fechar">&times;</button>
      </div>
    </header>
    <div class="memory-modal-body">
      <div id="memory-stats" class="memory-stat"></div>
      <div id="memory-status" class="memory-status"></div>
      <div id="memory-sessions" class="memory-sessions"></div>
    </div>
  </div>
</div>

<div class="memory-modal project-modal" id="project-modal" hidden aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="project-modal-title">
  <div class="memory-modal-backdrop" id="project-modal-backdrop"></div>
  <div class="memory-modal-dialog">
    <header class="memory-modal-header">
      <div>
        <h2 id="project-modal-title">Memória do projeto</h2>
        <div class="sub">Brief e fatos partilhados por todas as conversas do dashboard.</div>
      </div>
      <div style="display: flex; gap: 8px; align-items: center;">
        <button type="button" class="memory-refresh" id="project-refresh">Atualizar</button>
        <button type="button" class="memory-refresh" id="project-save">Guardar</button>
        <button type="button" class="memory-modal-close" id="project-modal-close" aria-label="Fechar">&times;</button>
      </div>
    </header>
    <div class="memory-modal-body">
      <label for="project-brief" style="font-size: 12px; color: var(--muted);">Brief (markdown)</label>
      <textarea id="project-brief" rows="6" style="width: 100%; resize: vertical; font-family: inherit; font-size: 13px;
        background: var(--panel-2); color: var(--fg); border: 1px solid var(--border); border-radius: 8px; padding: 10px;"></textarea>
      <div id="project-status" class="memory-status"></div>
      <div id="project-facts-list" class="memory-sessions"></div>
    </div>
  </div>
</div>
</body>
</html>
"""


def build_chat_html(hermes_dashboard_url: Optional[str] = None) -> str:
    html = (
        CHAT_PAGE.replace("__GOIS_MASCOT_SVG__", json.dumps(GOIS_MASCOT_SVG))
        .replace("__GOIS_MASCOT_INLINE__", GOIS_MASCOT_SVG)
        .replace(
            "__HERMES_DASHBOARD_URL__",
            json.dumps(hermes_dashboard_url or ""),
        )
    )
    return _inject_app_nav(
        html,
        "chat",
        hermes_dashboard_url=hermes_dashboard_url,
    )


RUFLO_CHAT_PAGE = r"""<!doctype html>
<html lang="pt-br">
<head>
<meta charset="utf-8">
<title>gois — Chat RuFlo</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<style>
  :root {
    --bg: #0f1115; --panel: #171a21; --panel-2: #1e222c; --border: #262b36;
    --fg: #e6e8ee; --muted: #8a93a6; --ok: #3ddc84; --bad: #ff5a5f;
    --accent: #c08bff; --accent-dim: rgba(192,139,255,.14);
    --mono: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }
  * { box-sizing: border-box; }
  html, body { margin: 0; height: 100%; background: var(--bg); color: var(--fg);
    font: 14px/1.45 -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; }
  body { display: flex; flex-direction: column; height: 100vh; overflow: hidden; }
  __APP_NAV_CSS__
  main { flex: 1 1 0; display: grid; grid-template-columns: 260px 1fr 300px; gap: 14px;
    padding: 16px 20px; min-height: 0; overflow: hidden; }
  @media (max-width: 1100px) {
    main { grid-template-columns: 1fr; overflow: auto; }
    body { overflow: auto; height: auto; min-height: 100vh; }
  }
  .panel { background: var(--panel); border: 1px solid var(--border); border-radius: 10px;
    display: flex; flex-direction: column; min-height: 0; overflow: hidden; }
  .panel h2 { margin: 0; padding: 12px 14px; font-size: 11px; font-weight: 600;
    color: var(--muted); text-transform: uppercase; letter-spacing: .8px;
    border-bottom: 1px solid var(--border); }
  .sessions { flex: 1; overflow: auto; padding: 8px; }
  .sess-row { position: relative; display: flex; align-items: stretch;
    margin-bottom: 6px; border-radius: 8px; border: 1px solid transparent; }
  .sess-row:hover { border-color: var(--border); }
  .sess-row.active { border-color: var(--accent); background: var(--accent-dim); }
  .sess { flex: 1; text-align: left; background: transparent; border: 0;
    color: var(--fg); border-radius: 8px 0 0 8px; padding: 10px 12px; cursor: pointer; }
  .sess .t { font-weight: 600; font-size: 13px; }
  .sess .m { color: var(--muted); font-size: 11px; font-family: var(--mono); margin-top: 4px; }
  .sess-del { background: transparent; border: 0; color: var(--muted);
    padding: 0 10px; cursor: pointer; font-size: 16px; line-height: 1; border-radius: 0 8px 8px 0; }
  .sess-del:hover { color: var(--bad); background: rgba(255,90,95,.08); }
  .sess-row.active .sess-del { color: var(--fg); }
  .chat-col { display: flex; flex-direction: column; min-height: 0; }
  .chat-log { flex: 1; overflow: auto; padding: 14px; display: flex; flex-direction: column; gap: 10px; }
  .msg { padding: 10px 12px; border-radius: 10px; white-space: pre-wrap; word-break: break-word; }
  .msg.user { background: var(--accent-dim); border: 1px solid rgba(192,139,255,.35); }
  .msg.bot { background: var(--panel-2); border: 1px solid var(--border); }
  .msg.err { border-color: rgba(255,90,95,.4); color: var(--bad); }
  .msg .meta { display: block; margin-top: 6px; color: var(--muted); font-size: 11px; font-family: var(--mono); }
  .msg .code-block { margin: 8px 0; border: 1px solid var(--border); border-radius: 8px;
    background: #0b1220; overflow: hidden; }
  .msg .code-block .code-head { display: flex; justify-content: space-between; align-items: center;
    padding: 4px 10px; font-size: 10px; font-family: var(--mono); color: var(--muted);
    background: rgba(192,139,255,.08); border-bottom: 1px solid var(--border); text-transform: uppercase;
    letter-spacing: .04em; }
  .msg .code-block .code-copy { background: transparent; color: var(--accent); border: 1px solid var(--border);
    border-radius: 4px; padding: 2px 8px; font-size: 10px; cursor: pointer; }
  .msg .code-block .code-copy:hover { border-color: var(--accent); }
  .msg .code-block pre { margin: 0; padding: 10px 12px; font-family: var(--mono); font-size: 12px;
    line-height: 1.45; color: #d8e0f0; white-space: pre; overflow-x: auto; }
  .msg .body-text { white-space: pre-wrap; word-break: break-word; }
  .msg.reasoning { background: rgba(192,139,255,.06); border: 1px dashed rgba(192,139,255,.28);
    font-size: 12px; color: var(--muted); padding: 0; overflow: hidden; }
  .msg.reasoning summary { cursor: pointer; padding: 10px 12px; font-weight: 600;
    color: var(--accent); list-style: none; user-select: none; }
  .msg.reasoning summary::-webkit-details-marker { display: none; }
  .msg.reasoning summary::before { content: "▸ "; display: inline-block; transition: transform .15s; }
  .msg.reasoning[open] summary::before { transform: rotate(90deg); }
  .msg.reasoning .reasoning-body { padding: 0 12px 10px; white-space: pre-wrap; word-break: break-word;
    border-top: 1px dashed rgba(192,139,255,.18); line-height: 1.5; }
  .msg.status { font-size: 12px; color: var(--muted); background: rgba(192,139,255,.06);
    border: 1px dashed rgba(192,139,255,.22); font-style: italic; white-space: pre-line; }
  .msg.status.live { border-style: solid; border-color: rgba(192,139,255,.35);
    color: var(--fg); font-style: normal; animation: ruflo-pulse 1.4s ease-in-out infinite; }
  @keyframes ruflo-pulse {
    0%, 100% { opacity: .72; }
    50% { opacity: 1; }
  }
  .compose { display: flex; gap: 8px; padding: 12px 14px; border-top: 1px solid var(--border); }
  .compose textarea { flex: 1; min-height: 72px; resize: vertical; background: var(--panel-2);
    color: var(--fg); border: 1px solid var(--border); border-radius: 8px; padding: 10px; font: inherit; }
  .compose button { background: var(--accent); color: #0b1220; border: 0; border-radius: 8px;
    padding: 10px 14px; font-weight: 600; cursor: pointer; align-self: flex-end; }
  .compose button[disabled] { opacity: .55; cursor: progress; }
  .approval-bar { display: flex; align-items: center; justify-content: space-between; gap: 10px;
    margin: 0 14px 10px; padding: 10px 12px; border-radius: 10px;
    border: 1px dashed rgba(255,180,84,.45); background: rgba(255,180,84,.08); }
  .approval-bar[hidden] { display: none !important; }
  .approval-bar .txt { color: var(--fg); font-size: 12px; }
  .approval-actions { display: inline-flex; gap: 8px; }
  .approval-actions button { border: 1px solid var(--border); border-radius: 8px;
    padding: 7px 12px; font-size: 12px; cursor: pointer; }
  .approval-actions .ok { background: rgba(61,220,132,.15); border-color: rgba(61,220,132,.45); color: var(--ok); }
  .approval-actions .no { background: rgba(255,90,95,.12); border-color: rgba(255,90,95,.35); color: var(--bad); }
  .side { padding: 12px 14px; overflow: auto; font-size: 12px; color: var(--muted); }
  .flo-403-hint { margin: 0 0 10px; padding: 10px; border-radius: 8px; font-size: 11px; line-height: 1.45;
    background: rgba(255,180,80,.08); border: 1px solid rgba(255,180,80,.35); color: var(--fg); }
  .flo-403-hint code { font-family: var(--mono); font-size: 10px; }
  .side pre { background: var(--panel-2); border: 1px solid var(--border); border-radius: 8px;
    padding: 10px; font-family: var(--mono); font-size: 11px; white-space: pre-wrap; }
  .toolbar { display: flex; flex-wrap: wrap; gap: 8px; padding: 10px 14px; border-bottom: 1px solid var(--border); }
  .toolbar button, .toolbar a { font-size: 12px; padding: 6px 10px; border-radius: 6px;
    border: 1px solid var(--border); background: var(--panel-2); color: var(--fg); cursor: pointer;
    text-decoration: none; }
  .toolbar a:hover, .toolbar button:hover { border-color: var(--accent); }
  .status-line { display: flex; align-items: center; justify-content: space-between; gap: 10px;
    padding: 8px 14px; font-size: 12px; color: var(--muted); font-family: var(--mono);
    border-bottom: 1px solid var(--border); }
  .status-line .status-text { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .auto-scroll-toggle { display: inline-flex; align-items: center; gap: 6px; font-size: 11px;
    color: var(--muted); user-select: none; white-space: nowrap; }
  .auto-scroll-toggle input { margin: 0; accent-color: var(--accent); }
  .history-toggle { border: 1px dashed var(--border); border-radius: 10px;
    background: rgba(192,139,255,.04); }
  .history-toggle summary { cursor: pointer; padding: 8px 12px; font-size: 12px;
    color: var(--muted); list-style: none; user-select: none; font-family: var(--mono); }
  .history-toggle summary::-webkit-details-marker { display: none; }
  .history-toggle summary::before { content: "▸"; display: inline-block; margin-right: 6px;
    transition: transform .15s; color: var(--accent); }
  .history-toggle[open] summary::before { transform: rotate(90deg); }
  .history-toggle summary:hover { color: var(--fg); }
  .history-body { display: flex; flex-direction: column; gap: 10px;
    padding: 4px 10px 10px; border-top: 1px dashed var(--border); }
  .history-body:empty { padding: 0; border-top: 0; }
</style>
</head>
<body>
__APP_NAV__
<main>
  <section class="panel">
    <h2>Conversas RuFlo</h2>
    <div class="toolbar">
      <button type="button" id="btn-new">Nova conversa</button>
    </div>
    <div class="sessions" id="sessions"></div>
  </section>
  <section class="panel chat-col">
    <div class="status-line">
      <span class="status-text" id="status">A carregar…</span>
      <span style="display:inline-flex;align-items:center;gap:6px;">
        <label for="ruflo-model" style="color:var(--muted);font-size:11px;">Modelo:</label>
        <select id="ruflo-model" style="background:var(--panel-2);color:var(--fg);border:1px solid var(--border);border-radius:6px;padding:4px 6px;font-size:12px;">
          <option value="">A carregar…</option>
        </select>
      </span>
      <label class="auto-scroll-toggle" for="auto-scroll">
        <input type="checkbox" id="auto-scroll" checked>
        Auto-scroll
      </label>
    </div>
    <div class="chat-log" id="log"></div>
    <div class="approval-bar" id="approval-bar" hidden>
      <span class="txt">Comando fora da allowlist detectado. Autorizar execução?</span>
      <div class="approval-actions">
        <button type="button" class="ok" id="bash-allow-btn">ALLOW</button>
        <button type="button" class="no" id="bash-cancel-btn">CANCELAR</button>
      </div>
    </div>
    <div class="compose">
      <textarea id="input" placeholder="Descreva a tarefa — RuFlo faz routing e memória antes da resposta…"></textarea>
      <button type="button" id="send">Enviar</button>
    </div>
  </section>
  <section class="panel">
    <h2>Orquestração</h2>
    <div class="side" id="orch">
      <p class="flo-403-hint"><strong>flo.ruv.io:</strong> se aparecer <code>403 status code (no body)</code> na tela, é quase sempre em <em>Settings → Application</em> (só admin) — feche definições e use o chat principal com <strong>Claude Sonnet 4.6</strong>. Ou converse aqui neste painel.</p>
      <p>Swarm, routing e memória via <code>npx ruflo@latest</code>.</p>
      <p><a id="link-hosted" href="https://flo.ruv.io/" target="_blank" rel="noopener">UI completa (flo.ruv.io)</a></p>
      <p><a id="link-local" href="http://127.0.0.1:3000/" target="_blank" rel="noopener">UI local (:3000)</a></p>
      <pre id="orch-pre">—</pre>
    </div>
  </section>
</main>
<script>
const API = "/ruflo";
const RUFLO_JOB_POLL_MS = 900;
const RUFLO_MSG_RELOAD_MS = 2500;
const RUFLO_HISTORY_KEEP_VISIBLE = 8;
const RUFLO_USER_CHECKIN_MS = __RUFLO_USER_CHECKIN_MS__;
const RUFLO_AUTO_SCROLL_KEY = "qcm.ruflo.auto_scroll";
const RUFLO_MODEL_KEY = "qcm.ruflo.model_id";
let sessions = [];
let activeKey = null;
let activeAgent = "ruflo";
let messagesLoadSeq = 0;
let pendingJob = null;
let liveProgressNode = null;
let liveProgressText = "";
let historyOpenByKey = Object.create(null);
let lastRenderedKey = null;
let lastRenderedCount = 0;
let stickToBottom = true;
let logScrollBound = false;
let autoScrollTimer = null;
let autoScrollEnabled = true;
let pendingBashApprovalUi = false;
let rufloSkillHint = "";
let rufloModels = [];
let rufloActiveModelId = "";
let rufloDefaultModelId = "";

function isCronTopic(text) {
  return /\b(cron|cron job|cron jobs|job[s]? de cron|agendament|schedule|agendamento|jobs?)\b/i.test(String(text || ""));
}

function startAutoScrollTimer() {
  if (autoScrollTimer || !autoScrollEnabled) return;
  autoScrollTimer = setInterval(() => {
    const box = el("log");
    if (box) box.scrollTop = box.scrollHeight;
  }, 500);
}

function stopAutoScrollTimer() {
  if (!autoScrollTimer) return;
  clearInterval(autoScrollTimer);
  autoScrollTimer = null;
}

function setAutoScrollEnabled(enabled) {
  autoScrollEnabled = !!enabled;
  const toggle = el("auto-scroll");
  if (toggle) toggle.checked = autoScrollEnabled;
  try {
    window.localStorage.setItem(RUFLO_AUTO_SCROLL_KEY, autoScrollEnabled ? "1" : "0");
  } catch (_) {
  }
  if (autoScrollEnabled) {
    stickToBottom = true;
    scrollLogToBottomIfSticky(true);
    startAutoScrollTimer();
  } else {
    stopAutoScrollTimer();
  }
}

function initAutoScrollToggle() {
  const toggle = el("auto-scroll");
  if (!toggle) return;
  let enabled = true;
  try {
    const raw = window.localStorage.getItem(RUFLO_AUTO_SCROLL_KEY);
    if (raw === "0") enabled = false;
  } catch (_) {
  }
  setAutoScrollEnabled(enabled);
  toggle.addEventListener("change", () => {
    setAutoScrollEnabled(toggle.checked);
  });
}

function renderRufloModels() {
  const sel = el("ruflo-model");
  if (!sel) return;
  if (!rufloModels.length) {
    sel.innerHTML = '<option value="">(modelos indisponíveis)</option>';
    sel.disabled = true;
    return;
  }
  const groups = {};
  rufloModels.forEach(m => {
    const g = m.group || "geral";
    (groups[g] = groups[g] || []).push(m);
  });
  let html = "";
  Object.keys(groups).sort().forEach(g => {
    html += '<optgroup label="' + escapeHtml(g) + '">';
    groups[g].forEach(m => {
      const lbl = m.label || m.id;
      const suffix = m.available ? "" : " (sem chave)";
      html += '<option value="' + escapeHtml(m.id) + '"'
        + (m.available ? "" : " disabled")
        + '>' + escapeHtml(lbl + suffix) + '</option>';
    });
    html += '</optgroup>';
  });
  sel.innerHTML = html;
  sel.disabled = false;
  const picked = rufloModels.find(m => m.id === rufloActiveModelId && m.available);
  const fallback = rufloModels.find(m => m.id === rufloDefaultModelId && m.available)
    || rufloModels.find(m => m.available);
  const chosen = picked || fallback;
  if (chosen) {
    rufloActiveModelId = chosen.id;
    sel.value = chosen.id;
  }
}

async function loadRufloModels() {
  try {
    const data = await api("/openclaw/models", { cache: "no-cache" }, 15000);
    if (!data.ok) return;
    rufloModels = Array.isArray(data.models) ? data.models : [];
    rufloDefaultModelId = data.default_model_id || "";
    let stored = "";
    try { stored = window.localStorage.getItem(RUFLO_MODEL_KEY) || ""; } catch (_) {}
    if (stored) rufloActiveModelId = stored;
    if (!rufloActiveModelId) rufloActiveModelId = rufloDefaultModelId;
    renderRufloModels();
  } catch (_) {
    /* optional */
  }
}

function initRufloModelPicker() {
  const sel = el("ruflo-model");
  if (!sel) return;
  sel.addEventListener("change", () => {
    rufloActiveModelId = sel.value || "";
    try { window.localStorage.setItem(RUFLO_MODEL_KEY, rufloActiveModelId); } catch (_) {}
  });
}

function bindLogScroll() {
  if (logScrollBound) return;
  const log = el("log");
  if (!log) return;
  log.addEventListener("scroll", () => {
    const slack = log.scrollHeight - log.scrollTop - log.clientHeight;
    stickToBottom = slack < 80;
  });
  logScrollBound = true;
  startAutoScrollTimer();
  window.addEventListener("beforeunload", () => {
    stopAutoScrollTimer();
  });
}

function scrollLogToBottomIfSticky(force) {
  const log = el("log");
  if (!log) return;
  if (!autoScrollEnabled) return;
  if (!force && !stickToBottom) return;
  log.scrollTop = log.scrollHeight;
  stickToBottom = true;
}

function el(id) { return document.getElementById(id); }
function escapeHtml(s) {
  return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}

async function api(path, opt, timeoutMs) {
  const ctrl = new AbortController();
  const t = setTimeout(() => ctrl.abort(), timeoutMs || 120000);
  try {
    const r = await fetch(path, Object.assign(
      { cache: "no-cache", credentials: "same-origin" },
      opt || {},
      { signal: ctrl.signal }
    ));
    const raw = await r.text();
    let data = {};
    if (raw) {
      try { data = JSON.parse(raw); } catch (_) {
        throw new Error("Resposta inválida (HTTP " + r.status + ")");
      }
    }
    if (!r.ok || data.ok === false) {
      const msg = data.error || data.message
        || (r.status === 401 ? "Não autenticado — abra /login"
        : r.status === 403 ? "403 Forbidden — verifique login ou ignore 403 de flo.ruv.io/debug/config"
        : ("HTTP " + r.status + (raw ? "" : " (sem corpo)")));
      throw new Error(msg);
    }
    return data;
  } finally { clearTimeout(t); }
}

function renderSessions() {
  const box = el("sessions");
  if (!sessions.length) {
    box.innerHTML = '<p style="color:var(--muted);padding:8px;">Nenhuma conversa — crie uma nova.</p>';
    return;
  }
  box.innerHTML = sessions.map(s => {
    const key = s.key || s.session_key || "";
    const rowCls = key === activeKey ? "sess-row active" : "sess-row";
    const title = escapeHtml(s.title || key);
    const teamBadge = s.team_id
      ? '<div class="m" style="color:var(--accent);font-size:10px;">🏷 ' + escapeHtml(s.team_id) + '</div>'
      : '<div class="m" style="color:orange;font-size:10px;">⚠ sem time</div>';
    return '<div class="' + rowCls + '" data-key="' + escapeHtml(key) + '">' +
      '<button type="button" class="sess" data-action="open" data-key="' + escapeHtml(key) + '">' +
        '<div class="t">' + title + '</div>' +
        teamBadge +
        '<div class="m">' + escapeHtml(key.slice(0, 40)) + '</div>' +
      '</button>' +
      '<button type="button" class="sess-del" data-action="delete" data-key="' + escapeHtml(key) +
        '" title="Apagar conversa" aria-label="Apagar conversa">×</button>' +
    '</div>';
  }).join("");
  box.querySelectorAll('[data-action="open"]').forEach(btn => {
    btn.addEventListener("click", () => selectSession(btn.dataset.key));
  });
  box.querySelectorAll('[data-action="delete"]').forEach(btn => {
    btn.addEventListener("click", ev => {
      ev.stopPropagation();
      deleteSession(btn.dataset.key);
    });
  });
}

async function deleteSession(key) {
  if (!key) return;
  const sess = sessions.find(s => (s.key || s.session_key) === key);
  const label = (sess && (sess.title || key)) || key;
  if (!window.confirm('Apagar a conversa "' + label + '"? Esta ação não pode ser desfeita.')) return;
  try {
    await api(API + "/session/delete", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ session_key: key }),
    }, 20000);
    if (key === activeKey) {
      activeKey = null;
      el("log").innerHTML = "";
      lastRenderedKey = null;
      lastRenderedCount = 0;
      liveProgressNode = null;
      stickToBottom = true;
      el("status").textContent = "Conversa apagada.";
    }
    delete historyOpenByKey[key];
    await loadSessions();
  } catch (e) {
    alert("Não foi possível apagar: " + e.message);
  }
}

function renderRichBody(container, text) {
  // Split text into code/text segments based on:
  //   <bash>…</bash> / <sh>…</sh> / <shell>…</shell>
  //   ```lang\n…\n```
  // Everything else is plain text rendered with preserved whitespace.
  let src = String(text || "");
  // Normaliza marcação de ferramentas para não vazar tags técnicas no chat.
  src = src
    .replace(/<qclaw_run_shell>\s*<command>([\s\S]*?)<\/command>\s*<\/qclaw_run_shell>/gi, (_, cmd) => {
      return "<bash>\n" + String(cmd || "") + "\n</bash>";
    })
    .replace(/<command>([\s\S]*?)<\/command>/gi, (_, cmd) => {
      return "<bash>\n" + String(cmd || "") + "\n</bash>";
    })
    .replace(/<\/??qclaw_[a-z0-9_:-]+>/gi, "")
    .replace(/\n{3,}/g, "\n\n");
  const re = /<(bash|sh|shell)>([\s\S]*?)<\/\1>|```([a-zA-Z0-9_+-]*)\n?([\s\S]*?)```/g;
  let lastIdx = 0;
  let m;
  const appendText = (chunk) => {
    if (!chunk) return;
    const span = document.createElement("span");
    span.className = "body-text";
    span.textContent = chunk;
    container.appendChild(span);
  };
  const appendCode = (lang, code) => {
    const block = document.createElement("div");
    block.className = "code-block";
    const head = document.createElement("div");
    head.className = "code-head";
    const label = document.createElement("span");
    label.textContent = lang || "code";
    const copy = document.createElement("button");
    copy.type = "button";
    copy.className = "code-copy";
    copy.textContent = "copiar";
    copy.addEventListener("click", () => {
      try {
        navigator.clipboard.writeText(code);
        copy.textContent = "copiado!";
        setTimeout(() => { copy.textContent = "copiar"; }, 1500);
      } catch (e) { /* ignore */ }
    });
    head.appendChild(label);
    head.appendChild(copy);
    const pre = document.createElement("pre");
    pre.textContent = code.replace(/\s+$/, "");
    block.appendChild(head);
    block.appendChild(pre);
    container.appendChild(block);
  };
  while ((m = re.exec(src)) !== null) {
    if (m.index > lastIdx) appendText(src.slice(lastIdx, m.index));
    if (m[1]) {
      appendCode(m[1].toLowerCase(), (m[2] || "").replace(/^\n/, ""));
    } else {
      appendCode((m[3] || "").toLowerCase() || "code", m[4] || "");
    }
    lastIdx = re.lastIndex;
  }
  if (lastIdx < src.length) appendText(src.slice(lastIdx));
  if (!container.childNodes.length) appendText(src);
}

function appendMsg(role, text, meta) {
  const div = document.createElement("div");
  div.className = "msg " + role;
  renderRichBody(div, text);
  if (meta) {
    const m = document.createElement("span");
    m.className = "meta";
    m.textContent = meta;
    div.appendChild(m);
  }
  el("log").appendChild(div);
  scrollLogToBottomIfSticky();
}

function appendReasoning(text, open) {
  const body = String(text || "").trim();
  if (!body) return;
  const details = document.createElement("details");
  details.className = "msg reasoning";
  if (open !== false) details.open = true;
  const summary = document.createElement("summary");
  summary.textContent = "Reasoning RuFlo";
  const pre = document.createElement("div");
  pre.className = "reasoning-body";
  pre.textContent = body;
  details.appendChild(summary);
  details.appendChild(pre);
  el("log").appendChild(details);
  scrollLogToBottomIfSticky();
}

function renderOrchReasoning(ruflo) {
  if (!ruflo) return;
  const text = ruflo.reasoning || "";
  if (text) el("orch-pre").textContent = text;
  if (ruflo.bash_approval === "waiting") {
    setBashApprovalUi(true);
  } else if (ruflo.bash_approval === "granted" || ruflo.bash_approval === "granted-error" || ruflo.bash_approval === "denied" || ruflo.bash_approval === "missing") {
    setBashApprovalUi(false);
  }
}

function clearLiveProgress() {
  liveProgressText = "";
  if (liveProgressNode && liveProgressNode.parentNode) liveProgressNode.remove();
  liveProgressNode = null;
}

function setLiveProgress(text) {
  const line = String(text || "").trim();
  if (!line) return;
  liveProgressText = line;
  if (!liveProgressNode) {
    liveProgressNode = document.createElement("div");
    liveProgressNode.className = "msg status live";
    liveProgressNode.id = "ruflo-live-progress";
    el("log").appendChild(liveProgressNode);
  }
  liveProgressNode.textContent = line;
  scrollLogToBottomIfSticky(true);
}

function appendStatusMsg(text) {
  const body = String(text || "").trim();
  if (!body) return;
  const div = document.createElement("div");
  div.className = "msg status";
  div.textContent = body;
  el("log").appendChild(div);
  scrollLogToBottomIfSticky(!!pendingJob);
}

function renderChatMessage(m) {
  const role = m.role || "";
  if (role === "assistant" && rufloSkillHint) {
    appendStatusMsg("Skill em uso: " + rufloSkillHint);
    rufloSkillHint = "";
  }
  if (role === "reasoning") {
    appendReasoning(m.text || "", false);
    return;
  }
  if (role === "status") {
    appendStatusMsg(m.text || "");
    return;
  }
  if (role === "user" || role === "assistant") {
    appendMsg(role === "user" ? "user" : "bot", m.text || "", "");
  }
}

function hasPendingBashApproval(msgs) {
  const items = Array.isArray(msgs) ? msgs : [];
  for (let i = items.length - 1; i >= 0; i--) {
    const row = items[i] || {};
    if (row.role !== "assistant" && row.role !== "status") continue;
    const text = String(row.text || "");
    return /responda\s+allow\b[\s\S]*\bcancelar\b/i.test(text);
  }
  return false;
}

function setBashApprovalUi(show) {
  pendingBashApprovalUi = !!show;
  const bar = el("approval-bar");
  if (!bar) return;
  bar.hidden = !pendingBashApprovalUi;
}

function isApprovalDecisionText(text) {
  const upper = String(text || "").trim().toUpperCase();
  return upper === "ALLOW" || upper === "ALLOW!" || upper === "CANCELAR" || upper === "CANCEL" || upper === "DENY" || upper === "NEGAR";
}

async function sendApprovalDecision(decision) {
  if (!decision) return;
  if (!activeKey) {
    appendMsg("err", "Não encontrei sessão ativa para responder à aprovação.", "");
    return;
  }
  const sendBtn = el("send");
  const previousDisabled = !!(sendBtn && sendBtn.disabled);
  if (sendBtn) sendBtn.disabled = true;
  setBashApprovalUi(false);
  appendMsg("user", decision, "");
  if (activeKey && lastRenderedKey === activeKey) {
    lastRenderedCount += 1;
  }
  try {
    const data = await api(API + "/send", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ message: decision, session_key: activeKey, model_id: rufloActiveModelId || undefined }),
    }, 15000);
    if (data.async && data.jobId) {
      pendingJob = data.jobId;
      setLiveProgress("RuFlo + LLM em curso…");
      el("status").textContent = "RuFlo + LLM em curso…";
      await pollJob(data.jobId);
      return;
    }
    renderOrchReasoning(data.ruflo);
    await loadMessages({ force: true });
    el("status").textContent = activeKey ? ("Sessão: " + activeKey) : "Pronto";
  } catch (e) {
    setBashApprovalUi(true);
    appendMsg("err", e.message || String(e), "");
  } finally {
    if (sendBtn) sendBtn.disabled = previousDisabled && !!pendingJob;
    if (sendBtn && !pendingJob) sendBtn.disabled = false;
  }
}

function formatJobProgress(data) {
  const progressLine = (data.lastProgress || "").split("\n")[0];
  const modelPrefix = data.modelLabel ? data.modelLabel + " · " : "";
  let text = "";
  if (data.toolMax > 0) {
    text = modelPrefix + "Ferramentas: passo " + (data.toolTurn || 0) + "/" + data.toolMax +
      (progressLine ? " — " + progressLine : "");
  } else if (progressLine) {
    text = modelPrefix + progressLine;
  } else {
    text = modelPrefix + "RuFlo + LLM a processar…";
  }
  const elapsed = data.elapsedSeconds != null
    ? Number(data.elapsedSeconds)
    : (data.startedAt ? Math.max(0, Math.floor(Date.now() / 1000 - data.startedAt)) : 0);
  if (elapsed > 0 && !progressLine) text += " (" + elapsed + "s)";
  return { text, progressLine, elapsed };
}

async function loadOrchStatus() {
  try {
    const data = await api(API + "/status", {}, 60000);
    if (data.hosted_ui_url) el("link-hosted").href = data.hosted_ui_url;
    if (data.local_ui_url) el("link-local").href = data.local_ui_url;
    const swarm = data.swarm || {};
    const hive = data.hive || {};
    const active = swarm.hasActiveSwarm != null ? swarm.hasActiveSwarm : "?";
    const hiveWorkers = Array.isArray(hive.workers) ? hive.workers.length : 0;
    const hiveStatus = hive.status || (data.hive_ok ? "active" : "idle");
    const lines = [
      "Swarm ativo: " + active,
      "Swarm agentes: " + String((swarm.agents && swarm.agents.total) || 0),
      "Hive status: " + hiveStatus,
      "Hive workers: " + hiveWorkers,
    ];
    if (data.swarm_ok === false && data.swarm_error) lines.push(data.swarm_error);
    if (data.hive_ok === false && data.hive_error) lines.push(data.hive_error);
    el("orch-pre").textContent = lines.join("\n");
  } catch (e) {
    el("orch-pre").textContent = "Status indisponível: " + e.message;
  }
}

async function loadSessions() {
  el("status").textContent = "Carregando sessões…";
  setBashApprovalUi(false);
  const data = await api(API + "/sessions", {}, 30000);
  sessions = data.sessions || [];
  if (!activeKey && data.default_session_key) activeKey = data.default_session_key;
  renderSessions();
  if (activeKey) await loadMessages();
  else el("status").textContent = "Pronto — nova conversa ou selecione uma sessão";
}

async function loadMessages(opts) {
  opts = opts || {};
  const silent = !!opts.silent;
  const force = !!opts.force;
  if (!activeKey) return;
  const capturedKey = activeKey;
  bindLogScroll();
  setBashApprovalUi(false);
  if (!silent) el("status").textContent = "Carregando mensagens…";
  const data = await api(API + "/messages?session_key=" + encodeURIComponent(capturedKey), {}, silent ? 15000 : 30000);
  // Guard: if user switched session while awaiting, discard stale response.
  if (activeKey !== capturedKey) return;
  const msgs = data.messages || [];
  const sameSession = lastRenderedKey === capturedKey;
  const grewOnly = sameSession && msgs.length >= lastRenderedCount;
  if (silent && !force && sameSession && msgs.length === lastRenderedCount) {
    // Nada novo — não tocar no DOM nem no scroll do usuário.
    if (pendingJob && liveProgressText) setLiveProgress(liveProgressText);
    return;
  }
  if (!sameSession) {
    // Troca de sessão: força stick-to-bottom no render inicial.
    stickToBottom = true;
  }
  if (grewOnly && lastRenderedCount > 0) {
    // Reaproveita o DOM e só anexa o que é novo, preservando scroll.
    const live = document.getElementById("ruflo-live-progress");
    if (live && live.parentNode) live.remove();
    for (let i = lastRenderedCount; i < msgs.length; i++) renderChatMessage(msgs[i]);
  } else {
    el("log").innerHTML = "";
    liveProgressNode = null;
    msgs.forEach(renderChatMessage);
    collapseOlderMessages();
  }
  lastRenderedKey = capturedKey;
  lastRenderedCount = msgs.length;
  if (pendingJob && liveProgressText) setLiveProgress(liveProgressText);
  if (pendingJob) scrollLogToBottomIfSticky(true);
  if (!silent) el("status").textContent = "Sessão: " + capturedKey;
}

async function flushMessagesAfterDone(beforeCount) {
  const maxAttempts = 8;
  for (let i = 0; i < maxAttempts; i++) {
    await loadMessages({ silent: true, force: true });
    if (lastRenderedCount > beforeCount) return true;
    await new Promise(r => setTimeout(r, i < 2 ? 300 : 650));
  }
  return false;
}

function collapseOlderMessages() {
  const log = el("log");
  if (!log) return;
  // Skip the live-progress node if present (it should always stay visible).
  const all = Array.from(log.children).filter(n => n.id !== "ruflo-live-progress");
  const hidden = all.length - RUFLO_HISTORY_KEEP_VISIBLE;
  if (hidden <= 0) return;
  const details = document.createElement("details");
  details.className = "history-toggle";
  const sessionKey = activeKey || "";
  details.open = !!historyOpenByKey[sessionKey];
  details.addEventListener("toggle", () => {
    historyOpenByKey[sessionKey] = details.open;
    if (details.open) log.scrollTop = details.offsetTop;
  });
  const summary = document.createElement("summary");
  const label = hidden === 1
    ? "1 mensagem anterior"
    : hidden + " mensagens anteriores";
  summary.textContent = label + " — clique para mostrar/ocultar";
  const body = document.createElement("div");
  body.className = "history-body";
  for (let i = 0; i < hidden; i++) body.appendChild(all[i]);
  details.appendChild(summary);
  details.appendChild(body);
  log.insertBefore(details, log.firstChild);
}

async function selectSession(key, agent) {
  messagesLoadSeq += 1;
  activeKey = key;
  activeAgent = agent || activeAgent || "ruflo";
  lastRenderedKey = null;
  lastRenderedCount = 0;
  stickToBottom = true;
  renderSessions();
  el("send").disabled = false;
  await loadMessages({ force: true });
}

async function newSession() {
  const data = await api(API + "/session/new", { method: "POST", headers: { "Content-Type": "application/json" }, body: "{}" }, 15000);
  activeKey = data.session_key;
  await loadSessions();
}

async function pollJob(jobId) {
  const startedAtMs = Date.now();
  const deadline = Date.now() + 660000;
  let lastProgressShown = "";
  let lastProgressAt = Date.now();
  let lastMsgReloadAt = 0;
  let userCheckinIdx = 0;
  let pollErrors = 0;
  const maxPollErrors = 4;
  let userCheckinTimer = null;
  const checkins = [
    "Ainda a trabalhar nisso. Vou te atualizando.",
    "Continuo processando os passos do RuFlo e do modelo.",
    "Sem travar: sigo executando e já volto com resultado.",
    "Ainda em andamento. Obrigado por aguardar.",
  ];
  function stopCheckins() {
    if (userCheckinTimer) {
      clearInterval(userCheckinTimer);
      userCheckinTimer = null;
    }
  }
  userCheckinTimer = setInterval(() => {
    if (!pendingJob) return;
    const phrase = checkins[userCheckinIdx % checkins.length];
    userCheckinIdx += 1;
    const elapsedNow = Math.max(0, Math.floor((Date.now() - startedAtMs) / 1000));
    appendStatusMsg(phrase + (elapsedNow > 0 ? " (" + elapsedNow + "s)" : ""));
  }, RUFLO_USER_CHECKIN_MS);
  setLiveProgress("Pedido recebido — RuFlo a fazer routing…");
  while (Date.now() < deadline) {
    let data;
    try {
      data = await api("/openclaw/send/status?job_id=" + encodeURIComponent(jobId), {}, 8000);
      pollErrors = 0;
    } catch (e) {
      pollErrors += 1;
      const warn = "Ligação instável ao acompanhar resposta (" + pollErrors + "/" + maxPollErrors + ") — a retomar…";
      setLiveProgress(warn);
      el("status").textContent = warn;
      if (pollErrors >= maxPollErrors) {
        pendingJob = null;
        stopCheckins();
        clearLiveProgress();
        el("send").disabled = false;
        appendMsg("err", "Não consegui acompanhar o progresso do RuFlo agora. Atualize a sessão para ver se a resposta já chegou.", "");
        return;
      }
      await new Promise(r => setTimeout(r, 1200));
      continue;
    }
    if (data.ok === false) throw new Error(data.error || "job não encontrado");
    const { text: progressText, progressLine } = formatJobProgress(data);
    const progressChanged = !!(progressLine && progressLine !== lastProgressShown);
    const now = Date.now();
    if (progressChanged) {
      lastProgressShown = progressLine;
      lastProgressAt = now;
      appendStatusMsg(progressText);
    }
    let statusText = progressText;
    const elapsed = data.elapsedSeconds != null ? Number(data.elapsedSeconds) : 0;
    if (elapsed > 0 && Date.now() - lastProgressAt > 10000) {
      statusText += " (" + elapsed + "s, ainda a processar…)";
    }
    setLiveProgress(statusText);
    el("status").textContent = statusText;
    if (progressChanged || now - lastMsgReloadAt >= RUFLO_MSG_RELOAD_MS) {
      lastMsgReloadAt = now;
      await loadMessages({ silent: true });
    }
    if (data.status === "done") {
      pendingJob = null;
      stopCheckins();
      clearLiveProgress();
      const result = data.result || {};
      if (!result.ok) {
        appendMsg("err", result.error || "envio falhou", "");
      } else {
        renderOrchReasoning(result.ruflo);
        const before = lastRenderedCount;
        const delivered = await flushMessagesAfterDone(before);
        const directReply = String(result.reply || "").trim();
        if (!delivered && directReply) {
          if (rufloSkillHint) appendStatusMsg("Skill em uso: " + rufloSkillHint);
          appendMsg("bot", directReply, "resposta instantânea (aguardando persistência)");
          // Alinha o contador para evitar duplicar quando o backend persistir logo em seguida.
          if (activeKey && lastRenderedKey === activeKey) {
            lastRenderedCount += 1;
          }
          void loadMessages({ silent: true, force: true }).catch(() => {});
        } else if (!delivered) {
          appendStatusMsg("RuFlo concluiu, mas não trouxe texto nesta tentativa. Vou manter o histórico carregado para não perder contexto.");
        }
      }
      el("status").textContent = activeKey ? ("Sessão: " + activeKey) : "Pronto";
      el("send").disabled = false;
      return;
    }
    if (data.status === "error") {
      pendingJob = null;
      stopCheckins();
      clearLiveProgress();
      const result = data.result || {};
      appendMsg("err", data.error || result.error || "falhou", "");
      el("send").disabled = false;
      return;
    }
    await new Promise(r => setTimeout(r, RUFLO_JOB_POLL_MS));
  }
  pendingJob = null;
  stopCheckins();
  clearLiveProgress();
  el("send").disabled = false;
  appendMsg("err", "Timeout aguardando resposta. A resposta pode chegar depois; recarregue a sessão para confirmar.", "");
}

async function sendMessage() {
  const text = el("input").value.trim();
  if (!text) return;
  const hideApprovalBar = pendingBashApprovalUi && isApprovalDecisionText(text);
  el("send").disabled = true;
  if (hideApprovalBar) setBashApprovalUi(false);
  rufloSkillHint = isCronTopic(text) ? "qclaw-ruflo-cron-jobs" : "";
  appendMsg("user", text, "");
  // Mantém o contador alinhado para que loadMessages({silent:true}) durante o
  // polling não reanexe a mesma mensagem do usuário vinda do backend.
  if (activeKey && lastRenderedKey === activeKey) {
    lastRenderedCount += 1;
  }
  el("input").value = "";
  try {
    const body = { message: text, session_key: activeKey || undefined, model_id: rufloActiveModelId || undefined };
    const data = await api(API + "/send", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(body),
    }, 15000);
    if (!activeKey && data.sessionKey) {
      activeKey = data.sessionKey;
      await loadSessions();
    }
    if (data.async && data.jobId) {
      pendingJob = data.jobId;
      setLiveProgress("RuFlo + LLM em curso…");
      el("status").textContent = "RuFlo + LLM em curso…";
      await pollJob(data.jobId);
    } else if (data.reply) {
      if (rufloSkillHint) appendStatusMsg("Skill em uso: " + rufloSkillHint);
      renderOrchReasoning(data.ruflo);
      await loadMessages();
      el("send").disabled = false;
    } else {
      await loadMessages();
      el("send").disabled = false;
    }
  } catch (e) {
    if (hideApprovalBar) setBashApprovalUi(true);
    appendMsg("err", e.message, "");
    el("send").disabled = false;
  }
}

el("btn-new").addEventListener("click", () => newSession().catch(e => alert(e.message)));
el("send").addEventListener("click", sendMessage);
el("bash-allow-btn").addEventListener("click", () => {
  sendApprovalDecision("ALLOW").catch(e => appendMsg("err", e.message || String(e), ""));
});
el("bash-cancel-btn").addEventListener("click", () => {
  sendApprovalDecision("CANCELAR").catch(e => appendMsg("err", e.message || String(e), ""));
});
el("input").addEventListener("keydown", ev => {
  if (ev.key === "Enter" && !ev.shiftKey) { ev.preventDefault(); sendMessage(); }
});

async function bootRufloChat() {
  try {
    initAutoScrollToggle();
    initRufloModelPicker();
    loadRufloModels();
    if (typeof window.qcmAuthGate === "function") {
      const auth = await window.qcmAuthGate();
      if (!auth || auth.ok === false) {
        el("status").textContent = "Faça login em /login para usar o chat RuFlo.";
        return;
      }
    }
    loadOrchStatus();
    void loadSessions().catch((e) => {
      el("status").textContent = "Erro: " + e.message;
    });
  } catch (e) {
    el("status").textContent = "Erro: " + e.message;
  }
}
bootRufloChat();
</script>
</body>
</html>
"""


def build_ruflo_chat_html(
  hermes_dashboard_url: Optional[str] = None,
  user_checkin_interval_seconds: float = 5.0,
) -> str:
  checkin_ms = max(5000, int(float(user_checkin_interval_seconds) * 1000))
  html = RUFLO_CHAT_PAGE.replace("__RUFLO_USER_CHECKIN_MS__", str(checkin_ms))
  return _inject_app_nav(
    html,
        "ruflo_chat",
        hermes_dashboard_url=hermes_dashboard_url,
    )


ERRORS_PAGE = r"""<!doctype html>
<html lang="pt-br">
<head>
<meta charset="utf-8">
<title>gois — log de erros</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<style>
  :root {
    --bg: #0f1115; --panel: #171a21; --panel-2: #1e222c; --border: #262b36;
    --fg: #e6e8ee; --muted: #8a93a6; --ok: #3ddc84; --bad: #ff5a5f;
    --accent: #ff8a65; --accent-dim: rgba(255,138,101,.12);
    --mono: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }
  * { box-sizing: border-box; }
  html, body { margin: 0; min-height: 100%; background: var(--bg); color: var(--fg);
    font: 14px/1.45 -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; }
  body { display: flex; flex-direction: column; }
  __APP_NAV_CSS__
  main { flex: 1; padding: 20px 24px; max-width: 1400px; margin: 0 auto; width: 100%; }
  h1 { margin: 0 0 6px; font-size: 22px; }
  .sub { color: var(--muted); font-size: 13px; margin: 0 0 16px; }
  .toolbar { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 14px; align-items: center; }
  .toolbar input, .toolbar select, .toolbar button {
    background: var(--panel-2); color: var(--fg); border: 1px solid var(--border);
    border-radius: 8px; padding: 8px 12px; font: inherit; font-size: 13px;
  }
  .toolbar input { flex: 1; min-width: 180px; max-width: 360px; }
  .toolbar button { cursor: pointer; font-family: var(--mono); }
  .toolbar button:hover { border-color: var(--accent); }
  .stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin-bottom: 18px; }
  @media (max-width: 720px) { .stats { grid-template-columns: repeat(2, 1fr); } }
  .stat { background: var(--panel); border: 1px solid var(--border); border-radius: 10px; padding: 12px 14px; }
  .stat .lbl { font-size: 10px; text-transform: uppercase; letter-spacing: .7px; color: var(--muted); }
  .stat .val { font-size: 24px; font-weight: 700; font-family: var(--mono); margin-top: 4px; }
  .stat.bad .val { color: var(--bad); }
  .status-line { font-family: var(--mono); font-size: 12px; color: var(--muted); margin-bottom: 12px; }
  .panel { background: var(--panel); border: 1px solid var(--border); border-radius: 10px; overflow: hidden; }
  table { width: 100%; border-collapse: collapse; font-size: 13px; }
  th { text-align: left; padding: 10px 12px; color: var(--muted); font-size: 11px;
    text-transform: uppercase; border-bottom: 1px solid var(--border); position: sticky; top: 0;
    background: var(--panel); }
  td { padding: 10px 12px; border-bottom: 1px dashed var(--border); vertical-align: top; }
  tr:last-child td { border-bottom: 0; }
  tr:hover td { background: rgba(255,255,255,.02); }
  td.mono { font-family: var(--mono); font-size: 11px; white-space: nowrap; color: var(--muted); }
  td.msg { font-family: var(--mono); font-size: 12px; white-space: pre-wrap; word-break: break-word; color: var(--fg); }
  td.cat { font-size: 11px; color: var(--accent); }
  td.src { font-size: 11px; color: var(--muted); max-width: 160px; word-break: break-all; }
  .empty { padding: 24px; text-align: center; color: var(--muted); }
  .sources { margin-top: 16px; font-size: 12px; color: var(--muted); }
  .sources summary { cursor: pointer; }
  .sources ul { margin: 8px 0 0; padding-left: 18px; font-family: var(--mono); font-size: 11px; }
  .miss { color: var(--bad); }
</style>
</head>
<body>
__APP_NAV__
<main>
  <h1>Log de erros</h1>
  <p class="sub">Agrega falhas do monitor, padrões do log scanner e linhas de erro nos ficheiros configurados.</p>
  <div class="toolbar">
    <input type="search" id="filter" placeholder="Filtrar mensagem, origem ou categoria…">
    <select id="source-filter"><option value="">Todas as origens</option></select>
    <button type="button" id="btn-refresh">Atualizar</button>
    <label style="display:flex;align-items:center;gap:6px;color:var(--muted);font-size:12px;">
      <input type="checkbox" id="auto-refresh" checked> Auto 30s
    </label>
  </div>
  <div class="status-line" id="status">A carregar…</div>
  <div class="stats">
    <div class="stat bad"><div class="lbl">Total</div><div class="val" id="v-total">—</div></div>
    <div class="stat"><div class="lbl">Ficheiros</div><div class="val" id="v-files">—</div></div>
    <div class="stat"><div class="lbl">Monitor</div><div class="val" id="v-monitor">—</div></div>
    <div class="stat"><div class="lbl">Em falta</div><div class="val" id="v-missing">—</div></div>
  </div>
  <div class="panel">
    <table>
      <thead><tr><th>Quando</th><th>Origem</th><th>Categoria</th><th>Mensagem</th></tr></thead>
      <tbody id="rows"><tr><td colspan="4" class="empty">—</td></tr></tbody>
    </table>
  </div>
  <details class="sources" id="sources-box" hidden>
    <summary>Ficheiros monitorizados</summary>
    <ul id="sources-list"></ul>
  </details>
</main>
<script>
const API = "/api/errors";
let allErrors = [];
let timer = null;

function el(id) { return document.getElementById(id); }
function escapeHtml(s) {
  return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}
function fmtTs(epoch, label) {
  if (label) return label;
  if (!epoch) return "—";
  try {
    const d = new Date(epoch * 1000);
    return d.toLocaleString("pt-BR");
  } catch (_) { return String(epoch); }
}

async function load() {
  el("status").textContent = "A carregar erros…";
  const r = await fetch(API + "?limit=500", { cache: "no-cache", credentials: "same-origin" });
  const data = await r.json();
  if (!r.ok || data.ok === false) throw new Error(data.error || ("HTTP " + r.status));
  allErrors = data.errors || [];
  const sum = data.summary || {};
  el("v-total").textContent = String(sum.total ?? allErrors.length);
  el("v-files").textContent = String(sum.from_logs ?? "—");
  el("v-monitor").textContent = String(sum.monitor_events ?? "—");
  el("v-missing").textContent = String(sum.sources_missing ?? "—");
  const sources = new Set();
  allErrors.forEach(e => {
    if (e.source_label) sources.add(e.source_label);
    else if (e.source) sources.add(e.source);
  });
  const sel = el("source-filter");
  const prev = sel.value;
  sel.innerHTML = '<option value="">Todas as origens</option>' +
    Array.from(sources).sort().map(s =>
      '<option value="' + escapeHtml(s) + '">' + escapeHtml(s) + '</option>'
    ).join("");
  sel.value = prev;
  const srcList = el("sources-list");
  const srcBox = el("sources-box");
  if (Array.isArray(data.sources) && data.sources.length) {
    srcBox.hidden = false;
    srcList.innerHTML = data.sources.map(s => {
      const cls = s.exists ? "" : ' class="miss"';
      return '<li' + cls + '>' + escapeHtml(s.path) + (s.exists ? "" : " (não encontrado)") + '</li>';
    }).join("");
  }
  render();
  el("status").textContent = "Atualizado " + new Date().toLocaleTimeString("pt-BR") +
    " · " + allErrors.length + " entrada(s)";
}

function render() {
  const q = el("filter").value.trim().toLowerCase();
  const src = el("source-filter").value;
  const rows = allErrors.filter(e => {
    const label = (e.source_label || e.source || "").toString();
    if (src && label !== src) return false;
    if (!q) return true;
    const hay = [e.line, e.category, label, e.source].join(" ").toLowerCase();
    return hay.includes(q);
  });
  const tbody = el("rows");
  if (!rows.length) {
    tbody.innerHTML = '<tr><td colspan="4" class="empty">Nenhum erro encontrado</td></tr>';
    return;
  }
  tbody.innerHTML = rows.map(e =>
    '<tr>' +
    '<td class="mono">' + escapeHtml(fmtTs(e.ts_epoch, e.ts)) + '</td>' +
    '<td class="src" title="' + escapeHtml(e.source || "") + '">' + escapeHtml(e.source_label || e.source || "—") + '</td>' +
    '<td class="cat">' + escapeHtml(e.category || "—") + '</td>' +
    '<td class="msg">' + escapeHtml(e.line || "") + '</td>' +
    '</tr>'
  ).join("");
}

function scheduleAuto() {
  if (timer) clearInterval(timer);
  timer = null;
  if (el("auto-refresh").checked) timer = setInterval(() => load().catch(() => {}), 30000);
}

el("btn-refresh").addEventListener("click", () => load().catch(e => { el("status").textContent = "Erro: " + e.message; }));
el("filter").addEventListener("input", render);
el("source-filter").addEventListener("change", render);
el("auto-refresh").addEventListener("change", scheduleAuto);
load().catch(e => { el("status").textContent = "Erro: " + e.message; });
scheduleAuto();
</script>
</body>
</html>
"""


def build_errors_html(hermes_dashboard_url: Optional[str] = None) -> str:
    return _inject_app_nav(
        ERRORS_PAGE,
        "errors",
        hermes_dashboard_url=hermes_dashboard_url,
    )


SKILLS_PAGE = r"""<!doctype html>
<html lang="pt-br">
<head>
<meta charset="utf-8">
<title>gois — skills OpenClaw</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<style>
  :root {
    --bg: #0f1115;
    --panel: #171a21;
    --panel-2: #1e222c;
    --border: #262b36;
    --fg: #e6e8ee;
    --muted: #8a93a6;
    --ok: #3ddc84;
    --bad: #ff5a5f;
    --warn: #ffb454;
    --accent: #6aa9ff;
    --accent-dim: rgba(106,169,255,.12);
    --mono: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }
  @media (prefers-color-scheme: light) {
    :root { --bg:#f5f6fa; --panel:#fff; --panel-2:#f0f2f7; --border:#e1e4ec;
            --fg:#15171c; --muted:#5b6477; }
  }
  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; min-height: 100%; background: var(--bg); color: var(--fg);
               font: 14px/1.45 -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; }
  body { display: flex; flex-direction: column; }
  __APP_NAV_CSS__
  main { flex: 1; padding: 24px 28px; max-width: 1200px; width: 100%; margin: 0 auto; }
  .toolbar { display: flex; flex-wrap: wrap; gap: 12px; align-items: center; margin-bottom: 18px; }
  .toolbar .grow { flex: 1; min-width: 220px; }
  .search { width: 100%; background: var(--panel); color: var(--fg);
            border: 1px solid var(--border); border-radius: 10px; padding: 12px 14px;
            font: inherit; font-size: 14px; }
  .search:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-dim); }
  .stats { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 16px; }
  .stat { background: var(--panel); border: 1px solid var(--border); border-radius: 10px;
          padding: 10px 14px; min-width: 120px; }
  .stat .label { color: var(--muted); font-size: 11px; text-transform: uppercase;
                 letter-spacing: .6px; margin-bottom: 4px; }
  .stat .value { font-size: 20px; font-weight: 600; font-family: var(--mono); }
  button.ctrl, select.ctrl { background: var(--panel); color: var(--fg);
                             border: 1px solid var(--border); border-radius: 8px;
                             padding: 8px 12px; font-size: 12px; font-family: var(--mono);
                             cursor: pointer; }
  button.ctrl:hover, select.ctrl:hover { border-color: var(--accent); }
  button.ctrl.active { color: var(--accent); border-color: var(--accent); background: var(--accent-dim); }
  .filters { display: flex; gap: 8px; flex-wrap: wrap; }
  .status-bar { color: var(--muted); font-size: 12px; font-family: var(--mono); margin-bottom: 14px; }
  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 12px; }
  .skill-card { background: var(--panel); border: 1px solid var(--border); border-radius: 10px;
                padding: 14px 16px; display: flex; flex-direction: column; gap: 8px; }
  .skill-card:hover { border-color: rgba(106,169,255,.35); }
  .skill-card .name { font-family: var(--mono); font-size: 13px; font-weight: 600; color: var(--accent);
                      word-break: break-word; }
  .skill-card .desc { color: var(--muted); font-size: 12px; line-height: 1.45;
                      display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  .skill-card .meta { color: var(--muted); font-size: 11px; font-family: var(--mono); word-break: break-all; }
  .skill-card .badges { display: flex; flex-wrap: wrap; gap: 6px; }
  .badge { display: inline-block; padding: 2px 8px; border-radius: 999px;
           background: var(--panel-2); border: 1px solid var(--border);
           color: var(--muted); font-size: 11px; font-family: var(--mono); }
  .badge.ok { color: var(--ok); border-color: rgba(61,220,132,.35); background: rgba(61,220,132,.08); }
  .badge.off { color: var(--bad); border-color: rgba(255,90,95,.35); background: rgba(255,90,95,.08); }
  .skill-card .actions { display: flex; gap: 8px; margin-top: auto; padding-top: 4px; }
  .skill-card .actions button { flex: 1; }
  .empty { color: var(--muted); font-style: italic; font-size: 14px; padding: 40px 20px;
           text-align: center; background: var(--panel); border: 1px dashed var(--border);
           border-radius: 10px; }
  .dirs { margin-top: 24px; background: var(--panel); border: 1px solid var(--border);
          border-radius: 10px; padding: 14px 16px; }
  .dirs h3 { margin: 0 0 8px; font-size: 11px; font-weight: 600; color: var(--muted);
             text-transform: uppercase; letter-spacing: .8px; }
  .dirs ul { margin: 0; padding-left: 18px; color: var(--muted); font-size: 12px;
             font-family: var(--mono); word-break: break-all; }
  .toast { position: fixed; bottom: 20px; right: 20px; background: var(--panel);
           border: 1px solid var(--accent); color: var(--fg); padding: 10px 14px;
           border-radius: 8px; font-size: 12px; font-family: var(--mono);
           opacity: 0; pointer-events: none; transition: opacity .2s; z-index: 100; }
  .toast.show { opacity: 1; }
</style>
</head>
<body>
__APP_NAV__
<main>
  <div class="toolbar">
    <div class="grow">
      <input type="search" class="search" id="skills-search" placeholder="Buscar por nome, slug ou descrição…" autofocus>
    </div>
    <select class="ctrl" id="agent-select" title="Agente OpenClaw">
      <option value="main">main</option>
    </select>
    <button type="button" class="ctrl" id="btn-refresh">Atualizar</button>
  </div>
  <div class="filters">
    <button type="button" class="ctrl active" data-filter="all">Todas</button>
    <button type="button" class="ctrl" data-filter="assigned">Do agente</button>
    <button type="button" class="ctrl" data-filter="enabled">Ativas</button>
  </div>
  <div class="stats" id="stats">
    <div class="stat"><div class="label">Exibidas</div><div class="value" id="stat-shown">—</div></div>
    <div class="stat"><div class="label">Total</div><div class="value" id="stat-total">—</div></div>
    <div class="stat"><div class="label">Do agente</div><div class="value" id="stat-assigned">—</div></div>
    <div class="stat"><div class="label">Ativas</div><div class="value" id="stat-enabled">—</div></div>
  </div>
  <div class="status-bar" id="status-bar">Carregando skills…</div>
  <div class="grid" id="skills-grid">
    <div class="empty">Carregando skills…</div>
  </div>
  <div class="dirs" id="skill-dirs" style="display:none">
    <h3>Diretórios escaneados</h3>
    <ul id="skill-dirs-list"></ul>
  </div>
</main>
<div class="toast" id="toast"></div>
<script>
const el = (id) => document.getElementById(id);
let skills = [];
let skillsFilter = "all";
let skillsQuery = "";
let activeAgent = "main";
let agents = ["main"];

function escapeHtml(s) {
  return String(s).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;");
}

function showToast(msg) {
  const t = el("toast");
  t.textContent = msg;
  t.classList.add("show");
  clearTimeout(showToast._timer);
  showToast._timer = setTimeout(() => t.classList.remove("show"), 1800);
}

function filteredSkills() {
  let rows = skills.slice();
  if (skillsFilter === "assigned") {
    rows = rows.filter((s) => s.assigned);
  } else if (skillsFilter === "enabled") {
    rows = rows.filter((s) => s.enabled !== false);
  }
  const q = skillsQuery.trim().toLowerCase();
  if (q) {
    rows = rows.filter((s) =>
      (s.name || "").toLowerCase().includes(q) ||
      (s.description || "").toLowerCase().includes(q) ||
      (s.slug || "").toLowerCase().includes(q) ||
      (s.path || "").toLowerCase().includes(q) ||
      (s.source || "").toLowerCase().includes(q)
    );
  }
  return rows;
}

function renderStats(data) {
  const rows = filteredSkills();
  el("stat-shown").textContent = rows.length;
  el("stat-total").textContent = skills.length;
  el("stat-assigned").textContent = data?.assigned_count ?? skills.filter((s) => s.assigned).length;
  el("stat-enabled").textContent = data?.enabled_count ?? skills.filter((s) => s.enabled !== false).length;
}

function renderSkills(data) {
  const box = el("skills-grid");
  const rows = filteredSkills();
  renderStats(data);
  el("status-bar").textContent = rows.length + " de " + skills.length + " skill(s) · agente " + activeAgent;
  if (!rows.length) {
    box.innerHTML = '<div class="empty">Nenhuma skill encontrada.</div>';
    return;
  }
  box.innerHTML = rows.map((s) => {
    const badges = [];
    if (s.assigned) badges.push('<span class="badge ok">agente</span>');
    if (s.enabled === false) badges.push('<span class="badge off">desativada</span>');
    else if (!s.assigned) badges.push('<span class="badge">disponível</span>');
    const meta = [s.source, s.path].filter(Boolean).join(" / ");
    return '<article class="skill-card">' +
      '<div class="name">' + escapeHtml(s.name) + '</div>' +
      (s.description ? '<div class="desc">' + escapeHtml(s.description) + '</div>' : '') +
      (meta ? '<div class="meta">' + escapeHtml(meta) + '</div>' : '') +
      '<div class="badges">' + badges.join("") + '</div>' +
      '<div class="actions">' +
      '<button type="button" class="ctrl" data-action="copy" data-name="' + escapeHtml(s.name) + '">Copiar</button>' +
      '<button type="button" class="ctrl" data-action="chat" data-name="' + escapeHtml(s.name) + '">Usar no chat</button>' +
      '</div></article>';
  }).join("");
  box.querySelectorAll("[data-action=copy]").forEach((btn) => {
    btn.addEventListener("click", () => {
      navigator.clipboard.writeText(btn.dataset.name || "").then(
        () => showToast("Copiado: " + btn.dataset.name),
        () => showToast(btn.dataset.name || "")
      );
    });
  });
  box.querySelectorAll("[data-action=chat]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const name = btn.dataset.name || "";
      const q = new URLSearchParams({ skill: name, agent: activeAgent });
      window.location.href = "/chat?" + q.toString();
    });
  });
}

function renderDirs(dirs) {
  const wrap = el("skill-dirs");
  const list = el("skill-dirs-list");
  if (!dirs || !dirs.length) {
    wrap.style.display = "none";
    return;
  }
  wrap.style.display = "";
  list.innerHTML = dirs.map((d) => "<li>" + escapeHtml(d) + "</li>").join("");
}

function updateAgentSelect() {
  const sel = el("agent-select");
  if (!sel) return;
  sel.innerHTML = agents.map((a) =>
    '<option value="' + escapeHtml(a) + '"' + (a === activeAgent ? " selected" : "") + '>' +
    escapeHtml(a) + '</option>'
  ).join("");
}

async function loadSkills() {
  el("status-bar").textContent = "Carregando skills…";
  try {
    const q = new URLSearchParams({ agent: activeAgent });
    const r = await fetch("/openclaw/skills?" + q.toString(), { cache: "no-cache" });
    const data = await r.json();
    if (!data.ok) throw new Error(data.error || "falha ao carregar");
    skills = data.skills || [];
    if (data.agentId && !agents.includes(data.agentId)) {
      agents.unshift(data.agentId);
    }
    activeAgent = data.agentId || activeAgent;
    updateAgentSelect();
    renderSkills(data);
    renderDirs(data.skill_dirs || []);
  } catch (e) {
    el("skills-grid").innerHTML = '<div class="empty">Erro: ' + escapeHtml(e.message) + '</div>';
    el("status-bar").textContent = "";
  }
}

el("skills-search").addEventListener("input", (ev) => {
  skillsQuery = ev.target.value || "";
  renderSkills();
});
document.querySelectorAll(".filters button").forEach((btn) => {
  btn.addEventListener("click", () => {
    document.querySelectorAll(".filters button").forEach((b) => b.classList.remove("active"));
    btn.classList.add("active");
    skillsFilter = btn.dataset.filter || "all";
    renderSkills();
  });
});
el("btn-refresh").addEventListener("click", loadSkills);
el("agent-select").addEventListener("change", (ev) => {
  activeAgent = ev.target.value || "main";
  loadSkills();
});

const params = new URLSearchParams(window.location.search);
if (params.get("q")) {
  skillsQuery = params.get("q");
  el("skills-search").value = skillsQuery;
}
if (params.get("agent")) {
  activeAgent = params.get("agent");
}

loadSkills();
</script>
</body>
</html>
"""


def build_skills_html(hermes_dashboard_url: Optional[str] = None) -> str:
    return _inject_app_nav(
        SKILLS_PAGE,
        "skills",
        hermes_dashboard_url=hermes_dashboard_url,
    )


ACTIVE_AGENTS_PAGE = r"""<!doctype html>
<html lang="pt-br">
<head>
<meta charset="utf-8">
<title>gois — agentes ativos</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<style>
  :root {
    --bg: #0f1115;
    --panel: #171a21;
    --panel-2: #1e222c;
    --border: #262b36;
    --fg: #e6e8ee;
    --muted: #8a93a6;
    --ok: #3ddc84;
    --bad: #ff5a5f;
    --warn: #ffb454;
    --accent: #6aa9ff;
    --accent-dim: rgba(106,169,255,.12);
    --mono: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }
  @media (prefers-color-scheme: light) {
    :root { --bg:#f5f6fa; --panel:#fff; --panel-2:#f0f2f7; --border:#e1e4ec;
            --fg:#15171c; --muted:#5b6477; }
  }
  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; min-height: 100%; background: var(--bg); color: var(--fg);
               font: 14px/1.45 -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; }
  body { display: flex; flex-direction: column; }
  __APP_NAV_CSS__
  main { flex: 1; padding: 24px 28px; max-width: 1280px; width: 100%; margin: 0 auto; }
  .page-head { display: flex; flex-wrap: wrap; align-items: flex-end; justify-content: space-between;
               gap: 12px; margin-bottom: 20px; }
  .page-head h1 { margin: 0; font-size: 22px; font-weight: 700; }
  .page-head p { margin: 4px 0 0; color: var(--muted); font-size: 13px; max-width: 52ch; }
  .toolbar { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; }
  button.ctrl, a.ctrl { background: var(--panel-2); color: var(--fg); border: 1px solid var(--border);
                         border-radius: 8px; padding: 8px 14px; font-size: 12px; font-family: var(--mono);
                         cursor: pointer; text-decoration: none; display: inline-flex; align-items: center;
                         justify-content: center; gap: 6px; }
  button.ctrl:hover, a.ctrl:hover { border-color: var(--accent); }
  button.ctrl.active { color: var(--accent); border-color: var(--accent); background: var(--accent-dim); }
  .stats { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 10px;
           margin-bottom: 22px; }
  .stat { background: var(--panel); border: 1px solid var(--border); border-radius: 10px;
          padding: 12px 14px; }
  .stat .label { font-size: 10px; text-transform: uppercase; letter-spacing: .7px;
                 color: var(--muted); font-weight: 600; }
  .stat .value { font-size: 24px; font-weight: 700; font-family: var(--mono); margin-top: 4px;
                 font-variant-numeric: tabular-nums; }
  .stat.accent .value { color: var(--accent); }
  .status-bar { color: var(--muted); font-size: 12px; font-family: var(--mono); margin-bottom: 18px; }
  .section { margin-bottom: 28px; }
  .section h2 { margin: 0 0 10px; font-size: 13px; font-weight: 600; color: var(--muted);
                text-transform: uppercase; letter-spacing: .8px; display: flex; align-items: center;
                gap: 8px; }
  .section h2 .count { color: var(--accent); font-family: var(--mono); font-size: 12px; }
  .panel { background: var(--panel); border: 1px solid var(--border); border-radius: 10px;
           overflow: hidden; }
  .table-scroll { width: 100%; overflow-x: auto; -webkit-overflow-scrolling: touch; }
  table.agents { width: 100%; border-collapse: collapse; font-size: 13px; min-width: 640px; }
  table.agents th { text-align: left; font-weight: 500; color: var(--muted);
                    padding: 10px 12px; border-bottom: 1px solid var(--border);
                    font-size: 11px; text-transform: uppercase; letter-spacing: .5px; }
  table.agents td { padding: 10px 12px; border-bottom: 1px dashed var(--border); vertical-align: top; }
  table.agents tr:last-child td { border-bottom: 0; }
  table.agents td.desc { color: var(--muted); max-width: 280px; }
  table.agents td.mono { font-family: var(--mono); font-size: 12px; word-break: break-all; }
  .pill { display: inline-flex; align-items: center; gap: 6px;
          padding: 3px 10px; border-radius: 999px; font-size: 11px;
          font-family: var(--mono); border: 1px solid var(--border); }
  .pill.running { color: var(--accent); background: rgba(106,169,255,.10); border-color: rgba(106,169,255,.35); }
  .pulse { width: 8px; height: 8px; border-radius: 50%; background: var(--accent);
           box-shadow: 0 0 0 0 rgba(106,169,255,.5); animation: aa-pulse 1.4s ease-out infinite; }
  @keyframes aa-pulse { 70% { box-shadow: 0 0 0 8px rgba(106,169,255,0); } 100% { box-shadow: 0 0 0 0 rgba(106,169,255,0); } }
  .cron-card { padding: 12px 14px; border-bottom: 1px dashed var(--border); }
  .cron-card:last-child { border-bottom: 0; }
  .cron-head { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; margin-bottom: 8px; }
  .cron-head .nm { font-weight: 600; }
  .cron-head .meta { font-size: 11px; font-family: var(--mono); color: var(--muted); }
  .cron-log { margin: 0; padding: 10px 12px; background: var(--panel-2); border-radius: 8px;
              font-family: var(--mono); font-size: 11px; line-height: 1.45; color: var(--muted);
              max-height: 140px; overflow: auto; white-space: pre-wrap; word-break: break-word; }
  .empty { color: var(--muted); font-style: italic; padding: 28px 20px; text-align: center; }
  .empty-global { background: var(--panel); border: 1px dashed var(--border); border-radius: 12px;
                  padding: 36px 24px; text-align: center; margin-bottom: 24px; }
  .empty-global strong { display: block; font-size: 16px; color: var(--fg); font-style: normal;
                         margin-bottom: 8px; }
  .step { display: block; margin-top: 4px; font-family: var(--mono); font-size: 11px;
          color: var(--accent); }
  .section[hidden] { display: none; }
</style>
</head>
<body>
__APP_NAV__
<main>
  <div class="page-head">
    <div>
      <h1>Agentes ativos</h1>
      <p>Loops do monitor, crons Hermes, envios de chat e ferramentas em execução neste momento.</p>
    </div>
    <div class="toolbar">
      <button type="button" class="ctrl active" id="btn-only-running" data-only="1">Só em execução</button>
      <button type="button" class="ctrl" id="btn-all-loops" data-only="0">Todos os loops</button>
      <button type="button" class="ctrl" id="btn-refresh">Atualizar</button>
      <a class="ctrl" href="/">Monitor</a>
    </div>
  </div>
  <div class="stats" id="stats">
    <div class="stat accent"><div class="label">Total ativo</div><div class="value" id="stat-total">—</div></div>
    <div class="stat"><div class="label">Loops monitor</div><div class="value" id="stat-loops">—</div></div>
    <div class="stat"><div class="label">Crons Hermes</div><div class="value" id="stat-crons">—</div></div>
    <div class="stat"><div class="label">Chat async</div><div class="value" id="stat-chat">—</div></div>
    <div class="stat"><div class="label">Ferramentas</div><div class="value" id="stat-tools">—</div></div>
    <div class="stat"><div class="label">Kanban</div><div class="value" id="stat-kanban">—</div></div>
  </div>
  <div class="status-bar" id="status-bar">Carregando…</div>
  <div class="empty-global" id="empty-global" hidden>
    <strong>Nenhum agente em execução</strong>
    Todos os loops estão em repouso. A página atualiza automaticamente a cada poucos segundos.
  </div>
  <section class="section" id="sec-loops" hidden>
    <h2>Loops do monitor <span class="count" id="count-loops"></span></h2>
    <div class="panel table-scroll">
      <table class="agents">
        <thead><tr>
          <th>Nome</th><th>Descrição</th><th>Estado</th><th>Última exec.</th><th>Duração</th><th>Passo / resultado</th>
        </tr></thead>
        <tbody id="loops-body"></tbody>
      </table>
    </div>
  </section>
  <section class="section" id="sec-crons" hidden>
    <h2>Crons Hermes <span class="count" id="count-crons"></span></h2>
    <div class="panel" id="crons-list"></div>
  </section>
  <section class="section" id="sec-chat" hidden>
    <h2>Chat (envio assíncrono) <span class="count" id="count-chat"></span></h2>
    <div class="panel table-scroll">
      <table class="agents">
        <thead><tr>
          <th>Sessão</th><th>Agente</th><th>Modelo</th><th>Ferramentas</th><th>Progresso</th>
        </tr></thead>
        <tbody id="chat-body"></tbody>
      </table>
    </div>
  </section>
  <section class="section" id="sec-tools" hidden>
    <h2>Ferramentas em curso <span class="count" id="count-tools"></span></h2>
    <div class="panel table-scroll">
      <table class="agents">
        <thead><tr>
          <th>Sessão</th><th>Tipo</th><th>Etiqueta</th><th>Modelo</th><th>Turno</th>
        </tr></thead>
        <tbody id="tools-body"></tbody>
      </table>
    </div>
  </section>
  <section class="section" id="sec-kanban" hidden>
    <h2>Agendamento Kanban <span class="count" id="count-kanban"></span></h2>
    <div class="panel table-scroll">
      <table class="agents">
        <thead><tr>
          <th>Job</th><th>Tarefa</th><th>Perfil</th><th>Status</th><th>Progresso</th>
        </tr></thead>
        <tbody id="kanban-body"></tbody>
      </table>
    </div>
  </section>
</main>
<script>
const el = (id) => document.getElementById(id);
let onlyRunningLoops = true;
let pollTimer = null;

function escapeHtml(s) {
  return String(s).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;");
}

function fmtDuration(s) {
  if (s == null || isNaN(s)) return "—";
  if (s < 1) return s.toFixed(1) + "s";
  if (s < 60) return Math.round(s) + "s";
  if (s < 3600) return Math.floor(s / 60) + "m " + Math.round(s % 60) + "s";
  return Math.floor(s / 3600) + "h " + Math.floor((s % 3600) / 60) + "m";
}

function fmtAgo(ts, now) {
  if (!ts) return "—";
  const s = now - ts;
  if (s < 2) return "agora";
  if (s < 60) return Math.round(s) + "s atrás";
  if (s < 3600) return Math.round(s / 60) + "m atrás";
  return Math.round(s / 3600) + "h atrás";
}

function setOnlyRunning(on) {
  onlyRunningLoops = !!on;
  el("btn-only-running").classList.toggle("active", onlyRunningLoops);
  el("btn-all-loops").classList.toggle("active", !onlyRunningLoops);
}

function renderLoops(rows, now) {
  const sec = el("sec-loops");
  const body = el("loops-body");
  const count = el("count-loops");
  if (!rows.length) {
    sec.hidden = true;
    return;
  }
  sec.hidden = false;
  count.textContent = "(" + rows.length + ")";
  body.innerHTML = rows.map((a) => {
    const running = a.state === "running" && a.enabled !== false;
    const paused = a.enabled === false;
    const state = paused ? "paused" : (a.state || "idle");
    const pillCls = running ? "pill running" : "pill";
    const dot = running ? '<span class="pulse"></span>' : "";
    const dur = running && a.started_at
      ? fmtDuration(now - a.started_at) + " (ao vivo)"
      : fmtDuration(a.last_duration_seconds);
    const step = a.current_step
      ? '<span class="step">' + escapeHtml(a.current_step) + "</span>"
      : (a.last_result ? escapeHtml(String(a.last_result).slice(0, 120)) : "—");
    return "<tr>" +
      "<td><strong>" + escapeHtml(a.name) + "</strong></td>" +
      '<td class="desc">' + escapeHtml(a.description || "—") + "</td>" +
      "<td><span class=\"" + pillCls + "\">" + dot + " " + escapeHtml(state) + "</span></td>" +
      "<td>" + fmtAgo(a.last_started_at, now) + "</td>" +
      "<td class=\"mono\">" + dur + "</td>" +
      "<td>" + step + "</td>" +
      "</tr>";
  }).join("");
}

function renderCrons(rows) {
  const sec = el("sec-crons");
  const box = el("crons-list");
  const count = el("count-crons");
  if (!rows.length) {
    sec.hidden = true;
    return;
  }
  sec.hidden = false;
  count.textContent = "(" + rows.length + ")";
  box.innerHTML = rows.map((job) => {
    const logLines = (job.log_tail || []).slice(-8).map(escapeHtml).join("\n");
    const modelEnabled = !(job.modelId || job.modelLabel)
      || (typeof isModelEnabled !== "function"
        ? true
        : isModelEnabled(job.modelId || job.modelLabel));
    const meta = [
      (job.profileLabel || job.profile) ? "perfil " + (job.profileLabel || job.profile) : "",
      job.modelLabel || job.modelId ? "modelo " + (job.modelLabel || job.modelId) : "",
      job.workdir ? job.workdir : "",
      job.seconds_since_activity != null ? job.seconds_since_activity + "s sem atividade" : "",
    ].filter(Boolean).join(" · ");
    return '<div class="cron-card">' +
      '<div class="cron-head">' +
        (modelEnabled
          ? '<span class="pill running"><span class="pulse"></span>executando</span>'
          : '<span class="pill paused">modelo pausado</span>') +
        '<span class="nm">' + escapeHtml(job.name || job.job_id || "cron") + '</span>' +
        (meta ? '<span class="meta">' + escapeHtml(meta) + "</span>" : "") +
      "</div>" +
      (job.last_message ? '<div class="meta" style="margin-bottom:6px">' + escapeHtml(job.last_message) + "</div>" : "") +
      '<pre class="cron-log">' + (logLines || "—") + "</pre>" +
      "</div>";
  }).join("");
}

function renderChat(rows) {
  const sec = el("sec-chat");
  const body = el("chat-body");
  const count = el("count-chat");
  if (!rows.length) {
    sec.hidden = true;
    return;
  }
  sec.hidden = false;
  count.textContent = "(" + rows.length + ")";
  body.innerHTML = rows.map((j) => {
    const tools = (j.toolTurn && j.toolMax)
      ? j.toolTurn + " / " + j.toolMax
      : "—";
    const key = j.displayKey || j.sessionKey || j.session_key || "—";
    return "<tr>" +
      '<td class="mono">' + escapeHtml(key) + "</td>" +
      "<td>" + escapeHtml(j.agentId || j.agent_id || "—") + "</td>" +
      "<td>" + escapeHtml(j.modelLabel || j.modelId || "—") + "</td>" +
      '<td class="mono">' + escapeHtml(tools) + "</td>" +
      "<td>" + escapeHtml(j.lastProgress || j.last_progress || "—") + "</td>" +
      "</tr>";
  }).join("");
}

function renderTools(rows) {
  const sec = el("sec-tools");
  const body = el("tools-body");
  const count = el("count-tools");
  if (!rows.length) {
    sec.hidden = true;
    return;
  }
  sec.hidden = false;
  body.innerHTML = rows.map((j) =>
    "<tr>" +
      '<td class="mono">' + escapeHtml(j.sessionKey || "—") + "</td>" +
      "<td>" + escapeHtml(j.kind || "—") + "</td>" +
      "<td>" + escapeHtml(j.label || "—") + "</td>" +
      "<td>" + escapeHtml(j.modelLabel || "—") + "</td>" +
      '<td class="mono">' + escapeHtml((j.turn != null ? j.turn : "—") + (j.maxTurns ? " / " + j.maxTurns : "")) + "</td>" +
      "<td>" + escapeHtml(j.lastProgress || j.last_progress || "—") + "</td>" +
      "</tr>"
  ).join("");
}

function renderKanban(rows) {
  const sec = el("sec-kanban");
  const body = el("kanban-body");
  const count = el("count-kanban");
  if (!rows.length) {
    sec.hidden = true;
    return;
  }
  count.textContent = "(" + rows.length + ")";
  sec.hidden = false;
  count.textContent = "(" + rows.length + ")";
  body.innerHTML = rows.map((j) =>
    "<tr>" +
      '<td class="mono">' + escapeHtml(j.jobId || "—") + "</td>" +
      "<td>" + escapeHtml(j.taskId || "—") + "</td>" +
      "<td>" + escapeHtml(j.profile || "—") + "</td>" +
      "<td>" + escapeHtml(j.status || "running") + "</td>" +
      "<td>" + escapeHtml(j.lastProgress || "—") + "</td>" +
    "</tr>"
  ).join("");
}

function renderSnapshot(data) {
  const now = (data.updated_at || Date.now() / 1000);
  const summary = data.summary || {};
  const total = summary.total_running ?? 0;
  el("stat-total").textContent = total;
  el("stat-loops").textContent = summary.monitor_loops ?? 0;
  el("stat-crons").textContent = summary.hermes_crons ?? 0;
  el("stat-chat").textContent = summary.chat_sends ?? 0;
  el("stat-tools").textContent = summary.tool_runs ?? 0;
  el("stat-kanban").textContent = summary.kanban_schedules ?? 0;
  el("empty-global").hidden = total > 0;
  const loops = onlyRunningLoops
    ? (data.monitor_loops || [])
    : (data.monitor_loops_all || []).filter((a) => a.enabled !== false);
  if (onlyRunningLoops) {
    renderLoops(loops, now);
  } else {
    const sorted = loops.slice().sort((a, b) => {
      if (a.state === b.state) return 0;
      return a.state === "running" ? -1 : 1;
    });
    renderLoops(sorted, now);
  }
  renderCrons(data.hermes_crons || []);
  renderChat(data.chat_sends || []);
  renderTools(data.tool_runs || []);
  renderKanban(data.kanban_schedules || []);
  const updated = new Date(now * 1000).toLocaleTimeString();
  if (data.pending) {
    el("status-bar").textContent = "Atualizando agentes ativos…";
    return;
  }
  el("status-bar").textContent = data.stale
    ? total + " trabalho(s) ativo(s) · atualizado " + updated + " · a atualizar"
    : total + " trabalho(s) ativo(s) · atualizado " + updated;
}

async function loadActiveAgents() {
  try {
    const r = await fetch("/active-agents", { cache: "no-cache" });
    const data = await r.json();
    if (!data.ok) throw new Error(data.error || "falha ao carregar");
    renderSnapshot(data);
  } catch (e) {
    el("status-bar").textContent = "Erro: " + e.message;
  }
}

function startPoll() {
  if (pollTimer) clearInterval(pollTimer);
  pollTimer = setInterval(loadActiveAgents, 4000);
}

el("btn-refresh").addEventListener("click", () => loadActiveAgents());
el("btn-only-running").addEventListener("click", () => {
  setOnlyRunning(true);
  loadActiveAgents();
});
el("btn-all-loops").addEventListener("click", () => {
  setOnlyRunning(false);
  loadActiveAgents();
});

setOnlyRunning(true);
loadActiveAgents();
startPoll();
document.addEventListener("visibilitychange", () => {
  if (document.visibilityState === "visible") loadActiveAgents();
});
</script>
</body>
</html>
"""


def build_active_agents_html(hermes_dashboard_url: Optional[str] = None) -> str:
    return _inject_app_nav(
        ACTIVE_AGENTS_PAGE,
        "active_agents",
        hermes_dashboard_url=hermes_dashboard_url,
    )


CRON_SLOTS_PAGE = r"""<!doctype html>
<html lang="pt-br">
<head>
<meta charset="utf-8">
<title>gois — slots cron</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<style>
  :root {
    --bg: #0f1115; --panel: #171a21; --panel-2: #1e222c; --border: #262b36;
    --fg: #e6e8ee; --muted: #8a93a6; --ok: #3ddc84; --bad: #ff5a5f;
    --accent: #6aa9ff; --accent-dim: rgba(106,169,255,.12);
    --mono: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }
  * { box-sizing: border-box; }
  html, body { margin: 0; min-height: 100%; background: var(--bg); color: var(--fg);
    font: 14px/1.45 -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; }
  body { display: flex; flex-direction: column; }
  __APP_NAV_CSS__
  main { flex: 1; padding: 24px 28px; max-width: 1100px; margin: 0 auto; width: 100%; }
  h1 { margin: 0 0 6px; font-size: 22px; }
  .sub { color: var(--muted); font-size: 13px; margin: 0 0 20px; }
  .stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin-bottom: 22px; }
  @media (max-width: 720px) { .stats { grid-template-columns: repeat(2, 1fr); } }
  .stat { background: var(--panel); border: 1px solid var(--border); border-radius: 10px; padding: 14px; }
  .stat .lbl { font-size: 10px; text-transform: uppercase; letter-spacing: .7px; color: var(--muted); }
  .stat .val { font-size: 28px; font-weight: 700; font-family: var(--mono); margin-top: 6px; }
  .stat.ok .val { color: var(--ok); }
  .stat.busy .val { color: var(--accent); }
  .toolbar { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 18px; }
  button.ctrl { background: var(--panel-2); color: var(--fg); border: 1px solid var(--border);
    border-radius: 8px; padding: 8px 14px; font-size: 12px; cursor: pointer; font-family: var(--mono); }
  button.ctrl:hover { border-color: var(--accent); }
  .slot-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 10px; margin-bottom: 24px; }
  @media (max-width: 900px) { .slot-grid { grid-template-columns: repeat(3, 1fr); } }
  .slot {
    aspect-ratio: 1; border-radius: 12px; border: 2px solid var(--border);
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    text-align: center; padding: 8px; background: var(--panel); transition: border-color .2s, background .2s;
  }
  .slot.free { border-color: rgba(61,220,132,.35); background: rgba(61,220,132,.06); }
  .slot.busy { border-color: rgba(106,169,255,.5); background: var(--accent-dim); }
  .slot.running-log { border-color: rgba(255,196,80,.55); background: rgba(255,196,80,.08);
    border-style: dashed; }
  .slot .num { font-size: 11px; color: var(--muted); font-family: var(--mono); }
  .slot .name { font-size: 11px; font-weight: 600; margin-top: 6px; line-height: 1.3;
    word-break: break-word; max-width: 100%; }
  .slot.free .state { color: var(--ok); font-size: 12px; font-weight: 600; margin-top: 4px; }
  .slot.busy .state { color: var(--accent); font-size: 11px; }
  .panel { background: var(--panel); border: 1px solid var(--border); border-radius: 10px; overflow: hidden; }
  table { width: 100%; border-collapse: collapse; font-size: 13px; }
  th { text-align: left; padding: 10px 12px; color: var(--muted); font-size: 11px;
    text-transform: uppercase; border-bottom: 1px solid var(--border); }
  td { padding: 10px 12px; border-bottom: 1px dashed var(--border); vertical-align: middle; }
  tr:last-child td { border-bottom: 0; }
  td.mono { font-family: var(--mono); font-size: 12px; }
  .status-line { font-family: var(--mono); font-size: 12px; color: var(--muted); margin-bottom: 14px; }
  .path { font-size: 11px; color: var(--muted); font-family: var(--mono); word-break: break-all; }
</style>
</head>
<body>
__APP_NAV__
<main>
  <h1>Slots de concorrência (crons Hermes)</h1>
  <p class="sub">Semáforo partilhado entre agentes agendados. Máximo configurado: <strong id="max-label">6</strong> em paralelo.</p>
  <p class="path" id="workspace-path">—</p>
  <div class="toolbar">
    <button type="button" class="ctrl" id="btn-refresh">Atualizar</button>
    <button type="button" class="ctrl" id="btn-prune">Limpar slots mortos</button>
    <a class="ctrl" href="/agentes" style="text-decoration:none;color:inherit;">Agentes ativos</a>
  </div>
  <div class="status-line" id="status">Carregando…</div>
  <div class="stats">
    <div class="stat"><div class="lbl">Máximo</div><div class="val" id="v-max">—</div></div>
    <div class="stat busy"><div class="lbl">Ocupados</div><div class="val" id="v-used">—</div></div>
    <div class="stat ok"><div class="lbl">Livres</div><div class="val" id="v-free">—</div></div>
    <div class="stat"><div class="lbl">TTL slot</div><div class="val" id="v-ttl" style="font-size:18px;">—</div></div>
  </div>
  <h2 style="font-size:13px;color:var(--muted);text-transform:uppercase;letter-spacing:.8px;">Grelha de slots</h2>
  <div class="slot-grid" id="slot-grid"></div>
  <h2 style="font-size:13px;color:var(--muted);text-transform:uppercase;letter-spacing:.8px;">Detalhe</h2>
  <div class="panel">
    <table>
      <thead><tr><th>Slot</th><th>Agente</th><th>PID</th><th>Idade</th><th></th></tr></thead>
      <tbody id="slot-rows"><tr><td colspan="5" class="sub">—</td></tr></tbody>
    </table>
  </div>
</main>
<script>
const API = "/api/cron/concurrency";

async function fetchJson(url, opt) {
  const r = await fetch(url, Object.assign({ cache: "no-cache", credentials: "same-origin" }, opt || {}));
  const raw = await r.text();
  let data = {};
  if (raw) try { data = JSON.parse(raw); } catch (_) {}
  if (!r.ok || data.ok === false) throw new Error(data.error || ("HTTP " + r.status));
  return data;
}

function renderGrid(data) {
  const max = data.maxConcurrent || 6;
  const slots = data.slots || [];
  const runningOnly = data.runningWithoutSlot || [];
  const grid = document.getElementById("slot-grid");
  grid.innerHTML = "";
  for (let i = 0; i < max; i++) {
    const slot = slots[i];
    const busy = !!slot;
    const isLogOnly = busy && slot && slot.running;
    const div = document.createElement("div");
    div.className = "slot " + (busy && slot ? (isLogOnly ? "running-log" : "busy") : "free");
    div.innerHTML = "<div class=\"num\">#" + (i + 1) + "</div>" +
      (busy && slot
        ? "<div class=\"state\">" + (isLogOnly ? "A correr" : "Ocupado") + "</div><div class=\"name\">" + escapeHtml(slot.name) + "</div>"
        : "<div class=\"state\">Livre</div>");
    grid.appendChild(div);
  }
  document.getElementById("v-max").textContent = String(max);
  const dispUsed = data.displayUsed != null ? data.displayUsed : (data.used ?? 0);
  const dispFree = data.displayFree != null ? data.displayFree : (data.free ?? 0);
  document.getElementById("v-used").textContent = String(dispUsed);
  document.getElementById("v-free").textContent = String(dispFree);
  document.getElementById("v-ttl").textContent = String(data.slotTtlMinutes ?? 45) + "m";
  document.getElementById("max-label").textContent = String(max);
  document.getElementById("workspace-path").textContent = data.workspace || "";

  const tbody = document.getElementById("slot-rows");
  const busySlots = slots.filter((s) => s && (s.running || s.pid != null || s.acquiredAt));
  if (!busySlots.length) {
    tbody.innerHTML = "<tr><td colspan=\"5\" style=\"color:var(--muted);font-style:italic\">Nenhum slot ocupado — todos livres.</td></tr>";
    return;
  }
  tbody.innerHTML = busySlots.map((s, idx) => {
    const logOnly = !!s.running;
    const releaseBtn = logOnly
      ? "<span style=\"color:var(--muted);font-size:11px\">agent.log</span>"
      : "<button type=\"button\" class=\"ctrl\" data-release=\"" + escapeHtml(s.name) + "\">Libertar</button>";
    return "<tr><td class=\"mono\">" + (idx + 1) + "</td><td>" + escapeHtml(s.name) +
      (logOnly ? " <span style=\"color:var(--muted);font-size:11px\">(a correr)</span>" : "") + "</td>" +
      "<td class=\"mono\">" + (s.pid != null ? s.pid : "—") + (s.pidAlive === false ? " (morto)" : "") + "</td>" +
      "<td class=\"mono\">" + (s.ageSeconds != null ? s.ageSeconds + "s" : "—") + "</td>" +
      "<td>" + releaseBtn + "</td></tr>";
  }).join("");
  tbody.querySelectorAll("[data-release]").forEach(btn => {
    btn.addEventListener("click", () => releaseSlot(btn.dataset.release));
  });
}

function escapeHtml(s) {
  return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}

async function load(prune) {
  document.getElementById("status").textContent = "A carregar…";
  try {
    const q = prune ? "?prune=1" : "";
    const data = await fetchJson(API + q);
    renderGrid(data);
    let line = "Atualizado " + new Date().toLocaleTimeString("pt-BR") +
      " — semáforo " + data.used + "/" + data.maxConcurrent + " (ficheiro), " + data.free + " livres.";
    if (runningOnly.length) {
      line += " · " + runningOnly.length + " a correr (agent.log, slot ainda não gravado).";
    }
    document.getElementById("status").textContent = line;
  } catch (e) {
    document.getElementById("status").textContent = "Erro: " + e.message;
  }
}

async function releaseSlot(name) {
  if (!name || !confirm("Libertar slot de \"" + name + "\"?")) return;
  await fetchJson(API + "/release", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ name }),
  });
  await load(false);
}

document.getElementById("btn-refresh").addEventListener("click", () => load(false));
document.getElementById("btn-prune").addEventListener("click", () => load(true));

(async function boot() {
  if (typeof window.qcmAuthGate === "function") {
    const auth = await window.qcmAuthGate();
    if (!auth || auth.ok === false) return;
  }
  await load(true);
  setInterval(() => load(false), 8000);
})();
</script>
</body>
</html>
"""


def build_cron_slots_html(hermes_dashboard_url: Optional[str] = None) -> str:
    return _inject_app_nav(
        CRON_SLOTS_PAGE,
        "cron_slots",
        hermes_dashboard_url=hermes_dashboard_url,
    )


CRON_COSTS_PAGE = r"""<!doctype html>
<html lang="pt-br">
<head>
<meta charset="utf-8">
<title>gois — custos por agente cron</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<style>
  :root {
    --bg: #0f1115; --panel: #171a21; --panel-2: #1e222c; --border: #262b36;
    --fg: #e6e8ee; --muted: #8a93a6; --ok: #3ddc84; --bad: #ff5a5f;
    --warn: #ffb454; --accent: #6aa9ff; --accent-dim: rgba(106,169,255,.12);
    --mono: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }
  * { box-sizing: border-box; }
  html, body { margin: 0; min-height: 100%; background: var(--bg); color: var(--fg);
    font: 14px/1.45 -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; }
  body { display: flex; flex-direction: column; }
  __APP_NAV_CSS__
  main { flex: 1; padding: 24px 28px; max-width: 1320px; margin: 0 auto; width: 100%; }
  h1 { margin: 0 0 6px; font-size: 22px; }
  .sub { color: var(--muted); font-size: 13px; margin: 0 0 18px; }
  .stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin-bottom: 18px; }
  @media (max-width: 880px) { .stats { grid-template-columns: repeat(2, 1fr); } }
  .stat { background: var(--panel); border: 1px solid var(--border); border-radius: 10px; padding: 14px; }
  .stat .lbl { font-size: 10px; text-transform: uppercase; letter-spacing: .7px; color: var(--muted); }
  .stat .val { font-size: 24px; font-weight: 700; font-family: var(--mono); margin-top: 6px; }
  .stat.accent .val { color: var(--accent); }
  .stat.ok .val { color: var(--ok); }
  .stat.warn .val { color: var(--warn); }
  .toolbar { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 14px; align-items: center; }
  button.ctrl, label.ctrl { background: var(--panel-2); color: var(--fg); border: 1px solid var(--border);
    border-radius: 8px; padding: 8px 12px; font-size: 12px; cursor: pointer; font-family: var(--mono);
    display: inline-flex; align-items: center; gap: 6px; }
  button.ctrl:hover { border-color: var(--accent); }
  label.ctrl input, label.ctrl select { background: transparent; color: var(--fg); border: 0;
    font-family: var(--mono); font-size: 12px; width: 80px; outline: none; }
  label.ctrl select { width: auto; }
  .status-line { font-family: var(--mono); font-size: 12px; color: var(--muted); margin-bottom: 14px; }
  .panel { background: var(--panel); border: 1px solid var(--border); border-radius: 10px; overflow: hidden; }
  .panel + .panel { margin-top: 18px; }
  .panel-header { padding: 12px 14px; border-bottom: 1px solid var(--border);
    display: flex; align-items: center; justify-content: space-between; gap: 10px; }
  .panel-header h2 { margin: 0; font-size: 13px; text-transform: uppercase;
    letter-spacing: .8px; color: var(--muted); font-weight: 600; }
  table { width: 100%; border-collapse: collapse; font-size: 13px; }
  th { text-align: left; padding: 10px 12px; color: var(--muted); font-size: 11px;
    text-transform: uppercase; border-bottom: 1px solid var(--border); cursor: pointer;
    user-select: none; white-space: nowrap; }
  th.num, td.num { text-align: right; font-variant-numeric: tabular-nums; }
  th.sorted { color: var(--accent); }
  td { padding: 10px 12px; border-bottom: 1px dashed var(--border); vertical-align: middle; }
  tr:last-child td { border-bottom: 0; }
  td.mono { font-family: var(--mono); font-size: 12px; }
  td.name { font-weight: 600; }
  td.name small { display: block; color: var(--muted); font-weight: 400; font-size: 11px; margin-top: 2px; }
  td.cost { font-family: var(--mono); }
  td.cost.hi { color: var(--warn); }
  td.cost.vhi { color: var(--bad); font-weight: 600; }
  tr.model-off td { opacity: .72; }
  .model-cell { display: flex; align-items: center; justify-content: space-between; gap: 8px; }
  .model-toggle-btn {
    background: var(--panel-2);
    color: var(--muted);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 3px 9px;
    font-size: 10px;
    font-family: var(--mono);
    text-transform: uppercase;
    cursor: pointer;
    white-space: nowrap;
  }
  .model-toggle-btn:hover { border-color: var(--accent); color: var(--accent); }
  .model-toggle-btn.on { color: var(--ok); border-color: rgba(61,220,132,.3); }
  .model-toggle-btn.off { color: var(--warn); border-color: rgba(255,180,84,.3); }
  td.pill { font-family: var(--mono); font-size: 11px; }
  tr.total td { border-top: 2px solid var(--border); font-weight: 700; background: var(--panel-2); }
  .price-row { display: grid; grid-template-columns: 1fr 110px 110px 80px; gap: 8px;
    padding: 8px 14px; border-bottom: 1px dashed var(--border); align-items: center; }
  .price-row:last-child { border-bottom: 0; }
  .price-row input { background: var(--panel-2); color: var(--fg); border: 1px solid var(--border);
    border-radius: 6px; padding: 5px 8px; font-family: var(--mono); font-size: 12px; width: 100%; }
  .price-row .key { font-family: var(--mono); font-size: 12px; color: var(--fg); word-break: break-all; }
  .price-row .key small { color: var(--muted); }
  .price-row button { background: transparent; color: var(--bad); border: 1px solid var(--border);
    border-radius: 6px; padding: 4px 8px; font-size: 11px; cursor: pointer; font-family: var(--mono); }
  .help { color: var(--muted); font-size: 12px; line-height: 1.55; padding: 10px 14px;
    background: var(--panel-2); border-bottom: 1px solid var(--border); }
  .help code { font-family: var(--mono); background: var(--panel); padding: 1px 5px; border-radius: 4px; }
  details summary { cursor: pointer; padding: 10px 14px; color: var(--muted); font-size: 12px;
    text-transform: uppercase; letter-spacing: .8px; }
  details[open] summary { border-bottom: 1px solid var(--border); }
  .grow { flex: 1 1 auto; }
  .badge { display: inline-block; padding: 2px 8px; border-radius: 999px;
    background: var(--panel-2); color: var(--muted); font-size: 11px; font-family: var(--mono); }
  .badge.active { color: var(--ok); border: 1px solid rgba(61,220,132,.3); }
  .badge.paused { color: var(--warn); border: 1px solid rgba(255,180,84,.3); }
  .model-row { display: grid; grid-template-columns: 20px 1fr 120px 90px 90px; gap: 10px;
    align-items: center; padding: 8px 14px; border-top: 1px dashed var(--border); }
  .model-row input { margin: 0; accent-color: #6aa9ff; }
  .model-meta strong { display: block; font-family: var(--mono); font-size: 12px; }
  .model-meta small { color: var(--muted); font-size: 11px; }
  .model-month { text-align: right; font-family: var(--mono); }
  .model-state { text-align: right; font-family: var(--mono); color: var(--muted); font-size: 11px; text-transform: uppercase; }
  .model-action { text-align: right; }
  @media (max-width: 780px) {
    .model-row { grid-template-columns: 20px 1fr; }
    .model-month, .model-state, .model-action { text-align: left; }
  }
</style>
</head>
<body>
__APP_NAV__
<main>
  <h1>Custos por agente cron</h1>
  <p class="sub">Estimativa de custo baseada em tokens de contexto (média e máximo) extraídos do <code>agent.log</code> do Hermes e em preços por modelo configuráveis.</p>
  <div class="status-line" id="status">Carregando…</div>

  <div class="toolbar">
    <button type="button" class="ctrl" id="btn-refresh">Atualizar</button>
    <label class="ctrl" title="Tokens de saída assumidos por execução (não são capturados pelo agent.log)">
      out tokens/exec
      <input type="number" min="0" step="50" id="in-out-tokens" value="800">
    </label>
    <label class="ctrl" title="Execuções estimadas por mês para projeção mensal">
      runs/mês
      <input type="number" min="0" step="1" id="in-runs-month" value="720">
    </label>
    <label class="ctrl" title="Taxa de câmbio USD→BRL para exibição">
      USD→BRL
      <input type="number" min="0" step="0.01" id="in-fx" value="5.20">
    </label>
    <label class="ctrl">
      moeda
      <select id="in-currency">
        <option value="USD">USD</option>
        <option value="BRL">BRL</option>
      </select>
    </label>
    <span class="grow"></span>
    <button type="button" class="ctrl" id="btn-reset-models" title="Reativar todos os modelos para cálculo">Reativar modelos</button>
    <button type="button" class="ctrl" id="btn-reset-prices" title="Restaurar tabela de preços padrão">Resetar preços</button>
  </div>

  <div class="stats">
    <div class="stat"><div class="lbl">Jobs com dados</div><div class="val" id="v-jobs">—</div></div>
    <div class="stat accent"><div class="lbl">Runs observados</div><div class="val" id="v-runs">—</div></div>
    <div class="stat warn"><div class="lbl">Custo observado</div><div class="val" id="v-cost-obs">—</div></div>
    <div class="stat ok"><div class="lbl">Custo / mês (proj.)</div><div class="val" id="v-cost-month">—</div></div>
  </div>

  <details class="panel" id="models-panel" open>
    <summary>Modelos ativos para cálculo</summary>
    <div class="help">
      Desmarque modelos para removê-los dos totais e KPIs. A seleção fica salva no navegador.
      A tabela continua a mostrar todos os jobs para auditoria.
    </div>
    <div id="model-list"></div>
  </details>

  <div class="panel">
    <div class="panel-header">
      <h2>Custo por agente</h2>
      <span class="badge" id="badge-updated">—</span>
    </div>
    <table id="tbl">
      <thead>
        <tr>
          <th data-sort="name">Agente</th>
          <th data-sort="profile">Perfil</th>
          <th data-sort="model">Modelo</th>
          <th class="num" data-sort="avg_tokens">Tokens médios</th>
          <th class="num" data-sort="token_max">Tokens máx</th>
          <th class="num" data-sort="token_runs">Runs</th>
          <th class="num" data-sort="cost_per_run">Custo/exec</th>
          <th class="num" data-sort="cost_observed">Custo observado</th>
          <th class="num" data-sort="cost_month">Custo/mês (proj.)</th>
        </tr>
      </thead>
      <tbody id="tbl-body"><tr><td colspan="9" class="sub">—</td></tr></tbody>
      <tfoot id="tbl-foot"></tfoot>
    </table>
  </div>

  <details class="panel" id="prices-panel">
    <summary>Tabela de preços por modelo (USD por 1M tokens)</summary>
    <div class="help">
      Preços são salvos no navegador (<code>localStorage</code>). O <em>match</em> é por substring contra o
      <strong>modelo informado pelo Hermes</strong> (campo <code>model=</code> nas linhas <code>context=~N</code>
      do <code>agent.log</code>). A primeira regra que casar é usada; <code>*</code> é o fallback.
      Quando o agent.log não traz o modelo, assume-se <code>*</code>.
    </div>
    <div id="price-list"></div>
    <div class="price-row" style="background:var(--panel-2)">
      <div>
        <input type="text" id="new-match" placeholder="ex.: claude-3-7-sonnet">
      </div>
      <div><input type="number" min="0" step="0.01" id="new-in" placeholder="USD/1M in"></div>
      <div><input type="number" min="0" step="0.01" id="new-out" placeholder="USD/1M out"></div>
      <div><button type="button" class="ctrl" id="btn-add-price" style="width:100%">Adicionar</button></div>
    </div>
  </details>
</main>
<script>
const API = "/hermes/cron";
const LS_PRICES = "qcm.cronCosts.prices.v1";
const LS_SETTINGS = "qcm.cronCosts.settings.v1";
const LS_MODEL_TOGGLES = "qcm.cronCosts.modelToggles.v1";
const LS_ROW_TOGGLES = "qcm.cronCosts.rowToggles.v1";

// Preços padrão (USD por 1M tokens). Match por substring no campo "model".
// Atualize via UI; ficam persistidos por usuário/navegador.
const DEFAULT_PRICES = [
  { match: "gpt-5",                     in: 1.25,  out: 10.00 },
  { match: "gpt-4o-mini",               in: 0.15,  out: 0.60  },
  { match: "gpt-4o",                    in: 2.50,  out: 10.00 },
  { match: "gpt-4.1-mini",              in: 0.40,  out: 1.60  },
  { match: "gpt-4.1",                   in: 2.00,  out: 8.00  },
  { match: "o4-mini",                   in: 1.10,  out: 4.40  },
  { match: "o3",                        in: 2.00,  out: 8.00  },
  { match: "claude-3-5-haiku",          in: 0.80,  out: 4.00  },
  { match: "claude-3-5-sonnet",         in: 3.00,  out: 15.00 },
  { match: "claude-3-7-sonnet",         in: 3.00,  out: 15.00 },
  { match: "claude-sonnet-4",           in: 3.00,  out: 15.00 },
  { match: "claude-opus-4",             in: 15.00, out: 75.00 },
  { match: "claude-haiku",              in: 0.25,  out: 1.25  },
  { match: "claude-sonnet",             in: 3.00,  out: 15.00 },
  { match: "claude-opus",               in: 15.00, out: 75.00 },
  { match: "deepseek-chat",             in: 0.27,  out: 1.10  },
  { match: "deepseek-reasoner",         in: 0.55,  out: 2.19  },
  { match: "deepseek",                  in: 0.27,  out: 1.10  },
  { match: "gemini-2.5-pro",            in: 1.25,  out: 10.00 },
  { match: "gemini-2.5-flash",          in: 0.30,  out: 2.50  },
  { match: "gemini",                    in: 0.30,  out: 2.50  },
  { match: "grok",                      in: 2.00,  out: 10.00 },
  { match: "*",                         in: 1.00,  out: 4.00  },
];

const DEFAULT_SETTINGS = { outTokens: 800, runsPerMonth: 720, fx: 5.20, currency: "USD" };

function loadPrices() {
  try {
    const raw = localStorage.getItem(LS_PRICES);
    if (raw) {
      const arr = JSON.parse(raw);
      if (Array.isArray(arr) && arr.length) return arr;
    }
  } catch (_) {}
  return DEFAULT_PRICES.slice();
}
function savePrices(arr) { try { localStorage.setItem(LS_PRICES, JSON.stringify(arr)); } catch (_) {} }
function loadSettings() {
  try {
    const raw = localStorage.getItem(LS_SETTINGS);
    if (raw) return Object.assign({}, DEFAULT_SETTINGS, JSON.parse(raw));
  } catch (_) {}
  return Object.assign({}, DEFAULT_SETTINGS);
}
function saveSettings(s) { try { localStorage.setItem(LS_SETTINGS, JSON.stringify(s)); } catch (_) {} }
function loadModelToggles() {
  try {
    const raw = localStorage.getItem(LS_MODEL_TOGGLES);
    if (raw) {
      const obj = JSON.parse(raw);
      if (obj && typeof obj === "object" && !Array.isArray(obj)) return obj;
    }
  } catch (_) {}
  return {};
}
function saveModelToggles(v) { try { localStorage.setItem(LS_MODEL_TOGGLES, JSON.stringify(v)); } catch (_) {} }
function loadRowToggles() {
  try {
    const raw = localStorage.getItem(LS_ROW_TOGGLES);
    if (raw) {
      const obj = JSON.parse(raw);
      if (obj && typeof obj === "object" && !Array.isArray(obj)) return obj;
    }
  } catch (_) {}
  return {};
}
function saveRowToggles(v) { try { localStorage.setItem(LS_ROW_TOGGLES, JSON.stringify(v)); } catch (_) {} }

let prices = loadPrices();
let settings = loadSettings();
let modelToggles = loadModelToggles();
let rowToggles = loadRowToggles();
let lastJobs = [];
let sortKey = "cost_month";
let sortDir = -1;

function escapeHtml(s) {
  return String(s == null ? "" : s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}

function priceFor(model) {
  const m = String(model || "").toLowerCase();
  for (const row of prices) {
    const key = String(row.match || "").toLowerCase();
    if (!key || key === "*") continue;
    if (m && m.includes(key)) return row;
  }
  return prices.find(r => String(r.match || "").trim() === "*") || { match: "*", in: 1.0, out: 4.0 };
}

function modelKey(model) {
  const key = String(model || "").trim().toLowerCase();
  return key || "*";
}

function modelLabel(model) {
  const label = String(model || "").trim();
  return label || "(desconhecido)";
}

function stableRowKey(job) {
  const id = String(job?.id || "").trim().toLowerCase();
  const name = String(job?.name || "").trim().toLowerCase();
  const profile = String(job?.source_profile || "").trim().toLowerCase();
  const sourceJobsPath = String(job?.source_jobs_path || "").trim().toLowerCase();
  const model = modelKey(job?.token_model || "");
  // Chave estável para manter o toggle da linha entre refresh/reabertura da tela.
  return [sourceJobsPath, profile, id || name, model].join("::");
}

function isModelEnabled(model) {
  const key = modelKey(model);
  if (!(key in modelToggles)) return true;
  return !!modelToggles[key];
}

function isModelEnabledByKey(key) {
  if (!(key in modelToggles)) return true;
  return !!modelToggles[key];
}

function isRowEnabled(row) {
  const key = String(row?.row_key || "");
  if (!key || !(key in rowToggles)) return true;
  return !!rowToggles[key];
}

function renderModelFilters(rows) {
  const wrap = document.getElementById("model-list");
  if (!wrap) return;

  const grouped = new Map();
  for (const r of rows) {
    const key = modelKey(r.model);
    const prev = grouped.get(key) || {
      key,
      label: modelLabel(r.model),
      jobs: 0,
      runs: 0,
      month: 0,
    };
    prev.jobs += 1;
    prev.runs += Number(r.token_runs) || 0;
    prev.month += Number(r.cost_month) || 0;
    grouped.set(key, prev);
  }

  const items = Array.from(grouped.values()).sort((a, b) => b.month - a.month || a.label.localeCompare(b.label));
  if (!items.length) {
    wrap.innerHTML = "<div class=\"help\" style=\"border:0;border-top:1px solid var(--border)\">Sem modelos detectados ainda.</div>";
    return;
  }

  wrap.innerHTML = items.map(it => {
    const enabled = isModelEnabledByKey(it.key);
    const toggleLabel = enabled ? "Desativar" : "Reativar";
    return "<label class=\"model-row\">" +
      "<input type=\"checkbox\" data-model-key=\"" + escapeHtml(it.key) + "\" " + (enabled ? "checked" : "") + ">" +
      "<div class=\"model-meta\">" +
        "<strong>" + escapeHtml(it.label) + "</strong>" +
        "<small>" + it.jobs + " jobs, " + fmtInt(it.runs) + " runs</small>" +
      "</div>" +
      "<div class=\"model-month\">" + fmtMoney(it.month) + "</div>" +
      "<div class=\"model-state\">" + (enabled ? "ativo" : "off") + "</div>" +
      "<div class=\"model-action\"><button type=\"button\" class=\"model-toggle-btn " + (enabled ? "on" : "off") + "\" data-model-toggle-btn=\"" + escapeHtml(it.key) + "\">" + toggleLabel + "</button></div>" +
    "</label>";
  }).join("");

  wrap.querySelectorAll("input[data-model-key]").forEach(inp => {
    inp.addEventListener("change", () => {
      const key = String(inp.dataset.modelKey || "").trim().toLowerCase() || "*";
      modelToggles[key] = !!inp.checked;
      saveModelToggles(modelToggles);
      renderTable();
    });
  });

  wrap.querySelectorAll("button[data-model-toggle-btn]").forEach(btn => {
    btn.addEventListener("click", (ev) => {
      ev.preventDefault();
      ev.stopPropagation();
      const key = String(btn.dataset.modelToggleBtn || "").trim().toLowerCase() || "*";
      modelToggles[key] = !isModelEnabledByKey(key);
      saveModelToggles(modelToggles);
      renderTable();
    });
  });
}

function fmtMoney(v) {
  if (!isFinite(v)) return "—";
  const cur = settings.currency;
  const fx = Number(settings.fx) || 1;
  const val = cur === "BRL" ? v * fx : v;
  const sym = cur === "BRL" ? "R$" : "$";
  if (Math.abs(val) >= 1000) return sym + val.toLocaleString("pt-BR", { maximumFractionDigits: 0 });
  if (Math.abs(val) >= 1)    return sym + val.toLocaleString("pt-BR", { maximumFractionDigits: 2, minimumFractionDigits: 2 });
  return sym + val.toLocaleString("pt-BR", { maximumFractionDigits: 4, minimumFractionDigits: 2 });
}

function fmtInt(v) {
  if (v == null || !isFinite(v)) return "—";
  return Number(v).toLocaleString("pt-BR");
}

function computeRow(job, index) {
  const avgIn = Number(job.avg_tokens) || 0;
  const maxIn = Number(job.token_max) || 0;
  const runs  = Number(job.token_runs) || 0;
  const model = job.token_model || "";
  const p = priceFor(model);
  const outTokens = Math.max(0, Number(settings.outTokens) || 0);
  const runsMonth = Math.max(0, Number(settings.runsPerMonth) || 0);
  const costPerRun = (avgIn * p.in + outTokens * p.out) / 1e6;
  return {
    job,
    job_id: String(job.id || "").trim(),
    row_idx: Number(index) || 0,
    row_key: stableRowKey(job),
    name: job.name || job.id || "",
    profile: job.source_profile || "",
    model,
    matched: p.match,
    avg_tokens: avgIn,
    token_max: maxIn,
    token_runs: runs,
    cost_per_run: costPerRun,
    cost_observed: costPerRun * runs,
    cost_month: costPerRun * runsMonth,
    active: !!job.active,
  };
}

function renderTable() {
  const tbody = document.getElementById("tbl-body");
  const foot  = document.getElementById("tbl-foot");
  const rows = lastJobs.map((job, i) => computeRow(job, i)).filter(r => r.token_runs > 0 || r.avg_tokens > 0);
  renderModelFilters(rows);
  const rowsActive = rows.filter(r => r.active && isModelEnabled(r.model) && isRowEnabled(r));

  rows.sort((a, b) => {
    const va = a[sortKey], vb = b[sortKey];
    if (typeof va === "number" && typeof vb === "number") return (va - vb) * sortDir;
    return String(va).localeCompare(String(vb)) * sortDir;
  });

  if (!rows.length) {
    tbody.innerHTML = "<tr><td colspan=\"9\" style=\"color:var(--muted);font-style:italic;padding:18px 14px\">" +
      "Nenhum cron com dados de tokens ainda — execute alguns crons e tente novamente." +
      "</td></tr>";
    foot.innerHTML = "";
  } else {
    tbody.innerHTML = rows.map(r => {
      const costClass = r.cost_month > 50 ? "vhi" : (r.cost_month > 10 ? "hi" : "");
      const enabledModel = isModelEnabled(r.model);
      const enabledRow = isRowEnabled(r);
      const effectiveEnabled = enabledModel && enabledRow;
      const toggleLabel = enabledRow ? "desativar" : "reativar";
      const modelTxt = r.model
        ? escapeHtml(r.model) + " <small style=\"color:var(--muted);font-family:var(--mono);font-size:10px\">(" + escapeHtml(r.matched) + ")</small>"
        : "<span style=\"color:var(--muted)\">desconhecido <small>(" + escapeHtml(r.matched) + ")</small></span>";
      const badge = r.active
        ? "<span class=\"badge active\">ativo</span>"
        : "<span class=\"badge paused\">pausado</span>";
      const modelBadge = effectiveEnabled
        ? "<span class=\"badge active\">modelo on</span>"
        : "<span class=\"badge paused\">modelo off</span>";
      const toggleBtn = "<button type=\"button\" class=\"model-toggle-btn " + (enabledRow ? "on" : "off") + "\" data-toggle-row=\"" + escapeHtml(r.row_key) + "\" data-toggle-job-id=\"" + escapeHtml(r.job_id) + "\">" + toggleLabel + "</button>";
      return "<tr class=\"" + (effectiveEnabled ? "" : "model-off") + "\">" +
        "<td class=\"name\">" + escapeHtml(r.name) + "<small>" + badge + " " + modelBadge + "</small></td>" +
        "<td class=\"mono\">" + escapeHtml(r.profile) + "</td>" +
        "<td class=\"mono\"><div class=\"model-cell\"><span>" + modelTxt + "</span>" + toggleBtn + "</div></td>" +
        "<td class=\"num mono\">" + fmtInt(r.avg_tokens) + "</td>" +
        "<td class=\"num mono\">" + fmtInt(r.token_max) + "</td>" +
        "<td class=\"num mono\">" + fmtInt(r.token_runs) + "</td>" +
        "<td class=\"num cost\">" + fmtMoney(r.cost_per_run) + "</td>" +
        "<td class=\"num cost " + costClass + "\">" + fmtMoney(r.cost_observed) + "</td>" +
        "<td class=\"num cost " + costClass + "\">" + fmtMoney(r.cost_month) + "</td>" +
        "</tr>";
    }).join("");

    const totRuns   = rowsActive.reduce((a, r) => a + r.token_runs, 0);
    const totObs    = rowsActive.reduce((a, r) => a + r.cost_observed, 0);
    const totMonth  = rowsActive.reduce((a, r) => a + r.cost_month, 0);
    const avgPerRun = totRuns > 0 ? (totObs / totRuns) : 0;
    foot.innerHTML = "<tr class=\"total\">" +
      "<td colspan=\"5\">Total (" + rowsActive.length + " considerados de " + rows.length + " jobs)</td>" +
      "<td class=\"num mono\">" + fmtInt(totRuns) + "</td>" +
      "<td class=\"num cost\">" + fmtMoney(avgPerRun) + "</td>" +
      "<td class=\"num cost\">" + fmtMoney(totObs) + "</td>" +
      "<td class=\"num cost\">" + fmtMoney(totMonth) + "</td>" +
      "</tr>";
  }

  tbody.querySelectorAll("button[data-toggle-row]").forEach(btn => {
    btn.addEventListener("click", async () => {
      const key = String(btn.dataset.toggleRow || "").trim();
      const jobId = String(btn.dataset.toggleJobId || "").trim();
      if (!key) return;
      const enabledNow = key in rowToggles ? !!rowToggles[key] : true;
      const enableNext = !enabledNow;
      const action = enableNext ? "resume" : "pause";
      if (!jobId) {
        alert("Falha: job sem id para " + action + ".");
        return;
      }
      const old = btn.textContent;
      btn.disabled = true;
      btn.textContent = "…";
      try {
        const resp = await fetch(
          "/hermes/cron/" + encodeURIComponent(jobId) + "/" + action,
          { method: "POST", cache: "no-cache", credentials: "same-origin" }
        );
        const raw = await resp.text();
        let data = {};
        if (raw) {
          try { data = JSON.parse(raw); } catch (_) {}
        }
        if (!resp.ok || data.ok === false) {
          throw new Error(data.error || ("HTTP " + resp.status));
        }
      } catch (e) {
        alert("Falha ao " + (action === "pause" ? "pausar" : "retomar") + " job: " + (e && e.message ? e.message : e));
        btn.disabled = false;
        btn.textContent = old || (enabledNow ? "desativar" : "reativar");
        return;
      }
      rowToggles[key] = enableNext;
      saveRowToggles(rowToggles);
      await loadJobs();
    });
  });

  document.querySelectorAll("th[data-sort]").forEach(th => {
    th.classList.toggle("sorted", th.dataset.sort === sortKey);
    th.textContent = th.textContent.replace(/[ ▲▼]+$/, "") +
      (th.dataset.sort === sortKey ? (sortDir < 0 ? " ▼" : " ▲") : "");
  });

  // Stats topo
  const totRuns  = rowsActive.reduce((a, r) => a + r.token_runs, 0);
  const totObs   = rowsActive.reduce((a, r) => a + r.cost_observed, 0);
  const totMonth = rowsActive.reduce((a, r) => a + r.cost_month, 0);
  document.getElementById("v-jobs").textContent = String(rowsActive.length);
  document.getElementById("v-runs").textContent = fmtInt(totRuns);
  document.getElementById("v-cost-obs").textContent = fmtMoney(totObs);
  document.getElementById("v-cost-month").textContent = fmtMoney(totMonth);
}

function renderPrices() {
  const wrap = document.getElementById("price-list");
  wrap.innerHTML = prices.map((p, i) => {
    const isStar = String(p.match || "").trim() === "*";
    return "<div class=\"price-row\">" +
      "<div class=\"key\">" + escapeHtml(p.match) + (isStar ? " <small>(fallback)</small>" : "") + "</div>" +
      "<div><input type=\"number\" min=\"0\" step=\"0.01\" data-i=\"" + i + "\" data-k=\"in\"  value=\"" + Number(p.in)  + "\"></div>" +
      "<div><input type=\"number\" min=\"0\" step=\"0.01\" data-i=\"" + i + "\" data-k=\"out\" value=\"" + Number(p.out) + "\"></div>" +
      "<div>" + (isStar ? "" : "<button type=\"button\" data-rm=\"" + i + "\">Remover</button>") + "</div>" +
      "</div>";
  }).join("");
  wrap.querySelectorAll("input[data-i]").forEach(inp => {
    inp.addEventListener("change", () => {
      const i = Number(inp.dataset.i); const k = inp.dataset.k;
      prices[i][k] = Number(inp.value) || 0;
      savePrices(prices); renderTable();
    });
  });
  wrap.querySelectorAll("button[data-rm]").forEach(btn => {
    btn.addEventListener("click", () => {
      const i = Number(btn.dataset.rm);
      prices.splice(i, 1); savePrices(prices); renderPrices(); renderTable();
    });
  });
}

async function loadJobs() {
  const status = document.getElementById("status");
  status.textContent = "A carregar…";
  try {
    const r = await fetch(API, { cache: "no-cache", credentials: "same-origin" });
    const raw = await r.text();
    let data = {};
    if (raw) try { data = JSON.parse(raw); } catch (_) {}
    if (!r.ok || data.ok === false) throw new Error(data.error || ("HTTP " + r.status));
    lastJobs = Array.isArray(data.jobs) ? data.jobs : [];
    renderTable();
    const when = new Date().toLocaleTimeString("pt-BR");
    status.textContent = "Atualizado " + when + " — " + lastJobs.length + " jobs lidos de " +
      (data.jobs_path || "—") + ".";
    document.getElementById("badge-updated").textContent = when;
  } catch (e) {
    status.textContent = "Erro: " + e.message;
  }
}

function bindHeaderSort() {
  document.querySelectorAll("th[data-sort]").forEach(th => {
    th.addEventListener("click", () => {
      const key = th.dataset.sort;
      if (key === sortKey) sortDir = -sortDir;
      else { sortKey = key; sortDir = (key === "name" || key === "profile" || key === "model") ? 1 : -1; }
      renderTable();
    });
  });
}

function bindSettings() {
  const map = {
    "in-out-tokens": "outTokens",
    "in-runs-month": "runsPerMonth",
    "in-fx": "fx",
    "in-currency": "currency",
  };
  Object.entries(map).forEach(([id, key]) => {
    const el = document.getElementById(id);
    el.value = settings[key];
    el.addEventListener("change", () => {
      settings[key] = el.tagName === "SELECT" ? el.value : (Number(el.value) || 0);
      saveSettings(settings); renderTable();
    });
  });
}

document.getElementById("btn-refresh").addEventListener("click", loadJobs);
document.getElementById("btn-reset-prices").addEventListener("click", () => {
  if (!confirm("Restaurar tabela de preços padrão?")) return;
  prices = DEFAULT_PRICES.slice(); savePrices(prices); renderPrices(); renderTable();
});
document.getElementById("btn-reset-models").addEventListener("click", () => {
  if (!confirm("Reativar todos os modelos para cálculo?")) return;
  modelToggles = {};
  rowToggles = {};
  saveModelToggles(modelToggles);
  saveRowToggles(rowToggles);
  renderTable();
});
document.getElementById("btn-add-price").addEventListener("click", () => {
  const match = (document.getElementById("new-match").value || "").trim();
  const inP   = Number(document.getElementById("new-in").value) || 0;
  const outP  = Number(document.getElementById("new-out").value) || 0;
  if (!match) { alert("Informe um padrão de modelo (ex.: claude-3-7-sonnet)."); return; }
  // Remove duplicate matches (case-insensitive)
  prices = prices.filter(p => String(p.match).toLowerCase() !== match.toLowerCase());
  // Insert before fallback "*"
  const starIdx = prices.findIndex(p => String(p.match).trim() === "*");
  const entry = { match, in: inP, out: outP };
  if (starIdx >= 0) prices.splice(starIdx, 0, entry); else prices.push(entry);
  savePrices(prices);
  document.getElementById("new-match").value = "";
  document.getElementById("new-in").value = "";
  document.getElementById("new-out").value = "";
  renderPrices(); renderTable();
});

(async function boot() {
  if (typeof window.qcmAuthGate === "function") {
    const auth = await window.qcmAuthGate();
    if (!auth || auth.ok === false) return;
  }
  bindHeaderSort();
  bindSettings();
  renderPrices();
  await loadJobs();
  setInterval(loadJobs, 30000);
})();
</script>
</body>
</html>
"""


def build_cron_costs_html(hermes_dashboard_url: Optional[str] = None) -> str:
    return _inject_app_nav(
        CRON_COSTS_PAGE,
        "cron_costs",
        hermes_dashboard_url=hermes_dashboard_url,
    )


ROLES_PAGE = r"""<!doctype html>
<html lang="pt-br">
<head>
<meta charset="utf-8">
<title>gois — papéis da equipe</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<style>
  :root {
    --bg: #0f1115;
    --panel: #171a21;
    --panel-2: #1e222c;
    --border: #262b36;
    --fg: #e6e8ee;
    --muted: #8a93a6;
    --ok: #3ddc84;
    --bad: #ff5a5f;
    --warn: #ffb454;
    --accent: #6aa9ff;
    --accent-dim: rgba(106,169,255,.12);
    --mono: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }
  @media (prefers-color-scheme: light) {
    :root { --bg:#f5f6fa; --panel:#fff; --panel-2:#f0f2f7; --border:#e1e4ec;
            --fg:#15171c; --muted:#5b6477; }
  }
  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; min-height: 100%; background: var(--bg); color: var(--fg);
               font: 14px/1.45 -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; }
  body { display: flex; flex-direction: column; }
  __APP_NAV_CSS__
  main { flex: 1; padding: 24px 28px; max-width: 1200px; width: 100%; margin: 0 auto; }
  .layout { display: grid; grid-template-columns: 1fr 340px; gap: 20px; align-items: start; }
  @media (max-width: 960px) { .layout { grid-template-columns: 1fr; } }
  .panel { background: var(--panel); border: 1px solid var(--border); border-radius: 10px;
           padding: 18px; }
  .panel h2 { margin: 0 0 12px; font-size: 12px; font-weight: 600; color: var(--muted);
              text-transform: uppercase; letter-spacing: .8px; }
  .hint { color: var(--muted); font-size: 12px; line-height: 1.5; margin-bottom: 14px; }
  .toolbar { display: flex; flex-wrap: wrap; gap: 10px; align-items: center; margin-bottom: 16px; }
  .toolbar .grow { flex: 1; min-width: 200px; }
  .search { width: 100%; background: var(--panel-2); color: var(--fg);
            border: 1px solid var(--border); border-radius: 10px; padding: 10px 12px;
            font: inherit; font-size: 13px; }
  .search:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-dim); }
  button.ctrl, select.ctrl { background: var(--panel-2); color: var(--fg);
                             border: 1px solid var(--border); border-radius: 8px;
                             padding: 8px 12px; font-size: 12px; font-family: var(--mono);
                             cursor: pointer; }
  button.ctrl:hover { border-color: var(--accent); }
  button.ctrl.primary { background: var(--accent); color: #0f1115; border-color: var(--accent);
                        font-weight: 600; }
  button.ctrl.primary:hover { filter: brightness(1.08); }
  button.ctrl:disabled { opacity: .55; cursor: not-allowed; }
  .filters { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 14px; }
  .filters button.active { color: var(--accent); border-color: var(--accent); background: var(--accent-dim); }
  .stats { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 16px; }
  .stat { background: var(--panel); border: 1px solid var(--border); border-radius: 10px;
          padding: 10px 14px; min-width: 100px; }
  .stat .label { color: var(--muted); font-size: 11px; text-transform: uppercase;
                 letter-spacing: .6px; margin-bottom: 4px; }
  .stat .value { font-size: 20px; font-weight: 600; font-family: var(--mono); }
  .status-bar { color: var(--muted); font-size: 12px; font-family: var(--mono); margin-bottom: 14px; }
  .auth-panel { margin-bottom: 14px; padding: 14px; border-radius: 10px;
                border: 1px solid rgba(255,180,84,.35); background: rgba(255,180,84,.08); display: none; }
  .auth-panel.show { display: block; }
  .auth-panel .title { font-weight: 600; margin-bottom: 6px; }
  .auth-panel .hint { margin: 0 0 10px; font-size: 12px; }
  .auth-form { display: grid; grid-template-columns: 1fr 1fr auto; gap: 8px; align-items: end; }
  .auth-form input { background: var(--panel-2); color: var(--fg);
                     border: 1px solid var(--border); border-radius: 8px;
                     padding: 8px 10px; font: inherit; font-size: 13px; min-width: 0; }
  .auth-form .ctrl { height: 36px; }
  .auth-switch { margin-top: 10px; }
  .auth-switch button { width: 100%; }
  .auth-msg { margin-top: 10px; font-size: 12px; color: var(--muted); font-family: var(--mono); }
  @media (max-width: 760px) { .auth-form { grid-template-columns: 1fr; } }
  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 12px; }
  .role-card { background: var(--panel); border: 1px solid var(--border); border-radius: 10px;
               padding: 14px 16px; display: flex; flex-direction: column; gap: 8px; }
  .role-card:hover { border-color: rgba(106,169,255,.35); }
  .role-card .name { font-family: var(--mono); font-size: 13px; font-weight: 600; color: var(--accent); }
  .role-card .desc { color: var(--muted); font-size: 12px; line-height: 1.45; }
  .role-card .meta { color: var(--muted); font-size: 11px; font-family: var(--mono); }
  .role-card .actions { display: flex; gap: 8px; margin-top: auto; padding-top: 4px; }
  .role-card .actions a, .role-card .actions button { flex: 1; text-align: center;
    text-decoration: none; display: inline-block; }
  .badge { display: inline-block; padding: 2px 8px; border-radius: 999px;
           background: var(--panel-2); border: 1px solid var(--border);
           color: var(--muted); font-size: 11px; font-family: var(--mono); }
  .badge.default { color: var(--warn); }
  .badge.installed { color: var(--ok); border-color: rgba(61,220,132,.35); }
  .badge.catalog { color: var(--muted); }
  .presets { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 14px; max-height: 280px;
             overflow-y: auto; }
  .preset { background: var(--panel-2); border: 1px solid var(--border); border-radius: 999px;
            padding: 6px 12px; font-size: 11px; cursor: pointer; color: var(--fg); }
  .preset:hover { border-color: var(--accent); color: var(--accent); }
  .preset .cat { color: var(--muted); margin-left: 4px; }
  textarea.compose { width: 100%; min-height: 120px; resize: vertical; background: var(--panel-2);
                    color: var(--fg); border: 1px solid var(--border); border-radius: 10px;
                    padding: 12px; font: inherit; font-size: 13px; line-height: 1.45; }
  textarea.compose:focus { outline: none; border-color: var(--accent); }
  .options { display: flex; flex-direction: column; gap: 10px; margin: 12px 0; }
  .options label { display: flex; flex-direction: column; gap: 4px; font-size: 11px;
                   color: var(--muted); text-transform: uppercase; letter-spacing: .5px; }
  .options input[type=text] { background: var(--panel-2); color: var(--fg);
                              border: 1px solid var(--border); border-radius: 8px;
                              padding: 8px 10px; font: inherit; font-size: 13px; }
  .options .row-check { flex-direction: row; align-items: center; gap: 8px;
                        text-transform: none; letter-spacing: 0; font-size: 13px; color: var(--fg); }
  .dev-fields { display: none; }
  .dev-fields.show { display: flex; flex-direction: column; gap: 10px; }
  .create-tabs { display: flex; gap: 6px; margin-bottom: 12px; }
  .create-tabs button { flex: 1; }
  .create-panel { display: none; }
  .create-panel.active { display: block; }
  .mascot-grid { display: flex; flex-wrap: wrap; gap: 8px; margin: 8px 0; }
  .mascot-opt { width: 52px; height: 52px; padding: 4px; border: 2px solid var(--border);
                border-radius: 10px; background: var(--panel-2); cursor: pointer; }
  .mascot-opt svg { width: 100%; height: 100%; display: block; }
  .mascot-opt.selected { border-color: var(--accent); background: var(--accent-dim); }
  .project-source { display: flex; gap: 12px; margin: 8px 0; font-size: 13px; }
  .project-source label { flex-direction: row; align-items: center; gap: 6px;
                          text-transform: none; letter-spacing: 0; color: var(--fg); }
  .project-field { display: none; }
  .project-field.show { display: flex; flex-direction: column; gap: 4px; }
  .path-pick-row { display: flex; gap: 8px; align-items: center; }
  .path-pick-row input { flex: 1; }
  .folder-browser { margin-top: 10px; border: 1px solid var(--border); border-radius: 10px;
                    background: var(--panel-2); max-height: 220px; overflow: auto; padding: 6px; }
  .folder-browser .path { color: var(--muted); font-family: var(--mono); font-size: 11px;
                          margin-bottom: 6px; word-break: break-all; }
  .folder-browser .entry { width: 100%; text-align: left; margin-bottom: 6px; }
  .folder-browser .entry:last-child { margin-bottom: 0; }
  .result { margin-top: 12px; padding: 12px; border-radius: 8px; font-size: 12px;
            border: 1px solid var(--border); background: var(--panel-2); display: none; }
  .result.ok { display: block; border-color: rgba(61,220,132,.35); }
  .result.err { display: block; border-color: rgba(255,90,95,.35); color: var(--bad); }
  .empty { color: var(--muted); font-style: italic; font-size: 14px; padding: 40px 20px;
           text-align: center; background: var(--panel); border: 1px dashed var(--border);
           border-radius: 10px; }
  .catalog-banner { margin-bottom: 16px; padding: 14px 16px; border-radius: 10px;
                    border: 1px solid rgba(106,169,255,.35); background: rgba(106,169,255,.08); }
  .catalog-banner h2 { margin: 0 0 6px; font-size: 14px; font-weight: 600; }
  .catalog-banner p { margin: 0; color: var(--muted); font-size: 12px; line-height: 1.5; }
  .catalog-banner .cats { margin-top: 8px; font-size: 11px; font-family: var(--mono); color: var(--muted); }
</style>
</head>
<body>
__APP_NAV__
<main>
  <div class="layout">
    <section>
      <div class="catalog-banner" id="catalog-banner">
        <h2>Catálogo de papéis</h2>
        <p id="catalog-summary">Carregando catálogo…</p>
        <div class="cats" id="catalog-cats"></div>
      </div>
      <div class="toolbar">
        <div class="grow">
          <input type="search" class="search" id="roles-search" placeholder="Buscar papéis por nome ou descrição…">
        </div>
        <button type="button" class="ctrl" id="btn-refresh">Atualizar</button>
        <button type="button" class="ctrl primary" id="btn-seed-all" title="Instala todos os papéis do catálogo no Hermes (rápido, disco)">
          Instalar catálogo
        </button>
        <button type="button" class="ctrl" id="btn-seed-roles" title="Papéis de desenvolvimento">
          Seed dev
        </button>
        <button type="button" class="ctrl" id="btn-seed-it" title="~120 papéis de operações de TI">Seed TI</button>
        <button type="button" class="ctrl" id="btn-seed-pesquisa" title="~240 papéis de pesquisa científica">Seed pesquisa</button>
        <button type="button" class="ctrl" id="btn-seed-youtube" title="~240 papéis YouTube/creator">Seed YouTube</button>
        <button type="button" class="ctrl" id="btn-seed-missing" title="Só os que ainda não existem no disco" style="display:none">Completar faltantes</button>
        <a class="ctrl" id="hermes-link" href="#" target="_blank" rel="noopener" style="display:none">Hermes</a>
      </div>
      <div class="filters" id="category-filters">
        <button type="button" class="ctrl active" data-cat="all">Todos</button>
      </div>
      <div class="stats">
        <div class="stat"><div class="label">Exibidos</div><div class="value" id="stat-shown">—</div></div>
        <div class="stat"><div class="label">Catálogo</div><div class="value" id="stat-total">—</div></div>
        <div class="stat"><div class="label">Instalados</div><div class="value" id="stat-installed">—</div></div>
      </div>
      <div class="status-bar" id="status-bar">Carregando papéis…</div>
      <div class="grid" id="roles-grid">
        <div class="empty">Carregando…</div>
      </div>
    </section>

    <aside class="panel">
      <h2>Criar agente</h2>
      <div class="create-tabs">
        <button type="button" class="ctrl active" id="tab-role">Papel</button>
        <button type="button" class="ctrl" id="tab-project">Projeto + Kanban</button>
      </div>

      <div class="create-panel active" id="panel-role">
        <p class="hint">
          Descreva o profissional em linguagem natural. Ative <strong>modo desenvolvimento</strong>
          para agendar um cron.
        </p>
        <div class="presets" id="presets"></div>
        <textarea class="compose" id="role-text" rows="5"
          placeholder="Ex.: Engenheiro de QA focado em testes E2E…"></textarea>
        <div class="options">
          <label class="row-check">
            <input type="checkbox" id="mode-dev">
            Modo desenvolvimento (perfil + cron)
          </label>
          <div class="dev-fields" id="dev-fields">
            <label>Agendamento
              <input type="text" id="role-schedule" placeholder="every 24h">
            </label>
            <label>Diretório do projeto
              <div class="path-pick-row">
                <input type="text" id="role-workdir" placeholder="/caminho/do/repo">
                <button type="button" class="ctrl" id="role-workdir-browse">Navegar</button>
              </div>
              <div class="folder-browser" id="role-folder-browser" style="display:none;">
                <div class="path" id="role-folder-path"></div>
                <button type="button" class="ctrl entry" id="role-folder-up">⬆ Subir</button>
                <div id="role-folder-list"></div>
              </div>
            </label>
          </div>
        </div>
        <a class="ctrl" href="/agents/novo" style="width:100%;text-align:center;margin-bottom:8px;">
          Criação avançada →
        </a>
        <button type="button" class="ctrl primary" id="btn-create" style="width:100%;">Criar papel</button>
      </div>

      <div class="create-panel" id="panel-project">
        <p class="hint">
          Agente com <strong>nome</strong>, <strong>mascote</strong>, papel da equipe e projeto
          (pasta local ou GitHub). No cron, clona o repo se preciso, lê <code>kanban.yaml</code>,
          implementa tarefas atribuídas a ele e faz commit + push.
        </p>
        <div class="options">
          <label>Nome do agente
            <input type="text" id="proj-display-name" placeholder="Maria Backend">
          </label>
          <label>Mascote</label>
          <div class="mascot-grid" id="mascot-grid">carregando…</div>
          <label>Papel (preset)
            <select class="ctrl" id="proj-role-preset" style="width:100%;">
              <option value="">— escolha ou descreva abaixo —</option>
            </select>
          </label>
          <label>Time
            <div class="path-pick-row">
              <select class="ctrl" id="proj-team-id" style="width:100%;">
                <option value="">Carregando times…</option>
              </select>
              <a class="ctrl" href="/times/novo" target="_blank" rel="noopener">Novo time</a>
              <a class="ctrl" href="/times" target="_blank" rel="noopener">Gerenciar</a>
            </div>
          </label>
          <textarea class="compose" id="proj-role-text" rows="3"
            placeholder="Opcional: texto do papel se não usar preset…"></textarea>
          <div class="project-source">
            <label><input type="radio" name="proj-src" value="github" checked> GitHub</label>
            <label><input type="radio" name="proj-src" value="local"> Pasta local</label>
          </div>
          <label class="project-field show" id="proj-github-wrap">URL do repositório
            <input type="text" id="proj-github-url" placeholder="https://github.com/org/repo">
          </label>
          <label class="project-field" id="proj-local-wrap">Caminho da pasta
            <div class="path-pick-row">
              <input type="text" id="proj-local-path" placeholder="/Users/voce/projeto">
              <button type="button" class="ctrl" id="proj-local-browse">Navegar</button>
            </div>
            <div class="folder-browser" id="proj-folder-browser" style="display:none;">
              <div class="path" id="proj-folder-path"></div>
              <button type="button" class="ctrl entry" id="proj-folder-up">⬆ Subir</button>
              <div id="proj-folder-list"></div>
            </div>
          </label>
          <label>Branch (GitHub)
            <input type="text" id="proj-github-branch" placeholder="main">
          </label>
          <label>Agendamento do cron
            <input type="text" id="proj-schedule" placeholder="every 24h">
          </label>
          <label>Tarefa do kanban (opcional)
            <input type="text" id="proj-task-id" placeholder="TASK-001">
          </label>
        </div>
        <button type="button" class="ctrl primary" id="btn-create-project" style="width:100%;">
          Criar agente de projeto
        </button>
      </div>
      <div class="result" id="create-result"></div>
    </aside>
  </div>
</main>
<script>
let PRESETS = [];
let catalogMeta = null;
let profiles = [];
let rolesGridWired = false;
let rolesRenderToken = 0;
const ROLES_RENDER_CHUNK = 48;
let query = "";
let category = "all";
let hermesDashboardUrl = "";
let selectedMascot = "gois";
let mascots = [];
let projectBrowsePath = "";
let roleBrowsePath = "";
let teams = [];

function el(id) { return document.getElementById(id); }

function escapeHtml(s) {
  return String(s || "").replace(/&/g,"&amp;").replace(/</g,"&lt;")
    .replace(/>/g,"&gt;").replace(/"/g,"&quot;");
}

function renderPresets() {
  const box = el("presets");
  if (!box) return;
  if (!PRESETS.length) {
    box.innerHTML = '<div class="empty">Carregando catálogo de modelos…</div>';
    return;
  }
  const cats = [...new Set(PRESETS.map(p => p.category))].sort();
  const filters = el("category-filters");
  filters.innerHTML = '<button type="button" class="ctrl active" data-cat="all">Todos</button>' +
    cats.map(c => '<button type="button" class="ctrl" data-cat="' + escapeHtml(c) + '">' +
      escapeHtml(c) + '</button>').join("");
  filters.querySelectorAll("button").forEach(btn => {
    btn.addEventListener("click", () => {
      filters.querySelectorAll("button").forEach(b => b.classList.remove("active"));
      btn.classList.add("active");
      category = btn.dataset.cat || "all";
      renderPresets();
      renderProfiles();
    });
  });
  const filtered = category === "all" ? PRESETS : PRESETS.filter(p => p.category === category);
  box.innerHTML = filtered.map(p =>
    '<button type="button" class="preset" data-id="' + escapeHtml(p.id) + '">' +
      escapeHtml(p.label) +
      '<span class="cat">' + escapeHtml(p.category) + '</span>' +
    '</button>'
  ).join("");
  box.querySelectorAll(".preset").forEach(btn => {
    btn.addEventListener("click", () => {
      const preset = PRESETS.find(x => x.id === btn.dataset.id);
      if (preset) {
        el("role-text").value = preset.prompt;
        el("role-text").focus();
      }
    });
  });
}

function installedProfilesMap() {
  const m = new Map();
  for (const p of profiles) {
    const n = String(p.name || "").trim();
    if (n && n !== "default") m.set(n, p);
  }
  return m;
}

function filteredProfiles() {
  const q = query.trim().toLowerCase();
  return profiles.filter(p => {
    if (p.name === "default" && !q) return false;
    const hay = [p.name, p.description, p.model, p.category, p.display_name]
      .filter(Boolean).join(" ").toLowerCase();
    return !q || hay.includes(q);
  });
}

function filteredRolesForGrid() {
  const q = query.trim().toLowerCase();
  const byInst = installedProfilesMap();
  if (PRESETS.length) {
    let catalog = category === "all"
      ? PRESETS.slice()
      : PRESETS.filter((p) => p.category === category);
    if (q) {
      catalog = catalog.filter((p) => {
        const hay = [p.id, p.label, p.category, p.prompt].filter(Boolean).join(" ").toLowerCase();
        return hay.includes(q);
      });
    }
    return catalog.map((preset) => {
      const inst = byInst.get(preset.id);
      return {
        name: preset.id,
        display_name: (inst && inst.display_name) || preset.label || preset.id,
        description: (inst && inst.description) || preset.label || "",
        category: preset.category || (inst && inst.category) || "",
        model: inst && inst.model,
        mascot: inst && inst.mascot,
        installed: !!inst,
      };
    });
  }
  return filteredProfiles().map((p) => Object.assign({}, p, { installed: true }));
}

function updateCatalogBanner(meta) {
  if (!meta) return;
  catalogMeta = meta;
  const total = meta.catalog_total || PRESETS.length || 0;
  const installed = meta.installed_total != null ? meta.installed_total : 0;
  const missing = meta.missing_count != null ? meta.missing_count : 0;
  const root = meta.profiles_root || "";
  el("catalog-summary").textContent =
    total + " papéis prontos no catálogo · " + installed + " instalados no Hermes" +
    (missing ? " · " + missing + " faltando" : " · catálogo completo") +
    (root ? " · " + root : "");
  const cats = meta.categories || {};
  const catLine = Object.keys(cats).sort().map((k) => k + ": " + cats[k]).join(" · ");
  el("catalog-cats").textContent = catLine || "";
  const missBtn = el("btn-seed-missing");
  if (missBtn) missBtn.style.display = missing > 0 ? "" : "none";
}

function roleCardHtml(p, dash) {
  const isDefault = p.name === "default";
  const href = dash ? dash + "/profiles" : "#";
  const desc = p.description ? escapeHtml(String(p.description)) : "";
  const model = p.model ? escapeHtml(String(p.model)) : "";
  const display = p.display_name ? escapeHtml(String(p.display_name)) : "";
  const mascot = p.mascot ? '<span class="badge">' + escapeHtml(p.mascot) + '</span> ' : '';
  const cat = p.category
    ? '<span class="badge">' + escapeHtml(String(p.category)) + '</span> '
    : "";
  const stateBadge = p.installed
    ? '<span class="badge installed">instalado</span> '
    : '<span class="badge catalog">catálogo</span> ';
  return '<article class="role-card">' +
    '<div class="name">' + stateBadge + mascot + cat + escapeHtml(p.name || "?") +
      (display ? ' <span class="meta">(' + display + ')</span>' : '') +
      (isDefault ? ' <span class="badge default">default</span>' : '') +
    '</div>' +
    (desc ? '<div class="desc">' + desc + '</div>' : '') +
    (model ? '<div class="meta">' + model + '</div>' : '') +
    '<div class="actions">' +
      (dash && p.installed
        ? '<a class="ctrl" href="' + href + '" target="_blank" rel="noopener">Abrir no Hermes</a>'
        : '') +
      '<button type="button" class="ctrl" data-copy="' + escapeHtml(p.name || "") + '">Copiar slug</button>' +
    '</div></article>';
}

function wireRolesGrid() {
  const box = el("roles-grid");
  if (!box || rolesGridWired) return;
  rolesGridWired = true;
  box.addEventListener("click", (ev) => {
    const btn = ev.target.closest("[data-copy]");
    if (!btn) return;
    navigator.clipboard.writeText(btn.dataset.copy || "");
  });
}

function renderProfiles() {
  const rows = filteredRolesForGrid();
  const token = ++rolesRenderToken;
  const installedCount = installedProfilesMap().size;
  const catalogTotal = catalogMeta && catalogMeta.catalog_total
    ? Number(catalogMeta.catalog_total)
    : (PRESETS.length || installedCount);
  el("stat-shown").textContent = String(rows.length);
  el("stat-total").textContent = String(catalogTotal);
  const statInstalled = el("stat-installed");
  if (statInstalled) statInstalled.textContent = String(installedCount);
  const box = el("roles-grid");
  wireRolesGrid();
  if (!rows.length) {
    const msg = PRESETS.length
      ? "Nenhum papel corresponde ao filtro."
      : "Nenhum papel encontrado. Crie um ao lado ou instale o catálogo.";
    box.innerHTML = '<div class="empty">' + escapeHtml(msg) + '</div>';
    el("status-bar").textContent = "0 papéis · Hermes " + (hermesDashboardUrl || "—");
    return;
  }
  const dash = hermesDashboardUrl ? hermesDashboardUrl.replace(/\/$/, "") : "";
  box.innerHTML = "";
  let idx = 0;
  function paintChunk() {
    if (token !== rolesRenderToken) return;
    const frag = document.createDocumentFragment();
    const end = Math.min(idx + ROLES_RENDER_CHUNK, rows.length);
    for (; idx < end; idx++) {
      const wrap = document.createElement("div");
      wrap.innerHTML = roleCardHtml(rows[idx], dash);
      frag.appendChild(wrap.firstElementChild);
    }
    box.appendChild(frag);
    if (idx < rows.length) {
      el("status-bar").textContent =
        "A mostrar " + idx + " / " + rows.length + " papéis…";
      requestAnimationFrame(paintChunk);
      return;
    }
    el("status-bar").textContent =
      rows.length + " no catálogo · " + installedCount + " instalados · Hermes " +
      (hermesDashboardUrl || "—");
  }
  paintChunk();
}

function redirectToGlobalLogin() {
  const next = window.location.pathname + window.location.search + window.location.hash;
  window.location.replace("/login?next=" + encodeURIComponent(next || "/"));
}

async function loadProfiles() {
  el("status-bar").textContent = "Carregando papéis…";
  try {
    if (typeof window.qcmAuthGate === "function") {
      const auth = await window.qcmAuthGate();
      if (!auth || auth.ok === false) return;
    }

    const r = await fetch("/hermes/profiles?quick=1&scope=roles", { cache: "no-cache" });
    const data = await r.json();
    if (!r.ok || data.ok === false) throw new Error(data.error || "falha ao carregar");
    profiles = data.profiles || [];
    updateCatalogBanner(data);
    hermesDashboardUrl = data.dashboard_url || hermesDashboardUrl;
    const link = el("hermes-link");
    if (link && hermesDashboardUrl) {
      link.href = hermesDashboardUrl;
      link.style.display = "";
    }
    renderProfiles();
    if (data.fallback) {
      const warn = (data.warning || "Hermes indisponível").trim();
      el("status-bar").textContent = "Modo fallback: exibindo dados locais. " + warn;
    }
  } catch (e) {
    const msg = String((e && e.message) || "falha ao carregar");
    if (msg.toLowerCase().includes("not authenticated")) {
      redirectToGlobalLogin();
      return;
    }
    el("roles-grid").innerHTML = '<div class="empty">Erro: ' + escapeHtml(msg) + '</div>';
    el("status-bar").textContent = "";
  }
}

async function createRole() {
  const text = el("role-text").value.trim();
  const btn = el("btn-create");
  const result = el("create-result");
  if (!text) return;
  btn.disabled = true;
  result.className = "result";
  result.textContent = "Criando…";
  result.style.display = "block";
  const payload = { text };
  if (el("mode-dev").checked) {
    payload.mode = "dev";
    const sched = el("role-schedule").value.trim();
    const work = el("role-workdir").value.trim();
    if (sched) payload.schedule = sched;
    if (work) payload.workdir = work;
  } else {
    payload.mode = "role";
  }
  try {
    const r = await fetch("/hermes/agents/create", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(payload),
    });
    const data = await r.json();
    if (!r.ok || data.ok === false) throw new Error(data.error || ("HTTP " + r.status));
    let msg = "Papel criado: " + (data.name || "?");
    if (data.renamed) msg += " (ajustado de " + data.requested_name + ")";
    if (data.description) msg += "\n" + data.description;
    if (data.cron && data.cron.job_id) msg += "\nCron: " + data.cron.job_id;
    result.className = "result ok";
    result.textContent = msg;
    el("role-text").value = "";
    loadProfiles();
  } catch (e) {
    result.className = "result err";
    result.textContent = "Falha: " + e.message;
  } finally {
    btn.disabled = false;
  }
}

function renderMascots() {
  const grid = el("mascot-grid");
  if (!grid) return;
  if (!mascots.length) {
    grid.innerHTML = '<span class="hint">sem mascotes</span>';
    return;
  }
  grid.innerHTML = mascots.map(m =>
    '<button type="button" class="mascot-opt' + (m.id === selectedMascot ? ' selected' : '') +
      '" data-id="' + escapeHtml(m.id) + '" title="' + escapeHtml(m.label) + '">' +
      (m.svg || '') + '</button>'
  ).join("");
  grid.querySelectorAll(".mascot-opt").forEach(btn => {
    btn.addEventListener("click", () => {
      selectedMascot = btn.dataset.id || "gois";
      renderMascots();
    });
  });
}

async function loadMascots() {
  try {
    const r = await fetch("/hermes/mascots", { cache: "no-cache" });
    const data = await r.json();
    if (r.ok && data.ok !== false) mascots = data.mascots || [];
  } catch (e) { /* ignore */ }
  renderMascots();
}

function renderTeamsSelect() {
  const sel = el("proj-team-id");
  if (!sel) return;
  if (!teams.length) {
    sel.innerHTML = '<option value="">Nenhum time encontrado</option>';
    return;
  }
  const opts = ['<option value="">— selecione um time —</option>'].concat(
    teams.map(t => '<option value="' + escapeHtml(String(t.id || "")) + '">' +
      escapeHtml(String(t.name || t.id || "?")) + "</option>")
  );
  sel.innerHTML = opts.join("");
  if (teams.length === 1) {
    sel.value = String(teams[0].id || "");
  }
}

async function loadTeams() {
  try {
    const r = await fetch("/teams", { cache: "no-cache", credentials: "same-origin" });
    const data = await r.json();
    if (!r.ok || data.ok === false) throw new Error(data.error || "falha ao carregar times");
    teams = Array.isArray(data.teams) ? data.teams : [];
  } catch (e) {
    teams = [];
  }
  renderTeamsSelect();
}

function populateProjectPresetSelect() {
  const sel = el("proj-role-preset");
  if (!sel || sel.dataset.populated === "1") return;
  PRESETS.forEach(p => {
    const opt = document.createElement("option");
    opt.value = p.id;
    opt.textContent = p.label + " (" + p.category + ")";
    sel.appendChild(opt);
  });
  sel.dataset.populated = "1";
}

async function loadPresets() {
  try {
    const r = await fetch("/hermes/roles/presets", { cache: "default" });
    const data = await r.json();
    if (r.ok && data.ok !== false) {
      PRESETS = data.presets || [];
      updateCatalogBanner(data);
    }
  } catch (_) {
    PRESETS = [];
  }
  renderPresets();
  populateProjectPresetSelect();
  renderProfiles();
}

function initProjectForm() {
  const sel = el("proj-role-preset");
  if (sel) {
    sel.addEventListener("change", () => {
      const preset = PRESETS.find(x => x.id === sel.value);
      if (preset) el("proj-role-text").value = preset.prompt;
    });
  }
  document.querySelectorAll('input[name="proj-src"]').forEach(radio => {
    radio.addEventListener("change", () => {
      const gh = radio.value === "github";
      el("proj-github-wrap").classList.toggle("show", gh);
      el("proj-local-wrap").classList.toggle("show", !gh);
      if (gh) {
        el("proj-folder-browser").style.display = "none";
      }
    });
  });
  const browseBtn = el("proj-local-browse");
  if (browseBtn) {
    browseBtn.addEventListener("click", async () => {
      const inputPath = el("proj-local-path").value.trim();
      const guess = inputPath || projectBrowsePath;
      await browseProjectFolders(guess);
      el("proj-folder-browser").style.display = "block";
    });
  }
  const upBtn = el("proj-folder-up");
  if (upBtn) {
    upBtn.addEventListener("click", async () => {
      if (!projectBrowsePath) return;
      await browseProjectFolders(projectBrowsePath, true);
    });
  }
}

function initRoleWorkdirBrowser() {
  const browseBtn = el("role-workdir-browse");
  if (browseBtn) {
    browseBtn.addEventListener("click", async () => {
      const inputPath = el("role-workdir").value.trim();
      const guess = inputPath || roleBrowsePath || projectBrowsePath;
      await browseRoleFolders(guess);
      el("role-folder-browser").style.display = "block";
    });
  }
  const upBtn = el("role-folder-up");
  if (upBtn) {
    upBtn.addEventListener("click", async () => {
      if (!roleBrowsePath) return;
      await browseRoleFolders(roleBrowsePath, true);
    });
  }
}

async function browseRoleFolders(path, goUp = false) {
  const q = new URLSearchParams();
  if (path) q.set("path", path);
  if (goUp) q.set("up", "1");
  const url = "/hermes/local-folders" + (q.toString() ? ("?" + q.toString()) : "");
  const r = await fetch(url, { cache: "no-cache" });
  const data = await r.json();
  if (!r.ok || data.ok === false) throw new Error(data.error || "falha ao listar pastas");
  roleBrowsePath = String(data.current || "");
  renderRoleFolderList(data);
}

function renderRoleFolderList(data) {
  const current = String(data.current || "");
  const parent = String(data.parent || "");
  const dirs = Array.isArray(data.directories) ? data.directories : [];
  el("role-folder-path").textContent = current || "—";
  const upBtn = el("role-folder-up");
  upBtn.disabled = !parent || parent === current;
  const list = el("role-folder-list");
  if (!dirs.length) {
    list.innerHTML = '<div class="empty" style="padding:10px;">Nenhuma subpasta visível.</div>';
    return;
  }
  list.innerHTML = dirs.map(d => (
    '<button type="button" class="ctrl entry" data-path="' + escapeHtml(String(d.path || "")) + '">' +
    '📁 ' + escapeHtml(String(d.name || d.path || "")) +
    "</button>"
  )).join("");
  list.querySelectorAll("[data-path]").forEach(btn => {
    btn.addEventListener("click", async () => {
      const picked = btn.dataset.path || "";
      if (!picked) return;
      el("role-workdir").value = picked;
      await browseRoleFolders(picked);
    });
  });
}

async function browseProjectFolders(path, goUp = false) {
  const q = new URLSearchParams();
  if (path) q.set("path", path);
  if (goUp) q.set("up", "1");
  const url = "/hermes/local-folders" + (q.toString() ? ("?" + q.toString()) : "");
  const r = await fetch(url, { cache: "no-cache" });
  const data = await r.json();
  if (!r.ok || data.ok === false) throw new Error(data.error || "falha ao listar pastas");
  projectBrowsePath = String(data.current || "");
  renderProjectFolderList(data);
}

function renderProjectFolderList(data) {
  const current = String(data.current || "");
  const parent = String(data.parent || "");
  const dirs = Array.isArray(data.directories) ? data.directories : [];
  el("proj-folder-path").textContent = current || "—";
  const upBtn = el("proj-folder-up");
  upBtn.disabled = !parent || parent === current;
  const list = el("proj-folder-list");
  if (!dirs.length) {
    list.innerHTML = '<div class="empty" style="padding:10px;">Nenhuma subpasta visível.</div>';
    return;
  }
  list.innerHTML = dirs.map(d => (
    '<button type="button" class="ctrl entry" data-path="' + escapeHtml(String(d.path || "")) + '">' +
    '📁 ' + escapeHtml(String(d.name || d.path || "")) +
    '</button>'
  )).join("");
  list.querySelectorAll("[data-path]").forEach(btn => {
    btn.addEventListener("click", async () => {
      const picked = btn.dataset.path || "";
      if (!picked) return;
      el("proj-local-path").value = picked;
      await browseProjectFolders(picked);
    });
  });
}

async function createProjectAgent() {
  const name = el("proj-display-name").value.trim();
  const btn = el("btn-create-project");
  const result = el("create-result");
  const teamId = el("proj-team-id").value.trim();
  if (!name) {
    result.className = "result err";
    result.textContent = "Informe o nome do agente.";
    result.style.display = "block";
    return;
  }
  const preset = el("proj-role-preset").value;
  const roleText = el("proj-role-text").value.trim();
  if (!preset && !roleText) {
    result.className = "result err";
    result.textContent = "Escolha um preset ou descreva o papel.";
    result.style.display = "block";
    return;
  }
  if (!teamId) {
    result.className = "result err";
    result.textContent = "Selecione um time para o agente de projeto.";
    result.style.display = "block";
    return;
  }
  const src = document.querySelector('input[name="proj-src"]:checked')?.value || "github";
  btn.disabled = true;
  result.className = "result";
  result.textContent = "Criando agente de projeto…";
  result.style.display = "block";
  const payload = {
    mode: "project",
    display_name: name,
    mascot: selectedMascot,
    team_id: teamId,
    project_source: src,
  };
  if (preset) payload.role_preset = preset;
  if (roleText) payload.role_text = roleText;
  if (src === "github") {
    payload.github_url = el("proj-github-url").value.trim();
    const br = el("proj-github-branch").value.trim();
    if (br) payload.github_branch = br;
  } else {
    payload.local_path = el("proj-local-path").value.trim();
  }
  const sched = el("proj-schedule").value.trim();
  if (sched) payload.schedule = sched;
  const taskId = el("proj-task-id").value.trim();
  if (taskId) payload.task_id = taskId;
  try {
    const r = await fetch("/hermes/agents/create", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(payload),
    });
    const data = await r.json();
    if (!r.ok || data.ok === false) throw new Error(data.error || ("HTTP " + r.status));
    let msg = "Agente: " + (data.display_name || data.name) + " → " + (data.name || "?");
    if (data.workdir) msg += "\nWorkdir: " + data.workdir;
    if (data.github_repo) msg += "\nRepo: " + data.github_repo;
    if (data.kanban_tasks_open != null) msg += "\nTarefas kanban abertas: " + data.kanban_tasks_open;
    if (data.task_id) msg += "\nTarefa designada: " + data.task_id;
    if (data.cron && data.cron.job_id) msg += "\nCron: " + data.cron.job_id;
    result.className = "result ok";
    result.textContent = msg;
    loadProfiles();
  } catch (e) {
    result.className = "result err";
    result.textContent = "Falha: " + e.message;
  } finally {
    btn.disabled = false;
  }
}

async function seedRolePresets(opts) {
  const categories = opts && opts.categories ? opts.categories : null;
  const label = (opts && opts.label) || "papéis";
  const buttons = ["btn-seed-roles", "btn-seed-it", "btn-seed-pesquisa", "btn-seed-youtube", "btn-seed-all", "btn-seed-missing"];
  const result = el("create-result");
  const catHint = categories ? categories.join(", ") : "desenvolvimento (time de software)";
  if (!confirm(
    "Criar perfis Hermes para: " + label + "?\n\n" +
    "Categorias: " + catHint + "\n" +
    "Perfis já existentes com o mesmo slug serão ignorados."
  )) return;
  buttons.forEach((id) => { const b = el(id); if (b) b.disabled = true; });
  result.className = "result";
  result.textContent = "Criando " + label + "…";
  result.style.display = "block";
  try {
    const body = { only_missing: !(opts && opts.onlyMissing === false) };
    if (categories) body.categories = categories;
    const r = await fetch("/hermes/roles/seed", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(body),
    });
    const data = await r.json();
    if (!r.ok || data.ok === false) throw new Error(data.error || ("HTTP " + r.status));
    if (data.started && data.running) {
      result.className = "result ok";
      result.textContent = (data.message || "Criação em segundo plano…") + " Aguarde.";
      await pollRoleSeedStatus(result);
      loadProfiles();
      return;
    }
    showRoleSeedResult(result, data);
    loadProfiles();
  } catch (e) {
    result.className = "result err";
    result.textContent = "Falha: " + e.message;
  } finally {
    buttons.forEach((id) => { const b = el(id); if (b) b.disabled = false; });
  }
}

function showRoleSeedResult(result, data) {
  const created = Array.isArray(data.created) ? data.created : [];
  const skipped = Array.isArray(data.skipped) ? data.skipped : [];
  const errors = Array.isArray(data.errors) ? data.errors : [];
  let msg = "Criados: " + created.length;
  if (created.length <= 8) {
    if (created.length) msg += " — " + created.map((c) => c.name || c.preset_id).join(", ");
  } else if (created.length) {
    msg += " (primeiros: " + created.slice(0, 5).map((c) => c.preset_id).join(", ") + "…)";
  }
  msg += "\nJá existiam: " + skipped.length;
  if (errors.length) {
    msg += "\nErros: " + errors.length;
    if (errors.length <= 5) {
      msg += " — " + errors.map((e) => (e.preset_id || "?") + ": " + e.error).join("; ");
    }
  }
  result.className = errors.length ? "result err" : "result ok";
  result.textContent = msg;
}

async function pollRoleSeedStatus(result) {
  for (let i = 0; i < 600; i++) {
    await new Promise((r) => setTimeout(r, 2000));
    try {
      const sr = await fetch("/hermes/roles/seed/status");
      const st = await sr.json();
      if (st.running) {
        const c = Array.isArray(st.created) ? st.created.length : (st.created || 0);
        const sk = Array.isArray(st.skipped) ? st.skipped.length : (st.skipped || 0);
        result.textContent = "Criando papéis… criados=" + c + " ignorados=" + sk;
        continue;
      }
      showRoleSeedResult(result, st);
      return;
    } catch (_) { /* retry */ }
  }
  result.className = "result err";
  result.textContent = "Seed ainda em execução — veja os logs do gois.";
}

function switchCreateTab(which) {
  const role = which === "role";
  el("tab-role").classList.toggle("active", role);
  el("tab-project").classList.toggle("active", !role);
  el("panel-role").classList.toggle("active", role);
  el("panel-project").classList.toggle("active", !role);
}

el("roles-search").addEventListener("input", (ev) => {
  query = ev.target.value || "";
  renderProfiles();
});
el("btn-refresh").addEventListener("click", loadProfiles);
el("btn-seed-roles").addEventListener("click", () => seedRolePresets({
  label: "papéis de desenvolvimento",
  categories: ["desenvolvimento", "qualidade", "operações", "gestão", "produto", "design", "dados", "segurança"],
}));
el("btn-seed-it").addEventListener("click", () => seedRolePresets({
  label: "operações de TI", categories: ["operacoes-ti"],
}));
el("btn-seed-pesquisa").addEventListener("click", () => seedRolePresets({
  label: "pesquisa científica", categories: ["pesquisa-cientifica"],
}));
el("btn-seed-youtube").addEventListener("click", () => seedRolePresets({
  label: "YouTube / creators", categories: ["youtube"],
}));
el("btn-seed-all").addEventListener("click", () => seedRolePresets({ label: "catálogo completo (" + (catalogMeta?.catalog_total || PRESETS.length) + " papéis)" }));
el("btn-seed-missing").addEventListener("click", () => seedRolePresets({ label: "papéis faltantes", onlyMissing: true }));
el("btn-create").addEventListener("click", createRole);
el("btn-create-project").addEventListener("click", createProjectAgent);
el("tab-role").addEventListener("click", () => switchCreateTab("role"));
el("tab-project").addEventListener("click", () => switchCreateTab("project"));
el("mode-dev").addEventListener("change", (ev) => {
  el("dev-fields").classList.toggle("show", ev.target.checked);
  if (!ev.target.checked) el("role-folder-browser").style.display = "none";
});
renderPresets();
initRoleWorkdirBrowser();
initProjectForm();
wireRolesGrid();
(async function bootRolesPage() {
  loadTeams();
  loadMascots();
  loadPresets();
  await loadProfiles();
})();
</script>
</body>
</html>
"""


def build_roles_html(hermes_dashboard_url: Optional[str] = None) -> str:
    # Presets load via GET /hermes/roles/presets (keeps HTML small and fast).
    html = ROLES_PAGE.replace("__ROLE_PRESETS__", "[]")
    return _inject_app_nav(
        html,
        "roles",
        hermes_dashboard_url=hermes_dashboard_url,
    )


TEAMS_PAGE = r"""<!doctype html>
<html lang="pt-br">
<head>
<meta charset="utf-8">
<title>gois — times</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<style>
  :root {
    --bg: #0f1115;
    --panel: #171a21;
    --panel-2: #1e222c;
    --border: #262b36;
    --fg: #e6e8ee;
    --muted: #8a93a6;
    --ok: #3ddc84;
    --bad: #ff5a5f;
    --warn: #ffb454;
    --accent: #6aa9ff;
    --accent-dim: rgba(106,169,255,.12);
    --mono: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }
  @media (prefers-color-scheme: light) {
    :root { --bg:#f5f6fa; --panel:#fff; --panel-2:#f0f2f7; --border:#e1e4ec;
            --fg:#15171c; --muted:#5b6477; }
  }
  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; min-height: 100%; background: var(--bg); color: var(--fg);
               font: 14px/1.45 -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; }
  body { display: flex; flex-direction: column; }
  __APP_NAV_CSS__
  main { flex: 1; padding: 24px 28px; max-width: 1200px; width: 100%; margin: 0 auto; }
  .page-head { margin-bottom: 20px; }
  .page-head h1 { margin: 0 0 6px; font-size: 22px; font-weight: 600; letter-spacing: -.2px; }
  .page-head p { margin: 0; color: var(--muted); font-size: 13px; line-height: 1.5; max-width: 640px; }
  .panel { background: var(--panel); border: 1px solid var(--border); border-radius: 12px;
           padding: 18px 20px; }
  .panel h2 { margin: 0 0 12px; font-size: 11px; font-weight: 600; color: var(--muted);
              text-transform: uppercase; letter-spacing: .8px; }
  .toolbar { display: flex; flex-wrap: wrap; gap: 10px; align-items: center; margin-bottom: 16px; }
  .toolbar .grow { flex: 1; min-width: 180px; }
  .search { width: 100%; background: var(--panel-2); color: var(--fg);
            border: 1px solid var(--border); border-radius: 10px; padding: 10px 12px;
            font: inherit; font-size: 13px; }
  .search:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-dim); }
  button.ctrl { background: var(--panel-2); color: var(--fg); border: 1px solid var(--border);
                 border-radius: 8px; padding: 8px 14px; font-size: 12px; font-family: var(--mono);
                 cursor: pointer; text-decoration: none; display: inline-flex; align-items: center;
                 justify-content: center; gap: 6px; }
  button.ctrl:hover, a.ctrl:hover { border-color: var(--accent); color: var(--fg); }
  button.ctrl.primary { background: var(--accent); color: #0f1115; border-color: var(--accent);
                         font-weight: 600; width: 100%; padding: 11px 14px; margin-top: 4px; }
  button.ctrl.primary:hover { filter: brightness(1.06); }
  button.ctrl:disabled { opacity: .55; cursor: not-allowed; }
  .stats { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 16px; }
  .stat { background: var(--panel-2); border: 1px solid var(--border); border-radius: 10px;
          padding: 10px 14px; min-width: 110px; flex: 1; }
  .stat .label { color: var(--muted); font-size: 10px; text-transform: uppercase;
                 letter-spacing: .6px; margin-bottom: 4px; }
  .stat .value { font-size: 22px; font-weight: 600; font-family: var(--mono); line-height: 1.1; }
  .status-bar { color: var(--muted); font-size: 12px; font-family: var(--mono); margin-bottom: 14px; }
  .teams-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 14px; }
  .team-card { background: var(--panel-2); border: 1px solid var(--border); border-radius: 12px;
               padding: 16px 18px; display: flex; flex-direction: column; gap: 10px;
               transition: border-color .15s, box-shadow .15s; }
  .team-card:hover { border-color: rgba(106,169,255,.4); box-shadow: 0 8px 24px rgba(0,0,0,.18); }
  .team-card-head { display: flex; align-items: flex-start; gap: 12px; }
  .team-avatar { width: 44px; height: 44px; border-radius: 10px; flex-shrink: 0;
                 display: flex; align-items: center; justify-content: center;
                 font-size: 18px; font-weight: 700; color: var(--accent);
                 background: var(--accent-dim); border: 1px solid rgba(106,169,255,.25); }
  .team-card-title { flex: 1; min-width: 0; }
  .team-card-title .name { font-size: 16px; font-weight: 600; margin: 0 0 4px;
                           word-break: break-word; }
  .team-card-title .slug { font-family: var(--mono); font-size: 11px; color: var(--muted); }
  .team-desc { color: var(--muted); font-size: 12px; line-height: 1.5; margin: 0;
               display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical;
               overflow: hidden; }
  .badges { display: flex; flex-wrap: wrap; gap: 6px; }
  .badge { display: inline-flex; align-items: center; gap: 4px; padding: 3px 9px;
           border-radius: 999px; font-size: 10px; font-family: var(--mono);
           border: 1px solid var(--border); background: var(--panel); color: var(--muted); }
  .badge.accent { color: var(--accent); border-color: rgba(106,169,255,.35);
                  background: rgba(106,169,255,.08); }
  .badge.ok { color: var(--ok); border-color: rgba(61,220,132,.35);
              background: rgba(61,220,132,.08); }
  .profiles { display: flex; flex-wrap: wrap; gap: 4px; }
  .profile-chip { font-size: 10px; font-family: var(--mono); padding: 2px 8px;
                  border-radius: 6px; background: var(--panel); border: 1px dashed var(--border);
                  color: var(--muted); }
  .team-actions { display: flex; flex-wrap: wrap; gap: 6px; margin-top: auto; padding-top: 8px;
                  border-top: 1px solid var(--border); }
  .team-actions .ctrl { flex: 0 0 auto; font-size: 11px; padding: 6px 10px; white-space: nowrap; }
  .team-actions .ctrl.danger { background: #dc354522; color: #dc3545; border-color: #dc354555;
                               margin-left: auto; }
  .team-actions .ctrl.danger:hover { background: #dc354544; }
  .empty { text-align: center; padding: 48px 24px; color: var(--muted); font-style: italic;
           background: var(--panel-2); border: 1px dashed var(--border); border-radius: 12px; }
  .empty strong { display: block; font-style: normal; color: var(--fg); font-size: 15px;
                  margin-bottom: 8px; }
  .modal[hidden] { display: none; }
  .modal { position: fixed; inset: 0; z-index: 50; display: flex; align-items: flex-start;
           justify-content: center; padding: 6vh 16px 24px; overflow-y: auto; }
  .modal-backdrop { position: fixed; inset: 0; background: rgba(0,0,0,.55); }
  .modal-card { position: relative; z-index: 1; margin: 0;
                background: var(--panel); border: 1px solid var(--border); border-radius: 12px;
                padding: 18px 20px; color: var(--fg); }
  .modal-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 14px; }
  .modal-head h3 { margin: 0; font-size: 16px; font-weight: 600; }
  .modal-close { cursor: pointer; }
  .modal-actions { margin-top: 16px; display: flex; gap: 8px; justify-content: flex-end; }
  .field label { display: block; font-size: 11px; font-weight: 600; color: var(--muted);
                 text-transform: uppercase; letter-spacing: .5px; margin-bottom: 6px; }
  input { width: 100%; background: var(--panel-2); color: var(--fg); border: 1px solid var(--border);
          border-radius: 8px; padding: 10px 12px; font: inherit; font-size: 13px; }
  input:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-dim); }
  .path-pick-row { display: flex; gap: 8px; align-items: center; }
  .path-pick-row input { flex: 1; }
  .folder-browser { margin-top: 8px; border: 1px solid var(--border); border-radius: 8px;
                    background: var(--panel-2); max-height: 240px; overflow: auto; padding: 6px; }
  .folder-browser .path { color: var(--muted); font-family: var(--mono); font-size: 11px;
                          margin-bottom: 6px; word-break: break-all; }
  .folder-browser .entry { width: 100%; text-align: left; margin-bottom: 6px; }
  .result { margin-top: 12px; border: 1px solid var(--border); border-radius: 8px;
            padding: 10px 12px; font-size: 12px; font-family: var(--mono); display: none;
            line-height: 1.45; white-space: pre-wrap; word-break: break-word; }
  .result.ok { display: block; border-color: rgba(61,220,132,.35); color: var(--ok); }
  .result.err { display: block; border-color: rgba(255,90,95,.35); color: var(--bad); }
  .form-stack { display: flex; flex-direction: column; gap: 14px; }
  .field label { display: block; font-size: 11px; font-weight: 600; color: var(--muted);
                 text-transform: uppercase; letter-spacing: .5px; margin-bottom: 6px; }
  .field .field-hint { font-size: 11px; color: var(--muted); font-weight: 400;
                       text-transform: none; letter-spacing: 0; margin: -2px 0 6px; line-height: 1.4; }
  .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  @media (max-width: 480px) { .field-row { grid-template-columns: 1fr; } }
  input, textarea {
    width: 100%; background: var(--panel-2); color: var(--fg); border: 1px solid var(--border);
    border-radius: 8px; padding: 10px 12px; font: inherit; font-size: 13px;
  }
  input:focus, textarea:focus { outline: none; border-color: var(--accent);
                               box-shadow: 0 0 0 3px var(--accent-dim); }
  textarea { min-height: 88px; resize: vertical; line-height: 1.45; }
  .result { margin-top: 12px; border: 1px solid var(--border); border-radius: 8px;
            padding: 10px 12px; font-size: 12px; font-family: var(--mono); display: none;
            line-height: 1.45; white-space: pre-wrap; word-break: break-word; }
  .result.ok { display: block; border-color: rgba(61,220,132,.35); color: var(--ok); }
  .result.err { display: block; border-color: rgba(255,90,95,.35); color: var(--bad); }
  .form-note { font-size: 11px; color: var(--muted); line-height: 1.45; margin: 0;
               padding: 10px 12px; border-radius: 8px; background: var(--panel-2);
               border: 1px solid var(--border); }
  .toast { position: fixed; bottom: 20px; right: 20px; background: var(--panel);
           border: 1px solid var(--accent); color: var(--fg); padding: 10px 14px;
           border-radius: 8px; font-size: 12px; font-family: var(--mono); z-index: 200;
           opacity: 0; pointer-events: none; transition: opacity .2s; max-width: 320px; }
  .toast.show { opacity: 1; }
  .presets-wrap { margin-bottom: 16px; }
  .presets-wrap h2 { margin: 0 0 10px; font-size: 11px; font-weight: 600; color: var(--muted);
                     text-transform: uppercase; letter-spacing: .8px; }
  .presets { display: flex; flex-wrap: wrap; gap: 8px; max-height: 200px; overflow-y: auto; }
  .preset-team { background: var(--panel-2); border: 1px solid var(--border); border-radius: 10px;
                 padding: 10px 14px; cursor: pointer; text-align: left; min-width: 200px; max-width: 280px;
                 transition: border-color .15s; }
  .preset-team:hover { border-color: var(--accent); }
  .preset-team .pt-name { font-weight: 600; font-size: 13px; margin-bottom: 4px; }
  .preset-team .pt-desc { color: var(--muted); font-size: 11px; line-height: 1.4;
                          display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
                          overflow: hidden; }
  .preset-team .pt-roles { margin-top: 6px; font-size: 10px; font-family: var(--mono); color: var(--accent); }
</style>
</head>
<body>
__APP_NAV__
<main>
  <header class="page-head">
    <h1>Times</h1>
    <p>Agrupe papéis Hermes e projetos por equipe. Cada time pode ter repositório GitHub ou pasta local e um quadro Kanban próprio.</p>
  </header>
  <section class="panel presets-wrap">
    <h2>Times prontos</h2>
    <p class="form-note" style="margin:0 0 10px;">Clique para criar o time com papéis sugeridos e tarefas iniciais no Kanban.</p>
    <div class="presets" id="team-presets"></div>
  </section>
  <section class="panel">
      <div class="toolbar">
        <div class="grow">
          <input type="search" class="search" id="teams-search" placeholder="Buscar por nome, slug ou descrição…" autocomplete="off">
        </div>
        <a class="ctrl primary" href="/times/novo" style="width:auto;padding:8px 16px;">+ Criar time</a>
        <button type="button" class="ctrl" id="teams-refresh">Atualizar</button>
        <a class="ctrl" href="/roles">Papéis →</a>
        <a class="ctrl" href="/kanban">Kanban →</a>
      </div>
      <div class="stats">
        <div class="stat"><div class="label">Times</div><div class="value" id="stat-teams">—</div></div>
        <div class="stat"><div class="label">Papéis vinculados</div><div class="value" id="stat-profiles">—</div></div>
        <div class="stat"><div class="label">Com projeto</div><div class="value" id="stat-projects">—</div></div>
      </div>
      <div class="status-bar" id="teams-status">Carregando…</div>
      <div class="teams-grid" id="teams-list">
        <div class="empty">Carregando times…</div>
      </div>
  </section>
</main>
<div class="toast" id="teams-toast" role="status" aria-live="polite"></div>
<div class="modal" id="team-dir-modal" hidden>
  <div class="modal-backdrop" id="team-dir-backdrop"></div>
  <div class="modal-card" role="dialog" aria-modal="true" style="width:min(560px,94vw);">
    <div class="modal-head">
      <h3 id="team-dir-title">Diretório do time</h3>
      <button class="ctrl modal-close" id="team-dir-close" type="button">Fechar</button>
    </div>
    <div class="field" style="margin-bottom:12px;">
      <label for="team-dir-input">Caminho local</label>
      <div class="path-pick-row">
        <input id="team-dir-input" placeholder="/caminho/do/projeto">
        <button type="button" class="ctrl" id="team-dir-browse-btn">Navegar</button>
      </div>
    </div>
    <div class="folder-browser" id="team-dir-browser" style="display:none;">
      <div class="path" id="team-dir-current-path"></div>
      <button type="button" class="ctrl entry" id="team-dir-up">⬆ Subir</button>
      <div id="team-dir-folder-list"></div>
    </div>
    <div class="modal-actions">
      <button type="button" class="ctrl" id="team-dir-cancel">Cancelar</button>
      <button type="button" class="ctrl primary" id="team-dir-save">Salvar diretório</button>
    </div>
    <div class="result" id="team-dir-result"></div>
  </div>
</div>
<div class="modal" id="wa-group-modal" hidden>
  <div class="modal-backdrop" id="wa-group-backdrop"></div>
  <div class="modal-card" role="dialog" aria-modal="true" style="width:min(520px,94vw);">
    <div class="modal-head">
      <h3>📱 Grupo WhatsApp — <span id="wa-group-team-name"></span></h3>
      <button class="ctrl modal-close" id="wa-group-close" type="button">Fechar</button>
    </div>
    <input type="hidden" id="wa-group-team-id">
    <div class="form-stack">
      <div class="field">
        <label for="wa-group-jid">JID do Grupo</label>
        <p class="field-hint">Formato: 120363XXXXXXXXXX@g.us</p>
        <input id="wa-group-jid" placeholder="120363045678901234@g.us">
      </div>
      <div class="field">
        <label for="wa-group-emails">Emails de notificação (separados por vírgula)</label>
        <input id="wa-group-emails" placeholder="pm@empresa.com, dev@empresa.com">
      </div>
      <div class="field-row">
        <div class="field">
          <label for="wa-group-smtp-host">SMTP Host</label>
          <input id="wa-group-smtp-host" placeholder="smtp.gmail.com">
        </div>
        <div class="field">
          <label for="wa-group-smtp-port">Porta</label>
          <input id="wa-group-smtp-port" type="number" placeholder="587">
        </div>
      </div>
      <div class="field-row">
        <div class="field">
          <label for="wa-group-smtp-user">SMTP Usuário</label>
          <input id="wa-group-smtp-user" placeholder="monitor@empresa.com">
        </div>
        <div class="field">
          <label for="wa-group-smtp-from">Remetente (From)</label>
          <input id="wa-group-smtp-from" placeholder="monitor@empresa.com">
        </div>
      </div>
      <div class="field" style="display:flex;align-items:center;gap:8px;">
        <input type="checkbox" id="wa-group-enabled" checked style="width:auto;">
        <label for="wa-group-enabled" style="margin:0;text-transform:none;font-size:13px;">Grupo ativo</label>
      </div>
      <p class="form-note">
        Comandos no grupo: <code>/card</code>, <code>/mover</code>, <code>/feito</code>, <code>/cards</code>, <code>/status</code>, <code>/prioridade</code>.<br>
        Senha SMTP via variável <code>TEAM_SMTP_PASSWORD</code> no <code>.env</code>.
      </p>
    </div>
    <div class="modal-actions">
      <button type="button" class="ctrl" id="wa-group-remove" style="color:var(--bad);">Desvincular</button>
      <button type="button" class="ctrl primary" id="wa-group-save">Salvar</button>
    </div>
    <div class="result" id="wa-group-result"></div>
  </div>
</div>
<div class="modal" id="edit-team-modal" hidden>
  <div class="modal-backdrop" id="edit-team-backdrop"></div>
  <div class="modal-card" role="dialog" aria-modal="true" style="width:min(600px,94vw);">
    <div class="modal-head">
      <h3>✏️ Editar time — <span id="edit-team-display-name"></span></h3>
      <button class="ctrl modal-close" id="edit-team-close" type="button">Fechar</button>
    </div>
    <input type="hidden" id="edit-team-id">
    <div class="form-stack">
      <div class="field">
        <label for="edit-team-name">Nome do time</label>
        <input id="edit-team-name" placeholder="Ex: Squad Produto">
      </div>
      <div class="field">
        <label for="edit-team-description">Descrição</label>
        <textarea id="edit-team-description" placeholder="Descrição do time e suas responsabilidades…"></textarea>
      </div>
      <div class="field-row">
        <div class="field">
          <label for="edit-team-github-url">GitHub URL</label>
          <input id="edit-team-github-url" placeholder="https://github.com/org/repo">
        </div>
        <div class="field">
          <label for="edit-team-github-branch">Branch</label>
          <input id="edit-team-github-branch" placeholder="main">
        </div>
      </div>
      <div class="field">
        <label for="edit-team-local-path">Caminho local</label>
        <input id="edit-team-local-path" placeholder="/caminho/do/projeto">
      </div>
      <div class="field">
        <label for="edit-team-app-url">URL da aplicação</label>
        <input id="edit-team-app-url" type="url" placeholder="https://meuapp.exemplo.com">
      </div>
      <div class="field">
        <label for="edit-team-profiles">Papéis (slugs separados por vírgula)</label>
        <p class="field-hint">Ex: product-manager, ux-designer, tech-lead</p>
        <input id="edit-team-profiles" placeholder="product-manager, dev-backend">
      </div>
      <div class="field">
        <label for="edit-team-whatsapp-numbers">Números WhatsApp (separados por vírgula)</label>
        <p class="field-hint">Formato: 5511999998888</p>
        <input id="edit-team-whatsapp-numbers" placeholder="5511999998888, 5521988887777">
      </div>
    </div>
    <div class="modal-actions">
      <button type="button" class="ctrl" id="edit-team-cancel">Cancelar</button>
      <button type="button" class="ctrl primary" id="edit-team-save">Salvar alterações</button>
    </div>
    <div class="result" id="edit-team-result"></div>
  </div>
</div>
<script>
function el(id) { return document.getElementById(id); }
function esc(s) {
  return String(s || "").replace(/&/g,"&amp;").replace(/</g,"&lt;")
    .replace(/>/g,"&gt;").replace(/"/g,"&quot;");
}
function showToast(msg) {
  const t = el("teams-toast");
  if (!t) return;
  t.textContent = msg;
  t.classList.add("show");
  clearTimeout(window._teamsToastTimer);
  window._teamsToastTimer = setTimeout(() => t.classList.remove("show"), 2800);
}
function teamInitials(name) {
  const parts = String(name || "?").trim().split(/\s+/).filter(Boolean);
  if (!parts.length) return "?";
  if (parts.length === 1) return parts[0].slice(0, 2).toUpperCase();
  return (parts[0][0] + parts[parts.length - 1][0]).toUpperCase();
}
function formatCreated(ts) {
  if (!ts) return "";
  const d = new Date(typeof ts === "number" ? ts * 1000 : ts);
  if (isNaN(d.getTime())) return "";
  return d.toLocaleDateString("pt-BR", { day: "2-digit", month: "short", year: "numeric" });
}
function projectBadge(t) {
  if (t.github_url) return '<span class="badge accent">GitHub</span>';
  if (t.local_path) return '<span class="badge ok">Local</span>';
  if (t.project_source) return '<span class="badge">' + esc(t.project_source) + '</span>';
  return '<span class="badge">sem projeto</span>';
}
function projectMeta(t) {
  if (t.github_url) {
    const u = String(t.github_url);
    const short = u.length > 42 ? u.slice(0, 40) + "…" : u;
    return esc(short);
  }
  if (t.local_path) {
    const p = String(t.local_path);
    const short = p.length > 36 ? "…" + p.slice(-34) : p;
    return esc(short);
  }
  return "";
}
function artifactsMeta(t) {
  if (t.artifacts_dir) {
    const p = String(t.artifacts_dir);
    const short = p.length > 36 ? "…" + p.slice(-34) : p;
    return '<span class="badge" title="Diretório de artefatos: ' + esc(p) + '">📁 ' + esc(short) + '</span>';
  }
  return "";
}
function whatsappGroupMeta(t) {
  const wg = t.whatsapp_group;
  if (!wg || !wg.group_jid) return "";
  const jid = String(wg.group_jid);
  const short = jid.length > 24 ? jid.slice(0, 12) + "…" + jid.slice(-8) : jid;
  const emails = (wg.notify_emails || []);
  const emailTip = emails.length ? " · Emails: " + emails.join(", ") : "";
  const enabled = wg.enabled !== false;
  const statusCls = enabled ? "ok" : "";
  const statusIcon = enabled ? "📱" : "📴";
  let html = '<div style="margin-top:6px;display:flex;flex-wrap:wrap;gap:6px;align-items:center;">';
  html += '<span class="badge ' + statusCls + '" title="Grupo WhatsApp: ' + esc(jid) + emailTip + '">';
  html += statusIcon + ' ' + esc(short) + '</span>';
  if (emails.length) {
    html += '<span class="badge" title="' + esc(emails.join(", ")) + '">📧 ' + emails.length + ' email(s)</span>';
  }
  html += '</div>';
  return html;
}

const TEAM_PRESETS = __TEAM_PRESETS__;
let teams = [];
let teamsQuery = "";

function renderTeamPresets() {
  const box = el("team-presets");
  if (!box) return;
  if (!TEAM_PRESETS.length) {
    box.innerHTML = '<span class="badge">Nenhum modelo disponível</span>';
    return;
  }
  box.innerHTML = TEAM_PRESETS.map((p) => {
    const roles = (p.profile_slugs || p.role_ids || []).join(", ");
    return '<button type="button" class="preset-team" data-preset="' + esc(p.id) + '">' +
      '<div class="pt-name">' + esc(p.name) + '</div>' +
      '<div class="pt-desc">' + esc(p.description || "") + '</div>' +
      (roles ? '<div class="pt-roles">' + esc(roles) + '</div>' : '') +
      '</button>';
  }).join("");
  box.querySelectorAll(".preset-team").forEach((btn) => {
    btn.addEventListener("click", () => createTeamFromPreset(btn.dataset.preset));
  });
}

async function createTeamFromPreset(presetId) {
  const preset = TEAM_PRESETS.find((p) => p.id === presetId);
  if (!preset) return;
  const existing = teams.find((t) => t.id === preset.id);
  if (existing) {
    showToast("Time " + preset.id + " já existe — abrindo Kanban");
    window.location.href = "/kanban?team=" + encodeURIComponent(preset.id);
    return;
  }
  el("teams-status").textContent = "Criando " + preset.name + "…";
  try {
    const r = await fetch("/teams", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        preset_id: preset.id,
        seed_kanban: true,
      }),
    });
    const data = await r.json();
    if (!r.ok || data.ok === false) throw new Error(data.error || "falha ao criar time");
    showToast("Time criado: " + (data.team && data.team.name ? data.team.name : preset.name));
    await loadTeams();
  } catch (e) {
    showToast("Erro: " + e.message);
    el("teams-status").textContent = "Erro ao criar preset: " + e.message;
  }
}

function filteredTeams() {
  const q = teamsQuery.trim().toLowerCase();
  if (!q) return teams.slice();
  return teams.filter((t) => {
    const hay = [
      t.name, t.id, t.description,
      (t.profile_slugs || []).join(" "),
      t.github_url, t.local_path,
    ].join(" ").toLowerCase();
    return hay.includes(q);
  });
}

function renderStats() {
  const total = teams.length;
  const profiles = teams.reduce((n, t) => n + ((t.profile_slugs || []).length), 0);
  const projects = teams.filter((t) => t.github_url || t.local_path || t.project_source).length;
  el("stat-teams").textContent = String(total);
  el("stat-profiles").textContent = String(profiles);
  el("stat-projects").textContent = String(projects);
}

function renderTeams() {
  const box = el("teams-list");
  const rows = filteredTeams();
  renderStats();
  el("teams-status").textContent = rows.length + " de " + teams.length + " time(s)";
  if (!teams.length) {
    box.innerHTML =
      '<div class="empty"><strong>Nenhum time ainda</strong>' +
      '<a class="ctrl primary" href="/times/novo" style="display:inline-flex;margin-top:12px;width:auto;">Criar primeiro time</a>' +
      '<p style="margin:12px 0 0;font-style:normal;font-size:12px;">Depois, use Papéis para adicionar agentes ao time.</p></div>';
    return;
  }
  if (!rows.length) {
    box.innerHTML = '<div class="empty"><strong>Nenhum resultado</strong>Tente outro termo na busca.</div>';
    return;
  }
  box.innerHTML = rows.map((t) => {
    const id = t.id || "";
    const name = t.name || id || "?";
    const profiles = (t.profile_slugs || []);
    const profileHtml = profiles.length
      ? '<div class="profiles">' + profiles.map((p) =>
          '<span class="profile-chip">' + esc(p) + '</span>'
        ).join("") + '</div>'
      : '<span class="badge">sem papéis</span>';
    const meta = projectMeta(t);
    const created = formatCreated(t.created_at);
    return '<article class="team-card">' +
      '<div class="team-card-head">' +
        '<div class="team-avatar" aria-hidden="true">' + esc(teamInitials(name)) + '</div>' +
        '<div class="team-card-title">' +
          '<div class="name"><a href="/times/detalhes?team=' + encodeURIComponent(id) + '" style="color:inherit;text-decoration:none;">' + esc(name) + '</a></div>' +
          '<div class="slug">' + esc(id) + (created ? " · " + esc(created) : "") + '</div>' +
        '</div>' +
      '</div>' +
      (t.description ? '<p class="team-desc">' + esc(t.description) + '</p>' : '') +
      '<div class="badges">' + projectBadge(t) +
        (profiles.length ? '<span class="badge ok">' + profiles.length + ' papel(is)</span>' : '') +
      '</div>' +
      (meta ? '<div class="slug" style="margin-top:-4px;">' + meta + '</div>' : '') +
      artifactsMeta(t) +
      whatsappGroupMeta(t) +
      profileHtml +
      '<div class="team-actions">' +
        '<a class="ctrl primary" href="/times/detalhes?team=' + encodeURIComponent(id) + '">🔍 Ver detalhes</a>' +
        '<button type="button" class="ctrl" data-edit-team="' + esc(id) + '">✏️ Editar</button>' +
        '<a class="ctrl" href="/kanban?team=' + encodeURIComponent(id) + '">Kanban</a>' +
        '<a class="ctrl" href="/times/mensagens?team=' + encodeURIComponent(id) + '">💬 Mensagens</a>' +
        '<button type="button" class="ctrl" data-browse-team="' + esc(id) + '">📁 Diretório</button>' +
        '<button type="button" class="ctrl" data-wa-group="' + esc(id) + '">' + (t.whatsapp_group ? '📱' : '📱+') + '</button>' +
        '<a class="ctrl" href="/roles">Papéis</a>' +
        '<button type="button" class="ctrl danger" data-delete-team="' + esc(id) + '" data-team-name="' + esc(name) + '">🗑 Deletar</button>' +
      '</div>' +
    '</article>';
  }).join("");
  box.querySelectorAll("[data-edit-team]").forEach(function(btn) {
    btn.addEventListener("click", function() { openEditTeamModal(btn.dataset.editTeam); });
  });
  box.querySelectorAll("[data-browse-team]").forEach(function(btn) {
    btn.addEventListener("click", function() { openTeamDirBrowser(btn.dataset.browseTeam); });
  });
  box.querySelectorAll("[data-wa-group]").forEach(function(btn) {
    btn.addEventListener("click", function() { openWhatsAppGroupModal(btn.dataset.waGroup); });
  });
  box.querySelectorAll("[data-delete-team]").forEach(function(btn) {
    btn.addEventListener("click", function() { deleteTeam(btn.dataset.deleteTeam, btn.dataset.teamName); });
  });
}

async function deleteTeam(teamId, teamName) {
  if (!confirm('Tem certeza que deseja deletar o time "' + (teamName || teamId) + '"? Esta ação não pode ser desfeita.')) return;
  try {
    const r = await fetch("/teams/" + encodeURIComponent(teamId), { method: "DELETE", cache: "no-cache" });
    const data = await r.json();
    if (!r.ok || data.ok === false) throw new Error(data.error || "falha ao deletar time");
    showToast("Time deletado com sucesso");
    loadTeams();
  } catch (e) {
    showToast("Erro: " + e.message);
  }
}

async function loadTeams() {
  el("teams-status").textContent = "Carregando…";
  try {
    const r = await fetch("/teams", { cache: "no-cache", credentials: "same-origin" });
    const data = await r.json();
    if (!r.ok || data.ok === false) throw new Error(data.error || "falha ao carregar times");
    teams = Array.isArray(data.teams) ? data.teams : [];
    renderTeams();
  } catch (e) {
    el("teams-list").innerHTML =
      '<div class="empty"><strong>Erro ao carregar</strong>' + esc(e.message) + '</div>';
    el("teams-status").textContent = "";
  }
}

el("teams-refresh").addEventListener("click", loadTeams);
el("teams-search").addEventListener("input", (ev) => {
  teamsQuery = ev.target.value || "";
  renderTeams();
});

let teamDirBrowsePath = "";
let teamDirActiveTeamId = "";

function openTeamDirBrowser(teamId) {
  const team = teams.find((t) => t.id === teamId);
  if (!team) return;
  teamDirActiveTeamId = teamId;
  el("team-dir-title").textContent = "Diretório — " + (team.name || teamId);
  el("team-dir-input").value = team.local_path || "";
  el("team-dir-browser").style.display = "none";
  el("team-dir-result").className = "result";
  el("team-dir-result").textContent = "";
  el("team-dir-modal").hidden = false;
}

function closeTeamDirBrowser() {
  el("team-dir-modal").hidden = true;
  teamDirActiveTeamId = "";
}

async function browseTeamDirFolders(path, goUp) {
  const q = new URLSearchParams();
  if (path) q.set("path", path);
  if (goUp) q.set("up", "1");
  const url = "/hermes/local-folders" + (q.toString() ? "?" + q.toString() : "");
  try {
    const r = await fetch(url, { cache: "no-cache" });
    const data = await r.json();
    if (!r.ok || data.ok === false) throw new Error(data.error || "falha ao listar");
    teamDirBrowsePath = String(data.current || "");
    renderTeamDirList(data);
  } catch (e) {
    showToast("Erro: " + e.message);
  }
}

function renderTeamDirList(data) {
  const current = String(data.current || "");
  const parent = String(data.parent || "");
  const dirs = Array.isArray(data.directories) ? data.directories : [];
  el("team-dir-current-path").textContent = current || "—";
  el("team-dir-up").disabled = !parent || parent === current;
  const list = el("team-dir-folder-list");
  if (!dirs.length) {
    list.innerHTML = '<div style="padding:8px;color:var(--muted);font-size:12px;">Nenhuma subpasta.</div>';
    return;
  }
  list.innerHTML = dirs.map((d) =>
    '<button type="button" class="ctrl entry" data-path="' + esc(d.path || "") + '">📁 ' +
    esc(d.name || d.path || "") + "</button>"
  ).join("");
  list.querySelectorAll("[data-path]").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const picked = btn.dataset.path || "";
      if (!picked) return;
      el("team-dir-input").value = picked;
      await browseTeamDirFolders(picked);
    });
  });
}

async function saveTeamDir() {
  if (!teamDirActiveTeamId) return;
  const path = el("team-dir-input").value.trim();
  const resultEl = el("team-dir-result");
  try {
    const r = await fetch("/teams/" + encodeURIComponent(teamDirActiveTeamId), {
      method: "PATCH",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        local_path: path || null,
        project_source: path ? "local" : null,
      }),
    });
    const data = await r.json();
    if (!r.ok || data.ok === false) throw new Error(data.error || "falha ao salvar");
    resultEl.className = "result ok";
    resultEl.textContent = "Diretório atualizado.";
    showToast("Diretório de " + teamDirActiveTeamId + " atualizado.");
    await loadTeams();
    setTimeout(closeTeamDirBrowser, 1200);
  } catch (e) {
    resultEl.className = "result err";
    resultEl.textContent = "Erro: " + e.message;
  }
}

el("team-dir-close").addEventListener("click", closeTeamDirBrowser);
el("team-dir-cancel").addEventListener("click", closeTeamDirBrowser);
el("team-dir-backdrop").addEventListener("click", closeTeamDirBrowser);
el("team-dir-save").addEventListener("click", saveTeamDir);
el("team-dir-browse-btn").addEventListener("click", async () => {
  const guess = el("team-dir-input").value.trim() || teamDirBrowsePath;
  await browseTeamDirFolders(guess);
  el("team-dir-browser").style.display = "block";
});
el("team-dir-up").addEventListener("click", async () => {
  if (!teamDirBrowsePath) return;
  await browseTeamDirFolders(teamDirBrowsePath, true);
});

/* ─── WhatsApp Group Modal ───────────────────────────────────────────────── */
function openWhatsAppGroupModal(teamId) {
  const team = teams.find(t => t.id === teamId);
  if (!team) return;
  const wg = team.whatsapp_group || {};
  el("wa-group-team-id").value = teamId;
  el("wa-group-team-name").textContent = team.name || teamId;
  el("wa-group-jid").value = wg.group_jid || "";
  el("wa-group-emails").value = (wg.notify_emails || []).join(", ");
  el("wa-group-smtp-host").value = wg.smtp_host || "smtp.gmail.com";
  el("wa-group-smtp-port").value = wg.smtp_port || 587;
  el("wa-group-smtp-user").value = wg.smtp_user || "";
  el("wa-group-smtp-from").value = wg.smtp_from || "";
  el("wa-group-enabled").checked = wg.enabled !== false;
  el("wa-group-result").className = "result";
  el("wa-group-result").textContent = "";
  el("wa-group-modal").hidden = false;
}

function closeWaGroupModal() {
  el("wa-group-modal").hidden = true;
}

async function saveWaGroup() {
  const teamId = el("wa-group-team-id").value;
  const groupJid = el("wa-group-jid").value.trim();
  const emailsRaw = el("wa-group-emails").value.trim();
  const emails = emailsRaw ? emailsRaw.split(/[,;]+/).map(e => e.trim()).filter(Boolean) : [];
  const smtpHost = el("wa-group-smtp-host").value.trim() || "smtp.gmail.com";
  const smtpPort = parseInt(el("wa-group-smtp-port").value) || 587;
  const smtpUser = el("wa-group-smtp-user").value.trim();
  const smtpFrom = el("wa-group-smtp-from").value.trim();
  const enabled = el("wa-group-enabled").checked;

  const payload = {};
  if (groupJid) {
    payload.whatsapp_group = {
      group_jid: groupJid,
      enabled: enabled,
      notify_emails: emails,
      auto_create_cards: true,
      auto_complete_cards: true,
      echo_to_group: true,
      smtp_host: smtpHost,
      smtp_port: smtpPort,
      smtp_user: smtpUser,
      smtp_password_env: "TEAM_SMTP_PASSWORD",
      smtp_from: smtpFrom,
    };
  } else {
    payload.whatsapp_group = null;
  }

  const res = el("wa-group-result");
  try {
    const r = await fetch("/teams/" + encodeURIComponent(teamId), {
      method: "PATCH",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(payload),
    });
    const data = await r.json();
    if (!r.ok || data.ok === false) throw new Error(data.error || "falha ao salvar");
    res.className = "result ok";
    res.textContent = groupJid ? "✅ Grupo vinculado!" : "✅ Grupo desvinculado.";
    await loadTeams();
  } catch (e) {
    res.className = "result err";
    res.textContent = "❌ " + e.message;
  }
}

async function removeWaGroup() {
  const teamId = el("wa-group-team-id").value;
  el("wa-group-jid").value = "";
  await saveWaGroup();
}

el("wa-group-save").addEventListener("click", saveWaGroup);
el("wa-group-remove").addEventListener("click", removeWaGroup);
el("wa-group-close").addEventListener("click", closeWaGroupModal);
el("wa-group-backdrop").addEventListener("click", closeWaGroupModal);

/* ─── Edit Team Modal ─────────────────────────────────────────────────── */
function openEditTeamModal(teamId) {
  const team = teams.find(t => t.id === teamId);
  if (!team) return;
  el("edit-team-id").value = teamId;
  el("edit-team-display-name").textContent = team.name || teamId;
  el("edit-team-name").value = team.name || "";
  el("edit-team-description").value = team.description || "";
  el("edit-team-github-url").value = team.github_url || "";
  el("edit-team-github-branch").value = team.github_branch || "main";
  el("edit-team-local-path").value = team.local_path || "";
  el("edit-team-app-url").value = team.app_url || "";
  el("edit-team-profiles").value = (team.profile_slugs || []).join(", ");
  el("edit-team-whatsapp-numbers").value = (team.whatsapp_numbers || []).join(", ");
  el("edit-team-result").className = "result";
  el("edit-team-result").textContent = "";
  el("edit-team-modal").hidden = false;
}

function closeEditTeamModal() {
  el("edit-team-modal").hidden = true;
}

async function saveEditTeam() {
  const teamId = el("edit-team-id").value;
  if (!teamId) return;
  const name = el("edit-team-name").value.trim();
  const description = el("edit-team-description").value.trim();
  const githubUrl = el("edit-team-github-url").value.trim();
  const githubBranch = el("edit-team-github-branch").value.trim() || "main";
  const localPath = el("edit-team-local-path").value.trim();
  const appUrl = el("edit-team-app-url").value.trim();
  const profilesRaw = el("edit-team-profiles").value.trim();
  const profiles = profilesRaw ? profilesRaw.split(/[,;]+/).map(s => s.trim()).filter(Boolean) : [];
  const whatsappRaw = el("edit-team-whatsapp-numbers").value.trim();
  const whatsappNumbers = whatsappRaw ? whatsappRaw.split(/[,;]+/).map(s => s.trim()).filter(Boolean) : [];

  const payload = {};
  if (name) payload.name = name;
  payload.description = description;
  payload.github_url = githubUrl || null;
  payload.github_branch = githubBranch;
  payload.local_path = localPath || null;
  payload.app_url = appUrl || null;
  payload.project_source = githubUrl ? "github" : (localPath ? "local" : null);
  payload.profile_slugs = profiles;
  payload.whatsapp_numbers = whatsappNumbers;

  const resEl = el("edit-team-result");
  try {
    const r = await fetch("/teams/" + encodeURIComponent(teamId), {
      method: "PATCH",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(payload),
    });
    const data = await r.json();
    if (!r.ok || data.ok === false) throw new Error(data.error || "falha ao salvar alterações");
    resEl.className = "result ok";
    resEl.textContent = "✅ Time atualizado com sucesso!";
    showToast("Time " + (name || teamId) + " atualizado.");
    await loadTeams();
    setTimeout(closeEditTeamModal, 1200);
  } catch (e) {
    resEl.className = "result err";
    resEl.textContent = "❌ " + e.message;
  }
}

el("edit-team-save").addEventListener("click", saveEditTeam);
el("edit-team-cancel").addEventListener("click", closeEditTeamModal);
el("edit-team-close").addEventListener("click", closeEditTeamModal);
el("edit-team-backdrop").addEventListener("click", closeEditTeamModal);

async function initTeamsPage() {
  if (typeof window.qcmAuthGate === "function") {
    const auth = await window.qcmAuthGate();
    if (!auth || auth.ok === false) return;
  }
  renderTeamPresets();
  await loadTeams();
}
initTeamsPage();
</script>
</body>
</html>
"""


def build_teams_html(hermes_dashboard_url: Optional[str] = None) -> str:
    from .team_presets import TEAM_PRESETS

    presets_json = json.dumps(TEAM_PRESETS, ensure_ascii=False)
    html = TEAMS_PAGE.replace("__TEAM_PRESETS__", presets_json)
    return _inject_app_nav(
        html,
        "teams",
        hermes_dashboard_url=hermes_dashboard_url,
    )


TEAM_CREATE_PAGE = r"""<!doctype html>
<html lang="pt-br">
<head>
<meta charset="utf-8">
<title>gois — novo time</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<style>
  :root {
    --bg: #0f1115;
    --panel: #171a21;
    --panel-2: #1e222c;
    --border: #262b36;
    --fg: #e6e8ee;
    --muted: #8a93a6;
    --ok: #3ddc84;
    --bad: #ff5a5f;
    --accent: #6aa9ff;
    --accent-dim: rgba(106,169,255,.12);
    --mono: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }
  @media (prefers-color-scheme: light) {
    :root { --bg:#f5f6fa; --panel:#fff; --panel-2:#f0f2f7; --border:#e1e4ec;
            --fg:#15171c; --muted:#5b6477; }
  }
  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; min-height: 100%; background: var(--bg); color: var(--fg);
               font: 14px/1.45 -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; }
  body { display: flex; flex-direction: column; }
  __APP_NAV_CSS__
  main { flex: 1; padding: 24px 28px; max-width: 720px; width: 100%; margin: 0 auto; }
  .page-head { margin-bottom: 20px; }
  .page-head h1 { margin: 0 0 6px; font-size: 22px; font-weight: 600; }
  .page-head p { margin: 0; color: var(--muted); font-size: 13px; line-height: 1.5; }
  .back-row { margin-bottom: 16px; }
  a.ctrl, button.ctrl { background: var(--panel-2); color: var(--fg); border: 1px solid var(--border);
                        border-radius: 8px; padding: 8px 14px; font-size: 12px; font-family: var(--mono);
                        cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; }
  a.ctrl:hover, button.ctrl:hover { border-color: var(--accent); }
  button.ctrl.primary { background: var(--accent); color: #0f1115; border-color: var(--accent);
                         font-weight: 600; padding: 11px 18px; }
  button.ctrl:disabled { opacity: .55; cursor: not-allowed; }
  .panel { background: var(--panel); border: 1px solid var(--border); border-radius: 12px;
           padding: 20px 22px; margin-bottom: 16px; }
  .panel h2 { margin: 0 0 14px; font-size: 11px; font-weight: 600; color: var(--muted);
              text-transform: uppercase; letter-spacing: .8px; }
  .form-stack { display: flex; flex-direction: column; gap: 14px; }
  .field label { display: block; font-size: 11px; font-weight: 600; color: var(--muted);
                 text-transform: uppercase; letter-spacing: .5px; margin-bottom: 6px; }
  .field .field-hint { font-size: 11px; color: var(--muted); font-weight: 400;
                       text-transform: none; letter-spacing: 0; margin: -2px 0 6px; line-height: 1.4; }
  .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  @media (max-width: 520px) { .field-row { grid-template-columns: 1fr; } }
  input, textarea {
    width: 100%; background: var(--panel-2); color: var(--fg); border: 1px solid var(--border);
    border-radius: 8px; padding: 10px 12px; font: inherit; font-size: 13px;
  }
  input:focus, textarea:focus { outline: none; border-color: var(--accent);
                               box-shadow: 0 0 0 3px var(--accent-dim); }
  textarea { min-height: 88px; resize: vertical; line-height: 1.45; }
  .source-row { display: flex; flex-wrap: wrap; gap: 16px; font-size: 13px; }
  .source-row label { display: inline-flex; align-items: center; gap: 8px; cursor: pointer;
                      text-transform: none; font-weight: 400; color: var(--fg); }
  .project-field { display: none; }
  .project-field.show { display: block; }
  .path-pick-row { display: flex; gap: 8px; align-items: stretch; }
  .path-pick-row input { flex: 1; min-width: 0; }
  .folder-browser { margin-top: 10px; padding: 10px; border: 1px solid var(--border);
                    border-radius: 8px; background: var(--panel-2); max-height: 220px; overflow: auto; }
  .folder-browser .path { font-family: var(--mono); font-size: 11px; color: var(--muted);
                          margin-bottom: 8px; word-break: break-all; }
  .folder-browser button.entry { width: 100%; text-align: left; margin-bottom: 4px; }
  .form-note { font-size: 12px; color: var(--muted); line-height: 1.5; margin: 0 0 14px; }
  .actions { display: flex; flex-wrap: wrap; gap: 10px; align-items: center; margin-top: 8px; }
  .result { border: 1px solid var(--border); border-radius: 8px; padding: 12px 14px;
            font-size: 12px; font-family: var(--mono); display: none; line-height: 1.45;
            white-space: pre-wrap; word-break: break-word; margin-top: 12px; }
  .result.ok { display: block; border-color: rgba(61,220,132,.35); color: var(--ok); }
  .result.err { display: block; border-color: rgba(255,90,95,.35); color: var(--bad); }
  .result .links { margin-top: 10px; display: flex; flex-wrap: wrap; gap: 8px; }
  .presets { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 4px; }
  .preset-chip { background: var(--panel-2); border: 1px solid var(--border); border-radius: 999px;
                 padding: 6px 12px; font-size: 12px; cursor: pointer; }
  .preset-chip:hover, .preset-chip.active { border-color: var(--accent); color: var(--accent); }
</style>
</head>
<body>
__APP_NAV__
<main>
  <div class="back-row">
    <a class="ctrl" href="/times">← Voltar aos times</a>
  </div>
  <header class="page-head">
    <h1>Criar time</h1>
    <p>Defina nome, slug e, se quiser, o repositório ou pasta do projeto. Depois vincule agentes em Papéis.</p>
  </header>
  <section class="panel" style="margin-bottom:16px;">
    <h2>Modelos prontos</h2>
    <p class="form-note">Preenche nome, slug, descrição e papéis sugeridos. Kanban nasce com colunas e tarefas exemplo.</p>
    <div class="presets" id="create-team-presets"></div>
  </section>
  <form class="form-stack" id="team-create-form" onsubmit="return false;">
    <section class="panel">
      <h2>Identidade</h2>
      <div class="field-row">
        <div class="field">
          <label for="team-name">Nome</label>
          <input id="team-name" required placeholder="Time Backend" autocomplete="organization">
        </div>
        <div class="field">
          <label for="team-id">Slug</label>
          <span class="field-hint">Opcional — URL e Kanban</span>
          <input id="team-id" placeholder="backend" pattern="[a-z0-9-]+" autocomplete="off">
        </div>
      </div>
      <div class="field" style="margin-top:14px;">
        <label for="team-description">Descrição</label>
        <textarea id="team-description" placeholder="Escopo, stack, responsabilidades…"></textarea>
      </div>
    </section>
    <section class="panel">
      <h2>Projeto (opcional)</h2>
      <p class="form-note">Associe um repositório GitHub ou pasta local ao time. Pode deixar em branco e configurar depois.</p>
      <div class="field">
        <label>Origem</label>
        <div class="source-row">
          <label><input type="radio" name="team-src" value="none" checked> Sem projeto</label>
          <label><input type="radio" name="team-src" value="github"> GitHub</label>
          <label><input type="radio" name="team-src" value="local"> Pasta local</label>
        </div>
      </div>
      <div class="field project-field" id="team-github-wrap">
        <label for="team-github-url">URL do repositório</label>
        <input id="team-github-url" type="url" placeholder="https://github.com/org/repo">
      </div>
      <div class="field project-field" id="team-github-branch-wrap">
        <label for="team-github-branch">Branch</label>
        <input id="team-github-branch" placeholder="main" value="main">
      </div>
      <div class="field project-field" id="team-local-wrap">
        <label for="team-local-path">Caminho da pasta</label>
        <div class="path-pick-row">
          <input id="team-local-path" placeholder="/Users/voce/projeto">
          <button type="button" class="ctrl" id="team-local-browse">Navegar</button>
        </div>
        <div class="folder-browser" id="team-folder-browser" style="display:none;">
          <div class="path" id="team-folder-path"></div>
          <button type="button" class="ctrl entry" id="team-folder-up">⬆ Subir</button>
          <div id="team-folder-list"></div>
        </div>
      </div>
      <div class="field">
        <label for="team-app-url">URL da aplicação</label>
        <input id="team-app-url" type="url" placeholder="https://meuapp.exemplo.com">
      </div>
    </section>
    <section class="panel">
      <h2>Diretório de Artefatos (opcional)</h2>
      <p class="form-note">Pasta onde os agentes do time salvam relatórios, builds e exports gerados. Será exibido no Kanban e na tela de times.</p>
      <div class="field">
        <label for="team-artifacts-dir">Pasta de artefatos</label>
        <div class="path-pick-row">
          <input id="team-artifacts-dir" placeholder="/Users/voce/projeto/artifacts">
          <button type="button" class="ctrl" id="team-artifacts-browse">Navegar</button>
        </div>
        <div class="folder-browser" id="team-artifacts-browser" style="display:none;">
          <div class="path" id="team-artifacts-path"></div>
          <button type="button" class="ctrl entry" id="team-artifacts-up">⬆ Subir</button>
          <div id="team-artifacts-list"></div>
        </div>
      </div>
    </section>
    <div class="actions">
      <button type="submit" class="ctrl primary" id="team-create">Criar time</button>
      <a class="ctrl" href="/times">Cancelar</a>
    </div>
    <div class="result" id="team-result"></div>
  </form>
</main>
<script>
const TEAM_PRESETS_CREATE = __TEAM_PRESETS__;
let selectedTeamPreset = "";

function el(id) { return document.getElementById(id); }
function esc(s) {
  return String(s || "").replace(/&/g,"&amp;").replace(/</g,"&lt;")
    .replace(/>/g,"&gt;").replace(/"/g,"&quot;");
}
let teamBrowsePath = "";

function renderCreateTeamPresets() {
  const box = el("create-team-presets");
  if (!box) return;
  box.innerHTML = TEAM_PRESETS_CREATE.map((p) =>
    '<button type="button" class="preset-chip" data-preset="' + esc(p.id) + '">' +
    esc(p.name) + "</button>"
  ).join("");
  box.querySelectorAll(".preset-chip").forEach((btn) => {
    btn.addEventListener("click", () => {
      const preset = TEAM_PRESETS_CREATE.find((x) => x.id === btn.dataset.preset);
      if (!preset) return;
      selectedTeamPreset = preset.id;
      box.querySelectorAll(".preset-chip").forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");
      el("team-name").value = preset.name || "";
      el("team-id").value = preset.id || "";
      el("team-description").value = preset.description || "";
    });
  });
}

function slugifyName(name) {
  return String(name || "").trim().toLowerCase()
    .normalize("NFD").replace(/[\u0300-\u036f]/g, "")
    .replace(/[^a-z0-9]+/g, "-").replace(/^-+|-+$/g, "").slice(0, 48);
}

function syncProjectFields() {
  const src = document.querySelector('input[name="team-src"]:checked');
  const mode = src ? src.value : "none";
  el("team-github-wrap").classList.toggle("show", mode === "github");
  el("team-github-branch-wrap").classList.toggle("show", mode === "github");
  el("team-local-wrap").classList.toggle("show", mode === "local");
  if (mode !== "local") el("team-folder-browser").style.display = "none";
}

document.querySelectorAll('input[name="team-src"]').forEach((radio) => {
  radio.addEventListener("change", syncProjectFields);
});
syncProjectFields();

el("team-name").addEventListener("blur", () => {
  const slugEl = el("team-id");
  if (slugEl.value.trim()) return;
  const s = slugifyName(el("team-name").value);
  if (s) slugEl.value = s;
});

async function browseTeamFolders(path, goUp = false) {
  const q = new URLSearchParams();
  if (path) q.set("path", path);
  if (goUp) q.set("up", "1");
  const url = "/hermes/local-folders" + (q.toString() ? ("?" + q.toString()) : "");
  const r = await fetch(url, { cache: "no-cache" });
  const data = await r.json();
  if (!r.ok || data.ok === false) throw new Error(data.error || "falha ao listar pastas");
  teamBrowsePath = String(data.current || "");
  renderTeamFolderList(data);
}

function renderTeamFolderList(data) {
  const current = String(data.current || "");
  const parent = String(data.parent || "");
  const dirs = Array.isArray(data.directories) ? data.directories : [];
  el("team-folder-path").textContent = current || "—";
  el("team-folder-up").disabled = !parent || parent === current;
  const list = el("team-folder-list");
  if (!dirs.length) {
    list.innerHTML = '<div style="padding:8px;color:var(--muted);font-size:12px;">Nenhuma subpasta.</div>';
    return;
  }
  list.innerHTML = dirs.map((d) =>
    '<button type="button" class="ctrl entry" data-path="' + esc(d.path || "") + '">📁 ' +
    esc(d.name || d.path || "") + "</button>"
  ).join("");
  list.querySelectorAll("[data-path]").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const picked = btn.dataset.path || "";
      if (!picked) return;
      el("team-local-path").value = picked;
      await browseTeamFolders(picked);
    });
  });
}

el("team-local-browse").addEventListener("click", async () => {
  const guess = el("team-local-path").value.trim() || teamBrowsePath;
  await browseTeamFolders(guess);
  el("team-folder-browser").style.display = "block";
});
el("team-folder-up").addEventListener("click", async () => {
  if (!teamBrowsePath) return;
  await browseTeamFolders(teamBrowsePath, true);
});

let artifactsBrowsePath = "";
async function browseArtifactsFolders(path, goUp = false) {
  const q = new URLSearchParams();
  if (path) q.set("path", path);
  if (goUp) q.set("up", "1");
  const url = "/hermes/local-folders" + (q.toString() ? ("?" + q.toString()) : "");
  const r = await fetch(url, { cache: "no-cache" });
  const data = await r.json();
  if (!r.ok || data.ok === false) throw new Error(data.error || "falha ao listar pastas");
  artifactsBrowsePath = String(data.current || "");
  renderArtifactsFolderList(data);
}
function renderArtifactsFolderList(data) {
  const current = String(data.current || "");
  const parent = String(data.parent || "");
  const dirs = Array.isArray(data.directories) ? data.directories : [];
  el("team-artifacts-path").textContent = current || "—";
  el("team-artifacts-up").disabled = !parent || parent === current;
  const list = el("team-artifacts-list");
  if (!dirs.length) {
    list.innerHTML = '<div style="padding:8px;color:var(--muted);font-size:12px;">Nenhuma subpasta.</div>';
    return;
  }
  list.innerHTML = dirs.map((d) =>
    '<button type="button" class="ctrl entry" data-path="' + esc(d.path || "") + '">📁 ' +
    esc(d.name || d.path || "") + "</button>"
  ).join("");
  list.querySelectorAll("[data-path]").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const picked = btn.dataset.path || "";
      if (!picked) return;
      el("team-artifacts-dir").value = picked;
      await browseArtifactsFolders(picked);
    });
  });
}
el("team-artifacts-browse").addEventListener("click", async () => {
  const guess = el("team-artifacts-dir").value.trim() || artifactsBrowsePath || teamBrowsePath;
  await browseArtifactsFolders(guess);
  el("team-artifacts-browser").style.display = "block";
});
el("team-artifacts-up").addEventListener("click", async () => {
  if (!artifactsBrowsePath) return;
  await browseArtifactsFolders(artifactsBrowsePath, true);
});

async function createTeam(ev) {
  if (ev) ev.preventDefault();
  const name = el("team-name").value.trim();
  const id = el("team-id").value.trim();
  const description = el("team-description").value.trim();
  const src = document.querySelector('input[name="team-src"]:checked');
  const mode = src ? src.value : "none";
  const out = el("team-result");
  const btn = el("team-create");
  if (!name) {
    out.className = "result err";
    out.textContent = "Informe o nome do time.";
    return;
  }
  const body = { name, id: id || undefined, description };
  if (selectedTeamPreset) {
    body.preset_id = selectedTeamPreset;
    body.seed_kanban = true;
  }
  if (mode === "github") {
    const github_url = el("team-github-url").value.trim();
    if (!github_url) {
      out.className = "result err";
      out.textContent = "Informe a URL do repositório GitHub.";
      return;
    }
    body.project_source = "github";
    body.github_url = github_url;
    body.github_branch = el("team-github-branch").value.trim() || "main";
  } else if (mode === "local") {
    const local_path = el("team-local-path").value.trim();
    if (!local_path) {
      out.className = "result err";
      out.textContent = "Informe o caminho da pasta local.";
      return;
    }
    body.project_source = "local";
    body.local_path = local_path;
  }
  const artifacts_dir = el("team-artifacts-dir").value.trim();
  if (artifacts_dir) {
    body.artifacts_dir = artifacts_dir;
  }
  const app_url = el("team-app-url").value.trim();
  if (app_url) {
    body.app_url = app_url;
  }
  btn.disabled = true;
  out.className = "result";
  out.textContent = "Criando time…";
  out.style.display = "block";
  try {
    const r = await fetch("/teams", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(body),
    });
    const data = await r.json();
    if (!r.ok || data.ok === false) throw new Error(data.error || ("HTTP " + r.status));
    const team = data.team || {};
    const label = team.name || team.id || name;
    const tid = team.id || id;
    out.className = "result ok";
    out.innerHTML = "Time criado: " + esc(label) +
      '<div class="links">' +
      '<a class="ctrl" href="/times">Ver times</a>' +
      (tid ? '<a class="ctrl" href="/kanban?team=' + encodeURIComponent(tid) + '">Abrir Kanban</a>' : "") +
      '<a class="ctrl" href="/roles">Papéis</a>' +
      "</div>";
    el("team-create-form").querySelectorAll("input, textarea, button").forEach((n) => {
      if (n.id !== "team-create") n.disabled = true;
    });
    btn.textContent = "Time criado";
  } catch (e) {
    out.className = "result err";
    out.textContent = "Falha: " + e.message;
    btn.disabled = false;
  }
}

el("team-create-form").addEventListener("submit", createTeam);
el("team-create").addEventListener("click", createTeam);

async function initTeamCreatePage() {
  if (typeof window.qcmAuthGate === "function") {
    const auth = await window.qcmAuthGate();
    if (!auth || auth.ok === false) return;
  }
  renderCreateTeamPresets();
}
initTeamCreatePage();
</script>
</body>
</html>
"""


def build_team_create_html(hermes_dashboard_url: Optional[str] = None) -> str:
    from .team_presets import TEAM_PRESETS

    presets_json = json.dumps(TEAM_PRESETS, ensure_ascii=False)
    html = TEAM_CREATE_PAGE.replace("__TEAM_PRESETS__", presets_json)
    return _inject_app_nav(
        html,
        "teams",
        hermes_dashboard_url=hermes_dashboard_url,
    )


KANBAN_PAGE = r"""<!doctype html>
<html lang="pt-br">
<head>
<meta charset="utf-8">
<title>gois — kanban</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<style>
  __APP_THEME_CSS__
  __APP_UI_CSS__
  __HERMES_CRON_EXEC_CSS__
  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; min-height: 100%; background: var(--bg); color: var(--fg);
               font: 14px/1.45 -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; }
  body { display: flex; flex-direction: column; min-height: 100vh; }
  __APP_NAV_CSS__
  main.kb-main {
    flex: 1; width: 100%; max-width: none; margin: 0; padding: 0;
    display: flex; flex-direction: column; min-height: 0;
  }
  .kb-shell {
    flex: 1;
    min-height: 0;
    display: grid;
    grid-template-columns: minmax(210px, 250px) minmax(0, 1fr);
    gap: 12px;
    padding: 14px 18px 18px;
    align-items: start;
  }
  .kb-side {
    position: sticky;
    top: 68px;
    max-height: calc(100vh - 84px);
    overflow: auto;
    padding: 12px;
    border-radius: 14px;
    border: 1px solid var(--border);
    background:
      radial-gradient(circle at top left, rgba(106,169,255,.12), transparent 42%),
      var(--panel);
    box-shadow: 0 12px 28px rgba(0,0,0,.16);
  }
  .kb-work {
    min-width: 0;
    min-height: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .kb-content {
    min-width: 0;
    min-height: 0;
    display: flex;
    flex-direction: column;
  }
  .page-head { margin-bottom: 10px; }
  .page-head h1 { margin: 0 0 6px; font-size: 22px; font-weight: 600; letter-spacing: -.2px; }
  .page-head p { margin: 0; color: var(--muted); font-size: 13px; line-height: 1.5; }
  .kb-toolbar {
    display: flex; flex-direction: column; gap: 10px; align-items: stretch;
    background: var(--panel); border: 1px solid var(--border); border-radius: 12px;
    padding: 12px;
  }
  .kb-toolbar h2 { margin: 0; width: 100%; font-size: 11px; font-weight: 600;
                   color: var(--muted); text-transform: uppercase; letter-spacing: .8px; }
  .kb-toolbar .grow { min-width: 0; }
  .kb-toolbar .project-select-wrap {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .kb-toolbar .project-select-wrap label {
    font-size: 11px;
    color: var(--muted);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .7px;
  }
  .kb-project-actions {
    display: grid;
    grid-template-columns: 1fr;
    gap: 6px;
  }
  .kb-project-actions .ctrl,
  .kb-project-actions .ctrl.primary {
    width: 100%;
    justify-content: center;
  }
  .kb-toolbar select, .kb-compose input, .kb-compose select,
  .kb-compose textarea, .modal-card input, .modal-card select, .modal-card textarea {
    width: 100%; background: var(--panel-2); color: var(--fg); border: 1px solid var(--border);
    border-radius: 10px; padding: 10px 12px; font: inherit; font-size: 13px;
  }
  .kb-toolbar select { cursor: pointer; font-weight: 600; }
  .kb-toolbar select:focus, .modal-card input:focus, .modal-card select:focus,
  .modal-card textarea:focus { outline: none; border-color: var(--accent);
                              box-shadow: 0 0 0 3px var(--accent-dim); }
  .kb-hint { color: var(--muted); font-size: 12px; font-family: var(--mono);
             margin: 10px 0 0; min-height: 1.2em; line-height: 1.45; }
  .kb-project-info { margin: 10px 0 0; font-size: 12px; font-family: var(--mono);
                     background: var(--card); border: 1px solid var(--border);
                     border-radius: 6px; padding: 8px 10px; }
  .kb-project-info[hidden] { display: none; }
  .kb-info-row { display: flex; align-items: baseline; gap: 6px; margin-bottom: 4px;
                 flex-wrap: wrap; }
  .kb-info-row:last-child { margin-bottom: 0; }
  .kb-info-row[hidden] { display: none; }
  .kb-info-icon { flex-shrink: 0; font-size: 13px; }
  .kb-info-label { color: var(--muted); flex-shrink: 0; }
  .kb-info-value { color: var(--fg); word-break: break-all; }
  .kb-info-link { color: var(--accent); text-decoration: none; word-break: break-all; }
  .kb-info-link:hover { text-decoration: underline; }
  .kb-stats { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 10px; }
  .kb-stats[hidden] { display: none; }
  .card-meta-badge {
    display: inline-flex; align-items: center; padding: 2px 7px; border-radius: 999px;
    font-size: 10px; font-family: var(--mono); color: var(--accent);
    border: 1px solid rgba(106,169,255,.35); background: rgba(106,169,255,.10);
    margin-left: 6px;
  }
  .kb-board-wrap {
    flex: 1;
    min-height: 0;
    overflow: auto;
    margin: 0;
    padding: 18px;
    background:
      radial-gradient(circle at top right, rgba(106,169,255,.16), transparent 44%),
      linear-gradient(180deg, var(--panel), color-mix(in srgb, var(--panel) 86%, #000 14%));
    border: 1px solid color-mix(in srgb, var(--accent) 36%, var(--border) 64%);
    border-radius: 16px;
    box-shadow: 0 16px 36px rgba(0,0,0,.22), inset 0 1px 0 rgba(255,255,255,.04);
    scrollbar-width: thin;
  }
  .board {
    display: flex; gap: 16px; align-items: flex-start;
    min-height: calc(100vh - 250px); width: max-content; min-width: 100%; padding-bottom: 24px;
  }
  .trello-col {
    flex: 0 0 320px; width: 320px; max-height: calc(100vh - 285px);
    display: flex; flex-direction: column; background: var(--panel);
    border: 1px solid color-mix(in srgb, var(--accent) 20%, var(--border) 80%);
    border-radius: 14px;
    box-shadow: 0 8px 20px rgba(0,0,0,.18);
  }
  .trello-col[data-tone="backlog"] .trello-col-head::before { background: var(--muted); }
  .trello-col[data-tone="todo"] .trello-col-head::before { background: var(--accent); }
  .trello-col[data-tone="doing"] .trello-col-head::before { background: var(--warn); }
  .trello-col[data-tone="review"] .trello-col-head::before { background: var(--accent); opacity: .65; }
  .trello-col[data-tone="done"] .trello-col-head::before { background: var(--ok); }
  .trello-col[data-tone="default"] .trello-col-head::before { background: var(--accent); }
  .trello-col-head {
    display: flex; align-items: center; gap: 10px; padding: 14px 16px 12px; flex-shrink: 0;
    border-bottom: 1px solid var(--border); position: relative;
  }
  .trello-col-head::before {
    content: ""; position: absolute; top: 0; left: 0; right: 0; height: 3px;
    border-radius: 14px 14px 0 0;
  }
  .trello-col-title {
    flex: 1; margin: 0; font-size: 11px; font-weight: 600; color: var(--muted);
    text-transform: uppercase; letter-spacing: .8px;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .trello-col-count {
    font-size: 11px; font-family: var(--mono); color: var(--muted);
    background: var(--panel-2); border: 1px solid var(--border);
    border-radius: 999px; padding: 2px 8px; min-width: 22px; text-align: center;
  }
  .trello-col-body {
    flex: 1; overflow-y: auto; padding: 10px 12px 12px;
    display: flex; flex-direction: column; gap: 8px; min-height: 56px;
  }
  .trello-col-body.drag-over {
    background: var(--accent-dim); outline: 1px dashed var(--accent); outline-offset: -3px;
    border-radius: 0 0 12px 12px;
  }
  .trello-card {
    background: var(--panel-2); border: 1px solid var(--border); border-radius: 8px;
    padding: 12px; cursor: grab; color: var(--fg);
    box-shadow: 0 6px 14px rgba(0,0,0,.10);
    transition: transform .16s ease, border-color .16s ease, box-shadow .16s ease;
  }
  .trello-card:hover {
    border-color: var(--accent);
    transform: translateY(-1px);
    box-shadow: 0 10px 18px rgba(0,0,0,.16);
  }
  .trello-card.dragging { opacity: .5; cursor: grabbing; }
  .trello-card .card-click-hint {
    font-size: 10px; color: var(--muted); margin-top: 6px; font-family: var(--mono);
  }
  .card-result-block {
    margin-top: 10px;
    padding-top: 10px;
    border-top: 1px dashed var(--border);
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .card-result-details {
    border: 1px solid var(--border);
    border-radius: 8px;
    background: rgba(106,169,255,.05);
    overflow: hidden;
  }
  .card-result-details summary {
    list-style: none;
    cursor: pointer;
    padding: 7px 9px;
    font-size: 11px;
    font-family: var(--mono);
    color: var(--muted);
    user-select: none;
  }
  .card-result-details summary::-webkit-details-marker { display: none; }
  .card-result-details summary::before {
    content: "▸";
    margin-right: 6px;
    color: var(--accent);
  }
  .card-result-details[open] summary::before { content: "▾"; }
  .card-result-details[open] summary {
    border-bottom: 1px dashed var(--border);
    color: var(--fg);
  }
  .card-result-details-body {
    padding: 8px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .card-result-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 4px 8px;
    font-size: 10px;
    font-family: var(--mono);
    color: var(--muted);
  }
  .card-result-meta .ok { color: var(--ok); }
  .card-result-meta .err { color: var(--bad); }
  .card-result-meta .warn { color: var(--warn); }
  .card-result-body {
    margin: 0;
    padding: 8px;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: color-mix(in srgb, var(--panel-2) 92%, #000 8%);
    color: var(--fg);
    font-size: 11px;
    line-height: 1.45;
    font-family: var(--mono);
    white-space: pre-wrap;
    word-break: break-word;
    max-height: 220px;
    overflow: auto;
  }
  .card-result-runs {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 4px;
    font-size: 10px;
    font-family: var(--mono);
    color: var(--muted);
  }
  .card-result-runs li {
    border: 1px solid var(--border);
    border-radius: 7px;
    padding: 4px 6px;
    background: rgba(106,169,255,.05);
    white-space: pre-wrap;
    word-break: break-word;
  }
  .task-detail-section {
    margin-top: 14px; padding-top: 12px; border-top: 1px dashed var(--border);
  }
  .task-detail-section h4 {
    margin: 0 0 8px; font-size: 11px; font-weight: 600; color: var(--muted);
    text-transform: uppercase; letter-spacing: .8px;
  }
  .task-detail-dl { margin: 0; display: grid; gap: 8px; }
  .task-detail-dl div { display: grid; grid-template-columns: 110px 1fr; gap: 8px; font-size: 12px; }
  .task-detail-dl dt { margin: 0; color: var(--muted); font-weight: 500; }
  .task-detail-dl dd { margin: 0; font-family: var(--mono); word-break: break-word; }
  .task-detail-body {
    margin: 0; padding: 12px; background: var(--panel-2); border: 1px solid var(--border);
    border-radius: 8px; font-size: 12px; line-height: 1.5; white-space: pre-wrap;
    word-break: break-word; max-height: min(42vh, 360px); overflow: auto;
    font-family: var(--mono);
  }
  .task-detail-runs { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 8px; }
  .task-detail-runs button {
    background: var(--panel); color: var(--muted); border: 1px solid var(--border);
    border-radius: 999px; padding: 4px 10px; font-size: 11px; cursor: pointer;
    font-family: var(--mono);
  }
  .task-detail-runs button.active { color: var(--accent); border-color: var(--accent); }
  .task-detail-muted { color: var(--muted); font-size: 12px; line-height: 1.45; }
  .modal-card.task-detail-card { width: min(640px, 94vw); }
  .modal-card.task-source-card { width: min(1040px, 96vw); }
  .task-source-path {
    margin: 4px 0 10px;
    font-size: 12px;
    color: var(--muted);
    font-family: var(--mono);
    word-break: break-all;
  }
  .task-source-body {
    margin: 0;
    padding: 12px;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--panel-2);
    color: var(--fg);
    font-size: 12px;
    line-height: 1.5;
    font-family: var(--mono);
    white-space: pre;
    overflow: auto;
    max-height: min(62vh, 560px);
  }
  .trello-card .card-top { display: flex; align-items: flex-start; justify-content: space-between;
                           gap: 8px; margin-bottom: 6px; }
  .trello-card .card-quick-actions {
    display: flex; gap: 4px; flex-shrink: 0;
  }
  .trello-card .card-quick-actions button {
    width: 26px; height: 26px; padding: 0; line-height: 1;
    font-size: 14px; border-radius: 6px;
  }
  .trello-card .card-quick-actions button.pm-btn {
    background: rgba(106,169,255,.12); border-color: rgba(106,169,255,.35);
    color: var(--accent); font-size: 11px; font-weight: 700;
  }
  .trello-card .card-quick-actions button.pm-btn:hover {
    background: rgba(106,169,255,.22); border-color: var(--accent);
  }
  .modal-card.pm-analysis-card { width: min(680px, 94vw); }
  .pm-analysis-card .pm-loading { text-align: center; padding: 28px; color: var(--muted); font-size: 13px; }
  .pm-analysis-card .pm-loading::after { content: ""; display: inline-block; width: 14px; height: 14px;
    border: 2px solid var(--accent); border-top-color: transparent; border-radius: 50%;
    animation: pm-spin .7s linear infinite; vertical-align: middle; margin-left: 8px; }
  @keyframes pm-spin { to { transform: rotate(360deg); } }
  .pm-analysis-card .pm-section { margin-top: 14px; }
  .pm-analysis-card .pm-section h4 { margin: 0 0 6px; font-size: 12px; font-weight: 600;
    color: var(--accent); text-transform: uppercase; letter-spacing: .6px; }
  .pm-analysis-card .pm-section ul { margin: 0; padding-left: 18px; font-size: 13px; line-height: 1.6; }
  .pm-analysis-card .pm-section p { margin: 0; font-size: 13px; line-height: 1.6; color: var(--fg); }
  .pm-analysis-card .pm-badge { display: inline-block; padding: 2px 8px; border-radius: 4px;
    font-size: 11px; font-weight: 600; margin-right: 6px; }
  .pm-analysis-card .pm-badge.done { background: rgba(61,220,132,.12); color: var(--ok); }
  .pm-analysis-card .pm-badge.doing { background: rgba(255,196,61,.12); color: var(--warn); }
  .pm-analysis-card .pm-badge.todo { background: rgba(106,169,255,.12); color: var(--accent); }
  .pm-analysis-card .pm-error { color: var(--bad); font-size: 13px; padding: 14px; }
  .trello-card .card-title { margin: 0; font-size: 13px; font-weight: 600; line-height: 1.45; flex: 1; }
  .trello-card .card-desc {
    margin: 0 0 10px; font-size: 12px; color: var(--muted); line-height: 1.45;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .trello-card .card-foot {
    display: flex; align-items: center; justify-content: space-between; gap: 8px;
  }
  .trello-card .card-id { font-size: 11px; color: var(--muted); font-family: var(--mono); }
  .trello-avatar {
    width: 24px; height: 24px; border-radius: 50%; font-size: 10px; font-weight: 700;
    font-family: var(--mono); display: inline-flex; align-items: center; justify-content: center;
    color: var(--accent); background: rgba(106,169,255,.10); border: 1px solid rgba(106,169,255,.35);
  }
  .trello-card-menu {
    display: flex; gap: 6px; margin-top: 10px; padding-top: 10px;
    border-top: 1px dashed var(--border);
  }
  .trello-card-menu button.ctrl { flex: 1; padding: 5px 8px; font-size: 11px; }
  .trello-card-menu button.ctrl.danger { color: var(--bad); border-color: rgba(255,90,95,.35); }
  .trello-card-menu button.ctrl.danger:hover {
    color: #fff; background: rgba(255,90,95,.2); border-color: var(--bad);
  }
  .trello-add-card {
    width: 100%; border: none; background: transparent; color: var(--muted);
    text-align: left; padding: 8px 10px; border-radius: 8px; cursor: pointer;
    font-size: 12px; font-family: var(--mono);
  }
  .trello-add-card:hover { color: var(--accent); background: var(--accent-dim); }
  .kb-empty-board {
    text-align: center; padding: 48px 24px; color: var(--muted); font-style: italic;
    border: 1px dashed var(--border); border-radius: 12px;
    background: var(--panel); margin: 8px auto; max-width: 420px; font-size: 13px;
  }
  .kb-empty-board strong { display: block; color: var(--fg); font-style: normal;
                           font-size: 14px; font-weight: 600; margin-bottom: 6px; }
  .kb-compose { display: none; }
  .grid2 { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px; }
  @media (max-width: 720px) {
    .grid2 { grid-template-columns: 1fr; }
    .trello-col { flex: 0 0 min(90vw, 308px); width: min(90vw, 308px); max-height: calc(100vh - 290px); }
    .kb-shell { grid-template-columns: 1fr; gap: 10px; padding: 10px; }
    .kb-side { position: static; max-height: none; }
    .kb-board-wrap { padding: 12px; border-radius: 12px; }
  }
  @media (min-width: 721px) and (max-width: 1180px) {
    .kb-shell { grid-template-columns: minmax(200px, 230px) minmax(0, 1fr); }
  }
  .field label { display: block; font-size: 11px; font-weight: 600; color: var(--muted);
                 text-transform: uppercase; letter-spacing: .8px; margin-bottom: 5px; }
  .kb-compose textarea { width: 100%; resize: vertical; min-height: 72px; }
  .result { margin-top: 12px; padding: 10px 12px; border-radius: 8px; font-size: 12px;
            font-family: var(--mono); display: none; }
  .result.ok { display: block; background: rgba(61,220,132,.08); color: var(--ok);
               border: 1px solid rgba(61,220,132,.35); }
  .result.err { display: block; background: rgba(255,90,95,.08); color: var(--bad);
                border: 1px solid rgba(255,90,95,.35); }
  .modal[hidden] { display: none; }
  .modal { position: fixed; inset: 0; z-index: 50; display: flex; align-items: flex-start;
           justify-content: center; padding: 6vh 16px 24px; overflow-y: auto; }
  .modal-backdrop { position: fixed; inset: 0; background: rgba(0,0,0,.55); }
  .kanban-schedule-progress {
    max-height: 180px;
    overflow-y: auto;
    margin: 10px 0 0;
    padding: 4px 0 0;
    border-top: 1px solid var(--border);
  }
  .kanban-schedule-progress[hidden] { display: none !important; }
  .kanban-schedule-status {
    font-size: 12px;
    line-height: 1.45;
    color: var(--muted);
    font-style: italic;
    padding: 8px 12px;
    margin: 4px 0;
    background: rgba(106,169,255,.06);
    border: 1px dashed rgba(106,169,255,.22);
    border-radius: 8px;
    white-space: pre-line;
  }
  .kanban-countdown-bar {
    margin-top: 6px;
    height: 4px;
    border-radius: 999px;
    background: rgba(106,169,255,.20);
    overflow: hidden;
  }
  .kanban-countdown-fill {
    display: block;
    height: 100%;
    width: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, rgba(106,169,255,.95), rgba(61,220,132,.85));
    transition: width .9s linear;
  }
  .modal-card {
    position: relative; z-index: 1; width: min(520px, 92vw); margin: 0;
    background: var(--panel); border: 1px solid var(--border); border-radius: 12px;
    padding: 18px 20px; color: var(--fg);
  }
  .modal-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 14px; }
  .modal-head h3 { margin: 0; font-size: 16px; font-weight: 600; }
  .modal-close { cursor: pointer; }
  .modal-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 12px; }
  .modal-grid label { display: block; font-size: 11px; font-weight: 600; color: var(--muted);
                      text-transform: uppercase; letter-spacing: .8px; margin-bottom: 4px; }
  .modal-actions { margin-top: 16px; display: flex; gap: 8px; justify-content: flex-end; }
  .modal-note, .hint { margin-top: 8px; color: var(--muted); font-size: 12px; line-height: 1.45; }
  .toast-kb {
    position: fixed; bottom: 20px; right: 20px; max-width: min(520px, 92vw);
    background: var(--panel); color: var(--fg); padding: 10px 14px; border-radius: 8px;
    border: 1px solid var(--border); font-size: 12px; font-family: var(--mono);
    box-shadow: 0 8px 24px rgba(0,0,0,.35); z-index: 60; display: none;
  }
  .toast-kb.show { display: block; }
  .path-pick-row { display: flex; gap: 8px; align-items: center; }
  .path-pick-row input { flex: 1; }
  .folder-browser { margin-top: 8px; border: 1px solid var(--border); border-radius: 8px;
                    background: var(--panel-2); max-height: 180px; overflow: auto; padding: 6px; }
  .folder-browser .path { color: var(--muted); font-family: var(--mono); font-size: 11px;
                          margin-bottom: 6px; word-break: break-all; }
  .folder-browser .entry { width: 100%; text-align: left; margin-bottom: 6px; }
  .row-check { display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--fg);
               text-transform: none; letter-spacing: 0; }
  button.ctrl.danger { color: var(--bad); border-color: rgba(255,90,95,.35); }
  button.ctrl.danger:hover { color: #fff; background: rgba(255,90,95,.18); border-color: var(--bad); }
  /* ── Tab bar ──────────────────────────────────────────────────── */
  .kb-tab-bar {
    display: flex; gap: 0; align-items: flex-end;
    padding: 0 24px; margin-top: 4px;
    border-bottom: 2px solid var(--border);
    flex-shrink: 0; position: sticky; top: 0; z-index: 26;
    background: color-mix(in srgb, var(--bg) 94%, transparent);
    backdrop-filter: blur(4px);
  }
  .kb-tab {
    padding: 10px 20px; font-size: 13px; font-weight: 600; cursor: pointer;
    color: var(--muted); background: transparent; border: none;
    border-bottom: 3px solid transparent; margin-bottom: -2px;
    border-radius: 8px 8px 0 0; transition: color .15s, border-color .15s, background .15s;
    display: inline-flex; align-items: center; gap: 7px; white-space: nowrap;
    touch-action: manipulation; user-select: none; line-height: 1;
  }
  .kb-tab:hover { color: var(--fg); background: var(--panel-2); }
  .kb-tab.active { color: var(--accent); border-bottom-color: var(--accent); background: transparent; }
  .kb-tab .kb-tab-badge {
    font-size: 10px; font-family: var(--mono); padding: 1px 6px; border-radius: 999px;
    background: var(--panel-2); border: 1px solid var(--border); color: var(--muted);
  }
  .kb-tab.active .kb-tab-badge { color: var(--accent); border-color: rgba(106,169,255,.4); background: rgba(106,169,255,.10); }
  /* ── Tab panels ───────────────────────────────────────────────── */
  .kb-panel { display: none; flex: 1; min-height: 0; flex-direction: column; }
  .kb-panel.active { display: flex; }
  /* ── Tests panel ──────────────────────────────────────────────── */
  .kb-tests-wrap {
    flex: 1; overflow: auto; padding: 20px 24px; display: flex; flex-direction: column; gap: 16px;
  }
  .kb-tests-toolbar {
    display: flex; flex-wrap: wrap; gap: 10px; align-items: center;
    background: var(--panel); border: 1px solid var(--border); border-radius: 12px;
    padding: 12px 16px; flex-shrink: 0;
  }
  .kb-tests-toolbar .grow { flex: 1; min-width: 200px; }
  .kb-tests-toolbar select {
    width: 100%; background: var(--panel-2); color: var(--fg); border: 1px solid var(--border);
    border-radius: 10px; padding: 9px 12px; font: inherit; font-size: 13px; cursor: pointer;
  }
  .kb-tests-empty {
    text-align: center; padding: 40px 20px; color: var(--muted); font-size: 13px;
    font-style: italic; border: 1px dashed var(--border); border-radius: 12px;
    background: var(--panel);
  }
  .kb-tests-empty strong { display: block; font-style: normal; color: var(--fg); margin-bottom: 6px; }
  .kb-test-row {
    background: var(--panel); border: 1px solid var(--border); border-radius: 10px;
    padding: 14px 16px; display: flex; flex-direction: column; gap: 10px;
    transition: border-color .15s;
  }
  .kb-test-row:hover { border-color: color-mix(in srgb, var(--accent) 50%, var(--border)); }
  .kb-test-head { display: flex; align-items: flex-start; gap: 12px; }
  .kb-test-info { flex: 1; min-width: 0; }
  .kb-test-title { font-size: 14px; font-weight: 600; margin: 0 0 4px; line-height: 1.35; }
  .kb-test-meta { font-size: 11px; color: var(--muted); font-family: var(--mono); }
  .kb-test-actions { display: flex; gap: 6px; flex-shrink: 0; flex-wrap: wrap; }
  .kb-test-result {
    font-size: 12px; font-family: var(--mono); padding: 10px 12px; border-radius: 8px;
    background: var(--panel-2); border: 1px solid var(--border); white-space: pre-wrap;
    max-height: 200px; overflow-y: auto; line-height: 1.5; display: none;
  }
  .kb-test-result.show { display: block; }
  .kb-test-result.ok { border-color: rgba(61,220,132,.4); color: var(--ok); }
  .kb-test-result.err { border-color: rgba(255,90,95,.4); color: var(--bad); }
  .kb-test-result.running { color: var(--accent); border-color: rgba(106,169,255,.4);
    animation: kb-test-pulse 1.2s ease-in-out infinite; }
  @keyframes kb-test-pulse { 50% { opacity: .65; } }
  .kb-test-status { font-size: 11px; font-family: var(--mono); margin-left: auto; flex-shrink: 0;
    padding: 2px 8px; border-radius: 999px; background: var(--panel-2);
    border: 1px solid var(--border); color: var(--muted); }
  .kb-test-status.ok { color: var(--ok); border-color: rgba(61,220,132,.4); }
  .kb-test-status.err { color: var(--bad); border-color: rgba(255,90,95,.4); }
  .kb-test-status.running { color: var(--accent); border-color: rgba(106,169,255,.4); }
  button.ctrl.kb-run-btn { color: var(--ok); border-color: rgba(61,220,132,.4); }
  button.ctrl.kb-run-btn:hover { background: rgba(61,220,132,.10); }
  button.ctrl.kb-run-btn:disabled { opacity: .5; cursor: not-allowed; }
  /* ── Usability panel ──────────────────────────────────────────── */
  .kb-usab-wrap {
    flex: 1; overflow: auto; padding: 20px 24px; display: flex; flex-direction: column; gap: 16px;
  }
  .kb-usab-toolbar {
    display: flex; flex-wrap: wrap; gap: 10px; align-items: center;
    background: var(--panel); border: 1px solid var(--border); border-radius: 12px;
    padding: 12px 16px; flex-shrink: 0;
  }
  .kb-usab-toolbar .grow { flex: 1; min-width: 200px; }
  .kb-usab-toolbar select {
    width: 100%; background: var(--panel-2); color: var(--fg); border: 1px solid var(--border);
    border-radius: 10px; padding: 9px 12px; font: inherit; font-size: 13px; cursor: pointer;
  }
  .kb-usab-summary {
    display: flex; flex-wrap: wrap; gap: 10px; padding: 12px 16px;
    background: var(--panel); border: 1px solid var(--border); border-radius: 10px; flex-shrink: 0;
  }
  .kb-usab-score {
    flex: 1; min-width: 180px; display: flex; flex-direction: column; gap: 4px;
  }
  .kb-usab-score-label { font-size: 11px; font-weight: 600; color: var(--muted);
    text-transform: uppercase; letter-spacing: .7px; }
  .kb-usab-score-bar { height: 8px; border-radius: 4px; background: var(--panel-2);
    border: 1px solid var(--border); overflow: hidden; margin-top: 2px; }
  .kb-usab-score-fill { height: 100%; border-radius: 4px; transition: width .4s ease;
    background: linear-gradient(90deg, var(--ok), var(--accent)); }
  .kb-usab-score-fill.warn { background: linear-gradient(90deg, var(--warn), #f08c00); }
  .kb-usab-score-fill.bad { background: linear-gradient(90deg, var(--bad), #cc0022); }
  .kb-usab-score-pct { font-size: 20px; font-weight: 700; font-family: var(--mono); line-height: 1; }
  .kb-usab-cats { display: flex; flex-wrap: wrap; gap: 6px; align-items: center; }
  .kb-usab-section { background: var(--panel); border: 1px solid var(--border); border-radius: 10px; }
  .kb-usab-section-head {
    padding: 12px 16px; display: flex; align-items: center; gap: 10px; cursor: pointer;
    border-radius: 10px; transition: background .12s;
  }
  .kb-usab-section-head:hover { background: var(--panel-2); }
  .kb-usab-section-title { flex: 1; font-size: 13px; font-weight: 600; margin: 0; }
  .kb-usab-section-icon { font-size: 16px; flex-shrink: 0; }
  .kb-usab-section-body { padding: 0 16px 14px; display: flex; flex-direction: column; gap: 8px; }
  .kb-usab-section-body[hidden] { display: none; }
  .kb-usab-item {
    display: flex; align-items: flex-start; gap: 12px; padding: 10px 12px;
    border-radius: 8px; background: var(--panel-2); border: 1px solid var(--border);
    cursor: pointer; transition: border-color .12s, background .12s;
  }
  .kb-usab-item:hover { border-color: var(--accent); }
  .kb-usab-item.checked { border-color: rgba(61,220,132,.45); background: rgba(61,220,132,.06); }
  .kb-usab-item.failed  { border-color: rgba(255,90,95,.45);  background: rgba(255,90,95,.06); }
  .kb-usab-item.na      { opacity: .55; }
  .kb-usab-item-check { width: 20px; height: 20px; border-radius: 6px; border: 2px solid var(--border);
    flex-shrink: 0; margin-top: 1px; display: flex; align-items: center; justify-content: center;
    font-size: 13px; transition: border-color .12s, background .12s; }
  .kb-usab-item.checked .kb-usab-item-check { border-color: var(--ok); background: rgba(61,220,132,.18); color: var(--ok); }
  .kb-usab-item.failed  .kb-usab-item-check { border-color: var(--bad); background: rgba(255,90,95,.18); color: var(--bad); }
  .kb-usab-item.na      .kb-usab-item-check { border-color: var(--muted); background: var(--panel); color: var(--muted); }
  .kb-usab-item-text { flex: 1; min-width: 0; }
  .kb-usab-item-label { font-size: 13px; font-weight: 500; line-height: 1.4; }
  .kb-usab-item-hint { font-size: 11px; color: var(--muted); margin-top: 2px; line-height: 1.4; }
  .kb-usab-item-actions {
    display: flex; gap: 4px; flex-shrink: 0; margin-top: 1px; visibility: hidden;
  }
  .kb-usab-item:hover .kb-usab-item-actions { visibility: visible; }
  .kb-usab-item-actions button {
    padding: 3px 8px; font-size: 11px; border-radius: 6px; cursor: pointer;
    background: var(--panel); border: 1px solid var(--border); color: var(--muted);
    font-family: var(--mono); transition: border-color .1s, color .1s;
  }
  .kb-usab-item-actions button:hover { color: var(--fg); border-color: var(--accent); }
  .kb-usab-note-row { margin-top: 6px; }
  .kb-usab-note-row textarea {
    width: 100%; background: var(--panel); color: var(--fg); border: 1px solid var(--border);
    border-radius: 8px; padding: 8px 10px; font: inherit; font-size: 12px; resize: vertical;
    min-height: 48px;
  }
  .kb-usab-note-row textarea:focus { outline: none; border-color: var(--accent); }
  .kb-usab-empty {
    text-align: center; padding: 40px 20px; color: var(--muted); font-size: 13px;
    font-style: italic; border: 1px dashed var(--border); border-radius: 12px;
    background: var(--panel);
  }
  .kb-usab-empty strong { display: block; font-style: normal; color: var(--fg); margin-bottom: 6px; }
  @media (max-width: 720px) {
    .kb-tab { padding: 8px 12px; font-size: 12px; }
    .kb-tests-wrap, .kb-usab-wrap { padding: 12px; }
  }
</style>
</head>
<body>
__APP_NAV__
<main class="kb-main">
  <!-- ── Tab bar ──────────────────────────────────────────────── -->
  <div class="kb-tab-bar" role="tablist" aria-label="Seções do Kanban">
    <button type="button" class="kb-tab active" role="tab" aria-selected="true"
            aria-controls="panel-board" id="tab-board" data-tab="board">
      📋 Quadro
    </button>
    <button type="button" class="kb-tab" role="tab" aria-selected="false"
            aria-controls="panel-tests" id="tab-tests" data-tab="tests">
      🧪 Testes
      <span class="kb-tab-badge" id="tab-tests-badge">0</span>
    </button>
    <button type="button" class="kb-tab" role="tab" aria-selected="false"
            aria-controls="panel-usab" id="tab-usab" data-tab="usab">
      ✅ Usabilidade
      <span class="kb-tab-badge" id="tab-usab-badge">—</span>
    </button>
  </div>

  <div class="kb-shell">
    <aside class="kb-side" aria-label="Projeto atual">
      <header class="page-head">
        <h1>Kanban</h1>
        <p>Selecione o projeto e organize as tarefas por coluna.</p>
      </header>
      <div class="kb-toolbar">
        <h2>Projeto</h2>
        <div class="project-select-wrap">
          <label for="project">Projeto ativo</label>
          <select id="project" aria-label="Projeto"></select>
        </div>
        <div class="kb-project-actions">
          <button type="button" class="ctrl" id="refresh">Atualizar</button>
          <button type="button" class="ctrl primary" id="new-task">Adicionar cartão</button>
        </div>
      </div>
      <div class="kb-hint" id="board-hint">Carregando projetos…</div>
      <div class="kb-project-info" id="kb-project-info" hidden>
        <div class="kb-info-row" id="kb-info-workdir" hidden>
          <span class="kb-info-icon">📁</span>
          <span class="kb-info-label">Diretório:</span>
          <span class="kb-info-value" id="kb-info-workdir-value"></span>
        </div>
        <div class="kb-info-row" id="kb-info-github" hidden>
          <span class="kb-info-icon">🔗</span>
          <span class="kb-info-label">GitHub:</span>
          <a class="kb-info-link" id="kb-info-github-link" href="#" target="_blank" rel="noopener"></a>
        </div>
        <div style="margin-top:8px;" id="kb-dir-browse-section" hidden>
          <button type="button" class="ctrl" id="kb-dir-change-btn" style="width:100%;font-size:11px;">📁 Alterar diretório</button>
          <div class="folder-browser" id="kb-dir-browser" style="display:none;margin-top:8px;">
            <div class="path" id="kb-dir-current-path"></div>
            <button type="button" class="ctrl entry" id="kb-dir-up">⬆ Subir</button>
            <div id="kb-dir-folder-list"></div>
            <button type="button" class="ctrl primary" id="kb-dir-select" style="width:100%;margin-top:8px;font-size:11px;">Selecionar esta pasta</button>
          </div>
        </div>
      </div>
      <div class="kb-stats" id="kb-stats" hidden></div>
      <div class="kb-wa-group" id="kb-wa-group" hidden style="margin-top:10px;padding:8px 12px;border-radius:8px;background:var(--panel-2);border:1px solid var(--border);font-size:12px;"></div>
    </aside>

    <div class="kb-content">
      <!-- ── Panel: Quadro (original) ─────────────────────────────── -->
      <div class="kb-panel active" id="panel-board" role="tabpanel" aria-labelledby="tab-board">
        <div class="kb-work">
          <div class="kb-board-wrap">
            <div class="board" id="board"></div>
          </div>
        </div>
      </div>

      <!-- ── Panel: Testes ────────────────────────────────────────── -->
      <div class="kb-panel" id="panel-tests" role="tabpanel" aria-labelledby="tab-tests">
        <div class="kb-tests-wrap">
          <div class="kb-tests-toolbar">
            <div class="grow">
              <select id="tests-task-filter" aria-label="Filtrar por tarefa">
                <option value="">Todas as tarefas</option>
              </select>
            </div>
            <button type="button" class="ctrl" id="tests-refresh">Atualizar</button>
            <button type="button" class="ctrl kb-run-btn" id="tests-run-all">▶ Executar todos</button>
          </div>
          <div id="tests-list"></div>
        </div>
      </div>

      <!-- ── Panel: Usabilidade ───────────────────────────────────── -->
      <div class="kb-panel" id="panel-usab" role="tabpanel" aria-labelledby="tab-usab">
        <div class="kb-usab-wrap">
          <div class="kb-usab-toolbar">
            <div class="grow">
              <select id="usab-task-filter" aria-label="Filtrar por tarefa">
                <option value="">Visão geral do projeto</option>
              </select>
            </div>
            <button type="button" class="ctrl" id="usab-reset">Limpar respostas</button>
            <button type="button" class="ctrl primary" id="usab-export">Exportar relatório</button>
          </div>
          <div class="kb-usab-summary" id="usab-summary"></div>
          <div id="usab-checklist"></div>
        </div>
      </div>
    </div>
  </div>

  <div class="toast-kb" id="kb-toast" role="status"></div>
</main>
<div class="modal" id="new-task-modal" hidden>
  <div class="modal-backdrop" id="new-task-backdrop"></div>
  <div class="modal-card" role="dialog" aria-modal="true">
    <div class="modal-head">
      <h3>Novo cartão</h3>
      <button class="ctrl modal-close" id="new-task-close" type="button">Fechar</button>
    </div>
    <div class="grid2">
      <div class="field"><label for="task-title">Título</label><input id="task-title" placeholder="Ex.: Implementar endpoint"></div>
      <div class="field"><label for="task-priority">Prioridade</label><input id="task-priority" type="number" min="1" max="9" placeholder="1–9"></div>
      <div class="field"><label for="task-assignee">Responsável</label><select id="task-assignee"></select></div>
      <div class="field"><label for="task-column">Lista</label><select id="task-column"></select></div>
      <div class="field" style="grid-column:1/-1;"><label for="task-workdir">Pasta no computador</label>
        <div class="path-pick-row">
          <input id="task-workdir" placeholder="opcional — pasta do projeto se vazio">
          <button type="button" class="ctrl" id="task-workdir-browse">Navegar</button>
        </div>
        <div class="folder-browser" id="task-folder-browser" style="display:none;">
          <div class="path" id="task-folder-path"></div>
          <button type="button" class="ctrl entry" id="task-folder-up">⬆ Subir</button>
          <div id="task-folder-list"></div>
        </div>
      </div>
      <div class="field" style="grid-column:1/-1;"><label for="task-schedule">Agendar ao criar (opcional)</label>
        <input id="task-schedule" placeholder="1m (uma execução)"></div>
      <div class="field" style="grid-column:1/-1;"><label for="task-skills">Skills da tarefa (opcional)</label>
        <input id="task-skills" placeholder="plan, tdd, review"></div>
      <div class="field" style="grid-column:1/-1;"><label for="task-model">Modelo LLM (opcional)</label>
        <select id="task-model"><option value="">— padrão do sistema —</option></select></div>
    </div>
    <label class="field" for="task-desc">Descrição</label>
    <textarea id="task-desc" rows="3" placeholder="Critérios de aceite…"></textarea>
    <div class="modal-actions">
      <button type="button" class="ctrl" id="new-task-cancel">Cancelar</button>
      <button type="button" class="ctrl primary" id="save-task">Criar cartão</button>
    </div>
    <div class="kanban-schedule-progress" id="new-task-schedule-progress" hidden></div>
    <div class="result" id="result"></div>
  </div>
</div>
<div class="modal" id="assign-schedule-modal" hidden>
  <div class="modal-backdrop" id="assign-schedule-backdrop"></div>
  <div class="modal-card" role="dialog" aria-modal="true" aria-labelledby="assign-schedule-title">
    <div class="modal-head">
      <h3 id="assign-schedule-title">Atribuir e agendar tarefa</h3>
      <button class="ctrl modal-close" id="assign-schedule-close" type="button">Fechar</button>
    </div>
    <div class="hint" id="assign-schedule-task">Tarefa: —</div>
    <div class="modal-note" id="assign-schedule-note"></div>
    <div class="modal-grid">
      <div style="grid-column:1/-1;">
        <label for="assign-schedule-assignee">Papel (perfil Hermes)</label>
        <select id="assign-schedule-assignee"></select>
      </div>
      <div style="grid-column:1/-1;">
        <label for="assign-schedule-skills">Skills para execução (opcional)</label>
        <input id="assign-schedule-skills" placeholder="plan, tdd, review">
      </div>
      <div style="grid-column:1/-1;">
        <label for="assign-schedule-workdir">Pasta no computador</label>
        <div class="path-pick-row">
          <input id="assign-schedule-workdir" placeholder="onde o agente executa o trabalho">
          <button type="button" class="ctrl" id="assign-schedule-browse">Navegar</button>
        </div>
        <div class="folder-browser" id="assign-folder-browser" style="display:none;">
          <div class="path" id="assign-folder-path"></div>
          <button type="button" class="ctrl entry" id="assign-folder-up">⬆ Subir</button>
          <div id="assign-folder-list"></div>
        </div>
      </div>
      <div>
        <label for="assign-schedule-cron">Quando executar</label>
        <input id="assign-schedule-cron" value="1m" placeholder="1m, 30m, every 2h…">
      </div>
      <div>
        <label class="row-check" for="assign-schedule-once">
          <input type="checkbox" id="assign-schedule-once" checked>
          Executar uma vez
        </label>
      </div>
    </div>
    <div class="modal-actions">
      <button type="button" class="ctrl" id="assign-schedule-cancel">Cancelar</button>
      <button type="button" class="ctrl primary" id="assign-schedule-save">Agendar no Hermes</button>
    </div>
    <div class="kanban-schedule-progress" id="assign-schedule-progress" hidden></div>
    <div class="result" id="assign-schedule-result"></div>
  </div>
</div>
<div class="modal" id="edit-task-modal" hidden>
  <div class="modal-backdrop" id="edit-task-backdrop"></div>
  <div class="modal-card" role="dialog" aria-modal="true">
    <div class="modal-head">
      <h3>Editar cartão</h3>
      <button class="ctrl modal-close" id="edit-task-close" type="button">Fechar</button>
    </div>
    <div class="hint" id="edit-task-id-label">—</div>
    <div class="grid2">
      <div class="field" style="grid-column:1/-1;"><label for="edit-task-title">Título</label>
        <input id="edit-task-title"></div>
      <div class="field"><label for="edit-task-priority">Prioridade</label>
        <input id="edit-task-priority" type="number" min="1" max="9"></div>
      <div class="field"><label for="edit-task-column">Lista</label>
        <select id="edit-task-column"></select></div>
      <div class="field" style="grid-column:1/-1;"><label for="edit-task-assignee">Papel</label>
        <select id="edit-task-assignee"></select></div>
      <div class="field" style="grid-column:1/-1;"><label for="edit-task-skills">Skills</label>
        <input id="edit-task-skills" placeholder="plan, tdd, review"></div>
      <div class="field" style="grid-column:1/-1;"><label for="edit-task-model">Modelo LLM</label>
        <select id="edit-task-model"><option value="">— padrão do sistema —</option></select></div>
      <div class="field" style="grid-column:1/-1;"><label for="edit-task-workdir">Pasta no computador</label>
        <div class="path-pick-row">
          <input id="edit-task-workdir" placeholder="opcional">
          <button type="button" class="ctrl" id="edit-task-workdir-browse">Navegar</button>
        </div>
        <div class="folder-browser" id="edit-folder-browser" style="display:none;">
          <div class="path" id="edit-folder-path"></div>
          <button type="button" class="ctrl entry" id="edit-folder-up">⬆ Subir</button>
          <div id="edit-folder-list"></div>
        </div>
      </div>
    </div>
    <label class="field" for="edit-task-desc">Descrição</label>
    <textarea id="edit-task-desc" rows="4"></textarea>
    <div class="modal-actions">
      <button type="button" class="ctrl danger" id="edit-task-delete" style="margin-right:auto;">Apagar</button>
      <button type="button" class="ctrl" id="edit-task-cancel">Cancelar</button>
      <button type="button" class="ctrl" id="edit-task-save">Salvar</button>
      <button type="button" class="ctrl primary" id="edit-task-save-schedule">Salvar e agendar</button>
    </div>
