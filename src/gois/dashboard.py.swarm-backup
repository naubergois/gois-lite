  }
  #hermes-cron-wrap .table-scroll table.agents { min-width: 1220px; }
  .cron-wa-cell { max-width: 220px; vertical-align: top; }
  .cron-wa-cell .cron-wa-check { color: var(--ok); font-weight: 700; margin-right: 4px; }
  .cron-wa-to { font-size: 11px; font-family: var(--mono); line-height: 1.35;
                word-break: break-all; color: var(--fg); }
  .cron-wa-to.grp { color: var(--muted); }
  .status { display: flex; align-items: center; gap: 18px; padding: 22px 24px;
            border-radius: 10px; border: 1px solid var(--border); }
  .status.up   { background: linear-gradient(135deg, rgba(61,220,132,.10), transparent); }
  .status.down { background: linear-gradient(135deg, rgba(255,90,95,.10), transparent); }
  .diag-card { border-color: rgba(255,90,95,.35); }
  .diag-card h2 { color: var(--bad); }
  .diag-headline { font-size: 16px; font-weight: 600; margin: 0 0 8px; }
  .diag-likely { color: var(--fg); font-size: 13px; line-height: 1.5; margin: 0 0 12px; }
  .diag-meta { color: var(--muted); font-family: var(--mono); font-size: 11px; margin-bottom: 12px; }
  .diag-causes { margin: 0 0 12px; padding: 0; list-style: none; }
  .diag-causes li { padding: 10px 12px; margin-bottom: 8px; background: var(--panel-2);
                    border: 1px solid var(--border); border-radius: 8px; font-size: 13px; }
  .diag-causes li strong { display: block; margin-bottom: 4px; color: var(--warn); }
  .diag-causes li span { color: var(--muted); font-size: 12px; line-height: 1.45; }
  .diag-hints { margin: 0; padding-left: 18px; color: var(--muted); font-size: 12px; line-height: 1.5; }
  .diag-hints li { margin-bottom: 6px; }
  .diag-checks { margin-top: 12px; font-family: var(--mono); font-size: 11px; color: var(--muted); }
  .diag-checks .ok { color: var(--ok); }
  .diag-checks .bad { color: var(--bad); }
  .dot { width: 14px; height: 14px; border-radius: 50%; flex-shrink: 0;
