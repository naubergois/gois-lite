  .kv { display: flex; justify-content: space-between; padding: 6px 0;
        border-bottom: 1px dashed var(--border); font-size: 13px; gap: 10px; }
  .kv:last-child { border: 0; }
  .kv .k { color: var(--muted); }
  .kv .v { font-family: var(--mono); text-align: right; word-break: break-all; }
  pre { margin: 0; padding: 12px; background: var(--panel-2); border-radius: 8px;
