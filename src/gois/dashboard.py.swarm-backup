<script>
let projects = [];
let agents = [];
let kbModels = [];
let boardData = null;
let assignScheduleCtx = null;
let editTaskId = null;
let taskDetailId = null;
let kbBrowsePath = "";
let kbSuppressCardClick = false;
let sourceViewCtx = null;
let kanbanAutoRefreshTimer = null;
let kanbanAutoRefreshBusy = false;
let kanbanAutoRefreshPausedUntil = 0;
let lastBoardSignature = "";

function el(id) { return document.getElementById(id); }
function esc(s) {
  return String(s || "").replace(/&/g,"&amp;").replace(/</g,"&lt;")
    .replace(/>/g,"&gt;").replace(/"/g,"&quot;");
}

__HERMES_CRON_EXEC_JS__

function monitorFetchError(e, url) {
  const msg = String((e && e.message) || e || "");
  if (msg === "Failed to fetch" || (e && e.name === "TypeError")) {
    return (
      "Não foi possível contactar o gois em " + window.location.origin +
      ". Abra o Kanban em http://127.0.0.1:9101/kanban, confirme ./scripts/start.sh --launchd e recarregue."
    );
  }
  if (e && e.name === "AbortError") {
    return "Tempo esgotado em " + url + " (criar cron no Hermes pode levar até 2 min).";
  }
  return msg || "erro de rede";
}
function selectedProject() {
  const idx = Number(el("project").value || "0");
  return projects[idx] || null;
}
function projectIdentity(project) {
  if (!project || typeof project !== "object") return "";
  const teamId = String(project.team_id || project.profile || "").trim();
  if (teamId) return "team:" + teamId;
  const workdir = String(project.workdir || "").trim();
  const kanbanFile = String(project.kanban_file || "").trim();
  if (!workdir) return "";
  return "wd:" + workdir + "|kb:" + kanbanFile;
}
function selectProjectByIdentity(identity) {
  const key = String(identity || "").trim();
  if (!key) return false;
  const idx = projects.findIndex((p) => projectIdentity(p) === key);
  if (idx < 0) return false;
  el("project").value = String(idx);
  return true;
}
function kanbanPayloadBase() {
  const p = selectedProject();
  if (!p) return null;
  const payload = {
    workdir: p.workdir,
    kanban_file: p.kanban_file,
  };
  const teamId = String(p.team_id || p.profile || "").trim();
  if (teamId) payload.team_id = teamId;
  return payload;
}
function boardSignature(data) {
  if (!data || typeof data !== "object") return "";
  const cols = Array.isArray(data.columns) ? data.columns.map((c) => columnId(c)).join(",") : "";
  const tasks = Array.isArray(data.tasks) ? data.tasks : [];
  const taskSig = tasks
    .map((t) => [
      String(t.id || ""),
      String(t.column || ""),
      String(t.title || ""),
      String(t.updated_at || t.completed_at || ""),
    ].join("|"))
    .sort()
    .join(";");
  return cols + "#" + taskSig;
}
function requireKanbanProject(actionLabel) {
  const base = kanbanPayloadBase();
  if (!base) {
    kbToast("Selecione um projeto antes de " + (actionLabel || "continuar") + ".");
  }
  return base;
}
function boardColumns() {
  if (!boardData) return [];
  const raw = boardData.columns || boardData.lanes || boardData.raias || [];
  return Array.isArray(raw) ? raw : [];
}
function boardTasks() {
  if (!boardData) return [];
  const raw = boardData.tasks || boardData.posts || [];
  return Array.isArray(raw) ? raw : [];
}
function columnId(col) {
  return String((col && (col.id || col.column || col.status || col.slug)) || "")
    .trim()
    .toLowerCase();
}
function columnTitle(col) {
  return String(
    (col && (col.title || col.label || col.name || col.id || col.column || col.status)) || ""
  ).trim();
}
function taskColumn(task) {
  return String((task && (task.column || task.status)) || "")
    .trim()
    .toLowerCase();
}
function taskAssignees(task) {
  const raw = task && (task.assignees || task.assignee);
  if (Array.isArray(raw)) return raw.map(a => String(a || "").trim()).filter(Boolean);
  if (raw == null) return [];
  const one = String(raw).trim();
  return one ? [one] : [];
}
function taskSkills(task) {
  const raw = task && (task.skills || task.skill);
  let parts = [];
  if (Array.isArray(raw)) parts = raw;
  else if (typeof raw === "string") parts = raw.split(/[\n,;]/);
  const out = [];
  const seen = new Set();
  parts.forEach((item) => {
    const text = String(item || "").trim();
    if (!text) return;
    const key = text.toLowerCase();
    if (seen.has(key)) return;
    seen.add(key);
    out.push(text);
  });
  return out;
}
function taskWorkdir(task) {
  const w = task && (task.workdir || task.local_path || task.folder);
  if (w && String(w).trim()) return String(w).trim();
  const p = selectedProject();
  return p ? String(p.workdir || "").trim() : "";
}
function taskArtifactsDir(task) {
  const p = selectedProject();
  return p && p.artifacts_dir ? String(p.artifacts_dir).trim() : "";
}
function parseSkillsInputValue(raw) {
  if (!raw) return [];
  const out = [];
  const seen = new Set();
  String(raw)
    .split(/[\n,;]/)
    .forEach((part) => {
      const text = String(part || "").trim();
      if (!text) return;
      const key = text.toLowerCase();
      if (seen.has(key)) return;
      seen.add(key);
      out.push(text);
    });
  return out;
}
function priorityBadge(prio) {
  if (prio == null || !Number.isFinite(prio)) return "";
  const tone = priorityTone(prio);
  const label = prio === 1 ? "Alta" : (prio === 2 ? "Média" : ("P" + prio));
  return '<span class="kb-prio ' + tone + '">' + esc(label) + "</span>";
}
function taskDescriptionPreview(task) {
  const desc = String((task && task.description) || "").trim();
  if (!desc) return "";
  return '<p class="card-desc">' + esc(desc) + "</p>";
}
function hashHue(str) {
  let h = 0;
  const s = String(str || "");
  for (let i = 0; i < s.length; i++) h = ((h << 5) - h) + s.charCodeAt(i);
  return Math.abs(h) % 360;
}
async function browseKbFolders(prefix, path, goUp) {
  const q = new URLSearchParams();
  if (path) q.set("path", path);
  if (goUp) q.set("up", "1");
  const url = "/hermes/local-folders" + (q.toString() ? ("?" + q.toString()) : "");
  const data = await api(url);
  kbBrowsePath = String(data.current || "");
  renderKbFolderList(prefix, data);
}
function renderKbFolderList(prefix, data) {
  const current = String(data.current || "");
  const parent = String(data.parent || "");
  const dirs = Array.isArray(data.directories) ? data.directories : [];
  el(prefix + "-folder-path").textContent = current || "—";
  const upBtn = el(prefix + "-folder-up");
  if (upBtn) upBtn.disabled = !parent || parent === current;
  const list = el(prefix + "-folder-list");
  if (!dirs.length) {
    list.innerHTML = '<div class="hint">Nenhuma subpasta visível.</div>';
    return;
  }
  list.innerHTML = dirs.map(d => (
    '<button type="button" class="ctrl entry" data-path="' + esc(String(d.path || "")) + '">' +
    "📁 " + esc(String(d.name || d.path || "")) + "</button>"
  )).join("");
  const inputId = prefix === "assign" ? "assign-schedule-workdir"
    : (prefix === "edit" ? "edit-task-workdir" : "task-workdir");
  list.querySelectorAll("[data-path]").forEach(btn => {
    btn.addEventListener("click", async () => {
      const picked = btn.dataset.path || "";
      if (!picked) return;
      el(inputId).value = picked;
      await browseKbFolders(prefix, picked);
    });
  });
}
function kanbanTeamFromUrl() {
  const explicit = new URLSearchParams(window.location.search).get("team") || "";
  if (explicit) return explicit;
  try {
    return localStorage.getItem("qcm_kanban_last_team") || "";
  } catch (_) {
    return "";
  }
}
function defaultTaskColumn() {
  const cols = boardColumns();
  const ids = cols.map(columnId).filter(Boolean);
  if (ids.includes("backlog")) return "backlog";
  if (ids.includes("todo")) return "todo";
  return ids[0] || "todo";
}
function selectProjectByTeam(teamId) {
  if (!teamId || !projects.length) return;
  const idx = projects.findIndex((p) =>
    String(p.team_id || p.profile || "") === String(teamId)
  );
  if (idx >= 0) el("project").value = String(idx);
}
function selectDefaultProject() {
  const idx = projects.findIndex((p) => {
    const tid = String(p.team_id || "");
    return tid === "projeto-padrao" || tid.startsWith("projeto-padrao-");
  });
  if (idx >= 0) el("project").value = String(idx);
  else if (projects.length) el("project").value = "0";
}
function openNewTaskModal(preferredColumn) {
  if (!requireKanbanProject("criar um cartão")) return;
  const modal = el("new-task-modal");
  if (!modal) return;
  renderTaskFormOptions();
  const colSel = el("task-column");
  if (colSel && preferredColumn) {
    colSel.value = String(preferredColumn).trim().toLowerCase();
  }
  modal.hidden = false;
  el("task-title").focus();
}
function closeNewTaskModal() {
  const modal = el("new-task-modal");
  if (modal) modal.hidden = true;
}
function colTone(cid) {
  const known = { backlog: "backlog", todo: "todo", doing: "doing", review: "review", done: "done" };
  return known[cid] || "default";
}
function priorityTone(priority) {
  const p = Number(priority);
  if (p === 1) return "prio-high";
  if (p === 2) return "prio-med";
  if (Number.isFinite(p) && p > 0) return "prio-low";
  return "";
}
function priorityBadge(priority) {
  const p = Number(priority);
  if (!Number.isFinite(p) || p <= 0) return "";
  const tone = priorityTone(p);
  const cls = tone === "prio-high" ? "bad" : tone === "prio-med" ? "warn" : "accent";
  return '<span class="badge ' + cls + '" title="Prioridade">P' + esc(String(p)) + '</span>';
}
function taskDescriptionPreview(task) {
  const d = String((task && task.description) || "").trim();
  if (!d) return "";
  const short = d.length > 120 ? d.slice(0, 117) + "…" : d;
  return '<p class="card-desc">' + esc(short) + '</p>';
}
function fmtKbCronWhen(v) {
  if (!v) return "—";
  const d = new Date(v);
  if (!isNaN(d.getTime())) {
    return d.toLocaleString("pt-BR", {
      day: "2-digit", month: "2-digit", hour: "2-digit", minute: "2-digit",
    });
  }
  return String(v);
}
function taskDetailAssigneeLabel(slug) {
  const key = String(slug || "").trim();
  if (!key) return "—";
  const agent = agents.find((a) => String(a.slug || "") === key);
  if (agent && agent.display_name) return agent.display_name + " (" + key + ")";
  return key;
}
function taskDetailColumnLabel(cid) {
  const col = boardColumns().find((c) => columnId(c) === String(cid || "").toLowerCase());
  return col ? (columnTitle(col) || cid) : (cid || "—");
}
function closeTaskDetailModal() {
  const modal = el("task-detail-modal");
  if (modal) modal.hidden = true;
  taskDetailId = null;
}
function closeTaskSourceModal() {
  const modal = el("task-source-modal");
  if (modal) modal.hidden = true;
}
async function openGeneratedSourceViewer(filePath, sourceWorkdir) {
  const relPath = String(filePath || "").trim();
  if (!relPath) return;
  const base = requireKanbanProject("ver código fonte");
  if (!base) return;
  const modal = el("task-source-modal");
  const pathEl = el("task-source-path");
  const bodyEl = el("task-source-body");
  if (!modal || !pathEl || !bodyEl) return;

  const srcWd = String(sourceWorkdir || "").trim();
  sourceViewCtx = { path: relPath, sourceWorkdir: srcWd };
  modal.hidden = false;
  pathEl.textContent = relPath;
  bodyEl.textContent = "Carregando código fonte…";

  const q = new URLSearchParams();
  q.set("workdir", String(base.workdir || ""));
  if (base.team_id) q.set("team_id", String(base.team_id));
  q.set("anchor_workdir", String(base.workdir || ""));
  q.set("path", relPath);
  if (srcWd) q.set("source_workdir", srcWd);

  try {
    const data = await api("/hermes/kanban/source?" + q.toString(), "GET", null, 45000);
    pathEl.textContent = (data.path || relPath) + " · " + (data.workdir || "");
    bodyEl.textContent = String(data.content || "");
    if (data.truncated) {
      bodyEl.textContent += "\n\n... (arquivo truncado para visualização)";
    }
  } catch (e) {
    bodyEl.textContent = "Falha ao carregar fonte: " + e.message;
  }
}
window.openGeneratedSourceViewer = openGeneratedSourceViewer;
function fillTaskDetailMeta(task) {
  const meta = el("task-detail-meta");
  if (!meta || !task) return;
  const assignees = taskAssignees(task);
  const assigneeTxt = assignees.length
    ? assignees.map(taskDetailAssigneeLabel).join(", ")
    : "—";
  const rows = [
    ["ID", task.id || "—"],
    ["Lista", taskDetailColumnLabel(taskColumn(task))],
    ["Prioridade", task.priority != null ? String(task.priority) : "—"],
    ["Responsável", assigneeTxt],
    ["Pasta", taskWorkdir(task) || "—"],
    ["Artefatos", taskArtifactsDir(task) || "—"],
    ["Criada", fmtKbCronWhen(task.created_at)],
    ["Concluída", fmtKbCronWhen(task.completed_at)],
  ];
  const skills = taskSkills(task);
  if (skills.length) rows.push(["Skills", skills.join(", ")]);
  meta.innerHTML = rows.map(([label, value]) =>
    "<div><dt>" + esc(label) + "</dt><dd>" + esc(value) + "</dd></div>"
  ).join("");
  const desc = String(task.description || "").trim();
  const notes = String(task.notes || "").trim();
  if (desc) {
    meta.innerHTML += '<div style="grid-column:1/-1;"><dt>Descrição</dt><dd style="white-space:pre-wrap;font-family:inherit;">' +
      esc(desc) + "</dd></div>";
  }
  if (notes) {
    meta.innerHTML += '<div style="grid-column:1/-1;"><dt>Notas / resultado</dt><dd style="white-space:pre-wrap;font-family:inherit;">' +
      esc(notes) + "</dd></div>";
  }
}
async function openTaskDetailModal(taskId) {
  const task = boardTasks().find((t) => String(t.id || "") === String(taskId));
  if (!task) return;
  taskDetailId = taskId;
  el("task-detail-title").textContent = task.title || taskId;
  el("task-detail-subtitle").textContent = taskId;
  fillTaskDetailMeta(task);
  el("task-detail-modal").hidden = false;
}
async function afterKanbanScheduled(data) {
  void data;
  await loadBoard();
}
function updateBoardStats() {
  const box = el("kb-stats");
  if (!box) return;
  if (!boardData) {
    box.hidden = true;
    return;
  }
  const tasks = boardTasks();
  const cols = boardColumns();
  const byCol = {};
  cols.forEach((c) => { byCol[columnId(c)] = 0; });
  let unassigned = 0;
  tasks.forEach((t) => {
    const cid = taskColumn(t);
    if (cid in byCol) byCol[cid] += 1;
    else if (!cid) byCol.todo = (byCol.todo || 0) + 1;
    if (!taskAssignees(t).length) unassigned += 1;
  });
  const total = tasks.length;
  const proj = selectedProject();
  const artDir = proj && proj.artifacts_dir ? proj.artifacts_dir : "";
  const artBadge = artDir
    ? '<span class="badge" title="Artefatos: ' + esc(artDir) + '">📁 artefatos</span>'
    : "";
  box.hidden = false;
  box.innerHTML =
    '<span class="badge accent">' + total + ' tarefa(s)</span>' +
    (unassigned ? '<span class="badge warn">' + unassigned + ' sem responsável</span>' : "") +
    artBadge +
    cols.slice(0, 6).map((c) => {
      const cid = columnId(c);
      const n = byCol[cid] || 0;
      return '<span class="badge">' + esc(columnTitle(c) || cid) + ': ' + n + '</span>';
    }).join("");
}
async function loadKbModels() {
  try {
    const r = await fetch("/openclaw/models");
    const data = await r.json();
    kbModels = data.models || [];
  } catch(e) { kbModels = []; }
  const opts = '<option value="">— padrão do sistema —</option>' +
    kbModels.map(m => '<option value="' + esc(m.id) + '">' + esc(m.label || m.id) + '</option>').join('');
  const s1 = el("task-model");
  const s2 = el("edit-task-model");
  if (s1) s1.innerHTML = opts;
  if (s2) s2.innerHTML = opts;
}
function renderTaskFormOptions() {
  const colSel = el("task-column");
  const assigneeSel = el("task-assignee");
  if (colSel) {
    const cols = boardColumns();
    const opts = (cols.length ? cols : [{ id: "todo", title: "A fazer" }]).map(col => {
      const cid = columnId(col) || "todo";
      const title = columnTitle(col) || cid;
      return '<option value="' + esc(cid) + '">' + esc(title) + " (" + esc(cid) + ")</option>";
    });
    colSel.innerHTML = opts.join("");
  }
  if (assigneeSel) {
    const opts = ['<option value="">Sem agente</option>'].concat(
      agents.map(a => {
        const slug = String(a.slug || "").trim();
        const label = String(a.display_name || a.slug || "").trim() || slug;
        if (!slug) return "";
        return '<option value="' + esc(slug) + '">' + esc(label) + " (" + esc(slug) + ")</option>";
      }).filter(Boolean)
    );
    assigneeSel.innerHTML = opts.join("");
  }
}
async function api(path, method = "GET", payload = null, timeoutMs) {
  const timeout = timeoutMs != null ? timeoutMs : 30000;
  const opt = { method, headers: { "Content-Type": "application/json" }, cache: "no-cache" };
  if (payload) opt.body = JSON.stringify(payload);
  const ctrl = new AbortController();
  const timer = setTimeout(() => ctrl.abort(), timeout);
  let r;
  try {
    r = await fetch(path, Object.assign({}, opt, { signal: ctrl.signal }));
    clearTimeout(timer);
  } catch (e) {
    clearTimeout(timer);
    throw new Error(monitorFetchError(e, path));
  }
  let data = {};
  try {
    data = await r.json();
  } catch (_) {
    throw new Error("Resposta inválida de " + path + " (HTTP " + r.status + ")");
  }
  if (!r.ok || data.ok === false) {
    throw new Error(data.error || data.reason || data.summary || ("HTTP " + r.status));
  }
  return data;
}
function kbToast(msg) {
  const t = el("kb-toast");
  if (!t) return;
  t.textContent = msg;
  t.classList.add("show");
  clearTimeout(kbToast._timer);
  kbToast._timer = setTimeout(() => t.classList.remove("show"), 2800);
}
function assigneeInitials(name) {
  const parts = String(name || "").trim().split(/\s+/).filter(Boolean);
  if (!parts.length) return "?";
  if (parts.length === 1) return parts[0].slice(0, 2).toUpperCase();
  return (parts[0][0] + parts[1][0]).toUpperCase();
}
async function moveTaskToColumn(taskId, targetCol) {
  const base = requireKanbanProject("mover o cartão");
  if (!base || !taskId || !targetCol) return;
  if (targetCol === "done") {
    const resultComment = (prompt("Comentário do resultado (resumo + commit)", "") || "").trim();
    if (!resultComment) {
      kbToast("Informe o comentário para concluir.");
      return;
    }
    await saveBoardAction({
      ...base,
      action: "complete_task",
      task_id: taskId,
      result_comment: resultComment,
    });
    kbToast("Cartão concluído.");
    return;
  }
  await saveBoardAction({
    ...base,
    action: "move_task",
    task_id: taskId,
    column: targetCol,
  });
  kbToast("Cartão movido.");
}
function bindBoardDnD(box) {
  box.querySelectorAll(".trello-card").forEach((card) => {
    card.addEventListener("dragstart", (ev) => {
      kbSuppressCardClick = true;
      ev.dataTransfer.setData("text/plain", card.dataset.taskId || "");
      card.classList.add("dragging");
    });
    card.addEventListener("dragend", () => {
      card.classList.remove("dragging");
      setTimeout(() => { kbSuppressCardClick = false; }, 80);
    });
    card.addEventListener("click", (ev) => {
      if (kbSuppressCardClick || ev.target.closest("button")) return;
      const tid = card.dataset.taskId || "";
      if (tid) openTaskDetailModal(tid);
    });
  });
  box.querySelectorAll(".trello-col-body").forEach((colBody) => {
    colBody.addEventListener("dragover", (ev) => {
      ev.preventDefault();
      colBody.classList.add("drag-over");
    });
    colBody.addEventListener("dragleave", () => colBody.classList.remove("drag-over"));
    colBody.addEventListener("drop", async (ev) => {
      ev.preventDefault();
      colBody.classList.remove("drag-over");
      const taskId = ev.dataTransfer.getData("text/plain");
      const colEl = colBody.closest(".trello-col");
      const targetCol = colEl ? colEl.dataset.column : "";
      if (taskId && targetCol) await moveTaskToColumn(taskId, targetCol);
    });
  });
}

// Accordion toggle for kanban cards
window.qcmToggleCard = function qcmToggleCard(headerEl) {
  const wrap = headerEl.closest('.qcm-card-wrap');
  if (!wrap) return;
  const body = wrap.querySelector('.qcm-card-body');
  const arrow = headerEl.querySelector('.arrow');
  if (!body) return;
  const isOpen = body.classList.toggle('open');
  headerEl.setAttribute('aria-expanded', isOpen);
  if (arrow) arrow.classList.toggle('open', isOpen);
  // Close other open cards in the same column
  const col = wrap.closest('.trello-col-body');
  if (col && isOpen) {
    col.querySelectorAll('.qcm-card-body.open').forEach(function(otherBody) {
      if (otherBody !== body) {
        otherBody.classList.remove('open');
        const otherHeader = otherBody.closest('.qcm-card-wrap')?.querySelector('.qcm-card-header');
        if (otherHeader) otherHeader.setAttribute('aria-expanded', 'false');
        const otherArrow = otherHeader?.querySelector('.arrow');
        if (otherArrow) otherArrow.classList.remove('open');
      }
    });
  }
};
function renderBoard() {
  const box = el("board");
  if (!boardData) {
    box.innerHTML = "";
    updateBoardStats();
    return;
  }
  const cols = boardColumns();
  const tasks = boardTasks();
  if (!cols.length) {
    box.innerHTML = '<div class="kb-empty-board"><strong>Sem listas</strong>Configure colunas no kanban.yaml.</div>';
    updateBoardStats();
    return;
  }
  box.innerHTML = cols.map(col => {
    const cid = columnId(col);
    const title = columnTitle(col) || cid;
    const tone = colTone(cid);
    const rows = tasks.filter(t => taskColumn(t) === cid);
    const cardsHtml = rows.map(t => {
        const assignees = taskAssignees(t);
        const prio = t.priority != null && String(t.priority).trim() !== "" ? Number(t.priority) : null;
        const prioHtml = priorityBadge(prio);
        const skills = taskSkills(t);
        const avatar = assignees.length
          ? '<span class="trello-avatar" title="' + esc(assignees.join(", ")) + '">' +
            esc(assigneeInitials(assignees[0])) + '</span>'
          : "";
        const skillsBadge = skills.length
          ? '<span class="card-meta-badge" title="Skills: ' + esc(skills.join(", ")) + '">skills:' + skills.length + "</span>"
          : "";
        const resultDetails = "";
        const descPreview = taskDescriptionPreview(t);
        const hasDesc = descPreview && descPreview.length > 20;
        const createdStr = t.created_at ? '<span class="meta-item">📅 ' + esc(t.created_at) + '</span>' : '';
        const colStr = '<span class="meta-item">📌 ' + esc(taskColumn(t)) + '</span>';
        const skillsMeta = skills.length ? '<span class="meta-item">🏷️ ' + esc(skills.join(', ')) + '</span>' : '';
        return '<article class="trello-card qcm-card-wrap" draggable="true" data-task-id="' + esc(t.id) + '">' +
          '<div class="qcm-card-header" onclick="qcmToggleCard(this)" role="button" tabindex="0" aria-expanded="false">' +
            '<span class="arrow">▶</span>' +
            '<span class="qcm-card-title">' + esc(t.title) + skillsBadge + '</span>' +
            prioHtml +
          '</div>' +
          '<div class="qcm-card-body">' +
            (hasDesc ? descPreview : '') +
            '<div class="meta">' +
              '<span class="meta-item">🔗 ' + esc(t.id) + '</span>' +
              createdStr +
              colStr +
              skillsMeta +
              (avatar ? '<span class="meta-item">👤 ' + esc(assignees.join(', ')) + '</span>' : '') +
            '</div>' +
            '<div style="display:flex;gap:6px;margin-top:8px;flex-wrap:wrap">' +
              '<button type="button" class="ctrl" data-edit="' + esc(t.id) + '">✎ Editar</button>' +
              '<button type="button" class="ctrl" data-assign-schedule="' + esc(t.id) + '">📅 Agendar</button>' +
              '<button type="button" class="ctrl pm-btn" data-pm-analysis="' + esc(t.id) + '" title="Gerente de Projetos">📊 GP</button>' +
              '<button type="button" class="ctrl danger" data-delete="' + esc(t.id) + '">🗑️ Apagar</button>' +
            '</div>' +
            resultDetails +
          '</div>' +
        '</article>';
      }).join("");
    return '<section class="trello-col" data-column="' + esc(cid) + '" data-tone="' + esc(tone) + '">' +
      '<header class="trello-col-head">' +
        '<h3 class="trello-col-title">' + esc(title) + '</h3>' +
        '<span class="trello-col-count">' + rows.length + '</span>' +
      '</header>' +
      '<div class="trello-col-body">' + cardsHtml +
        '<button type="button" class="trello-add-card" data-add-card="' + esc(cid) + '">+ Adicionar cartão</button>' +
      '</div>' +
      '</section>';
  }).join("");
  bindBoardDnD(box);
  updateBoardStats();

  box.querySelectorAll("[data-add-card]").forEach(btn => {
    btn.addEventListener("click", () => {
      openNewTaskModal(btn.dataset.addCard || defaultTaskColumn());
    });
  });
  box.querySelectorAll("[data-edit]").forEach(btn => {
    btn.addEventListener("click", () => openEditTaskModal(btn.dataset.edit));
  });
  box.querySelectorAll("[data-assign-schedule]").forEach(btn => {
    btn.addEventListener("click", (ev) => {
      ev.stopPropagation();
      const tid = btn.getAttribute("data-assign-schedule") || btn.dataset.assignSchedule || "";
      openAssignScheduleModal(tid, "assign_schedule");
    });
  });
  box.querySelectorAll("[data-delete]").forEach(btn => {
    btn.addEventListener("click", () => deleteTask(btn.dataset.delete));
  });
  box.querySelectorAll("[data-pm-analysis]").forEach(btn => {
    btn.addEventListener("click", (ev) => {
      ev.stopPropagation();
      openPmAnalysisModal(btn.dataset.pmAnalysis);
    });
  });
}
async function deleteTask(taskId) {
  const base = requireKanbanProject("apagar o cartão");
  if (!base || !taskId) return;
  const task = boardTasks().find(t => String(t.id || "") === String(taskId));
  const label = task && task.title ? (taskId + " — " + task.title) : taskId;
  if (!confirm("Apagar o cartão " + label + "?\n\nEsta ação não pode ser desfeita.")) return;
  try {
    await saveBoardAction({
      ...base,
      action: "delete_task",
      task_id: taskId,
    }, true);
    if (editTaskId && String(editTaskId) === String(taskId)) closeEditTaskModal();
    kbToast("Cartão apagado.");
  } catch (e) {
    kbToast("Falha ao apagar: " + e.message);
  }
}
function openPmAnalysisModal(taskId) {
  const task = boardTasks().find(t => String(t.id || "") === String(taskId));
  if (!task) return;
  const modal = el("pm-analysis-modal");
  const subtitle = el("pm-analysis-subtitle");
  const body = el("pm-analysis-body");
  subtitle.textContent = task.id + " — " + (task.title || "Sem título");
  body.innerHTML = '<div class="pm-loading">Analisando entregas e benefícios…</div>';
  modal.hidden = false;
  fetchPmAnalysis(task);
}
function closePmAnalysisModal() {
  el("pm-analysis-modal").hidden = true;
}
async function fetchPmAnalysis(task) {
  const body = el("pm-analysis-body");
  const base = kanbanPayloadBase();
  try {
    const payload = {
      team: base ? base.team : "",
      project: base ? base.project : "",
      task_id: task.id,
      title: task.title || "",
      column: taskColumn(task) || "",
      description: task.description || "",
      notes: task.notes || "",
      assignees: taskAssignees(task),
      skills: taskSkills(task),
      completed_at: task.completed_at || "",
      created_at: task.created_at || "",
      priority: task.priority != null ? task.priority : null,
    };
    const r = await fetch("/hermes/kanban/pm-analysis", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(payload),
    });
    const data = await r.json();
    if (!r.ok || data.ok === false) {
      throw new Error(data.error || "Falha na análise");
    }
    renderPmAnalysis(data, task);
  } catch (e) {
    body.innerHTML = '<div class="pm-error">Erro: ' + esc(e.message) + '</div>';
  }
}
function renderPmAnalysis(data, task) {
  const body = el("pm-analysis-body");
  const col = taskColumn(task) || "todo";
  const badgeCls = col === "done" ? "done" : col === "doing" ? "doing" : "todo";
  const statusLabel = col === "done" ? "Concluído" : col === "doing" ? "Em andamento" : "Pendente";
  let html = '<div class="pm-section"><p><span class="pm-badge ' + badgeCls + '">' + esc(statusLabel) + '</span>';
  if (task.completed_at) html += ' Finalizado em ' + esc(task.completed_at);
  html += '</p></div>';
  if (data.deliverables && data.deliverables.length) {
    html += '<div class="pm-section"><h4>📦 O que foi entregue</h4><ul>';
    data.deliverables.forEach(d => { html += '<li>' + esc(d) + '</li>'; });
    html += '</ul></div>';
  }
  if (data.benefits && data.benefits.length) {
    html += '<div class="pm-section"><h4>✅ Benefícios</h4><ul>';
    data.benefits.forEach(b => { html += '<li>' + esc(b) + '</li>'; });
    html += '</ul></div>';
  }
  if (data.summary) {
    html += '<div class="pm-section"><h4>📋 Resumo do Gerente de Projetos</h4><p>' + esc(data.summary) + '</p></div>';
  }
  if (data.next_steps && data.next_steps.length) {
    html += '<div class="pm-section"><h4>🔜 Próximos passos sugeridos</h4><ul>';
    data.next_steps.forEach(s => { html += '<li>' + esc(s) + '</li>'; });
    html += '</ul></div>';
  }
  if (data.risks && data.risks.length) {
    html += '<div class="pm-section"><h4>⚠️ Riscos identificados</h4><ul>';
    data.risks.forEach(r => { html += '<li>' + esc(r) + '</li>'; });
    html += '</ul></div>';
  }
  body.innerHTML = html;
}
function showResult(ok, text, targetId) {
  const r = el(targetId || "result");
  if (!r) return;
  r.className = "result " + (ok ? "ok" : "err");
  r.textContent = text;
}
function closeAssignScheduleModal() {
  const modal = el("assign-schedule-modal");
  if (!modal) return;
  modal.hidden = true;
  assignScheduleCtx = null;
  clearKanbanScheduleProgress("assign-schedule-progress");
}
function openAssignScheduleModal(taskId, mode = "assign_schedule") {
  const modal = el("assign-schedule-modal");
  if (!modal) return;
  clearKanbanScheduleProgress("assign-schedule-progress");
  const task = boardTasks().find(t => String(t.id || "") === String(taskId));
  const assigneeSel = el("assign-schedule-assignee");
  const schedIn = el("assign-schedule-cron");
  const taskLbl = el("assign-schedule-task");
  const noteLbl = el("assign-schedule-note");
  const current = String(taskAssignees(task)[0] || "");
  const currentSkills = taskSkills(task);
  const options = agents
    .map(a => ({ slug: String(a.slug || "").trim(), label: String(a.display_name || a.slug || "").trim() }))
    .filter(a => a.slug);
  assigneeSel.innerHTML = options.length
    ? options.map(o => {
        const label = o.label ? (o.label + " (" + o.slug + ")") : o.slug;
        return '<option value="' + esc(o.slug) + '"' + (o.slug === current ? " selected" : "") + '>' + esc(label) + '</option>';
      }).join("")
    : '<option value="">sem perfis</option>';
  if (options.length && !current) assigneeSel.value = options[0].slug;
  taskLbl.textContent = "Tarefa: " + taskId + (task && task.title ? (" — " + task.title) : "");
  el("assign-schedule-title").textContent = "Agendar tarefa no Hermes";
  assigneeSel.disabled = false;
  noteLbl.textContent = "Escolha o papel, a pasta de trabalho e confirme para criar um cron de execução única.";
  const wdIn = el("assign-schedule-workdir");
  if (wdIn) wdIn.value = taskWorkdir(task);
  const skillsIn = el("assign-schedule-skills");
  if (skillsIn) skillsIn.value = currentSkills.join(", ");
  schedIn.value = "1m";
  const onceCb = el("assign-schedule-once");
  if (onceCb) onceCb.checked = true;
  el("assign-folder-browser").style.display = "none";
  showResult(true, "", "assign-schedule-result");
  assignScheduleCtx = { taskId, mode };
  modal.hidden = false;
}
function closeEditTaskModal() {
  const modal = el("edit-task-modal");
  if (modal) modal.hidden = true;
  editTaskId = null;
  clearKanbanScheduleProgress("edit-task-schedule-progress");
}
function openEditTaskModal(taskId) {
  const task = boardTasks().find(t => String(t.id || "") === String(taskId));
  if (!task) return;
  clearKanbanScheduleProgress("edit-task-schedule-progress");
  editTaskId = taskId;
  el("edit-task-id-label").textContent = taskId;
  el("edit-task-title").value = String(task.title || "");
  el("edit-task-priority").value = task.priority != null ? String(task.priority) : "";
  el("edit-task-desc").value = String(task.description || "");
  el("edit-task-workdir").value = taskWorkdir(task);
  const colSel = el("edit-task-column");
  const cols = boardColumns();
  colSel.innerHTML = (cols.length ? cols : [{ id: "todo", title: "A fazer" }]).map(col => {
    const cid = columnId(col) || "todo";
    return '<option value="' + esc(cid) + '">' + esc(columnTitle(col) || cid) + "</option>";
  }).join("");
  colSel.value = taskColumn(task) || defaultTaskColumn();
  const assigneeSel = el("edit-task-assignee");
  const current = String(taskAssignees(task)[0] || "");
  assigneeSel.innerHTML = ['<option value="">Sem papel</option>'].concat(
    agents.map(a => {
      const slug = String(a.slug || "").trim();
      const label = String(a.display_name || slug).trim();
      return '<option value="' + esc(slug) + '">' + esc(label) + " (" + esc(slug) + ")</option>";
    }).filter(Boolean)
  ).join("");
  assigneeSel.value = current;
  const skillsIn = el("edit-task-skills");
  if (skillsIn) skillsIn.value = taskSkills(task).join(", ");
  const modelSel = el("edit-task-model");
  if (modelSel) modelSel.value = String(task.model_id || "");
  el("edit-folder-browser").style.display = "none";
  showResult(true, "", "edit-task-result");
  el("edit-task-modal").hidden = false;
}
async function saveEditTaskModal(andSchedule) {
  const base = requireKanbanProject("salvar o cartão");
  if (!base || !editTaskId) return;
  const title = el("edit-task-title").value.trim();
  if (!title) {
    showResult(false, "Título é obrigatório.", "edit-task-result");
    return;
  }
  const priorityRaw = el("edit-task-priority").value.trim();
  const priority = priorityRaw ? Number(priorityRaw) : null;
  const assignee = String(el("edit-task-assignee").value || "").trim();
  const skills = parseSkillsInputValue(el("edit-task-skills").value || "");
  const assignees = assignee ? [assignee] : [];
  const column = (el("edit-task-column").value || defaultTaskColumn()).trim().toLowerCase();
  const description = el("edit-task-desc").value.trim();
  const workdir = String(el("edit-task-workdir").value || "").trim();
  const modelId = String(el("edit-task-model").value || "").trim();
  const taskPatch = { title, priority, assignees, skills, column, description };
  if (workdir) taskPatch.workdir = workdir;
  else taskPatch.workdir = null;
  if (modelId) taskPatch.model_id = modelId;
  else taskPatch.model_id = null;
  try {
    await saveBoardAction({
      ...base,
      action: "update_task",
      task_id: editTaskId,
      task: taskPatch,
    }, true);
    if (andSchedule) {
      if (!assignee) {
        showResult(false, "Escolha um papel para agendar.", "edit-task-result");
        return;
      }
      const schData = await scheduleKanbanTask({
        ...base,
        task_id: editTaskId,
        assignee,
        skills,
        task_workdir: workdir || base.workdir,
        model_id: modelId || undefined,
        schedule: "1m",
        once: true,
      }, { progressElId: "edit-task-schedule-progress" });
      const jobId = String(((schData.cron || {}).job_id) || "").trim();
      showResult(true, "Tarefa salva e cron criado no Hermes." +
        (jobId ? " Job " + jobId + "." : "."), "edit-task-result");
      closeEditTaskModal();
      kbToast("Agendada no Hermes.");
      await afterKanbanScheduled(schData);
      return;
    } else {
      showResult(true, "Tarefa atualizada.", "edit-task-result");
      closeEditTaskModal();
      kbToast("Cartão atualizado.");
    }
  } catch (e) {
    showResult(false, "Falha: " + e.message, "edit-task-result");
  }
}
function clearKanbanScheduleProgress(elId) {
  const box = el(elId);
  if (!box) return;
  box.hidden = true;
  box.innerHTML = "";
}
let kanbanCountdownTimer = null;
function stopKanbanCountdownTimer() {
  if (kanbanCountdownTimer) {
    clearInterval(kanbanCountdownTimer);
    kanbanCountdownTimer = null;
  }
}
function formatCountdownSeconds(totalSeconds) {
  const secs = Math.max(0, Number(totalSeconds) || 0);
  if (secs < 60) return secs + "s";
  const mm = Math.floor(secs / 60);
  const ss = secs % 60;
  return mm + "m " + String(ss).padStart(2, "0") + "s";
}
function renderProgressLineWithCountdown(text) {
  const raw = String(text || "");
  const re = /(.*\bnext run in\s+)(\d+)(s\b.*)/i;
  const m = raw.match(re);
  if (!m) return esc(raw);
  const prefix = esc(m[1]);
  const seconds = Math.max(0, Number(m[2] || 0) || 0);
  const suffix = esc(m[3] || "");
  return (
    prefix +
    '<span class="js-kanban-countdown" data-seconds="' +
    seconds +
    '" data-init="' +
    seconds +
    '">' +
    esc(formatCountdownSeconds(seconds)) +
    "</span>" +
    suffix +
    '<div class="kanban-countdown-bar"><span class="kanban-countdown-fill js-kanban-countdown-fill" style="width:100%"></span></div>'
  );
}
function startKanbanCountdownTimer(container) {
  stopKanbanCountdownTimer();
  if (!container) return;
  const tick = () => {
    const nodes = container.querySelectorAll(".js-kanban-countdown");
    let active = 0;
    nodes.forEach((node) => {
      const current = Math.max(0, Number(node.dataset.seconds || "0") || 0);
      const initial = Math.max(current, Number(node.dataset.init || "0") || 0);
      const fill = node.parentElement ? node.parentElement.querySelector(".js-kanban-countdown-fill") : null;
      if (current > 0) {
        const next = current - 1;
        node.dataset.seconds = String(next);
        node.textContent = formatCountdownSeconds(next);
        if (fill) {
          const ratio = initial > 0 ? Math.max(0, Math.min(1, next / initial)) : 0;
          fill.style.width = String(Math.round(ratio * 10000) / 100) + "%";
        }
      } else {
        node.textContent = "0s";
        if (fill) fill.style.width = "0%";
      }
      if (Number(node.dataset.seconds || "0") > 0) active += 1;
    });
    if (!active) stopKanbanCountdownTimer();
  };
  const hasCountdown = container.querySelector(".js-kanban-countdown");
  if (!hasCountdown) return;
  kanbanCountdownTimer = setInterval(tick, 1000);
}
function renderKanbanScheduleProgress(container, lines, lastProgress) {
  if (!container) return;
  container.hidden = false;
  const all = lines && lines.length ? lines.slice() : [];
  if (lastProgress && (!all.length || all[all.length - 1] !== lastProgress)) {
    all.push(lastProgress);
  }
  if (!all.length) {
    stopKanbanCountdownTimer();
    container.innerHTML = '<div class="kanban-schedule-status">A iniciar…</div>';
    return;
  }
  container.innerHTML = all.map((line) =>
    '<div class="kanban-schedule-status">' + renderProgressLineWithCountdown(line) + "</div>"
  ).join("");
  container.scrollTop = container.scrollHeight;
  startKanbanCountdownTimer(container);
}
async function pollKanbanScheduleJob(jobId, opts) {
  opts = opts || {};
  const progressEl = opts.progressElId ? el(opts.progressElId) : null;
  const deadline = Date.now() + 130000;
  while (Date.now() < deadline) {
    const data = await api(
      "/hermes/kanban/schedule/status?job_id=" + encodeURIComponent(jobId),
      "GET",
      null,
      20000
    );
    renderKanbanScheduleProgress(progressEl, data.progress || [], data.lastProgress);
    if (data.status === "done") {
      const result = data.result || {};
      if (!result.ok) throw new Error(result.error || data.error || "falha");
      return result;
    }
    if (data.status === "error") {
      throw new Error(data.error || (data.result && data.result.error) || "falha");
    }
    await new Promise((resolve) => setTimeout(resolve, 1200));
  }
  throw new Error("Tempo esgotado aguardando o agendamento.");
}
async function scheduleKanbanTask(payload, opts) {
  opts = opts || {};
  const progressElId = opts.progressElId || "assign-schedule-progress";
  const body = Object.assign({ async: true }, payload);
  const start = await api("/hermes/kanban/schedule", "POST", body, 45000);
  if (!start.async || !start.jobId) {
    return start;
  }
  renderKanbanScheduleProgress(el(progressElId), ["Pedido aceite — a processar…"], null);
  return pollKanbanScheduleJob(start.jobId, { progressElId });
}
async function submitAssignScheduleModal() {
  const base = requireKanbanProject("agendar a tarefa");
  if (!base || !assignScheduleCtx) return;
  const taskId = assignScheduleCtx.taskId;
  const assignee = String(el("assign-schedule-assignee").value || "").trim();
  const schedule = String(el("assign-schedule-cron").value || "").trim();
  const skills = parseSkillsInputValue(el("assign-schedule-skills").value || "");
  const taskWorkdirVal = String(el("assign-schedule-workdir").value || "").trim();
  const once = el("assign-schedule-once") ? el("assign-schedule-once").checked : true;
  const saveBtn = el("assign-schedule-save");
  if (!assignee) {
    const msg = "Escolha um perfil válido.";
    showResult(false, msg, "assign-schedule-result");
    kbToast(msg);
    return;
  }
  if (!taskWorkdirVal) {
    const msg = "Informe a pasta de trabalho.";
    showResult(false, msg, "assign-schedule-result");
    kbToast(msg);
    return;
  }
  const saveLabel = saveBtn ? saveBtn.textContent : "";
  if (saveBtn) {
    saveBtn.disabled = true;
    saveBtn.textContent = "Agendando…";
  }
  try {
    const data = await scheduleKanbanTask({
      ...base,
      task_id: taskId,
      assignee,
      skills,
      schedule: schedule || "1m",
      task_workdir: taskWorkdirVal,
      once,
      persist_assign: true,
    }, { progressElId: "assign-schedule-progress" });
    const jobId = ((data.cron || {}).job_id || "").trim();
    const msg = "Tarefa " + taskId + " agendada para " + assignee +
      (data.once ? " (execução única)" : "") +
      (jobId ? " — cron " + jobId : "");
    showResult(true, msg + ".", "assign-schedule-result");
    kbToast("Cron criado.");
    closeAssignScheduleModal();
    await afterKanbanScheduled(data);
  } catch (e) {
    const msg = "Falha ao agendar: " + e.message;
    showResult(false, msg, "assign-schedule-result");
    kbToast(msg);
  } finally {
    if (saveBtn) {
      saveBtn.disabled = false;
      saveBtn.textContent = saveLabel || "Agendar no Hermes";
    }
  }
}
function applyProjectsPayload(data, opts) {
  const options = opts || {};
  const previousIdentity = options.keepSelection
    ? projectIdentity(selectedProject())
    : "";
  projects = data.projects || [];
  agents = data.agents || [];
  loadKbModels();
  renderTaskFormOptions();
  const sel = el("project");
  const fallbackMsg = data.fallback
    ? "Modo fallback: exibindo projetos locais. " + String(data.warning || "Hermes indisponível")
    : "";
  if (!projects.length) {
    sel.innerHTML = '<option value="">sem projetos</option>';
    el("board-hint").textContent = fallbackMsg || "Nenhum agente de projeto encontrado em /roles.";
    boardData = null;
    renderBoard();
    return false;
  }
  sel.innerHTML = projects.map((p, i) => '<option value="' + i + '">' + esc(p.label || p.workdir) + '</option>').join("");
  const teamWanted = kanbanTeamFromUrl();
  let restored = false;
  if (teamWanted) {
    selectProjectByTeam(teamWanted);
    const current = selectedProject();
    restored = Boolean(
      current && String(current.team_id || current.profile || "") === String(teamWanted)
    );
    if (restored) {
      try {
        localStorage.setItem("qcm_kanban_last_team", String(teamWanted));
      } catch (_) {}
    }
  } else if (previousIdentity) {
    restored = selectProjectByIdentity(previousIdentity);
  }
  if (!teamWanted && !restored && !options.keepSelection) {
    selectDefaultProject();
  }
  if (!teamWanted && !restored && options.keepSelection) {
    const idx = Number(sel.value || "-1");
    if (!Number.isFinite(idx) || idx < 0 || idx >= projects.length) {
      sel.value = "0";
    }
  }
  const hintTeam = teamWanted && selectedProject()
    ? " · time " + teamWanted
    : "";
  const pending = options.pendingHermes ? " · sincronizando com Hermes…" : "";
  el("board-hint").textContent = (fallbackMsg || (projects.length + " projeto(s) com kanban")) + hintTeam + pending;
  updateProjectInfo();
  return true;
}
async function syncHermesProjectsInBackground() {
  try {
    const data = await api("/hermes/kanban/projects", "GET", null, 45000);
    if (applyProjectsPayload(data, { keepSelection: true })) {
      await loadBoard();
    }
    const hint = el("board-hint");
    if (hint) {
      hint.textContent = hint.textContent.replace(/ · sincronizando com Hermes…/g, "");
    }
  } catch (e) {
    const hint = el("board-hint");
    if (hint && projects.length) {
      hint.textContent = hint.textContent.replace(/ · sincronizando com Hermes…/g, "")
        + " · Hermes: " + String(e.message || e);
    } else if (!projects.length) {
      throw e;
    }
  }
}
async function loadProjects() {
  el("board-hint").textContent = "Carregando projetos…";
  let hadQuick = false;
  try {
    const qr = await fetch("/hermes/kanban/projects?quick=1", { cache: "no-cache" });
    const quickData = await qr.json();
    if (qr.ok && quickData.ok !== false && (quickData.projects || []).length) {
      hadQuick = applyProjectsPayload(quickData, { pendingHermes: true });
      if (hadQuick) await loadBoard();
    }
  } catch (_) { /* full load below */ }
  if (hadQuick) {
    void syncHermesProjectsInBackground();
    return;
  }
  const data = await api("/hermes/kanban/projects", "GET", null, 45000);
  const hadProjects = applyProjectsPayload(data, { keepSelection: false });
  if (hadProjects) await loadBoard();
}
async function loadBoard() {
  const base = kanbanPayloadBase();
  if (!base) return;
  const q = new URLSearchParams(base);
  boardData = await api("/hermes/kanban?" + q.toString());
  lastBoardSignature = boardSignature(boardData);
  renderBoard();
  renderTaskFormOptions();
}
async function saveBoardAction(payload, quiet) {
  try {
    const data = await api("/hermes/kanban", "POST", payload);
    boardData = data;
    lastBoardSignature = boardSignature(boardData);
    renderBoard();
    renderTaskFormOptions();
    if (!quiet) showResult(true, "Kanban atualizado.");
    return data;
  } catch (e) {
    if (!quiet) showResult(false, "Falha: " + e.message);
    throw e;
  }
}

function canAutoRefreshKanbanNow() {
  if (Date.now() < kanbanAutoRefreshPausedUntil) return false;
  if (document.hidden) return false;
  if (kanbanAutoRefreshBusy) return false;
  if (el("new-task-modal") && !el("new-task-modal").hidden) return false;
  if (el("assign-schedule-modal") && !el("assign-schedule-modal").hidden) return false;
  if (el("edit-task-modal") && !el("edit-task-modal").hidden) return false;
  if (el("task-detail-modal") && !el("task-detail-modal").hidden) return false;
  if (el("task-source-modal") && !el("task-source-modal").hidden) return false;
  return true;
}

async function refreshBoardSilently() {
  if (!canAutoRefreshKanbanNow()) return;
  const base = kanbanPayloadBase();
  if (!base) return;
  kanbanAutoRefreshBusy = true;
  try {
    const q = new URLSearchParams(base);
    const data = await api("/hermes/kanban?" + q.toString(), "GET", null, 12000);
    const nextSig = boardSignature(data);
    if (!nextSig || nextSig === lastBoardSignature) return;
    boardData = data;
    lastBoardSignature = nextSig;
    renderBoard();
    renderTaskFormOptions();
    kbToast("Kanban atualizado automaticamente.");
  } catch (_) {
  } finally {
    kanbanAutoRefreshBusy = false;
  }
}

function scheduleKanbanAutoRefresh() {
  if (kanbanAutoRefreshTimer) clearInterval(kanbanAutoRefreshTimer);
  kanbanAutoRefreshTimer = setInterval(refreshBoardSilently, 8000);
}

function updateProjectInfo() {
  const p = selectedProject();
  const container = el("kb-project-info");
  const wdRow = el("kb-info-workdir");
  const ghRow = el("kb-info-github");
  const dirSection = el("kb-dir-browse-section");
  if (!p) { container.hidden = true; return; }
  const wd = String(p.workdir || "").trim();
  const gh = String(p.github || "").trim();
  const teamId = String(p.team_id || p.profile || "").trim();
  if (!wd && !gh && !teamId) { container.hidden = true; return; }
  container.hidden = false;
  if (wd) {
    wdRow.hidden = false;
    el("kb-info-workdir-value").textContent = wd;
    el("kb-info-workdir-value").title = wd;
  } else { wdRow.hidden = true; }
  if (gh) {
    ghRow.hidden = false;
    const link = el("kb-info-github-link");
    link.textContent = gh.replace(/^https?:\/\/(www\.)?/i, "");
    link.href = gh.startsWith("http") ? gh : "https://" + gh;
    link.title = gh;
  } else { ghRow.hidden = true; }
  if (dirSection) {
    dirSection.hidden = !teamId;
    el("kb-dir-browser").style.display = "none";
  }
  // WhatsApp group indicator
  const waEl = el("kb-wa-group");
  if (waEl && p.whatsapp_group && p.whatsapp_group.group_jid) {
    const wg = p.whatsapp_group;
    const jid = String(wg.group_jid);
    const shortJid = jid.length > 20 ? jid.slice(0, 10) + "…" + jid.slice(-8) : jid;
    const emails = (wg.notify_emails || []);
    let html = '<strong>📱 Grupo WhatsApp</strong><br>';
    html += '<span style="font-family:var(--mono);font-size:11px;">' + shortJid + '</span>';
    if (emails.length) {
      html += ' · <span title="' + emails.join(", ") + '">📧 ' + emails.length + ' email(s)</span>';
    }
    html += '<br><span style="color:var(--muted);font-size:11px;">Comandos: /card, /mover, /feito, /cards, /status</span>';
    waEl.innerHTML = html;
    waEl.hidden = false;
  } else if (waEl) {
    waEl.hidden = true;
  }
}

el("project").addEventListener("change", () => {
  const current = selectedProject();
  const teamId = String((current && (current.team_id || current.profile)) || "").trim();
  if (teamId) {
    try {
      localStorage.setItem("qcm_kanban_last_team", teamId);
    } catch (_) {}
  }
  updateProjectInfo();
  loadBoard();
});
el("refresh").addEventListener("click", () => { loadBoard(); });
el("new-task").addEventListener("click", openNewTaskModal);
el("new-task-close").addEventListener("click", closeNewTaskModal);
el("new-task-cancel").addEventListener("click", closeNewTaskModal);
el("new-task-backdrop").addEventListener("click", closeNewTaskModal);
el("assign-schedule-close").addEventListener("click", closeAssignScheduleModal);
el("assign-schedule-cancel").addEventListener("click", closeAssignScheduleModal);
el("assign-schedule-backdrop").addEventListener("click", closeAssignScheduleModal);
el("assign-schedule-save").addEventListener("click", () => { submitAssignScheduleModal(); });
el("assign-schedule-browse").addEventListener("click", async () => {
  const guess = el("assign-schedule-workdir").value.trim() || kbBrowsePath || (selectedProject() && selectedProject().workdir) || "";
  await browseKbFolders("assign", guess);
  el("assign-folder-browser").style.display = "block";
});
el("assign-folder-up").addEventListener("click", async () => {
  if (!kbBrowsePath) return;
  await browseKbFolders("assign", kbBrowsePath, true);
});
el("task-workdir-browse").addEventListener("click", async () => {
  const guess = el("task-workdir").value.trim() || kbBrowsePath || (selectedProject() && selectedProject().workdir) || "";
  await browseKbFolders("task", guess);
  el("task-folder-browser").style.display = "block";
});
el("task-folder-up").addEventListener("click", async () => {
  if (!kbBrowsePath) return;
  await browseKbFolders("task", kbBrowsePath, true);
});
el("edit-task-workdir-browse").addEventListener("click", async () => {
  const guess = el("edit-task-workdir").value.trim() || kbBrowsePath || "";
  await browseKbFolders("edit", guess);
  el("edit-folder-browser").style.display = "block";
});
el("edit-folder-up").addEventListener("click", async () => {
  if (!kbBrowsePath) return;
  await browseKbFolders("edit", kbBrowsePath, true);
});

/* ── Kanban sidebar directory browser ─────────────────────────── */
let kbDirBrowsePath = "";

function renderKbDirFolderList(data) {
  const current = String(data.current || "");
  const parent = String(data.parent || "");
  const dirs = Array.isArray(data.directories) ? data.directories : [];
  el("kb-dir-current-path").textContent = current || "—";
  el("kb-dir-up").disabled = !parent || parent === current;
  const list = el("kb-dir-folder-list");
  if (!dirs.length) {
    list.innerHTML = '<div style="padding:8px;color:var(--muted);font-size:12px;">Nenhuma subpasta.</div>';
    return;
  }
  list.innerHTML = dirs.map((d) =>
    '<button type="button" class="ctrl entry" data-path="' + esc(String(d.path || "")) + '">📁 ' +
    esc(String(d.name || d.path || "")) + '</button>'
  ).join("");
  list.querySelectorAll("[data-path]").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const picked = btn.dataset.path || "";
      if (!picked) return;
      kbDirBrowsePath = picked;
      await browseKbDirFolders(picked);
    });
  });
}

async function browseKbDirFolders(path, goUp) {
  const q = new URLSearchParams();
  if (path) q.set("path", path);
  if (goUp) q.set("up", "1");
  const url = "/hermes/local-folders" + (q.toString() ? "?" + q.toString() : "");
  try {
    const data = await api(url);
    kbDirBrowsePath = String(data.current || "");
    renderKbDirFolderList(data);
  } catch (e) {
    kbToast("Erro ao navegar: " + e.message);
  }
}

async function saveKbTeamDir() {
  const p = selectedProject();
  if (!p) return;
  const teamId = String(p.team_id || p.profile || "").trim();
  if (!teamId) { kbToast("Nenhum time associado ao projeto."); return; }
  const newPath = kbDirBrowsePath || "";
  if (!newPath) { kbToast("Selecione uma pasta."); return; }
  try {
    const r = await fetch("/teams/" + encodeURIComponent(teamId), {
      method: "PATCH",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        local_path: newPath,
        project_source: "local",
      }),
    });
    const data = await r.json();
    if (!r.ok || data.ok === false) throw new Error(data.error || "falha ao salvar");
    kbToast("Diretório do time atualizado: " + newPath);
    el("kb-dir-browser").style.display = "none";
    el("kb-info-workdir-value").textContent = newPath;
    el("kb-info-workdir-value").title = newPath;
    el("kb-info-workdir").hidden = false;
    if (p) p.workdir = newPath;
  } catch (e) {
    kbToast("Erro: " + e.message);
  }
}

el("kb-dir-change-btn").addEventListener("click", async () => {
  const p = selectedProject();
  const guess = (p && p.workdir) || kbDirBrowsePath || "";
  await browseKbDirFolders(guess);
  el("kb-dir-browser").style.display = "block";
});
el("kb-dir-up").addEventListener("click", async () => {
  if (!kbDirBrowsePath) return;
  await browseKbDirFolders(kbDirBrowsePath, true);
});
el("kb-dir-select").addEventListener("click", saveKbTeamDir);

el("edit-task-close").addEventListener("click", closeEditTaskModal);
el("edit-task-cancel").addEventListener("click", closeEditTaskModal);
el("edit-task-backdrop").addEventListener("click", closeEditTaskModal);
el("edit-task-save").addEventListener("click", () => saveEditTaskModal(false));
el("edit-task-save-schedule").addEventListener("click", () => saveEditTaskModal(true));
el("edit-task-delete").addEventListener("click", () => {
  if (editTaskId) deleteTask(editTaskId);
});
el("save-task").addEventListener("click", async () => {
  const base = requireKanbanProject("criar um cartão");
  if (!base) return;
  const title = el("task-title").value.trim();
  if (!title) {
    showResult(false, "Título é obrigatório.");
    return;
  }
  const priorityRaw = el("task-priority").value.trim();
  const priority = priorityRaw ? Number(priorityRaw) : null;
  const assignee = String(el("task-assignee").value || "").trim();
  const skills = parseSkillsInputValue(el("task-skills").value || "");
  const assignees = assignee ? [assignee] : [];
  const column = (el("task-column").value || defaultTaskColumn()).trim().toLowerCase();
  const schedEl = el("task-schedule");
  const schedule = schedEl ? String(schedEl.value || "").trim() : "";
  const description = el("task-desc").value.trim();
  const workdir = String(el("task-workdir").value || "").trim();
  const modelId = String((el("task-model") || {}).value || "").trim();
  const taskBody = { title, priority, assignees, skills, column, description };
  if (workdir) taskBody.workdir = workdir;
  if (modelId) taskBody.model_id = modelId;
  try {
    const data = await saveBoardAction({
      ...base,
      action: "create_task",
      task: taskBody,
    });
    const createdTaskId = String((data && data.task_id) || "").trim();
    if (data && createdTaskId && assignee && (schedule || workdir)) {
      try {
        const sch = await scheduleKanbanTask({
          ...base,
          task_id: createdTaskId,
          assignee,
          skills,
          schedule: schedule || "1m",
          task_workdir: workdir || base.workdir,
          once: true,
          persist_assign: true,
        }, { progressElId: "new-task-schedule-progress" });
        const jobId = String(((sch.cron || {}).job_id) || "").trim();
        showResult(true, "Post " + createdTaskId + " criado e agendado para " + assignee +
          (jobId ? " (cron: " + jobId + ")." : "."));
        await afterKanbanScheduled(sch);
      } catch (e) {
        showResult(false, "Post criado, mas falhou ao agendar: " + e.message);
      }
    } else {
      showResult(true, createdTaskId ? ("Cartão " + createdTaskId + " criado.") : "Cartão criado.");
    }
    el("task-title").value = "";
    el("task-priority").value = "";
    el("task-assignee").value = "";
    el("task-skills").value = "";
    el("task-desc").value = "";
    if (el("task-workdir")) el("task-workdir").value = "";
    closeNewTaskModal();
    kbToast("Cartão criado.");
  } catch (e) {
    showResult(false, "Falha ao criar: " + e.message);
  }
});

el("task-detail-close").addEventListener("click", closeTaskDetailModal);
el("task-detail-backdrop").addEventListener("click", closeTaskDetailModal);
el("task-detail-edit").addEventListener("click", () => {
  const tid = taskDetailId;
  closeTaskDetailModal();
  if (tid) openEditTaskModal(tid);
});
el("task-detail-schedule-btn").addEventListener("click", () => {
  const tid = taskDetailId;
  closeTaskDetailModal();
  if (tid) openAssignScheduleModal(tid, "assign_schedule");
});
el("task-detail-delete").addEventListener("click", () => {
  const tid = taskDetailId;
  closeTaskDetailModal();
  if (tid) deleteTask(tid);
});
el("task-source-close").addEventListener("click", closeTaskSourceModal);
el("task-source-backdrop").addEventListener("click", closeTaskSourceModal);
el("pm-analysis-close").addEventListener("click", closePmAnalysisModal);
el("pm-analysis-backdrop").addEventListener("click", closePmAnalysisModal);
el("pm-analysis-close-btn").addEventListener("click", closePmAnalysisModal);
el("task-source-refresh").addEventListener("click", () => {
  if (!sourceViewCtx) return;
  openGeneratedSourceViewer(sourceViewCtx.path, sourceViewCtx.sourceWorkdir);
});
el("task-source-copy").addEventListener("click", async () => {
  const body = el("task-source-body");
  const text = body ? String(body.textContent || "") : "";
  if (!text) return;
  try {
    await navigator.clipboard.writeText(text);
    kbToast("Código copiado para a área de transferência.");
  } catch (_) {
    kbToast("Falha ao copiar código.");
  }
});
document.addEventListener("keydown", (ev) => {
  if (ev.key === "Escape" && el("task-detail-modal") && !el("task-detail-modal").hidden) {
    closeTaskDetailModal();
  }
  if (ev.key === "Escape" && el("task-source-modal") && !el("task-source-modal").hidden) {
    closeTaskSourceModal();
  }
  if (ev.key === "Escape" && el("pm-analysis-modal") && !el("pm-analysis-modal").hidden) {
    closePmAnalysisModal();
  }
});
async function initKanbanPage() {
  if (typeof window.qcmAuthGate === "function") {
    const auth = await window.qcmAuthGate();
    if (!auth || auth.ok === false) return;
  }
  try {
    await loadProjects();
    scheduleKanbanAutoRefresh();
    document.addEventListener("visibilitychange", () => {
      if (!document.hidden) void refreshBoardSilently();
    });
    window.addEventListener("focus", () => {
      void refreshBoardSilently();
    });
  } catch (e) {
    el("board-hint").textContent = "Erro: " + e.message;
  }
}
initKanbanPage();
</script>
</body>
</html>
"""


def build_kanban_html(hermes_dashboard_url: Optional[str] = None) -> str:
    html = inject_hermes_cron_exec(
        KANBAN_PAGE.replace("__APP_THEME_CSS__", APP_THEME_CSS)
        .replace("__APP_UI_CSS__", APP_UI_CSS)
    )
    return _inject_app_nav(
        html,
        "kanban",
        hermes_dashboard_url=hermes_dashboard_url,
    )


METRICS_PAGE = r"""<!doctype html>
<html lang="pt-br">
<head>
<meta charset="utf-8">
<title>gois — métricas</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<style>
  :root {
    --bg: #0f1115;
    --panel: #171a21;
    --panel-2: #1e222c;
    --border: #262b36;
    --fg: #e6e8ee;
    --muted: #8a93a6;
    --ok: #3ddc84;
    --bad: #ff5a5f;
    --warn: #ffb454;
    --accent: #6aa9ff;
    --accent-dim: rgba(106,169,255,.12);
    --mono: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }
  @media (prefers-color-scheme: light) {
    :root { --bg:#f5f6fa; --panel:#fff; --panel-2:#f0f2f7; --border:#e1e4ec;
            --fg:#15171c; --muted:#5b6477; }
  }
  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; min-height: 100%; background: var(--bg); color: var(--fg);
               font: 14px/1.45 -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; }
  body { display: flex; flex-direction: column; }
  __APP_NAV_CSS__
  main { flex: 1; padding: 24px 28px; max-width: 1100px; width: 100%; margin: 0 auto; }
  .toolbar { display: flex; flex-wrap: wrap; gap: 12px; align-items: center; margin-bottom: 18px; }
  .toolbar .grow { flex: 1; }
  .status-bar { color: var(--muted); font-size: 12px; font-family: var(--mono); }
  button.ctrl, a.ctrl { background: var(--panel); color: var(--fg);
                        border: 1px solid var(--border); border-radius: 8px;
                        padding: 8px 12px; font-size: 12px; font-family: var(--mono);
                        cursor: pointer; text-decoration: none; display: inline-block; }
  button.ctrl:hover, a.ctrl:hover { border-color: var(--accent); }
  .hero { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 12px;
          margin-bottom: 20px; }
  .hero-card { background: var(--panel); border: 1px solid var(--border); border-radius: 10px;
               padding: 16px 18px; }
  .hero-card .label { color: var(--muted); font-size: 11px; text-transform: uppercase;
                      letter-spacing: .7px; margin-bottom: 8px; }
  .hero-card .value { font-size: 22px; font-weight: 700; font-family: var(--mono); }
  .hero-card .sub { color: var(--muted); font-size: 11px; font-family: var(--mono); margin-top: 6px; }
  .hero-card.ok .value { color: var(--ok); }
  .hero-card.bad .value { color: var(--bad); }
  .hero-card.warn .value { color: var(--warn); }
  .section { margin-bottom: 22px; }
  .section h2 { margin: 0 0 12px; font-size: 12px; font-weight: 600; color: var(--muted);
                text-transform: uppercase; letter-spacing: .8px; }
  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 12px; }
  .card { background: var(--panel); border: 1px solid var(--border); border-radius: 10px;
          padding: 14px 16px; }
  .card .k { color: var(--muted); font-size: 11px; text-transform: uppercase;
             letter-spacing: .5px; margin-bottom: 6px; word-break: break-word; }
  .card .v { font-size: 18px; font-weight: 600; font-family: var(--mono); }
  .card .hint { color: var(--muted); font-size: 11px; font-family: var(--mono); margin-top: 6px; }
  table.metrics { width: 100%; border-collapse: collapse; background: var(--panel);
                 border: 1px solid var(--border); border-radius: 10px; overflow: hidden; }
  table.metrics th, table.metrics td { padding: 10px 12px; text-align: left;
                                        border-bottom: 1px solid var(--border); font-size: 12px; }
  table.metrics th { color: var(--muted); font-weight: 600; text-transform: uppercase;
                      letter-spacing: .5px; font-size: 11px; background: var(--panel-2); }
  table.metrics td.name { font-family: var(--mono); color: var(--accent); word-break: break-all; }
  table.metrics td.val { font-family: var(--mono); text-align: right; white-space: nowrap; }
  table.metrics tr:last-child td { border-bottom: none; }
  details.raw { background: var(--panel); border: 1px solid var(--border); border-radius: 10px;
                padding: 12px 16px; }
  details.raw summary { cursor: pointer; color: var(--muted); font-size: 12px;
                        text-transform: uppercase; letter-spacing: .6px; }
  pre.raw { margin: 12px 0 0; padding: 12px; background: var(--panel-2); border-radius: 8px;
            overflow: auto; max-height: 360px; font-family: var(--mono); font-size: 11px;
            color: var(--muted); white-space: pre-wrap; word-break: break-all; }
  .empty { color: var(--muted); font-style: italic; padding: 20px; text-align: center; }
</style>
</head>
<body>
__APP_NAV__
<main>
  <div class="toolbar">
    <div class="grow status-bar" id="status-bar">Carregando…</div>
    <button type="button" class="ctrl" id="btn-refresh">Atualizar</button>
    <a class="ctrl" href="/metrics" target="_blank" rel="noopener">Prometheus (/metrics)</a>
    <a class="ctrl" href="/status" target="_blank" rel="noopener">JSON (/status)</a>
  </div>

  <div class="hero" id="hero">
    <div class="hero-card"><div class="label">QClaw</div><div class="value" id="hero-qclaw">—</div>
      <div class="sub" id="hero-qclaw-sub"></div></div>
    <div class="hero-card" id="hero-hermes-wrap" style="display:none">
      <div class="label">Hermes</div><div class="value" id="hero-hermes">—</div>
      <div class="sub" id="hero-hermes-sub"></div></div>
    <div class="hero-card" id="hero-whatsapp-wrap" style="display:none">
      <div class="label">WhatsApp Auto-reply</div><div class="value" id="hero-whatsapp">—</div>
      <div class="sub" id="hero-whatsapp-sub"></div></div>
    <div class="hero-card"><div class="label">Falhas consecutivas</div>
      <div class="value" id="hero-failures">—</div></div>
    <div class="hero-card"><div class="label">Memória RSS total</div>
      <div class="value" id="hero-mem">—</div></div>
  </div>

  <div class="section">
    <h2>Saúde e recuperação</h2>
    <div class="grid" id="grid-health"></div>
  </div>

  <div class="section">
    <h2>Memória por papel</h2>
    <div class="grid" id="grid-mem"></div>
  </div>

  <div class="section">
    <h2>Reaper e logs</h2>
    <div class="grid" id="grid-ops"></div>
  </div>

  <div class="section">
    <h2>Todas as métricas Prometheus</h2>
    <table class="metrics">
      <thead><tr><th>Métrica</th><th style="text-align:right">Valor</th></tr></thead>
      <tbody id="metrics-body"><tr><td colspan="2" class="empty">Carregando…</td></tr></tbody>
    </table>
  </div>

  <div class="section">
    <details class="raw">
      <summary>Export bruto Prometheus</summary>
      <pre class="raw" id="raw-metrics">—</pre>
    </details>
  </div>
</main>
<script>
const POLL_MS = 3000;
let pollTimer = null;

function el(id) { return document.getElementById(id); }

const _renderFp = {};
function _memo(key, value, fn) {
  let fp;
  try { fp = JSON.stringify(value); } catch (e) { fp = String(Math.random()); }
  if (_renderFp[key] === fp) return;
  _renderFp[key] = fp;
  fn();
}

function escapeHtml(s) {
  return String(s || "").replace(/&/g,"&amp;").replace(/</g,"&lt;")
    .replace(/>/g,"&gt;").replace(/"/g,"&quot;");
}

function fmtBytes(n) {
  const v = Number(n);
  if (!Number.isFinite(v) || v <= 0) return "0 B";
  const u = ["B","KB","MB","GB","TB"];
  let i = 0, x = v;
  while (x >= 1024 && i < u.length - 1) { x /= 1024; i++; }
  return x.toFixed(i ? 1 : 0) + " " + u[i];
}

function fmtTs(ts) {
  const v = Number(ts);
  if (!Number.isFinite(v) || v <= 0) return "—";
  const d = new Date(v * 1000);
  const ago = Math.max(0, Math.round((Date.now() - d.getTime()) / 1000));
  if (ago < 60) return "há " + ago + "s";
  if (ago < 3600) return "há " + Math.floor(ago / 60) + "min";
  if (ago < 86400) return "há " + Math.floor(ago / 3600) + "h";
  return d.toLocaleString();
}

function parsePrometheus(text) {
  const out = [];
  for (const line of text.split("\n")) {
    const t = line.trim();
    if (!t || t.startsWith("#")) continue;
    const sp = t.lastIndexOf(" ");
    if (sp <= 0) continue;
    const namePart = t.slice(0, sp);
    const val = parseFloat(t.slice(sp + 1));
    if (!Number.isFinite(val)) continue;
    const m = namePart.match(/^([a-zA-Z_:][a-zA-Z0-9_:]*)(?:\{([^}]*)\})?$/);
    if (!m) continue;
    const labels = {};
    if (m[2]) {
      for (const part of m[2].match(/(?:[^,"\\]|\\.)+/g) || []) {
        const eq = part.indexOf("=");
        if (eq > 0) {
          labels[part.slice(0, eq)] = part.slice(eq + 1).replace(/^"|"$/g, "");
        }
      }
    }
    out.push({ name: m[1], labels, value: val, key: namePart });
  }
  return out;
}

function metricVal(rows, name, labels) {
  const hit = rows.find(r => {
    if (r.name !== name) return false;
    if (!labels) return !Object.keys(r.labels).length;
    return Object.entries(labels).every(([k, v]) => r.labels[k] === v);
  });
  return hit ? hit.value : null;
}

function sumMetric(rows, name, labelKey) {
  return rows.filter(r => r.name === name).reduce((a, r) => a + r.value, 0);
}

function card(k, v, hint) {
  return '<div class="card"><div class="k">' + escapeHtml(k) + '</div>' +
    '<div class="v">' + escapeHtml(v) + '</div>' +
    (hint ? '<div class="hint">' + escapeHtml(hint) + '</div>' : '') +
    '</div>';
}

function setHero(id, text, cls, sub) {
  const box = el(id).closest(".hero-card");
  el(id).textContent = text;
  box.classList.remove("ok", "bad", "warn");
  if (cls) box.classList.add(cls);
  const subEl = el(id + "-sub");
  if (subEl) subEl.textContent = sub || "";
}

function render(status, promRows, rawText) {
  const up = status.up === true || metricVal(promRows, "qclaw_up") === 1;
  setHero("hero-qclaw", up ? "UP" : "DOWN", up ? "ok" : "bad",
    status.last_health_ok_ts ? "último OK " + fmtTs(status.last_health_ok_ts) : "");

  const hermes = status.hermes;
  if (hermes) {
    el("hero-hermes-wrap").style.display = "";
    const hUp = hermes.up === true || metricVal(promRows, "hermes_up") === 1;
    setHero("hero-hermes", hUp ? "UP" : "DOWN", hUp ? "ok" : "bad",
      hermes.consecutive_failures != null
        ? hermes.consecutive_failures + " falha(s)" : "");
  }

  const wa = status.whatsapp_inbound;
  if (wa && (wa.inbound_enabled || wa.auto_reply_enabled)) {
    el("hero-whatsapp-wrap").style.display = "";
    const fails = Number(wa.failures) || 0;
    const label = wa.auto_reply_enabled ? (fails > 0 ? String(fails) + " falha(s)" : "OK") : "desligado";
    const cls = wa.auto_reply_enabled ? (fails > 0 ? "warn" : "ok") : "bad";
    const sub = wa.last_error
      ? fmtTs(wa.last_failure_ts) + " — " + escapeHtml(String(wa.last_error))
      : (wa.auto_reply_enabled ? "sem falhas" : "auto-reply desativado");
    setHero("hero-whatsapp", label, cls, sub);
  }

  const fails = status.consecutive_failures ?? metricVal(promRows, "qclaw_consecutive_failures");
  const threshold = status.failure_threshold ?? "—";
  el("hero-failures").textContent = fails != null ? String(fails) + " / " + threshold : "—";
  el("hero-failures").closest(".hero-card").classList.toggle("warn", Number(fails) > 0);
  el("hero-failures").closest(".hero-card").classList.toggle("bad",
    Number(fails) >= Number(threshold));

  const memTotal = status.qclaw_memory && status.qclaw_memory.total_bytes != null
    ? status.qclaw_memory.total_bytes
    : metricVal(promRows, "qclaw_memory_rss_total_bytes");
  el("hero-mem").textContent = memTotal != null ? fmtBytes(memTotal) : "—";

  const health = [
    ["Checks OK", metricVal(promRows, "qclaw_health_checks_total", {result: "ok"})],
    ["Checks fail", metricVal(promRows, "qclaw_health_checks_total", {result: "fail"})],
    ["Recuperações", metricVal(promRows, "qclaw_recovery_attempts_total")],
    ["Erros do agente", metricVal(promRows, "qclaw_recovery_agent_errors_total")],
    ["Última recuperação", fmtTs(status.last_recovery_ts || metricVal(promRows, "qclaw_last_recovery_timestamp_seconds"))],
    ["Intervalo monitor", (status.monitor_interval_seconds || "—") + " s"],
    ["Cooldown", (status.cooldown_seconds || "—") + " s"],
    ["Recuperações (run)", (status.recovery_attempts_this_run ?? "—") + " / " + (status.max_recovery_attempts ?? "—")],
  ];
  el("grid-health").innerHTML = health.map(([k, v]) =>
    card(k, v != null && v !== undefined ? String(v) : "—")).join("");

  const byRole = (status.qclaw_memory && status.qclaw_memory.by_role_bytes) || {};
  _memo("grid-mem", { byRole, rss: promRows.filter(r => r.name === "qclaw_memory_rss_bytes") }, () => {
    const memCards = Object.keys(byRole).sort().map(role =>
      card("role: " + role, fmtBytes(byRole[role]))
    );
    promRows.filter(r => r.name === "qclaw_memory_rss_bytes").forEach(r => {
      const role = r.labels.role || "?";
      if (!byRole[role]) memCards.push(card("role: " + role, fmtBytes(r.value)));
    });
    el("grid-mem").innerHTML = memCards.length
      ? memCards.join("")
      : card("—", "sem dados");
  });

  const reaper = status.reaper || {};
  const logSc = status.log_scanner || {};
  const ops = [
    ["Reaper — último scan", fmtTs(reaper.last_ts || metricVal(promRows, "qclaw_last_reap_timestamp_seconds"))],
    ["Zombies (último)", reaper.last_zombies ?? metricVal(promRows, "qclaw_last_reap_zombies") ?? "—"],
    ["Órfãos (último)", reaper.last_orphans ?? metricVal(promRows, "qclaw_last_reap_orphans") ?? "—"],
    ["Processos eliminados", sumMetric(promRows, "qclaw_processes_reaped_total") || reaper.last_killed || "—"],
    ["Zombies detectados", metricVal(promRows, "qclaw_zombies_detected_total") ?? "—"],
    ["Scans de log", metricVal(promRows, "qclaw_log_scans_total") ?? "—"],
    ["Matches de log", sumMetric(promRows, "qclaw_log_matches_total") || "—"],
    ["Último scan de log", fmtTs(logSc.last_ts)],
  ];
  el("grid-ops").innerHTML = ops.map(([k, v]) => card(k, String(v ?? "—"))).join("");

  const sorted = [...promRows].sort((a, b) => a.key.localeCompare(b.key));
  _memo("metrics-body", sorted, () => {
    el("metrics-body").innerHTML = sorted.length
      ? sorted.map(r => '<tr><td class="name">' + escapeHtml(r.key) +
          '</td><td class="val">' + escapeHtml(String(r.value)) + '</td></tr>').join("")
      : '<tr><td colspan="2" class="empty">Nenhuma métrica</td></tr>';
  });

  _memo("raw-metrics", rawText, () => { el("raw-metrics").textContent = rawText || "—"; });
  el("status-bar").textContent = "Atualizado " + new Date().toLocaleTimeString() +
    " · polling a cada " + (POLL_MS / 1000) + "s";
}

let refreshInFlight = false;

async function refresh() {
  if (refreshInFlight) return;
  if (document.hidden) return;
  refreshInFlight = true;
  try {
    const [statusRes, promRes] = await Promise.all([
      fetch("/status", { cache: "no-cache" }),
      fetch("/metrics", { cache: "no-cache" }),
    ]);
    const status = await statusRes.json();
    const rawText = await promRes.text();
    const promRows = parsePrometheus(rawText);
    render(status, promRows, rawText);
  } catch (e) {
    el("status-bar").textContent = "Erro: " + e.message;
  } finally {
    refreshInFlight = false;
  }
}

function startPoll() {
  if (pollTimer) clearTimeout(pollTimer);
  refresh();
  pollTimer = setTimeout(async function tick() {
    await refresh();
    pollTimer = setTimeout(tick, POLL_MS);
  }, POLL_MS);
}

el("btn-refresh").addEventListener("click", refresh);
document.addEventListener("visibilitychange", () => {
  if (!document.hidden) refresh();
});
startPoll();
</script>
</body>
</html>
"""


def build_metrics_html(hermes_dashboard_url: Optional[str] = None) -> str:
    return _inject_app_nav(
        METRICS_PAGE,
        "metrics",
        hermes_dashboard_url=hermes_dashboard_url,
    )


LATEX_PAGE = r"""<!doctype html>
<html lang="pt-br">
<head>
<meta charset="utf-8">
<title>gois — artigos LaTeX</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<style>
  :root {
    --bg: #0f1115;
    --panel: #171a21;
    --panel-2: #1e222c;
    --border: #262b36;
    --fg: #e6e8ee;
    --muted: #8a93a6;
    --ok: #3ddc84;
    --bad: #ff5a5f;
    --warn: #ffb454;
    --accent: #6aa9ff;
    --accent-dim: rgba(106,169,255,.12);
    --mono: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }
  @media (prefers-color-scheme: light) {
    :root { --bg:#f5f6fa; --panel:#fff; --panel-2:#f0f2f7; --border:#e1e4ec;
            --fg:#15171c; --muted:#5b6477; }
  }
  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; min-height: 100%; background: var(--bg); color: var(--fg);
               font: 14px/1.45 -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; }
  body { display: flex; flex-direction: column; }
  __APP_NAV_CSS__
  main { flex: 1; display: flex; min-height: 0; }
  .sidebar { width: 300px; flex-shrink: 0; border-right: 1px solid var(--border);
             background: var(--panel); display: flex; flex-direction: column; }
  .sidebar-head { padding: 16px; border-bottom: 1px solid var(--border); }
  .sidebar-head h1 { margin: 0 0 6px; font-size: 15px; font-weight: 600; }
  .sidebar-head p { margin: 0; color: var(--muted); font-size: 12px; line-height: 1.45; }
  .register { padding: 14px 16px; border-bottom: 1px solid var(--border); }
  .register label { display: block; font-size: 11px; color: var(--muted);
                    text-transform: uppercase; letter-spacing: .5px; margin-bottom: 4px; }
  .register input { width: 100%; background: var(--panel-2); color: var(--fg);
                    border: 1px solid var(--border); border-radius: 8px; padding: 8px 10px;
                    font: inherit; font-size: 13px; margin-bottom: 8px; }
  .register input:focus { outline: none; border-color: var(--accent); }
  .path-row { display: flex; gap: 8px; }
  .path-row input { flex: 1; }
  button.ctrl, a.ctrl { background: var(--panel-2); color: var(--fg); border: 1px solid var(--border);
                         border-radius: 8px; padding: 8px 12px; font-size: 12px; font-family: var(--mono);
                         cursor: pointer; text-decoration: none; }
  button.ctrl:hover { border-color: var(--accent); }
  button.ctrl.primary { background: var(--accent); color: #0f1115; border-color: var(--accent); font-weight: 600; }
  button.ctrl:disabled { opacity: .55; cursor: not-allowed; }
  .folder-browser { margin-top: 8px; border: 1px solid var(--border); border-radius: 8px;
                   background: var(--panel-2); max-height: 160px; overflow: auto; padding: 6px;
                   display: none; }
  .folder-browser .path { color: var(--muted); font-family: var(--mono); font-size: 11px;
                          margin-bottom: 6px; word-break: break-all; }
  .folder-browser .entry { width: 100%; text-align: left; margin-bottom: 4px; }
  .workspace-list { flex: 1; overflow: auto; padding: 8px; }
  .ws-item { width: 100%; text-align: left; background: transparent; border: 1px solid transparent;
             border-radius: 8px; color: var(--fg); padding: 10px 12px; cursor: pointer; margin-bottom: 4px; }
  .ws-item:hover { background: var(--panel-2); border-color: var(--border); }
  .ws-item.active { background: var(--accent-dim); border-color: rgba(106,169,255,.35); }
  .ws-item .name { font-weight: 600; font-size: 13px; }
  .ws-item .path { color: var(--muted); font-size: 11px; font-family: var(--mono); word-break: break-all; }
  .ws-item .badge-missing { color: var(--bad); font-size: 10px; }
  .content { flex: 1; display: flex; flex-direction: column; min-width: 0; }
  .content-head { padding: 16px 20px; border-bottom: 1px solid var(--border); background: var(--panel);
                  display: flex; flex-wrap: wrap; gap: 10px; align-items: center; }
  .content-head h2 { margin: 0; font-size: 16px; flex: 1; min-width: 120px; }
  .status { color: var(--muted); font-size: 12px; font-family: var(--mono); }
  .split { flex: 1; display: flex; min-height: 0; }
  .articles { width: 320px; flex-shrink: 0; border-right: 1px solid var(--border);
              overflow: auto; background: var(--panel-2); }
  .article-item { display: block; width: 100%; text-align: left; background: transparent;
                  border: 0; border-bottom: 1px solid var(--border); color: var(--fg);
                  padding: 12px 14px; cursor: pointer; }
  .article-item:hover { background: var(--panel); }
  .article-item.active { background: var(--accent-dim); }
  .article-item .title { font-weight: 500; font-size: 13px; }
  .article-item .meta { color: var(--muted); font-size: 11px; font-family: var(--mono); margin-top: 4px; }
  .preview { flex: 1; display: flex; flex-direction: column; min-width: 0; background: var(--bg); }
  .preview-toolbar { padding: 10px 14px; border-bottom: 1px solid var(--border);
                     display: flex; gap: 8px; flex-wrap: wrap; align-items: center; }
  .preview-frame { flex: 1; border: 0; width: 100%; background: #525659; }
  .log-box { max-height: 140px; overflow: auto; padding: 10px 14px; border-top: 1px solid var(--border);
             background: var(--panel); font-family: var(--mono); font-size: 11px; color: var(--muted);
             white-space: pre-wrap; display: none; }
  .log-box.show { display: block; }
  .empty { color: var(--muted); font-style: italic; padding: 24px; text-align: center; }
</style>
</head>
<body>
__APP_NAV__
<main>
  <aside class="sidebar">
    <div class="sidebar-head">
      <h1>Pastas de artigos</h1>
      <p>Cadastre uma pasta com arquivos <code>.tex</code> (com <code>\\documentclass</code>). Compile e visualize o PDF.</p>
    </div>
    <div class="register">
      <label for="ws-name">Nome</label>
      <input type="text" id="ws-name" placeholder="Meus artigos">
      <label for="ws-path">Caminho da pasta</label>
      <div class="path-row">
        <input type="text" id="ws-path" placeholder="/Users/voce/artigos-latex">
        <button type="button" class="ctrl" id="btn-browse">Navegar</button>
      </div>
      <div class="folder-browser" id="folder-browser">
        <div class="path" id="folder-path"></div>
        <button type="button" class="ctrl entry" id="folder-up">⬆ Subir</button>
        <div id="folder-list"></div>
      </div>
      <button type="button" class="ctrl primary" id="btn-register" style="width:100%;margin-top:10px;">
        Cadastrar pasta
      </button>
    </div>
    <div class="workspace-list" id="workspace-list">
      <div class="empty">Carregando…</div>
    </div>
  </aside>
  <section class="content">
    <header class="content-head">
      <h2 id="content-title">Selecione uma pasta</h2>
      <span class="status" id="content-status"></span>
      <button type="button" class="ctrl" id="btn-refresh-articles" disabled>Atualizar lista</button>
      <button type="button" class="ctrl" id="btn-remove-ws" disabled title="Remove só o cadastro">Remover cadastro</button>
    </header>
    <div class="split">
      <div class="articles" id="articles-list">
        <div class="empty">Escolha uma pasta à esquerda.</div>
      </div>
      <div class="preview">
        <div class="preview-toolbar">
          <span class="status" id="article-label">—</span>
          <button type="button" class="ctrl primary" id="btn-compile" disabled>Compilar PDF</button>
          <button type="button" class="ctrl" id="btn-toggle-log" disabled>Log</button>
          <a class="ctrl" id="btn-open-pdf" href="#" target="_blank" rel="noopener" style="display:none">Abrir PDF</a>
        </div>
        <iframe class="preview-frame" id="pdf-frame" title="Pré-visualização PDF"></iframe>
        <pre class="log-box" id="compile-log"></pre>
      </div>
    </div>
  </section>
</main>
<script>
const el = (id) => document.getElementById(id);
let workspaces = [];
let articles = [];
let activeWsId = null;
let activeArticleId = null;
let browsePath = "";

function escapeHtml(s) {
  return String(s || "").replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;");
}

async function apiJson(url, opt) {
  const r = await fetch(url, Object.assign({ credentials: "same-origin" }, opt || {}));
  let data = {};
  try { data = await r.json(); } catch (_) {}
  if (!r.ok && data.ok !== true) {
    throw new Error(data.error || ("HTTP " + r.status));
  }
  return data;
}

async function loadWorkspaces() {
  const data = await apiJson("/latex/workspaces");
  workspaces = data.workspaces || [];
  renderWorkspaces();
}

function renderWorkspaces() {
  const box = el("workspace-list");
  if (!workspaces.length) {
    box.innerHTML = '<div class="empty">Nenhuma pasta cadastrada.</div>';
    return;
  }
  box.innerHTML = workspaces.map((w) => {
    const active = w.id === activeWsId ? " active" : "";
    const missing = w.exists === false ? '<span class="badge-missing"> · pasta ausente</span>' : "";
    return '<button type="button" class="ws-item' + active + '" data-id="' + escapeHtml(w.id) + '">' +
      '<div class="name">' + escapeHtml(w.name) + missing + '</div>' +
      '<div class="path">' + escapeHtml(w.resolved_path || w.path) + '</div></button>';
  }).join("");
  box.querySelectorAll(".ws-item").forEach((btn) => {
    btn.addEventListener("click", () => selectWorkspace(btn.dataset.id));
  });
}

async function selectWorkspace(id) {
  activeWsId = id;
  activeArticleId = null;
  renderWorkspaces();
  const ws = workspaces.find((w) => w.id === id);
  el("content-title").textContent = ws ? ws.name : "Pasta";
  el("btn-refresh-articles").disabled = !id;
  el("btn-remove-ws").disabled = !id;
  el("btn-compile").disabled = true;
  el("btn-toggle-log").disabled = true;
  el("btn-open-pdf").style.display = "none";
  el("pdf-frame").removeAttribute("src");
  el("article-label").textContent = "—";
  el("compile-log").classList.remove("show");
  await loadArticles();
}

async function loadArticles() {
  if (!activeWsId) return;
  el("content-status").textContent = "Listando .tex…";
  try {
    const data = await apiJson("/latex/articles?workspace_id=" + encodeURIComponent(activeWsId));
    articles = data.articles || [];
    renderArticles();
    el("content-status").textContent = articles.length + " artigo(s)";
  } catch (e) {
    el("content-status").textContent = "Erro: " + e.message;
    el("articles-list").innerHTML = '<div class="empty">' + escapeHtml(e.message) + '</div>';
  }
}

function renderArticles() {
  const box = el("articles-list");
  if (!articles.length) {
    box.innerHTML = '<div class="empty">Nenhum .tex com \\documentclass nesta pasta.</div>';
    return;
  }
  box.innerHTML = articles.map((a) => {
    const active = a.id === activeArticleId ? " active" : "";
    const pdf = a.has_pdf ? " · PDF" : "";
    return '<button type="button" class="article-item' + active + '" data-id="' + escapeHtml(a.id) + '">' +
      '<div class="title">' + escapeHtml(a.title || a.id) + '</div>' +
      '<div class="meta">' + escapeHtml(a.id) + pdf + '</div></button>';
  }).join("");
  box.querySelectorAll(".article-item").forEach((btn) => {
    btn.addEventListener("click", () => selectArticle(btn.dataset.id));
  });
}

function pdfPreviewUrl() {
  if (!activeWsId || !activeArticleId) return "";
  const q = new URLSearchParams({
    workspace_id: activeWsId,
    article_id: activeArticleId,
  });
  return "/latex/pdf?" + q.toString();
}

function selectArticle(id) {
  activeArticleId = id;
  renderArticles();
  const art = articles.find((a) => a.id === id);
  el("article-label").textContent = art ? (art.title || art.id) : id;
  el("btn-compile").disabled = !id;
  el("btn-toggle-log").disabled = !id;
  const url = pdfPreviewUrl();
  const open = el("btn-open-pdf");
  if (art && art.has_pdf) {
    el("pdf-frame").src = url + "&_=" + Date.now();
    open.href = url;
    open.style.display = "";
  } else {
    el("pdf-frame").removeAttribute("src");
    open.style.display = "none";
  }
}

async function compileActive() {
  if (!activeWsId || !activeArticleId) return;
  el("content-status").textContent = "Compilando…";
  el("btn-compile").disabled = true;
  try {
    const data = await apiJson("/latex/compile", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        workspace_id: activeWsId,
        article_id: activeArticleId,
      }),
    });
    const log = el("compile-log");
    const logText = data.log_tail || data.log || "";
    if (logText) {
      log.textContent = logText;
      log.classList.add("show");
    }
    if (data.ok) {
      el("content-status").textContent = "Compilado";
      await loadArticles();
      selectArticle(activeArticleId);
    } else {
      el("content-status").textContent = data.error || "Falha na compilação";
    }
  } catch (e) {
    el("content-status").textContent = e.message;
  } finally {
    el("btn-compile").disabled = !activeArticleId;
  }
}

async function registerWorkspace() {
  const name = el("ws-name").value.trim();
  const path = el("ws-path").value.trim();
  if (!name || !path) {
    alert("Informe nome e caminho da pasta.");
    return;
  }
  el("content-status").textContent = "Cadastrando…";
  try {
    const data = await apiJson("/latex/workspaces", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ name, path }),
    });
    el("ws-name").value = "";
    await loadWorkspaces();
    if (data.workspace && data.workspace.id) {
      await selectWorkspace(data.workspace.id);
    }
    el("content-status").textContent = "Pasta cadastrada";
  } catch (e) {
    el("content-status").textContent = e.message;
    alert(e.message);
  }
}

async function removeWorkspace() {
  if (!activeWsId) return;
  const ws = workspaces.find((w) => w.id === activeWsId);
  if (!confirm("Remover cadastro de «" + (ws ? ws.name : activeWsId) + "»? (os arquivos no disco não são apagados)")) {
    return;
  }
  try {
    await apiJson("/latex/workspaces/remove", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ workspace_id: activeWsId }),
    });
    activeWsId = null;
    activeArticleId = null;
    await loadWorkspaces();
    el("content-title").textContent = "Selecione uma pasta";
    el("articles-list").innerHTML = '<div class="empty">Escolha uma pasta à esquerda.</div>';
    el("pdf-frame").removeAttribute("src");
  } catch (e) {
    alert(e.message);
  }
}

async function browseFolders(path, goUp) {
  const q = new URLSearchParams();
  if (path) q.set("path", path);
  if (goUp) q.set("up", "1");
  const url = "/hermes/local-folders" + (q.toString() ? ("?" + q.toString()) : "");
  const data = await apiJson(url);
  browsePath = String(data.current || "");
  el("folder-browser").style.display = "block";
  el("folder-path").textContent = browsePath || "—";
  const upBtn = el("folder-up");
  upBtn.disabled = !data.parent || data.parent === browsePath;
  const dirs = Array.isArray(data.directories) ? data.directories : [];
  const list = el("folder-list");
  if (!dirs.length) {
    list.innerHTML = '<div class="empty" style="padding:8px;">Sem subpastas.</div>';
    return;
  }
  list.innerHTML = dirs.map((d) =>
    '<button type="button" class="ctrl entry" data-path="' + escapeHtml(String(d.path || "")) + '">' +
    "📁 " + escapeHtml(String(d.name || d.path || "")) + "</button>"
  ).join("");
  list.querySelectorAll("[data-path]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const picked = btn.dataset.path || "";
      if (!picked) return;
      el("ws-path").value = picked;
      browseFolders(picked);
    });
  });
}

el("btn-browse").addEventListener("click", () => browseFolders(el("ws-path").value.trim()));
el("folder-up").addEventListener("click", () => browseFolders(browsePath, true));
el("btn-register").addEventListener("click", () => registerWorkspace());
el("btn-refresh-articles").addEventListener("click", () => loadArticles());
el("btn-remove-ws").addEventListener("click", () => removeWorkspace());
el("btn-compile").addEventListener("click", () => compileActive());
el("btn-toggle-log").addEventListener("click", () => el("compile-log").classList.toggle("show"));

(async function init() {
  try {
    if (typeof window.qcmAuthGate === "function") {
      const auth = await window.qcmAuthGate();
      if (!auth || auth.ok === false) {
        el("workspace-list").innerHTML = '<div class="empty">Faça login para usar.</div>';
        return;
      }
    }
    await loadWorkspaces();
  } catch (e) {
    el("workspace-list").innerHTML = '<div class="empty">Erro: ' + escapeHtml(e.message) + '</div>';
  }
})();
</script>
</body>
</html>
"""


def build_latex_html(hermes_dashboard_url: Optional[str] = None) -> str:
    return _inject_app_nav(
        LATEX_PAGE,
        "latex",
        hermes_dashboard_url=hermes_dashboard_url,
    )


ALLOWLIST_PAGE = r"""<!doctype html>
<html lang="pt-br">
<head>
<meta charset="utf-8">
<title>gois — Allowlist WhatsApp</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<style>
  :root {
    --bg: #0f1115;
    --panel: #171a21;
    --panel-2: #1e222c;
    --border: #262b36;
    --fg: #e6e8ee;
    --muted: #8a93a6;
    --ok: #3ddc84;
    --bad: #ff5a5f;
    --warn: #ffb454;
    --accent: #6aa9ff;
    --accent-dim: rgba(106,169,255,.12);
    --mono: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }
  @media (prefers-color-scheme: light) {
    :root { --bg:#f5f6fa; --panel:#fff; --panel-2:#f0f2f7; --border:#e1e4ec;
            --fg:#15171c; --muted:#5b6477; }
  }
  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; min-height: 100%; background: var(--bg); color: var(--fg);
               font: 14px/1.45 -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; }
  body { display: flex; flex-direction: column; }
  __APP_NAV_CSS__
  main { flex: 1; padding: 24px 28px; max-width: 1100px; width: 100%; margin: 0 auto; }
  h1 { font-size: 18px; font-weight: 600; margin: 0 0 18px; display: flex; align-items: center; gap: 10px; }
  h1 .icon { font-size: 22px; }
  .stats { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 18px; }
  .stat { background: var(--panel); border: 1px solid var(--border); border-radius: 10px;
          padding: 10px 14px; min-width: 110px; }
  .stat .label { color: var(--muted); font-size: 11px; text-transform: uppercase;
                 letter-spacing: .6px; margin-bottom: 4px; }
  .stat .value { font-size: 20px; font-weight: 600; font-family: var(--mono); }
  .toolbar { display: flex; flex-wrap: wrap; gap: 10px; align-items: center; margin-bottom: 18px; }
  button.ctrl { background: var(--panel-2); color: var(--fg); border: 1px solid var(--border);
                border-radius: 8px; padding: 8px 14px; font-size: 12px; font-family: var(--mono);
                cursor: pointer; display: inline-flex; align-items: center; gap: 6px; }
  button.ctrl:hover { border-color: var(--accent); }
  button.ctrl.primary { background: var(--accent); color: #0f1115; border-color: var(--accent); font-weight: 600; }
  button.ctrl.primary:hover { filter: brightness(1.06); }
  button.ctrl.danger { color: var(--bad); border-color: rgba(255,90,95,.4); }
  button.ctrl.danger:hover { background: rgba(255,90,95,.1); }
  .table-wrap { overflow-x: auto; }
  table { width: 100%; border-collapse: collapse; background: var(--panel);
          border: 1px solid var(--border); border-radius: 10px; overflow: hidden; }
  th, td { padding: 10px 14px; text-align: left; border-bottom: 1px solid var(--border); font-size: 13px; }
  th { background: var(--panel-2); color: var(--muted); font-size: 11px; text-transform: uppercase;
       letter-spacing: .6px; font-weight: 600; }
  tr:last-child td { border-bottom: none; }
  tr:hover td { background: rgba(106,169,255,.04); }
  .badge { display: inline-block; padding: 2px 8px; border-radius: 999px;
           font-size: 11px; font-family: var(--mono); }
  .badge.ok { color: var(--ok); background: rgba(61,220,132,.08); border: 1px solid rgba(61,220,132,.35); }
  .badge.off { color: var(--bad); background: rgba(255,90,95,.08); border: 1px solid rgba(255,90,95,.35); }
  .empty { color: var(--muted); font-style: italic; font-size: 14px; padding: 40px 20px;
           text-align: center; background: var(--panel); border: 1px dashed var(--border);
           border-radius: 10px; }
  .actions { display: flex; gap: 6px; }
  .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.6);
                   z-index: 200; align-items: center; justify-content: center; }
  .modal-overlay.show { display: flex; }
  .modal { background: var(--panel); border: 1px solid var(--border); border-radius: 12px;
           padding: 24px; width: 90%; max-width: 440px; }
  .modal h2 { margin: 0 0 16px; font-size: 16px; }
  .modal label { display: block; color: var(--muted); font-size: 11px; text-transform: uppercase;
                 letter-spacing: .6px; margin-bottom: 4px; margin-top: 12px; }
  .modal input[type="text"], .modal input[type="tel"] {
    width: 100%; background: var(--panel-2); color: var(--fg);
    border: 1px solid var(--border); border-radius: 8px; padding: 10px 12px;
    font: inherit; font-size: 14px;
  }
  .modal input:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-dim); }
  .modal .modal-actions { display: flex; gap: 10px; margin-top: 20px; justify-content: flex-end; }
  .toast { position: fixed; bottom: 20px; right: 20px; background: var(--panel);
           border: 1px solid var(--accent); color: var(--fg); padding: 10px 14px;
           border-radius: 8px; font-size: 12px; font-family: var(--mono);
           opacity: 0; pointer-events: none; transition: opacity .2s; z-index: 300; }
  .toast.show { opacity: 1; }
  .phone-col { font-family: var(--mono); font-size: 12px; }
</style>
</head>
<body>
__APP_NAV__
<main>
  <h1><span class="icon">📋</span> Allowlist WhatsApp</h1>
  <div class="stats" id="stats">
    <div class="stat"><div class="label">Total</div><div class="value" id="stat-total">—</div></div>
    <div class="stat"><div class="label">Ativos</div><div class="value" id="stat-enabled">—</div></div>
    <div class="stat"><div class="label">Inativos</div><div class="value" id="stat-disabled">—</div></div>
  </div>
  <div class="toolbar">
    <button type="button" class="ctrl primary" id="btn-add">+ Adicionar</button>
    <button type="button" class="ctrl" id="btn-refresh">Atualizar</button>
  </div>
  <div class="table-wrap">
    <table id="allowlist-table">
      <thead>
        <tr>
          <th>Nome</th>
          <th>Telefone</th>
          <th>JID</th>
          <th>Label</th>
          <th>Status</th>
          <th>Ações</th>
        </tr>
      </thead>
      <tbody id="allowlist-body">
        <tr><td colspan="6" class="empty">Carregando…</td></tr>
      </tbody>
    </table>
  </div>
</main>

<div class="modal-overlay" id="modal-overlay">
  <div class="modal">
    <h2 id="modal-title">Adicionar destinatário</h2>
    <label for="input-name">Nome</label>
    <input type="text" id="input-name" placeholder="Ex: João Silva">
    <label for="input-phone">Telefone (com DDD e país)</label>
    <input type="tel" id="input-phone" placeholder="Ex: +55 85 99173-6779">
    <label for="input-label">Label (opcional)</label>
    <input type="text" id="input-label" placeholder="Ex: suporte, dev, pessoal">
    <div class="modal-actions">
      <button type="button" class="ctrl" id="btn-cancel">Cancelar</button>
      <button type="button" class="ctrl primary" id="btn-save">Salvar</button>
    </div>
  </div>
</div>
<div class="toast" id="toast"></div>

<script>
const el = (id) => document.getElementById(id);
let entries = [];
let editingId = null;

function escapeHtml(s) {
  return String(s).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;");
}

function showToast(msg) {
  const t = el("toast");
  t.textContent = msg;
  t.classList.add("show");
  clearTimeout(showToast._timer);
  showToast._timer = setTimeout(() => t.classList.remove("show"), 2200);
}

function renderStats() {
  const total = entries.length;
  const enabled = entries.filter(e => e.enabled).length;
  el("stat-total").textContent = total;
  el("stat-enabled").textContent = enabled;
  el("stat-disabled").textContent = total - enabled;
}

function renderTable() {
  const tbody = el("allowlist-body");
  renderStats();
  if (!entries.length) {
    tbody.innerHTML = '<tr><td colspan="6" class="empty">Nenhum destinatário cadastrado.</td></tr>';
    return;
  }
  tbody.innerHTML = entries.map(e => {
    const status = e.enabled
      ? '<span class="badge ok">ativo</span>'
      : '<span class="badge off">inativo</span>';
    return '<tr>' +
      '<td>' + escapeHtml(e.name) + '</td>' +
      '<td class="phone-col">+' + escapeHtml(e.phone_digits) + '</td>' +
      '<td class="phone-col">' + escapeHtml(e.jid || '') + '</td>' +
      '<td>' + escapeHtml(e.label || '\u2014') + '</td>' +
      '<td>' + status + '</td>' +
      '<td class="actions">' +
        '<button class="ctrl" data-action="edit" data-id="' + e.id + '" title="Editar">\u270F\uFE0F</button>' +
        '<button class="ctrl" data-action="toggle" data-id="' + e.id + '" data-enabled="' + (e.enabled ? '0' : '1') + '" title="' + (e.enabled ? 'Desativar' : 'Ativar') + '">' + (e.enabled ? '\u23F8' : '\u25B6\uFE0F') + '</button>' +
        '<button class="ctrl danger" data-action="remove" data-id="' + e.id + '" title="Remover">\uD83D\uDDD1\uFE0F</button>' +
      '</td></tr>';
  }).join("");

  tbody.querySelectorAll("[data-action=edit]").forEach(btn => {
    btn.addEventListener("click", () => openEditModal(btn.dataset.id));
  });
  tbody.querySelectorAll("[data-action=toggle]").forEach(btn => {
    btn.addEventListener("click", () => toggleEntry(btn.dataset.id, btn.dataset.enabled === "1"));
  });
  tbody.querySelectorAll("[data-action=remove]").forEach(btn => {
    btn.addEventListener("click", () => removeEntry(btn.dataset.id));
  });
}

async function loadEntries() {
  try {
    const r = await fetch("/whatsapp/allowlist", { cache: "no-cache" });
    const data = await r.json();
    if (!data.ok) throw new Error(data.error || "falha");
    entries = data.entries || [];
    renderTable();
  } catch (e) {
    el("allowlist-body").innerHTML = '<tr><td colspan="6" class="empty">Erro: ' + escapeHtml(e.message) + '</td></tr>';
  }
}

function openAddModal() {
  editingId = null;
  el("modal-title").textContent = "Adicionar destinat\u00e1rio";
  el("input-name").value = "";
  el("input-phone").value = "";
  el("input-label").value = "";
  el("modal-overlay").classList.add("show");
  el("input-name").focus();
}

function openEditModal(id) {
  const entry = entries.find(e => e.id === id);
  if (!entry) return;
  editingId = id;
  el("modal-title").textContent = "Editar destinat\u00e1rio";
  el("input-name").value = entry.name || "";
  el("input-phone").value = entry.phone_digits || "";
  el("input-label").value = entry.label || "";
  el("modal-overlay").classList.add("show");
  el("input-name").focus();
}

function closeModal() {
  el("modal-overlay").classList.remove("show");
  editingId = null;
}

async function saveEntry() {
  const name = el("input-name").value.trim();
  const phone = el("input-phone").value.trim();
  const label = el("input-label").value.trim();
  if (!name || !phone) {
    showToast("Nome e telefone s\u00e3o obrigat\u00f3rios");
    return;
  }
  try {
    let url, payload;
    if (editingId) {
      url = "/whatsapp/allowlist/update";
      payload = { id: editingId, name, phone, label };
    } else {
      url = "/whatsapp/allowlist";
      payload = { name, phone, label };
    }
    const r = await fetch(url, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(payload),
    });
    const data = await r.json();
    if (!data.ok) throw new Error(data.error || "falha");
    showToast(editingId ? "Atualizado!" : "Adicionado!");
    closeModal();
    await loadEntries();
  } catch (e) {
    showToast("Erro: " + e.message);
  }
}

async function toggleEntry(id, enabled) {
  try {
    const r = await fetch("/whatsapp/allowlist/toggle", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ id, enabled }),
    });
    const data = await r.json();
    if (!data.ok) throw new Error(data.error || "falha");
    showToast(enabled ? "Ativado" : "Desativado");
    await loadEntries();
  } catch (e) {
    showToast("Erro: " + e.message);
  }
}

async function removeEntry(id) {
  const entry = entries.find(e => e.id === id);
  if (!confirm("Remover " + (entry ? entry.name : id) + " da allowlist?")) return;
  try {
    const r = await fetch("/whatsapp/allowlist/remove", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ id }),
    });
    const data = await r.json();
    if (!data.ok) throw new Error(data.error || "falha");
    showToast("Removido!");
    await loadEntries();
  } catch (e) {
    showToast("Erro: " + e.message);
  }
}

el("btn-add").addEventListener("click", openAddModal);
el("btn-refresh").addEventListener("click", loadEntries);
el("btn-cancel").addEventListener("click", closeModal);
el("btn-save").addEventListener("click", saveEntry);
el("modal-overlay").addEventListener("click", (ev) => {
  if (ev.target === el("modal-overlay")) closeModal();
});
document.addEventListener("keydown", (ev) => {
  if (ev.key === "Escape") closeModal();
  if (ev.key === "Enter" && el("modal-overlay").classList.contains("show")) saveEntry();
});

loadEntries();
</script>
</body>
</html>
"""


def build_allowlist_html(hermes_dashboard_url: Optional[str] = None) -> str:
    return _inject_app_nav(
        ALLOWLIST_PAGE,
        "allowlist",
        hermes_dashboard_url=hermes_dashboard_url,
    )
