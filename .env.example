# Copy to .env or run: .venv/bin/python scripts/sync_deepseek_env.py
# macOS desktop control: run ./scripts/setup-macos-desktop-python.sh once, then optional:
# GOIS_PYTHON=$HOME/.local/gois/runtime/python3.13
# Reuses the same DEEPSEEK_* as ~/.hermes, AIManager, CGEClaw, etc.
# HERMES_HOME must match hermes_cron_recovery.jobs_path parent directory.
HERMES_HOME=/Volumes/NAUBER/HomeOffload/hermes
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
# Optional: override project-wide chat memory JSON (default ./.stack/chat/project_memory.json)
# GOIS_STACK_ROOT affects all .stack paths including project memory.
# Runtime state (monitor, priority queue, swarm checkpoints) — Redis when reachable:
# REDIS_URL=redis://localhost:6379/0
# QCLAW_RUNTIME_REDIS=0        # force JSON files (tests / offline)
# QCLAW_RUNTIME_JSON_MIRROR=1  # opt-in disk mirror while Redis is up (default off)
# After a Redis write failure, auto-mirror activates until monitor restart.
# Durable app data — MongoDB (SQLite/JSON are migration-only):
# MONGODB_URI=mongodb://localhost:27017
# MONGODB_DB=gois
# One-shot legacy import: python -m gois.scripts.migrate_all_to_mongo
# Roteiro Viral worker (fila de livros/roteiros):
# QCLAW_RV_WORKER_ENABLED=1       # sobe worker ao enfileirar jobs / boot embutido
# DISABLE_AUTO_WORKER_START=0     # legado; manter 0 quando RV worker ativo
# WORKER_IDLE_EXIT_SEC=3600       # segundos sem jobs antes do worker encerrar (0 = nunca)
